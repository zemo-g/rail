import "stdlib/anthropic_client.rail"

main =
  let _ = print "anthropic_chat — live call to api.anthropic.com (pure Rail, no socat):"
  let r = anthropic_chat "claude-haiku-4-5-20251001" "Reply with exactly: hello from pure rail" 40 "/Users/ledaticempire/.fleet/anthropic_key"
  let status = let (a, _) = r in a
  let text = let (_, b) = r in b
  let _ = print (join "" ["  status = ", show status])
  let _ = print (join "" ["  reply  = ", text])
  if status == 200 then
    let _ = print "PASS — direct HTTPS to Anthropic works, socat is out of the loop"
    0
  else 1
