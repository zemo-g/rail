-- The launch-day dog food: announce Rail v3.0.0 by using the v3.0.0
-- Slack client to post a message. The very existence of this working
-- end-to-end is the announcement.

import "stdlib/slack_client.rail"

msg _ = join "" [
  ":rocket: *Rail v3.0.0 shipped* — _Rail speaks TLS_", char_from_int 10,
  char_from_int 10,
  "This message was posted from a pure-Rail program. No socat, no libssl, no curl, no Python.", char_from_int 10,
  "The TLS 1.3 handshake with slack.com, the ECDSA cert verify, the SAN hostname match, the AEAD record layer, the POST request — all in Rail.", char_from_int 10,
  char_from_int 10,
  "• ~3,800 lines of new pure-Rail crypto + TLS across 16 new stdlib modules", char_from_int 10,
  "• Every primitive NIST- or RFC-vector validated (SHA-256/384/512, HMAC, HKDF, ChaCha20-Poly1305, X25519, ECDSA-P256, ECDSA-P384, RSA-PSS, RSA-PKCS1)", char_from_int 10,
  "• Full X.509 chain walk validates api.anthropic.com → GTS Root R4 in the macOS /etc/ssl/cert.pem trust store", char_from_int 10,
  "• 22 pure-Rail TLS tests, all green. Self-compile 2-pass byte-identical preserved.", char_from_int 10,
  char_from_int 10,
  "`Rail runs on Rail, the rest runs on physics.`"]

main =
  let _ = print "Posting v3.0.0 launch announcement to Slack (pure Rail → slack.com)..."
  let r = slack_post_text "D0ATHQ1BQD7" (msg 0) "/Users/ledaticempire/.fleet/slack_token"
  let ok = let (a, _) = r in a
  let _ = print (join "" ["  ok = ", show ok])
  if ok then
    let _ = print "PASS — launch announcement delivered via pure-Rail HTTPS"
    0
  else 1
