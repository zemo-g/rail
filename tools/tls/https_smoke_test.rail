-- Layer 7 smoke test — hit a real HTTPS endpoint end-to-end.
--
-- Usage: resolve the host's IP via shell, then pass it as argv[1].
-- For now we hardcode api.anthropic.com and its current IP.
-- If the test errors with a non-zero status (e.g. 405 Method Not Allowed),
-- that proves the TLS handshake completed and we got a real HTTP response.

import "stdlib/https_client.rail"

main =
  let host = "api.anthropic.com"
  let ip = "160.79.104.10"
  let port = 443
  let path = "/"
  let _ = print (join "" ["GET https://", host, path, " (", ip, ":", show port, ")"])
  let result = https_get host ip port path
  let status = fst result
  let body = snd result
  let _ = print (join "" ["  status = ", show status])
  let _ = print (join "" ["  body (first 200 chars) = ", if length body > 200 then str_sub body 0 200 else body])
  if status >= 100 then
    let _ = print "PASS — handshake + HTTP response received"
    0
  else
    let _ = print "FAIL — no valid HTTP response"
    1

fst t = let (a, _) = t in a
snd t = let (_, b) = t in b
