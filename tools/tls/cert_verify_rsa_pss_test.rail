-- Layer 8b — RSA-PSS-SHA256 CertificateVerify integration test.
--
-- Generates an RSA-2048 self-signed cert + RSA-PSS signature over a
-- known TLS 1.3 transcript hash, then runs tls13_cert_verify_sig with
-- sig_alg = 0x0804 (rsa_pss_rsae_sha256). This exercises:
--   * cv_extract_rsa_pubkey via asn1_cert_fields (rsaEncryption OID match)
--   * RSAPublicKey SEQUENCE { n, e } DER walk
--   * cv_build_signed (TLS 1.3 signing prefix + transcript_hash)
--   * rsa_pss_verify_sha256 (modexp + EMSA-PSS-VERIFY + MGF1)
--
-- Cert + sig generated via Python `cryptography` (see git log for the
-- generator script in the commit body).

import "stdlib/tls13_client.rail"

cert_hex _ = ""

sig_hex _ = ""

main =
  let cert = hex_to_bytes (cert_hex 0)
  let sig = hex_to_bytes (sig_hex 0)
  let ts = hex_to_bytes "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
  let _ = print "tls13_cert_verify_sig — RSA-PSS-SHA256 (sig_alg 0x0804):"
  -- 2052 = 0x0804
  let ok = tls13_cert_verify_sig cert 683 2052 sig 256 ts
  let _ = print (join "" ["  valid = ", show ok])
  if ok == 1 then
    let _ = print "PASS"
    0
  else
    let _ = print "FAIL"
    1
