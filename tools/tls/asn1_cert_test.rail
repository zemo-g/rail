-- Test asn1.rail against RFC 8448 §3's embedded certificate.
-- The cert is at offset 11 in the server flight, length 432 bytes (0x01b0).

import "stdlib/sha256.rail"
import "stdlib/asn1.rail"

-- RFC 8448 §3 certificate (DER bytes), extracted from the server flight
-- starting at the first 0x30 byte after "0b 00 01 b9 00 00 01 b5 00 01 b0".
-- 432 bytes total.

rfc_cert _ = hex_to_bytes ""

main =
  let cert = rfc_cert 0
  let cert_len = 432
  let fields = asn1_cert_fields cert cert_len
  let valid = arr_get fields 12
  let _ = print (join "" ["parsed valid=", show valid])
  if valid == 0 then 1
  else
    let tbs_off = arr_get fields 0
    let tbs_len = arr_get fields 1
    let sa_oid_off = arr_get fields 2
    let sa_oid_len = arr_get fields 3
    let sv_off = arr_get fields 4
    let sv_len = arr_get fields 5
    let pa_oid_off = arr_get fields 6
    let pa_oid_len = arr_get fields 7
    let pk_off = arr_get fields 10
    let pk_len = arr_get fields 11
    let _ = print (join "" ["  tbs_off=", show tbs_off, " tbs_len=", show tbs_len])
    let _ = print (join "" ["  sig_alg_oid_off=", show sa_oid_off, " len=", show sa_oid_len])
    let _ = print (join "" ["  sig_val_off=", show sv_off, " len=", show sv_len])
    let _ = print (join "" ["  pub_alg_oid_off=", show pa_oid_off, " len=", show pa_oid_len])
    let _ = print (join "" ["  pub_key_off=", show pk_off, " len=", show pk_len])
    -- Check OIDs. RFC 8448 §3 cert: sigAlg = sha256WithRSAEncryption,
    -- SPKI = rsaEncryption.
    let is_sha256_rsa = asn1_oid_eq cert sa_oid_off sa_oid_len (asn1_oid_sha256_rsa 0) 9
    let is_rsa_pubkey = asn1_oid_eq cert pa_oid_off pa_oid_len (asn1_oid_rsa_pubkey 0) 9
    let _ = print (join "" ["  sig alg == sha256WithRSA? ", show is_sha256_rsa])
    let _ = print (join "" ["  pub alg == rsaEncryption? ", show is_rsa_pubkey])
    if is_sha256_rsa == 1 then
      if is_rsa_pubkey == 1 then
        let _ = print "PASS — OIDs match expected (RSA-2048 / SHA-256 with RSA)."
        0
      else 1
    else 1
