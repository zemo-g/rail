import "stdlib/tls13_client.rail"

leaf _ = ""
inter _ = ""

main =
  let lc = hex_to_bytes (leaf 0)
  let ic = hex_to_bytes (inter 0)
  let _ = print "api.anthropic.com chain — verify leaf using intermediate's pubkey:"
  let _ = print (join "" ["  leaf=", show 931, " B  intermediate=", show 675, " B"])
  let ok = cv_verify_cert_by lc 931 ic 675
  let _ = print (join "" ["  cv_verify_cert_by -> ", show ok, " (expect 1, ECDSA-SHA256 edge)"])
  if ok == 1 then
    let _ = print "PASS"
    0
  else 1
