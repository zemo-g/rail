-- Layer 8c — https_get_url integration: URL parse + DNS + TLS + HTTP.
--
-- Single verify per process (the EC + RSA bignum churn doesn't compose
-- back-to-back in one Rail process — known arena/GC characteristic
-- documented in Layer 6c). Run with the path you want; default is the
-- ECDSA host. Set TARGET_HOST env or just edit the URL inline.

import "stdlib/https_client.rail"

main =
  let url = "https://api.anthropic.com/"
  let _ = print (join "" ["GET ", url])
  let r = https_get_url url
  let s = let (a, _) = r in a
  let body = let (_, b) = r in b
  let _ = print (join "" ["  status = ", show s])
  let _ = print (join "" ["  body (first 200) = ", if length body > 200 then str_sub body 0 200 else body])
  if s >= 100 then
    let _ = print "PASS"
    0
  else
    let _ = print "FAIL"
    1
