import "stdlib/slack_client.rail"

main =
  let _ = print "slack_post_text — live DM to brockbro2 (Ledatic DM per DDA policy):"
  let r = slack_post_text "D0ATHQ1BQD7" "v3.0.0 smoke: pure-Rail TLS direct to slack.com, no socat." "/Users/ledaticempire/.fleet/slack_token"
  let ok = let (a, _) = r in a
  let resp = let (_, b) = r in b
  let _ = print (join "" ["  ok   = ", show ok])
  let _ = print (join "" ["  resp (first 300) = ", if length resp > 300 then str_sub resp 0 300 else resp])
  if ok then
    let _ = print "PASS — Slack accepted pure-Rail HTTPS POST"
    0
  else 1
