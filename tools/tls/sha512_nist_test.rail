import "stdlib/hmac.rail"
import "stdlib/sha512.rail"

main =
  let abc = string_to_bytes "abc"
  let h384 = sha384_bytes abc 3
  let _ = print (join "" ["SHA-384(abc) = ", bytes_to_hex h384 48])
  let _ = print "expected     = cb00753f45a35e8bb5a03d699ac65007272c32ab0eded1631a8b605a43ff5bed8086072ba1e7cc2358baeca134c825a7"
  let h512 = sha512_bytes abc 3
  let _ = print (join "" ["SHA-512(abc) = ", bytes_to_hex h512 64])
  let _ = print "expected     = ddaf35a193617abacc417349ae20413112e6fa4e89a97ea20a9eeee64b55d39a2192992a274fc1a836ba3c23a3feebbd454d4423643ce80e2a9ac94fa54ca49f"
  let empty = arr_new 0 0
  let h512e = sha512_bytes empty 0
  let _ = print (join "" ["SHA-512(empty) = ", bytes_to_hex h512e 64])
  let _ = print "expected       = cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e"
  0
