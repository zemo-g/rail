import "stdlib/sha256.rail"
import "stdlib/asn1.rail"
import "stdlib/b64.rail"
import "stdlib/pem.rail"

main =
  let _ = print "Loading /etc/ssl/cert.pem trust store..."
  let store = pem_load_trust_store "/etc/ssl/cert.pem"
  let n = arr_get store 2
  let _ = print (join "" ["  loaded ", show n, " certs"])
  let certs = arr_get store 0
  let lens = arr_get store 1
  let _ = print (join "" ["  cert[0] len=", show (arr_get lens 0), " B"])
  let _ = print (join "" ["  cert[", show (n - 1), "] len=", show (arr_get lens (n - 1)), " B"])
  if n > 0 then 0 else 1
