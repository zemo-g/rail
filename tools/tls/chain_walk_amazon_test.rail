import "stdlib/tls13_client.rail"
import "stdlib/b64.rail"
import "stdlib/pem.rail"
import "stdlib/cert_chain.rail"

c0_hex _ = ""
c1_hex _ = ""
c2_hex _ = ""

main =
  let _ = print "Loading trust store..."
  let store = pem_load_trust_store "/etc/ssl/cert.pem"
  let _ = print (join "" ["  ", show (arr_get store 2), " roots"])
  let certs = arr_new 3 0
  let lens = arr_new 3 0
  let _ = arr_set certs 0 (hex_to_bytes (c0_hex 0))
  let _ = arr_set lens 0 1967
  let _ = arr_set certs 1 (hex_to_bytes (c1_hex 0))
  let _ = arr_set lens 1 1167
  let _ = arr_set certs 2 (hex_to_bytes (c2_hex 0))
  let _ = arr_set lens 2 1251
  let _ = print "Walking www.amazon.com chain (3 RSA-PKCS1 edges + DigiCert Root G2 in store)..."
  let ok = cc_walk_chain store certs lens 3
  let _ = print (join "" ["  cc_walk_chain -> ", show ok])
  if ok == 1 then
    let _ = print "PASS — full chain to root verified end-to-end"
    0
  else
    let _ = print "FAIL"
    1
