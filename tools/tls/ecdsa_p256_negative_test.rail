-- ECDSA-P256 negative test — tampered signature must fail.

import "stdlib/sha256.rail"
import "stdlib/ecdsa_p256.rail"

main =
  let qx = hex_to_bytes "60fed4ba255a9d31c961eb74c6356d68c049b8923b61fa6ce669622e60f29fb6"
  let qy = hex_to_bytes "7903fe1008b8bc99a41ae9e95628bc64f2f1b20c2d7e9f5177a3c294d4462299"
  let h = hex_to_bytes "af2bdbe1aa9b6ec1e2ade1d694f41fc71a831d0268e9891562113d8a62add1bf"
  -- Original r, but flip the low bit.
  let r_bad = hex_to_bytes "efd48b2aacb6a8fd1140dd9cd45e81d69d2c877b56aaf991c34d0ea84eaf3717"
  let s = hex_to_bytes "f7cb1c942d657c41d436c7a1b6e29f65f3e900dbb9aff4064dc4ab2f843acda8"
  -- Wrong hash.
  let h_bad = hex_to_bytes "af2bdbe1aa9b6ec1e2ade1d694f41fc71a831d0268e9891562113d8a62add1be"
  let r_good = hex_to_bytes "efd48b2aacb6a8fd1140dd9cd45e81d69d2c877b56aaf991c34d0ea84eaf3716"
  -- Zero signature (must be rejected as out of range).
  let z = arr_new 32 0
  let _ = print "Negative tests — verify must return 0:"
  let e1 = ecdsa_p256_verify qx qy h r_bad s
  let _ = print (join "" ["  tampered r -> ", show e1])
  let e2 = ecdsa_p256_verify qx qy h_bad r_good s
  let _ = print (join "" ["  tampered hash -> ", show e2])
  let e3 = ecdsa_p256_verify qx qy h z s
  let _ = print (join "" ["  r = 0 -> ", show e3])
  let e4 = ecdsa_p256_verify qx qy h r_good z
  let _ = print (join "" ["  s = 0 -> ", show e4])
  if e1 == 0 then
    if e2 == 0 then
      if e3 == 0 then
        if e4 == 0 then
          let _ = print "PASS — all invalid signatures rejected"
          0
        else 1
      else 1
    else 1
  else 1
