-- Test P-256 bignum primitives against known values.

import "stdlib/sha256.rail"
import "stdlib/ecdsa_p256.rail"

-- Roundtrip: bytes → bignum → bytes.
test_roundtrip _ =
  let hex_in = "ffffffff00000001000000000000000000000000ffffffffffffffffffffffff"
  let b_in = hex_to_bytes hex_in
  let x = p256_from_bytes b_in
  let b_out = p256_to_bytes x
  let hex_out = bytes_to_hex b_out 32
  if str_find hex_in hex_out == 0 then
    let _ = print "  OK   roundtrip p"
    0
  else
    let _ = print (join "" ["  FAIL roundtrip p: in=", hex_in, " out=", hex_out])
    1

-- 2 * G should equal hand-computed 2*G (well-known P-256 doubling).
-- 2G has affine x = 7CF27B188D034F7E8A52380304B51AC3C08969E277F21B35A60B48FC47669978
-- 2G has affine y = 07775510DB8ED040293D9AC69F7430DBBA7DADE63CE982299E04B79D227873D1

test_2g _ =
  let Gpt = p256_point_new 0
  let _ = p256_copy (arr_get Gpt 0) (p256_load_gx 0)
  let _ = p256_copy (arr_get Gpt 1) (p256_load_gy 0)
  let _ = arr_set (arr_get Gpt 2) 0 1
  let Pt = p256_point_new 0
  let _ = p256_point_dbl Pt Gpt
  let ax = p256_new 0
  let ay = p256_new 0
  let ok = p256_to_affine ax ay Pt
  if ok == 0 then
    let _ = print "  FAIL 2G — to_affine failed"
    1
  else
    let bx = p256_to_bytes ax
    let by = p256_to_bytes ay
    let got_x = bytes_to_hex bx 32
    let got_y = bytes_to_hex by 32
    let exp_x = "7cf27b188d034f7e8a52380304b51ac3c08969e277f21b35a60b48fc47669978"
    let exp_y = "07775510db8ed040293d9ac69f7430dbba7dade63ce982299e04b79d227873d1"
    if str_find exp_x got_x == 0 then
      if str_find exp_y got_y == 0 then
        let _ = print "  OK   2G"
        0
      else
        let _ = print (join "" ["  FAIL 2G y got=", got_y, " exp=", exp_y])
        1
    else
      let _ = print (join "" ["  FAIL 2G x got=", got_x, " exp=", exp_x])
      1

-- Scalar 2 * G via double-and-add should also produce 2G.
test_smul_2g _ =
  let Gpt = p256_point_new 0
  let _ = p256_copy (arr_get Gpt 0) (p256_load_gx 0)
  let _ = p256_copy (arr_get Gpt 1) (p256_load_gy 0)
  let _ = arr_set (arr_get Gpt 2) 0 1
  let k = p256_new 0
  let _ = arr_set k 0 2
  let Pt = p256_point_new 0
  let _ = p256_scalar_mul Pt k Gpt
  let ax = p256_new 0
  let ay = p256_new 0
  let ok = p256_to_affine ax ay Pt
  if ok == 0 then
    let _ = print "  FAIL scalar-mul 2G — to_affine failed"
    1
  else
    let got_x = bytes_to_hex (p256_to_bytes ax) 32
    let exp_x = "7cf27b188d034f7e8a52380304b51ac3c08969e277f21b35a60b48fc47669978"
    if str_find exp_x got_x == 0 then
      let _ = print "  OK   scalar-mul 2G"
      0
    else
      let _ = print (join "" ["  FAIL scalar-mul 2G x got=", got_x])
      1

main =
  let _ = print "P-256 bignum primitive tests:"
  let e1 = test_roundtrip 0
  let e2 = test_2g 0
  let e3 = test_smul_2g 0
  let tot = e1 + e2 + e3
  if tot == 0 then
    let _ = print "PASS"
    0
  else
    let _ = print (join "" ["FAIL ", show tot, " cases"])
    1
