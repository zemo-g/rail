-- Layer 8c — DNS A-record resolver smoke test.
--
-- Resolves three real public hostnames via UDP to the system resolver
-- (read from /etc/resolv.conf, fallback 1.1.1.1). Returns the first
-- IPv4 from the answer section. No fancy retry, no DNSSEC, no AAAA.
--
-- Just proves the pure-Rail UDP DNS path works against real resolvers.

import "stdlib/socket.rail"
import "stdlib/dns.rail"

main =
  let _ = print "DNS A-record resolves (UDP, system resolver):"
  let ip1 = dns_resolve_a "api.anthropic.com"
  let _ = print (join "" ["  api.anthropic.com -> ", ip1])
  let ip2 = dns_resolve_a "www.amazon.com"
  let _ = print (join "" ["  www.amazon.com -> ", ip2])
  let ip3 = dns_resolve_a "example.com"
  let _ = print (join "" ["  example.com -> ", ip3])
  if length ip1 > 0 then if length ip2 > 0 then if length ip3 > 0 then
    let _ = print "PASS — all three hosts resolved"
    0
  else 1 else 1 else 1
