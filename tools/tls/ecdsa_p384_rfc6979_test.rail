-- RFC 6979 §A.2.6 ECDSA-P384-SHA384, message "sample".
import "stdlib/hmac.rail"
import "stdlib/ecdsa_p384.rail"

main =
  let qx = hex_to_bytes "ec3a4e415b4e19a4568618029f427fa5da9a8bc4ae92e02e06aae5286b300c64def8f0ea9055866064a254515480bc13"
  let qy = hex_to_bytes "8015d9b72d7d57244ea8ef9ac0c621896708a59367f9dfb9f54ca84b3f1c9db1288b231c3ae0d4fe7344fd2533264720"
  let h = hex_to_bytes "9a9083505bc92276aec4be312696ef7bf3bf603f4bbd381196a029f340585312313bca4a9b5b890efee42c77b1ee25fe"
  let r = hex_to_bytes "94edbb92a5ecb8aad4736e56c691916b3f88140666ce9fa73d64c4ea95ad133c81a648152e44acf96e36dd1e80fabe46"
  let s = hex_to_bytes "99ef4aeb15f178cea1fe40db2603138f130e740a19624526203b6351d0a3a94fa329c145786e679e7b82c71a38628ac8"
  let _ = print "RFC 6979 §A.2.6 ECDSA-P384-SHA384 verify (sample):"
  let ok = ecdsa_p384_verify qx qy h r s
  let _ = print (join "" ["  valid = ", show ok])
  if ok == 1 then let _ = print "PASS" in 0 else 1
