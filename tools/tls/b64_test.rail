import "stdlib/sha256.rail"
import "stdlib/b64.rail"

main =
  -- "hello, world!" in base64 = aGVsbG8sIHdvcmxkIQ==
  let r1 = b64_decode_to_arr "aGVsbG8sIHdvcmxkIQ=="
  let b1 = arr_get r1 0
  let n1 = arr_get r1 1
  let _ = print (join "" ["b64(aGVsbG8sIHdvcmxkIQ==) -> ", show n1, " bytes: ", bytes_to_hex b1 n1])
  let _ = print "expected = 13 bytes: 68656c6c6f2c20776f726c6421"
  -- Test with newlines (PEM-style wrapping)
  let r2 = b64_decode_to_arr "aGVsbG8sIHdvcmxk\nIQ=="
  let _ = print (join "" ["b64 with newline -> ", show (arr_get r2 1), " bytes: ", bytes_to_hex (arr_get r2 0) (arr_get r2 1)])
  0
