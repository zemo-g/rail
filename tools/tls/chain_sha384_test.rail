import "stdlib/tls13_client.rail"

inter _ = ""
root  _ = ""

-- Closed 2026-04-18 by stdlib/ecdsa_p384.rail: GTS Root R4's P-384
-- pubkey is now accepted via cv_extract_p384_pubkey + ecdsa_p384_verify,
-- with sha384_bytes(TBS) feeding the verify directly (no truncation —
-- P-384's order is 384 bits, same as the hash).
main =
  let i = hex_to_bytes (inter 0)
  let r = hex_to_bytes (root 0)
  let _ = print "WE1 (ecdsa-with-SHA384) verified by GTS Root R4 (P-384 pubkey):"
  let ok = cv_verify_cert_by i 675 r 894
  let _ = print (join "" ["  cv_verify_cert_by -> ", show ok, " (expect 1)"])
  if ok == 1 then let _ = print "PASS — P-384 chain edge verified" in 0 else 1
