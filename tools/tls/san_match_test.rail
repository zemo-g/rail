-- Layer 8a — SAN hostname validation against a captured api.anthropic.com cert.
--
-- This cert was captured 2026-04-18; SAN contains `DNS:api.anthropic.com`
-- only. When the cert rotates, this test will need a refresh; that's
-- intended — proves the parse against a real-world Google Trust Services
-- ECDSA-P256 leaf, not a synthetic.

import "stdlib/tls13_client.rail"

cert_hex _ = ""

main =
  let cert = hex_to_bytes (cert_hex 0)
  let cert_len = 931
  let _ = print (join "" ["api.anthropic.com SAN cert (", show cert_len, " bytes):"])
  let r1 = cv_validate_hostname cert cert_len "api.anthropic.com"
  let _ = print (join "" ["  api.anthropic.com -> ", show r1, " (expect 1)"])
  let r2 = cv_validate_hostname cert cert_len "evil.example.com"
  let _ = print (join "" ["  evil.example.com -> ", show r2, " (expect 0)"])
  let r3 = cv_validate_hostname cert cert_len "API.ANTHROPIC.COM"
  let _ = print (join "" ["  API.ANTHROPIC.COM (case) -> ", show r3, " (expect 1)"])
  let r4 = cv_validate_hostname cert cert_len "anthropic.com"
  let _ = print (join "" ["  anthropic.com (parent, no impl wildcard) -> ", show r4, " (expect 0)"])
  if r1 == 1 then if r2 == 0 then if r3 == 1 then if r4 == 0 then
    let _ = print "PASS"
    0
  else 1 else 1 else 1 else 1
