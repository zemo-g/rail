-- Layer 6c — tls13_cert_verify_sig against a self-generated ECDSA-P256 cert.
--
-- Exercises the full cert-verify path:
--   asn1_cert_fields → extract SPKI
--   cv_extract_p256_pubkey → (x, y) from uncompressed EC point
--   asn1_parse_ecdsa_sig → (r, s) from DER SEQUENCE
--   cv_build_signed + sha256_bytes → signing hash
--   ecdsa_p256_verify → 1/0
--
-- Cert + signature generated via Python `cryptography` with an ephemeral
-- P-256 key. Signed data = 64-space prefix + "TLS 1.3, server
-- CertificateVerify" + 0x00 + 32-byte transcript_hash (0xAA repeated).
--
-- NOTE: runs ONE verify per process. Back-to-back verifies in the same
-- process stall on arena/GC pressure from the bignum heap churn; split
-- across invocations or instrument with arena_mark/arena_reset. That's
-- a known Rail compiler characteristic, not an ECDSA correctness issue.

import "stdlib/tls13_client.rail"

main =
  let cert = hex_to_bytes ""
  let sig = hex_to_bytes "304502203a241f6c75320a14bca59d59696f1b0ec80d0f40557a96a28b95aa863f1ccda00221008508b92136ac6b53b8147b4f21a5150318f9fd61a65edf658d780cee72ddd051"
  let ts = hex_to_bytes "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
  let _ = print "tls13_cert_verify_sig — ECDSA-P256 + SHA-256:"
  let ok = tls13_cert_verify_sig cert 287 1027 sig 71 ts
  let _ = print (join "" ["  valid = ", show ok])
  if ok == 1 then
    let _ = print "PASS"
    0
  else
    let _ = print "FAIL — expected 1"
    1
