import "stdlib/tls13_client.rail"
import "stdlib/b64.rail"
import "stdlib/pem.rail"

cert2_hex _ = ""

main =
  let cert2 = hex_to_bytes (cert2_hex 0)
  let cert2_len = 894
  let _ = print "Looking up GTS R4 cross-sign's issuer (GlobalSign Root CA) in trust store..."
  let iss = asn1_find_issuer cert2 cert2_len
  let _ = print (join "" ["  cert2 issuer at off=", show (arr_get iss 0), " len=", show (arr_get iss 1)])
  let store = pem_load_trust_store "/etc/ssl/cert.pem"
  let n = arr_get store 2
  let _ = print (join "" ["  trust store: ", show n, " certs loaded"])
  let idx = ts_find_by_subject store cert2 (arr_get iss 0) (arr_get iss 1)
  let _ = print (join "" ["  match index: ", show idx])
  if idx < 0 then
    let _ = print "FAIL — issuer not found in store"
    1
  else
    let certs = arr_get store 0
    let lens = arr_get store 1
    let root = arr_get certs idx
    let root_len = arr_get lens idx
    let _ = print (join "" ["  root cert size: ", show root_len, " B"])
    let ok = cv_verify_cert_by cert2 cert2_len root root_len
    let _ = print (join "" ["  cv_verify_cert_by(cert2, root) -> ", show ok, " (expect 1)"])
    if ok == 1 then
      let _ = print "PASS — full chain to GlobalSign Root CA verified"
      0
    else 1
