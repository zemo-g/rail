-- Minimal Metal matmul test
-- Compiles kernel, dispatches on GPU, verifies against CPU

type Tensor = | Tensor data shape strides
mul_acc a b = a * b
cs shape = cs_a (tail (reverse shape)) [1]
cs_a d a = if length d == 0 then a else cs_a (tail d) (cons (head d * head a) a)
tnew s v = let sz = fold mul_acc 1 s in Tensor (float_arr_new sz v) s (cs s)
tgf t i = match t | Tensor d s st -> float_arr_get d i
tsf t i v = match t | Tensor d s st -> float_arr_set d i v

-- CPU matmul for verification
matmul_cpu a b m n k =
  let c = tnew [m, n] 0.0
  let _ = mc_i a b c m n k 0
  c
mc_i a b c m n k i = if i >= m then 0 else let _ = mc_j a b c m n k i 0 in mc_i a b c m n k (i + 1)
mc_j a b c m n k i j = if j >= n then 0 else let acc = float_arr_new 1 0.0 in let _ = mc_k a b acc k n i j 0 in let _ = tsf c (i * n + j) (float_arr_get acc 0) in mc_j a b c m n k i (j + 1)
mc_k a b acc k n i j ki = if ki >= k then 0 else let _ = float_arr_set acc 0 (float_arr_get acc 0 + tgf a (i * k + ki) * tgf b (ki * n + j)) in mc_k a b acc k n i j (ki + 1)

-- Write tensor data to binary file (float32 for Metal)
write_f32_buf t path =
  let n = match t | Tensor d s st -> float_arr_len d
  let py = cat [
    "import struct\n",
    "data = [", tensor_to_py_list t n 0, "]\n",
    "with open('", path, "', 'wb') as f:\n",
    "  for v in data:\n",
    "    f.write(struct.pack('<f', v))\n"]
  let _ = write_file "/tmp/rail_metal_write.py" py
  shell "python3 /tmp/rail_metal_write.py"

tensor_to_py_list t n i =
  if i >= n then ""
  else if i == 0 then cat [show_float (tgf t i), tensor_to_py_list t n (i + 1)]
  else cat [",", show_float (tgf t i), tensor_to_py_list t n (i + 1)]

-- Read float32 binary to tensor
read_f32_buf path n =
  let t = tnew [n] 0.0
  let py = cat [
    "import struct\n",
    "with open('", path, "', 'rb') as f: data = f.read()\n",
    "vals = [struct.unpack('<f', data[i:i+4])[0] for i in range(0, len(data), 4)]\n",
    "with open('/tmp/rail_metal_vals.txt', 'w') as f:\n",
    "  f.write(' '.join(str(v) for v in vals))\n"]
  let _ = write_file "/tmp/rail_metal_read.py" py
  let _ = shell "python3 /tmp/rail_metal_read.py"
  let vals = read_file "/tmp/rail_metal_vals.txt"
  let _ = parse_vals_into t vals n 0
  t

parse_vals_into t vals_str n i =
  if i >= n then 0
  else
    let parts = split " " vals_str
    parse_parts_into t parts n 0

parse_parts_into t parts n i =
  if i >= n then 0
  else if length parts == 0 then 0
  else
    let _ = tsf t i (to_float (parse_int_s (head parts)))
    parse_parts_into t (tail parts) n (i + 1)

parse_int_s s = let cs = chars s in pi_acc cs 0 1
pi_acc cs a sg = if length cs == 0 then a * sg else if head cs == "-" then pi_acc (tail cs) a (0 - 1) else if head cs == "." then a * sg else pi_acc (tail cs) (a * 10 + dv (head cs)) sg
dv c = if c == "0" then 0 else if c == "1" then 1 else if c == "2" then 2 else if c == "3" then 3 else if c == "4" then 4 else if c == "5" then 5 else if c == "6" then 6 else if c == "7" then 7 else if c == "8" then 8 else if c == "9" then 9 else 0

main =
  let _ = print "=== Metal GPU Matmul Test ==="
  let m = 4
  let k = 4
  let n = 4

  -- Create test matrices
  let a = tnew [m, k] 0.0
  let _ = tsf a 0 1.0
  let _ = tsf a 1 2.0
  let _ = tsf a 2 3.0
  let _ = tsf a 3 4.0
  let _ = tsf a 4 5.0
  let _ = tsf a 5 6.0
  let _ = tsf a 6 7.0
  let _ = tsf a 7 8.0
  let _ = tsf a 8 9.0
  let _ = tsf a 9 10.0
  let _ = tsf a 10 11.0
  let _ = tsf a 11 12.0
  let _ = tsf a 12 13.0
  let _ = tsf a 13 14.0
  let _ = tsf a 14 15.0
  let _ = tsf a 15 16.0

  let b = tnew [k, n] 0.0
  let _ = tsf b 0 0.1
  let _ = tsf b 1 0.2
  let _ = tsf b 2 0.3
  let _ = tsf b 3 0.4
  let _ = tsf b 4 0.5
  let _ = tsf b 5 0.6
  let _ = tsf b 6 0.7
  let _ = tsf b 7 0.8
  let _ = tsf b 8 0.9
  let _ = tsf b 9 1.0
  let _ = tsf b 10 1.1
  let _ = tsf b 11 1.2
  let _ = tsf b 12 1.3
  let _ = tsf b 13 1.4
  let _ = tsf b 14 1.5
  let _ = tsf b 15 1.6

  -- CPU matmul
  let cpu = matmul_cpu a b m n k
  let _ = print (cat ["  CPU C[0,0] = ", show_float (tgf cpu 0)])
  let _ = print (cat ["  CPU C[3,3] = ", show_float (tgf cpu 15)])

  -- Write buffers for Metal
  let _ = write_f32_buf a "/tmp/metal_a.bin"
  let _ = write_f32_buf b "/tmp/metal_b.bin"

  -- Compile Metal kernel
  let _ = write_file "/tmp/metal_mm.metal" "kernel void matmul_kernel(device const float *A [[buffer(0)]], device const float *B [[buffer(1)]], device float *C [[buffer(2)]], constant uint &M [[buffer(3)]], constant uint &N [[buffer(4)]], constant uint &K [[buffer(5)]], uint2 gid [[thread_position_in_grid]]) { uint row = gid.y; uint col = gid.x; if (row >= M || col >= N) return; float sum = 0.0; for (uint i = 0; i < K; i++) sum += A[row * K + i] * B[i * N + col]; C[row * N + col] = sum; }"

  let _ = shell "xcrun metal -c /tmp/metal_mm.metal -o /tmp/metal_mm.air 2>&1"
  let _ = shell "xcrun metallib /tmp/metal_mm.air -o /tmp/metal_mm.metallib 2>&1"
  let _ = print "  Metal kernel compiled"

  -- Write ObjC dispatch program
  let _ = write_file "/tmp/metal_dispatch.m" "#import <Metal/Metal.h>\n#import <Foundation/Foundation.h>\nint main() {\n  id<MTLDevice> dev = MTLCreateSystemDefaultDevice();\n  NSError *err;\n  NSURL *url = [NSURL fileURLWithPath:@\"/tmp/metal_mm.metallib\"];\n  id<MTLLibrary> lib = [dev newLibraryWithURL:url error:&err];\n  id<MTLFunction> fn = [lib newFunctionWithName:@\"matmul_kernel\"];\n  id<MTLComputePipelineState> ps = [dev newComputePipelineStateWithFunction:fn error:&err];\n  id<MTLCommandQueue> q = [dev newCommandQueue];\n  FILE *fa = fopen(\"/tmp/metal_a.bin\",\"rb\"); fseek(fa,0,SEEK_END); long sa=ftell(fa); rewind(fa);\n  void *da = malloc(sa); fread(da,1,sa,fa); fclose(fa);\n  FILE *fb = fopen(\"/tmp/metal_b.bin\",\"rb\"); fseek(fb,0,SEEK_END); long sb=ftell(fb); rewind(fb);\n  void *db = malloc(sb); fread(db,1,sb,fb); fclose(fb);\n  uint M=4,N=4,K=4;\n  id<MTLBuffer> bA = [dev newBufferWithBytes:da length:sa options:0];\n  id<MTLBuffer> bB = [dev newBufferWithBytes:db length:sb options:0];\n  id<MTLBuffer> bC = [dev newBufferWithLength:M*N*4 options:0];\n  id<MTLBuffer> bM = [dev newBufferWithBytes:&M length:4 options:0];\n  id<MTLBuffer> bN = [dev newBufferWithBytes:&N length:4 options:0];\n  id<MTLBuffer> bK = [dev newBufferWithBytes:&K length:4 options:0];\n  id<MTLCommandBuffer> cb = [q commandBuffer];\n  id<MTLComputeCommandEncoder> enc = [cb computeCommandEncoder];\n  [enc setComputePipelineState:ps];\n  [enc setBuffer:bA offset:0 atIndex:0];\n  [enc setBuffer:bB offset:0 atIndex:1];\n  [enc setBuffer:bC offset:0 atIndex:2];\n  [enc setBuffer:bM offset:0 atIndex:3];\n  [enc setBuffer:bN offset:0 atIndex:4];\n  [enc setBuffer:bK offset:0 atIndex:5];\n  MTLSize grid = MTLSizeMake(N,M,1);\n  MTLSize tg = MTLSizeMake(MIN(N,ps.maxTotalThreadsPerThreadgroup),1,1);\n  [enc dispatchThreads:grid threadsPerThreadgroup:tg];\n  [enc endEncoding];\n  [cb commit]; [cb waitUntilCompleted];\n  float *out = (float*)[bC contents];\n  FILE *fo = fopen(\"/tmp/metal_c.bin\",\"wb\"); fwrite(out,4,M*N,fo); fclose(fo);\n  free(da); free(db);\n  return 0;\n}\n"

  let _ = shell "clang -framework Metal -framework Foundation /tmp/metal_dispatch.m -o /tmp/metal_dispatch 2>&1"
  let _ = shell "/tmp/metal_dispatch 2>&1"
  let _ = print "  Metal dispatch complete"

  -- Read GPU result
  let gpu = read_f32_buf "/tmp/metal_c.bin" (m * n)
  let _ = print (cat ["  GPU C[0,0] = ", show_float (tgf gpu 0)])
  let _ = print (cat ["  GPU C[3,3] = ", show_float (tgf gpu 15)])

  -- Compare
  let _ = print (cat ["  Match [0,0]: ", if tgf cpu 0 - tgf gpu 0 < 0.01 then "YES" else "NO"])
  let _ = print "=== DONE ==="
  0
