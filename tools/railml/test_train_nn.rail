type Tensor = | Tensor data shape strides
mul_acc a b = a * b
cs shape = cs_a (tail (reverse shape)) [1]
cs_a d a = if length d == 0 then a else cs_a (tail d) (cons (head d * head a) a)
tnew s v = let sz = fold mul_acc 1 s in Tensor (float_arr_new sz v) s (cs s)
tgf t i = match t | Tensor d s st -> float_arr_get d i
tsf t i v = match t | Tensor d s st -> float_arr_set d i v
tsz t = match t | Tensor d s st -> float_arr_len d

matmul a b =
  match a | Tensor ad as_ ast ->
  match b | Tensor bd bs bst ->
    let m = head as_
    let k = head (tail as_)
    let n = head (tail bs)
    let c = tnew [m, n] 0.0
    let _ = mm_i ad bd c m n k 0
    c
mm_i a b c m n k i = if i >= m then 0 else let _ = mm_j a b c m n k i 0 in mm_i a b c m n k (i + 1)
mm_j a b c m n k i j = if j >= n then 0 else let acc = float_arr_new 1 0.0 in let _ = mm_k a b acc k n i j 0 in let _ = tsf c (i * n + j) (float_arr_get acc 0) in mm_j a b c m n k i (j + 1)
mm_k a b acc k n i j ki = if ki >= k then 0 else let _ = float_arr_set acc 0 (float_arr_get acc 0 + float_arr_get a (i * k + ki) * float_arr_get b (ki * n + j)) in mm_k a b acc k n i j (ki + 1)

mse p t = let n = tsz p in let a = float_arr_new 1 0.0 in let _ = mse_l p t n 0 a in float_arr_get a 0 / to_float n
mse_l p t n i a = if i >= n then 0 else let d = tgf p i - tgf t i in let _ = float_arr_set a 0 (float_arr_get a 0 + d * d) in mse_l p t n (i + 1) a

-- Inline gradient: perturb w[i], compute loss, restore
grad_step x y w lr =
  let nw = tsz w
  let _ = gs_l x y w nw 0 lr
  0
gs_l x y w nw i lr =
  if i >= nw then 0
  else
    let o = tgf w i
    let _ = tsf w i (o + 0.0001)
    let fp = mse (matmul x w) y
    let _ = tsf w i (o - 0.0001)
    let fm = mse (matmul x w) y
    let g = (fp - fm) / 0.0002
    let _ = tsf w i (o - lr * g)
    gs_l x y w nw (i + 1) lr

main =
  let _ = print "=== NN: y = 3*x1 + 2*x2 ==="
  let w = tnew [2, 1] 0.0
  let _ = tsf w 0 0.5
  let _ = tsf w 1 (0.0 - 0.3)

  let x = tnew [4, 2] 0.0
  let _ = tsf x 0 1.0
  let _ = tsf x 1 0.0
  let _ = tsf x 2 0.0
  let _ = tsf x 3 1.0
  let _ = tsf x 4 1.0
  let _ = tsf x 5 1.0
  let _ = tsf x 6 2.0
  let _ = tsf x 7 3.0
  let y = tnew [4, 1] 0.0
  let _ = tsf y 0 3.0
  let _ = tsf y 1 2.0
  let _ = tsf y 2 5.0
  let _ = tsf y 3 12.0

  let _ = tloop x y w 0.005 500 0
  let _ = print (cat ["  w = [", show_float (tgf w 0), ", ", show_float (tgf w 1), "] (expect [3, 2])"])
  let _ = print "=== DONE ==="
  0

tloop x y w lr steps step =
  if step >= steps then 0
  else
    let _ = if step / 50 * 50 == step then
      let loss = mse (matmul x w) y
      print (cat ["  step ", show step, " loss=", show_float loss])
    else 0
    let _ = grad_step x y w lr
    tloop x y w lr steps (step + 1)
