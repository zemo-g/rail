-- test_gradients.rail — Numerical gradient checking (no higher-order functions)
-- Each test: perturb element +/- eps, compute (f+-f-)/2eps, compare to analytical

import "stdlib/tensor.rail"

eps = 0.0001

-- ── sum(x^2) ────────────────────────────────────────────
sum_sq t =
  let n = tensor_size t
  sum_sq_acc t n 0 0.0
sum_sq_acc t n i acc =
  if i >= n then acc
  else
    let v = tensor_get_flat t i
    sum_sq_acc t n (i + 1) (acc + v * v)

-- ── sum(relu(x)) ────────────────────────────────────────
sum_relu t =
  let n = tensor_size t
  sum_relu_acc t n 0 0.0
sum_relu_acc t n i acc =
  if i >= n then acc
  else
    let v = tensor_get_flat t i
    let r = if v > 0.0 then v else 0.0
    sum_relu_acc t n (i + 1) (acc + r)

-- ── sum(exp(x)) ─────────────────────────────────────────
sum_exp t =
  let n = tensor_size t
  sum_exp_acc t n 0 0.0
sum_exp_acc t n i acc =
  if i >= n then acc
  else
    sum_exp_acc t n (i + 1) (acc + exp (tensor_get_flat t i))

-- ── Inline numerical gradient for sum_sq ────────────────
numgrad_sumsq t i =
  let orig = tensor_get_flat t i
  let _ = tensor_set_flat t i (orig + eps)
  let fp = sum_sq t
  let _ = tensor_set_flat t i (orig - eps)
  let fm = sum_sq t
  let _ = tensor_set_flat t i orig
  (fp - fm) / (2.0 * eps)

-- ── Inline numerical gradient for sum_relu ──────────────
numgrad_relu t i =
  let orig = tensor_get_flat t i
  let _ = tensor_set_flat t i (orig + eps)
  let fp = sum_relu t
  let _ = tensor_set_flat t i (orig - eps)
  let fm = sum_relu t
  let _ = tensor_set_flat t i orig
  (fp - fm) / (2.0 * eps)

-- ── Inline numerical gradient for sum_exp ───────────────
numgrad_exp t i =
  let orig = tensor_get_flat t i
  let _ = tensor_set_flat t i (orig + eps)
  let fp = sum_exp t
  let _ = tensor_set_flat t i (orig - eps)
  let fm = sum_exp t
  let _ = tensor_set_flat t i orig
  (fp - fm) / (2.0 * eps)

-- ── Check helper ────────────────────────────────────────
abs_f x = if x > 0.0 then x else 0.0 - x

check name i numerical analytical =
  let diff = abs_f (numerical - analytical)
  let denom = abs_f analytical + 0.000001
  let rel = diff / denom
  let tag = if rel < 0.01 then "PASS" else "FAIL"
  let _ = print (cat ["  ", name, "[", show i, "]: num=", show_float numerical, " ana=", show_float analytical, " err=", show_float rel, " ", tag])
  tag

main =
  let _ = print "=== RailML Gradient Checks ==="
  let _ = print ""

  -- Test 1: d/dx sum(x^2) = 2x
  let _ = print "--- Test 1: d/dx sum(x^2) = 2x ---"
  let x1 = tensor_new [4] 0.0
  let _ = tensor_set_flat x1 0 1.0
  let _ = tensor_set_flat x1 1 (0.0 - 2.0)
  let _ = tensor_set_flat x1 2 3.0
  let _ = tensor_set_flat x1 3 0.5
  let _ = check "x^2" 0 (numgrad_sumsq x1 0) 2.0
  let _ = check "x^2" 1 (numgrad_sumsq x1 1) (0.0 - 4.0)
  let _ = check "x^2" 2 (numgrad_sumsq x1 2) 6.0
  let _ = check "x^2" 3 (numgrad_sumsq x1 3) 1.0
  let _ = print ""

  -- Test 2: d/dx sum(relu(x)) = 1{x>0}
  let _ = print "--- Test 2: d/dx sum(relu(x)) = 1{x>0} ---"
  let x2 = tensor_new [4] 0.0
  let _ = tensor_set_flat x2 0 2.0
  let _ = tensor_set_flat x2 1 (0.0 - 1.0)
  let _ = tensor_set_flat x2 2 0.5
  let _ = tensor_set_flat x2 3 (0.0 - 3.0)
  let _ = check "relu" 0 (numgrad_relu x2 0) 1.0
  let _ = check "relu" 1 (numgrad_relu x2 1) 0.0
  let _ = check "relu" 2 (numgrad_relu x2 2) 1.0
  let _ = check "relu" 3 (numgrad_relu x2 3) 0.0
  let _ = print ""

  -- Test 3: d/dx sum(exp(x)) = exp(x)
  let _ = print "--- Test 3: d/dx sum(exp(x)) = exp(x) ---"
  let x3 = tensor_new [3] 0.0
  let _ = tensor_set_flat x3 0 0.0
  let _ = tensor_set_flat x3 1 1.0
  let _ = tensor_set_flat x3 2 (0.0 - 1.0)
  let _ = check "exp" 0 (numgrad_exp x3 0) (exp 0.0)
  let _ = check "exp" 1 (numgrad_exp x3 1) (exp 1.0)
  let _ = check "exp" 2 (numgrad_exp x3 2) (exp (0.0 - 1.0))

  let _ = print ""
  let _ = print "=== Gradient checks complete ==="
  0
