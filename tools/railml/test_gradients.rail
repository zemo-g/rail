
type Tensor = | Tensor data shape strides
mul_acc a b = a * b
cs shape = cs_a (tail (reverse shape)) [1]
cs_a d a = if length d == 0 then a else cs_a (tail d) (cons (head d * head a) a)
tnew s v = let sz = fold mul_acc 1 s in Tensor (float_arr_new sz v) s (cs s)
tgf t i = match t | Tensor d s st -> float_arr_get d i
tsf t i v = match t | Tensor d s st -> float_arr_set d i v
tsz t = match t | Tensor d s st -> float_arr_len d

ssq t = let n = tsz t in let a = float_arr_new 1 0.0 in let _ = sq_l t n 0 a in float_arr_get a 0
sq_l t n i a = if i >= n then 0 else let v = tgf t i in let _ = float_arr_set a 0 (float_arr_get a 0 + v * v) in sq_l t n (i + 1) a

srl t = let n = tsz t in let a = float_arr_new 1 0.0 in let _ = rl_l t n 0 a in float_arr_get a 0
rl_l t n i a = if i >= n then 0 else let v = tgf t i in let r = if v > 0.0 then v else 0.0 in let _ = float_arr_set a 0 (float_arr_get a 0 + r) in rl_l t n (i + 1) a

sex t = let n = tsz t in let a = float_arr_new 1 0.0 in let _ = ex_l t n 0 a in float_arr_get a 0
ex_l t n i a = if i >= n then 0 else let _ = float_arr_set a 0 (float_arr_get a 0 + exp (tgf t i)) in ex_l t n (i + 1) a

ng_s t i = let o = tgf t i in let _ = tsf t i (o + 0.0001) in let fp = ssq t in let _ = tsf t i (o - 0.0001) in let fm = ssq t in let _ = tsf t i o in (fp - fm) / 0.0002
ng_r t i = let o = tgf t i in let _ = tsf t i (o + 0.0001) in let fp = srl t in let _ = tsf t i (o - 0.0001) in let fm = srl t in let _ = tsf t i o in (fp - fm) / 0.0002
ng_e t i = let o = tgf t i in let _ = tsf t i (o + 0.0001) in let fp = sex t in let _ = tsf t i (o - 0.0001) in let fm = sex t in let _ = tsf t i o in (fp - fm) / 0.0002

p s v = print (cat [s, show_float v])

main =
  let _ = print "=== d/dx sum(x^2) = 2x ==="
  let x1 = tnew [4] 0.0
  let _ = tsf x1 0 1.0
  let _ = tsf x1 1 (0.0 - 2.0)
  let _ = tsf x1 2 3.0
  let _ = tsf x1 3 0.5
  let _ = p "  [0] expect  2: " (ng_s x1 0)
  let _ = p "  [1] expect -4: " (ng_s x1 1)
  let _ = p "  [2] expect  6: " (ng_s x1 2)
  let _ = p "  [3] expect  1: " (ng_s x1 3)

  let _ = print "=== d/dx sum(relu(x)) = 1{x>0} ==="
  let x2 = tnew [4] 0.0
  let _ = tsf x2 0 2.0
  let _ = tsf x2 1 (0.0 - 1.0)
  let _ = tsf x2 2 0.5
  let _ = tsf x2 3 (0.0 - 3.0)
  let _ = p "  [0] expect 1: " (ng_r x2 0)
  let _ = p "  [1] expect 0: " (ng_r x2 1)
  let _ = p "  [2] expect 1: " (ng_r x2 2)
  let _ = p "  [3] expect 0: " (ng_r x2 3)

  let _ = print "=== d/dx sum(exp(x)) = exp(x) ==="
  let x3 = tnew [3] 0.0
  let _ = tsf x3 0 0.0
  let _ = tsf x3 1 1.0
  let _ = tsf x3 2 (0.0 - 1.0)
  let _ = p "  [0] expect 1.0:   " (ng_e x3 0)
  let _ = p "  [1] expect 2.718: " (ng_e x3 1)
  let _ = p "  [2] expect 0.368: " (ng_e x3 2)
  let _ = print "=== ALL DONE ==="
  0
