type Tensor = | Tensor data shape strides
mul_acc a b = a * b
cs shape = cs_a (tail (reverse shape)) [1]
cs_a d a = if length d == 0 then a else cs_a (tail d) (cons (head d * head a) a)
tnew s v = let sz = fold mul_acc 1 s in Tensor (float_arr_new sz v) s (cs s)
tgf t i = match t | Tensor d s st -> float_arr_get d i
tsf t i v = match t | Tensor d s st -> float_arr_set d i v
tsz t = match t | Tensor d s st -> float_arr_len d
tsh t = match t | Tensor d s st -> s

matmul a b =
  match a | Tensor ad as_ ast ->
  match b | Tensor bd bs bst ->
    let m = head as_
    let k = head (tail as_)
    let n = head (tail bs)
    let c = tnew [m, n] 0.0
    let _ = mm_i ad bd c m n k 0
    c
mm_i a b c m n k i =
  if i >= m then 0
  else let _ = mm_j a b c m n k i 0 in mm_i a b c m n k (i + 1)
mm_j a b c m n k i j =
  if j >= n then 0
  else
    let acc = float_arr_new 1 0.0
    let _ = mm_k a b acc k n i j 0
    let _ = tsf c (i * n + j) (float_arr_get acc 0)
    mm_j a b c m n k i (j + 1)
mm_k a b acc k n i j ki =
  if ki >= k then 0
  else
    let _ = float_arr_set acc 0 (float_arr_get acc 0 + float_arr_get a (i * k + ki) * float_arr_get b (ki * n + j))
    mm_k a b acc k n i j (ki + 1)

tsum t = let n = tsz t in let a = float_arr_new 1 0.0 in let _ = ts_l t n 0 a in float_arr_get a 0
ts_l t n i a = if i >= n then 0 else let _ = float_arr_set a 0 (float_arr_get a 0 + tgf t i) in ts_l t n (i + 1) a

-- softmax over flat tensor
softmax t =
  let n = tsz t
  let mx = float_arr_new 1 (0.0 - 999999.0)
  let _ = smax_l t n 0 mx
  let mxv = float_arr_get mx 0
  let out = tnew [n] 0.0
  let sm = float_arr_new 1 0.0
  let _ = sexp_l t out n 0 mxv sm
  let smv = float_arr_get sm 0
  let _ = snrm_l out n 0 smv
  out
smax_l t n i mx = if i >= n then 0 else let v = tgf t i in let _ = if v > float_arr_get mx 0 then float_arr_set mx 0 v else 0 in smax_l t n (i + 1) mx
sexp_l t o n i mx sm = if i >= n then 0 else let v = exp (tgf t i - mx) in let _ = tsf o i v in let _ = float_arr_set sm 0 (float_arr_get sm 0 + v) in sexp_l t o n (i + 1) mx sm
snrm_l o n i s = if i >= n then 0 else let _ = tsf o i (tgf o i / s) in snrm_l o n (i + 1) s

-- layer norm (1D, no gamma/beta for simplicity)
lnorm t =
  let n = tsz t
  let mu = tsum t / to_float n
  let var_acc = float_arr_new 1 0.0
  let _ = var_l t n 0 mu var_acc
  let var = float_arr_get var_acc 0 / to_float n
  let std = sqrt (var + 0.00001)
  let out = tnew [n] 0.0
  let _ = norm_l t out n 0 mu std
  out
var_l t n i mu a = if i >= n then 0 else let d = tgf t i - mu in let _ = float_arr_set a 0 (float_arr_get a 0 + d * d) in var_l t n (i + 1) mu a
norm_l t o n i mu std = if i >= n then 0 else let _ = tsf o i ((tgf t i - mu) / std) in norm_l t o n (i + 1) mu std

-- numerical gradient helper
ng t i f_sum =
  let o = tgf t i
  let _ = tsf t i (o + 0.0001)
  let fp = f_sum t
  let _ = tsf t i (o - 0.0001)
  let fm = f_sum t
  let _ = tsf t i o
  (fp - fm) / 0.0002

-- sum(matmul(A, B)) gradient w.r.t. A[i]
sum_mm a b = tsum (matmul a b)

ng_mm a b i =
  let o = tgf a i
  let _ = tsf a i (o + 0.0001)
  let fp = sum_mm a b
  let _ = tsf a i (o - 0.0001)
  let fm = sum_mm a b
  let _ = tsf a i o
  (fp - fm) / 0.0002

-- sum(softmax(x)) gradient (should be 0 everywhere — softmax sums to 1)
sum_sm t = tsum (softmax t)
ng_sm t i =
  let o = tgf t i
  let _ = tsf t i (o + 0.0001)
  let fp = sum_sm t
  let _ = tsf t i (o - 0.0001)
  let fm = sum_sm t
  let _ = tsf t i o
  (fp - fm) / 0.0002

-- sum(lnorm(x)) gradient (should be ~0 — normalized sum is near 0)
sum_ln t = tsum (lnorm t)
ng_ln t i =
  let o = tgf t i
  let _ = tsf t i (o + 0.0001)
  let fp = sum_ln t
  let _ = tsf t i (o - 0.0001)
  let fm = sum_ln t
  let _ = tsf t i o
  (fp - fm) / 0.0002

p s v = print (cat [s, show_float v])

main =
  let _ = print "=== MATMUL GRADIENT ==="
  let a = tnew [2, 3] 0.0
  let _ = tsf a 0 1.0
  let _ = tsf a 1 2.0
  let _ = tsf a 2 3.0
  let _ = tsf a 3 4.0
  let _ = tsf a 4 5.0
  let _ = tsf a 5 6.0
  let b = tnew [3, 2] 0.0
  let _ = tsf b 0 0.1
  let _ = tsf b 1 0.2
  let _ = tsf b 2 0.3
  let _ = tsf b 3 0.4
  let _ = tsf b 4 0.5
  let _ = tsf b 5 0.6
  let _ = p "  dA[0,0] expect 0.3: " (ng_mm a b 0)
  let _ = p "  dA[0,1] expect 0.7: " (ng_mm a b 1)
  let _ = p "  dA[0,2] expect 1.1: " (ng_mm a b 2)

  let _ = print "=== SOFTMAX GRADIENT ==="
  let s = tnew [4] 0.0
  let _ = tsf s 0 2.0
  let _ = tsf s 1 1.0
  let _ = tsf s 2 0.5
  let _ = tsf s 3 0.0
  let _ = p "  d_sum(sm)[0] expect ~0: " (ng_sm s 0)
  let _ = p "  d_sum(sm)[1] expect ~0: " (ng_sm s 1)
  let sm = softmax s
  let _ = p "  sm[0] (largest): " (tgf sm 0)
  let _ = p "  sm sum (expect 1): " (tsum sm)

  let _ = print "=== LAYER NORM ==="
  let x = tnew [4] 0.0
  let _ = tsf x 0 1.0
  let _ = tsf x 1 2.0
  let _ = tsf x 2 3.0
  let _ = tsf x 3 4.0
  let normed = lnorm x
  let _ = p "  norm[0]: " (tgf normed 0)
  let _ = p "  norm[3]: " (tgf normed 3)
  let _ = p "  norm mean (~0): " (tsum normed / 4.0)

  let _ = print "=== ALL FORWARD+GRADIENT CHECKS DONE ==="
  0
