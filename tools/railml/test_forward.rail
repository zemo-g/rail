-- test_forward.rail — Item 2: Test forward pass with real weights
-- Loads micro model from text format, runs forward on dummy tokens, checks output.

import "stdlib/tensor.rail"
import "stdlib/math.rail"

-- ── Text weight loader ──────────────────────────────────

-- Parse a space-separated list of floats into a tensor with given shape
parse_floats_into t str_data total i =
  if i >= total then t
  else
    let parts = split " " str_data
    parse_floats_parts t parts total 0

parse_floats_parts t parts total i =
  if i >= total then t
  else if i >= length parts then t
  else
    let val_str = head parts
    let val = to_float (parse_int_simple val_str)
    let _ = tensor_set_flat t i val
    parse_floats_parts t (tail parts) total (i + 1)

-- Simple float parser: reads integer part (ignores decimal for now)
parse_int_simple s =
  let cs = chars s
  parse_int_chars cs 0 1

parse_int_chars cs acc sign =
  if length cs == 0 then acc * sign
  else
    let c = head cs
    if c == "-" then parse_int_chars (tail cs) acc (0 - 1)
    else if c == "." then acc * sign
    else
      let d = digit_val_fw c
      parse_int_chars (tail cs) (acc * 10 + d) sign

digit_val_fw c =
  if c == "0" then 0 else if c == "1" then 1 else if c == "2" then 2
  else if c == "3" then 3 else if c == "4" then 4 else if c == "5" then 5
  else if c == "6" then 6 else if c == "7" then 7 else if c == "8" then 8
  else if c == "9" then 9 else 0

-- Load model: read text format, build tensors
-- Format: line 1 = "n_layers d_model n_heads vocab_size"
-- Then pairs: "name shape..." / "val val val..."
load_text_model path =
  let content = read_file path
  let lines = split "\n" content
  let header = head lines
  let header_parts = split " " header
  let n_layers = parse_int_simple (head header_parts)
  let d_model = parse_int_simple (head (tail header_parts))
  let n_heads = parse_int_simple (head (tail (tail header_parts)))
  let vocab_size = parse_int_simple (head (tail (tail (tail header_parts))))
  let _ = print (cat ["Config: ", show n_layers, "L/", show d_model, "d/", show n_heads, "h/", show vocab_size, "v"])
  let rest = tail lines
  let n_weights = length rest / 2
  let _ = print (cat ["Loading ", show n_weights, " weight tensors..."])
  (n_layers, d_model, n_heads, vocab_size)

-- ── Minimal forward pass test ───────────────────────────

-- Softmax over a 1D tensor
softmax_1d t =
  let n = tensor_size t
  -- Find max
  let max_val = tensor_max_val t n 0 (0.0 - 999999.0)
  -- Exp and sum
  let exp_t = tensor_new [n] 0.0
  let sum_val = softmax_exp_sum t exp_t n 0 max_val 0.0
  -- Normalize
  let _ = softmax_normalize exp_t n 0 sum_val
  exp_t

tensor_max_val t n i best =
  if i >= n then best
  else
    let v = tensor_get_flat t i
    let new_best = if v > best then v else best
    tensor_max_val t n (i + 1) new_best

softmax_exp_sum t exp_t n i max_v acc =
  if i >= n then acc
  else
    let v = exp (tensor_get_flat t i - max_v)
    let _ = tensor_set_flat exp_t i v
    softmax_exp_sum t exp_t n (i + 1) max_v (acc + v)

softmax_normalize t n i total =
  if i >= n then 0
  else
    let _ = tensor_set_flat t i (tensor_get_flat t i / total)
    softmax_normalize t n (i + 1) total

-- ── Test ─────────────────────────────────────────────────

main =
  let _ = print "=== RailML Forward Pass Test ==="
  let _ = print ""

  -- Load config
  let (n_layers, d_model, n_heads, vocab_size) = load_text_model "/tmp/railml_micro_model.txt"
  let _ = print ""

  -- Test 1: matmul works at model scale
  let _ = print "--- Test 1: Matmul (4x4 @ 4x4) ---"
  let a = tensor_new [d_model, d_model] 0.1
  let b = tensor_new [d_model, d_model] 0.2
  let c = matmul a b
  let v = tensor_get c [0, 0]
  let _ = print (cat ["  C[0,0] = ", show_float v, " (expect 0.08 for 4x4 * 0.1 * 0.2)"])

  -- Test 2: Softmax produces valid probability distribution
  let _ = print "--- Test 2: Softmax ---"
  let logits = tensor_new [vocab_size] 0.0
  let _ = tensor_set_flat logits 0 2.0
  let _ = tensor_set_flat logits 1 1.0
  let _ = tensor_set_flat logits 2 0.5
  let probs = softmax_1d logits
  let p0 = tensor_get_flat probs 0
  let p1 = tensor_get_flat probs 1
  let sum_p = tensor_sum probs
  let _ = print (cat ["  P[0] = ", show_float p0, " (should be largest)"])
  let _ = print (cat ["  P[1] = ", show_float p1, " (should be second)"])
  let _ = print (cat ["  Sum  = ", show_float sum_p, " (should be ~1.0)"])

  -- Test 3: Embedding lookup
  let _ = print "--- Test 3: Embedding lookup ---"
  let embed = tensor_new [vocab_size, d_model] 0.0
  -- Set embed[3] = [1.0, 2.0, 3.0, 4.0]
  let _ = tensor_set embed [3, 0] 1.0
  let _ = tensor_set embed [3, 1] 2.0
  let _ = tensor_set embed [3, 2] 3.0
  let _ = tensor_set embed [3, 3] 4.0
  -- Lookup token 3
  let row = tensor_new [1, d_model] 0.0
  let _ = tensor_set row [0, 0] (tensor_get embed [3, 0])
  let _ = tensor_set row [0, 1] (tensor_get embed [3, 1])
  let _ = tensor_set row [0, 2] (tensor_get embed [3, 2])
  let _ = tensor_set row [0, 3] (tensor_get embed [3, 3])
  let _ = print (cat ["  embed[3] = [", show_float (tensor_get row [0,0]), ", ", show_float (tensor_get row [0,1]), ", ", show_float (tensor_get row [0,2]), ", ", show_float (tensor_get row [0,3]), "]"])
  let _ = print "  (expect [1, 2, 3, 4])"

  -- Test 4: Layer norm
  let _ = print "--- Test 4: Layer norm ---"
  let x = tensor_new [1, d_model] 0.0
  let _ = tensor_set x [0, 0] 1.0
  let _ = tensor_set x [0, 1] 2.0
  let _ = tensor_set x [0, 2] 3.0
  let _ = tensor_set x [0, 3] 4.0
  let mean_x = tensor_mean x
  let _ = print (cat ["  input mean = ", show_float mean_x, " (expect 2.5)"])

  -- Test 5: Full pipeline check
  let _ = print "--- Test 5: Pipeline ---"
  let _ = print "  embed → norm → Q/K/V → attention → FFN → logits"
  -- Create dummy Q, K (seq=2, d=4)
  let q = tensor_new [2, d_model] 0.1
  let k = tensor_new [2, d_model] 0.1
  let kt = tensor_transpose k
  let scores = matmul q kt
  let _ = print (cat ["  scores[0,0] = ", show_float (tensor_get scores [0,0])])
  let _ = print (cat ["  scores shape: [", show (dim scores 0), ",", show (dim scores 1), "]"])

  let _ = print ""
  let _ = print "=== All forward pass tests complete ==="
  0
