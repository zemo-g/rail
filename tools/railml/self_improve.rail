-- ══════════════════════════════════════════════════════════════════════════════
-- PROGRESS TRACKING — persist state across runs
-- ══════════════════════════════════════════════════════════════════════════════

parse_kv lines key =
  if length lines == 0 then 0
  else
    let parts = split "=" (head lines)
    if length parts >= 2 then
      if head parts == key then to_int (head (tail parts))
      else parse_kv (tail lines) key
    else parse_kv (tail lines) key

read_progress dummy =
  let content = read_file progress_path
  if length content == 0 then (1, 1, 0, 0, 0, 0)
  else
    let lines = split "\n" content
    let round = parse_kv lines "round"
    let level = parse_kv lines "level"
    let harvested = parse_kv lines "harvested"
    let since_retrain = parse_kv lines "since_retrain"
    let consecutive_pass = parse_kv lines "consecutive_pass"
    let consecutive_zero = parse_kv lines "consecutive_zero"
    (round, level, harvested, since_retrain, consecutive_pass, consecutive_zero)

write_progress round level harvested since_retrain consecutive_pass consecutive_zero =
  write_file progress_path (cat [
    "round=", show round, "\n",
    "level=", show level, "\n",
    "harvested=", show harvested, "\n",
    "since_retrain=", show since_retrain, "\n",
    "consecutive_pass=", show consecutive_pass, "\n",
    "consecutive_zero=", show consecutive_zero, "\n"])

-- ══════════════════════════════════════════════════════════════════════════════
-- GOAL STEERING — read goals from file, focus training on specific capabilities
-- ══════════════════════════════════════════════════════════════════════════════

load_goals dummy =
  let content = read_file goals_path
  if length content == 0 then []
  else
    let lines = split "\n" content
    -- Filter out comments (lines starting with #) and short lines
    filter (\l -> if length l < 3 then false else head (chars l) != "#") lines

pick_goal goals round =
  if length goals == 0 then ""
  else
    let idx = round % length goals
    nth_elem goals idx

-- ══════════════════════════════════════════════════════════════════════════════
-- TASK SELECTION — pick and parse tasks
-- ══════════════════════════════════════════════════════════════════════════════

task_desc t = head (tail (split "\t" t))

task_expected t =
  let parts = split "\t" t
  if length parts >= 3 then head (tail (tail parts))
  else ""

-- Shuffle tasks via shell for diversity
shuffle_tasks tasks =
  let _ = write_file "/tmp/railml_si_tasks.txt" (join "\n" tasks)
  let shuffled = shell "shuf /tmp/railml_si_tasks.txt 2>/dev/null || cat /tmp/railml_si_tasks.txt"
  filter (\s -> length s > 3) (split "\n" shuffled)

-- ══════════════════════════════════════════════════════════════════════════════
-- RETRAIN TRIGGER — rebuild dataset and retrain when enough new data
-- ══════════════════════════════════════════════════════════════════════════════

-- Retrain threshold: how many new examples before triggering retrain
retrain_threshold = 50

-- Rebuild dataset from all harvest files, then call train.rail
retrain model_dir =
  let _ = print "\n================================================================"
  let _ = print "  RETRAINING — closing the loop"
  let _ = print "================================================================"
  -- Merge harvest + repairs into a unified dataset
  let _ = shell (cat ["mkdir -p ", dataset_path])
  let _ = shell (cat ["cat ", harvest_path, " ", repair_path, " > ", dataset_path, "/all.jsonl 2>/dev/null"])
  -- Dedup the merged file
  let _ = write_file "/tmp/railml_dedup.py" (cat [
    "import json, hashlib\n",
    "seen = set()\n",
    "unique = []\n",
    "with open('", dataset_path, "/all.jsonl') as f:\n",
    "    for line in f:\n",
    "        line = line.strip()\n",
    "        if not line: continue\n",
    "        try:\n",
    "            obj = json.loads(line)\n",
    "            code = ''\n",
    "            for m in obj.get('messages', []):\n",
    "                if m.get('role') == 'assistant': code = m.get('content', '')\n",
    "            h = hashlib.sha256(code.encode()).hexdigest()\n",
    "            if h not in seen:\n",
    "                seen.add(h)\n",
    "                unique.append(line)\n",
    "        except: pass\n",
    "import random; random.seed(42); random.shuffle(unique)\n",
    "n = len(unique)\n",
    "t = int(n * 0.9)\n",
    "v = int(n * 0.95)\n",
    "with open('", dataset_path, "/train.jsonl', 'w') as f:\n",
    "    for l in unique[:t]: f.write(l + '\\n')\n",
    "with open('", dataset_path, "/valid.jsonl', 'w') as f:\n",
    "    for l in unique[t:v]: f.write(l + '\\n')\n",
    "with open('", dataset_path, "/test.jsonl', 'w') as f:\n",
    "    for l in unique[v:]: f.write(l + '\\n')\n",
    "print(f'{n} total -> {len(unique)} unique (train={t}, valid={v-t}, test={n-v})')\n"])
  let split_result = trim (shell "python3 /tmp/railml_dedup.py 2>&1")
  let _ = print (cat ["  Dataset: ", split_result])
  -- Call train.rail (Phase 5) — pure Rail training
  let train_bin = cat [model_dir, "/train_bin"]
  let has_train = trim (shell (cat ["test -f ", train_bin, " && echo ok || echo no"]))
  if has_train == "ok" then
    let _ = print "  Training via train.rail (pure Rail)..."
    let train_result = shell (cat [train_bin, " ", dataset_path, "/train.jsonl ", dataset_path, "/valid.jsonl ", model_dir, " 2>&1"])
    let _ = print (cat ["  Train result: ", trim train_result])
    let _ = print "  Retrain complete."
    0
  else
    -- Fallback: call MLX LoRA training
    let _ = print "  No train_bin found. Falling back to MLX LoRA..."
    let _ = print "  (Set up Phase 5 train.rail for pure-Rail training)"
    let train_out = shell (cat ["/Users/ledaticempire/homebrew/bin/python3.11 -m mlx_lm lora ",
      "--model /Users/ledaticempire/models/Qwen3.5-4B-4bit ",
      "--train --data ", dataset_path, "/ ",
      "--iters 500 --batch-size 1 --learning-rate 1e-5 --num-layers 8 ",
      "--steps-per-report 100 --steps-per-eval 250 ",
      "--max-seq-length 1024 --mask-prompt ",
      "--adapter-path ", model_dir, "/adapters 2>&1"])
    let _ = print (cat ["  MLX LoRA: ", trim (shell "tail -3 /tmp/railml_train.log 2>/dev/null")])
    let _ = print "  Retrain complete (MLX fallback)."
    0

-- ══════════════════════════════════════════════════════════════════════════════
-- THE META-LOOP — the unprecedented part
-- ══════════════════════════════════════════════════════════════════════════════
--
-- Phase A: Model generates Rail code -> compiler verifies -> harvest -> retrain
--          (this is the standard self-training loop, same as self_train.rail)
--
-- Phase B: Model proposes COMPILER improvements -> compile compiler with changes
--          -> verify fixed point -> accept/reject
--          (this is self-improvement with a proof checker)
--
-- The compiler is both the oracle AND the artifact being improved.
-- A fixed-point check (compile compiler with proposed changes, output must be
-- byte-identical when compiled again) provides a mathematical guarantee that
-- the proposed change is sound.

-- Propose a compiler improvement: ask the model to suggest a change
-- Returns ("description", "patch") or ("", "") if nothing good
propose_compiler_improvement model_dir goal =
  let prompt = cat [
    "You are improving the Rail compiler (tools/compile.rail). ",
    "Rail is a self-hosting language — the compiler compiles itself.\n\n",
    "Current goal: ", goal, "\n\n",
    "Propose ONE small, targeted improvement to the compiler. ",
    "Output as:\nDESCRIPTION: <what the change does>\n",
    "FILE: tools/compile.rail\n",
    "OLD:\n<exact lines to replace>\n",
    "NEW:\n<replacement lines>\n\n",
    "The change must preserve the self-hosting fixed point: ",
    "compiling the compiler with the change must produce a binary ",
    "that, when used to compile the compiler again, produces byte-identical output.\n\n",
    "Keep changes minimal. One function at a time. Test-passing is mandatory."]
  let response = model_generate model_dir prompt
  -- Parse the response for description and patch
  let _ = write_file "/tmp/railml_si_proposal.txt" response
  let desc = trim (shell "grep '^DESCRIPTION:' /tmp/railml_si_proposal.txt 2>/dev/null | head -1 | sed 's/^DESCRIPTION: *//'")
  if length desc < 5 then ("", "")
  else (desc, response)

-- Verify a compiler change preserves the fixed point
-- Returns true if the change is safe, false otherwise
verify_fixed_point dummy =
  let _ = print "  Verifying fixed point..."
  -- Step 1: compile the modified compiler
  let _ = shell "cd ~/projects/rail && ./rail_native tools/compile.rail 2>&1 && cp /tmp/rail_out /tmp/railml_si_new_compiler"
  let has_new = trim (shell "test -f /tmp/railml_si_new_compiler && echo ok || echo fail")
  if has_new == "fail" then
    let _ = print "    Fixed point FAILED: modified compiler does not compile"
    false
  else
    -- Step 2: use the new compiler to compile itself
    let _ = shell "chmod +x /tmp/railml_si_new_compiler && /tmp/railml_si_new_compiler tools/compile.rail 2>&1 && cp /tmp/rail_out /tmp/railml_si_new_compiler_2"
    let has_gen2 = trim (shell "test -f /tmp/railml_si_new_compiler_2 && echo ok || echo fail")
    if has_gen2 == "fail" then
      let _ = print "    Fixed point FAILED: gen2 compiler does not compile"
      false
    else
      -- Step 3: check byte-identity
      let diff = trim (shell "cmp /tmp/railml_si_new_compiler /tmp/railml_si_new_compiler_2 2>&1 && echo identical || echo differ")
      if diff == "identical" then
        let _ = print "    Fixed point VERIFIED: gen1 == gen2 (byte-identical)"
        true
      else
        let _ = print (cat ["    Fixed point FAILED: ", diff])
        false

-- Run the test suite on a compiler binary
verify_tests binary =
  let result = trim (shell (cat [binary, " test 2>&1 | tail -1"]))
  let _ = print (cat ["    Tests: ", result])
  str_contains "98/98" result

-- ══════════════════════════════════════════════════════════════════════════════
-- BATCH RUNNER — process a batch of tasks, track results
-- ══════════════════════════════════════════════════════════════════════════════

run_batch model_dir tasks round level pass fail harvested =
  if length tasks == 0 then (pass, fail, harvested)
  else
    let task_line = head tasks
    let desc = task_desc task_line
    let expected = task_expected task_line
    let _ = print (cat ["\n  -> ", desc, if expected == "" then "" else cat [" [expect: ", expected, "]"]])
    -- Reset arena to prevent accumulation across tasks
    let m = arena_mark 0
    let (code, result) = try_task model_dir desc expected
    let _ = arena_reset m
    if result == "success" then
      let _ = print "    PASS"
      -- Score the generation
      let score = score_generation code expected
      let _ = log_quality round level desc score
      -- Harvest the successful code
      let n = append_harvest desc code
      run_batch model_dir (tail tasks) round level (pass + 1) fail (harvested + n)
    else
      let _ = print (cat ["    FAIL (", result, ")"])
      run_batch model_dir (tail tasks) round level pass (fail + 1) harvested

-- ══════════════════════════════════════════════════════════════════════════════
-- SELF-IMPROVE — the core loop that ties everything together
-- ══════════════════════════════════════════════════════════════════════════════

-- self_improve model_dir compiler curriculum -> improved_model
-- This is the function that closes the loop.
self_improve model_dir =
  -- Ensure directories exist
  let _ = shell "mkdir -p training/railml"
  let _ = shell (cat ["mkdir -p ", model_dir])

  -- Load progress
  let (round, level, harvested, since_retrain, cp, cz) = read_progress 0
  let _ = print (cat ["  Round ", show round, " | Level ", show level, " | Harvested ", show harvested, " | Since retrain ", show since_retrain])
  let _ = print (cat ["  Consecutive pass: ", show cp, " | Consecutive zero: ", show cz])

  -- Load goals
  let goals = load_goals 0
  let _ = if length goals > 0 then
    let _ = print (cat ["  Goals (", show (length goals), "):"])
    let _ = map (\g -> print (cat ["    - ", g])) goals
    0
  else print "  No goals set (add to training/railml/goals.txt)"
  let goal = pick_goal goals round

  -- Get tasks for this level
  let tasks = seeds_for level
  let _ = print (cat ["  Seed tasks at level ", show level, ": ", show (length tasks)])

  -- Shuffle for diversity
  let tasks = shuffle_tasks tasks
  let batch = take_n tasks 10

  -- Run the batch
  let (pass, fail, new_harvested) = run_batch model_dir batch round level 0 0 0

  let pass_rate = if (pass + fail) > 0 then pass * 100 / (pass + fail) else 0
  let _ = print (cat ["\n  Round ", show round, " results: ", show pass, "/", show (pass + fail), " (", show pass_rate, "%)"])
  let _ = print (cat ["  New harvested: ", show new_harvested])

  -- Update totals
  let harvested = harvested + new_harvested
  let since_retrain = since_retrain + new_harvested

  -- Log the round
  let _ = write_line log_path (cat ["round=", show round, " level=", show level, " pass=", show pass, "/", show (pass + fail), " rate=", show pass_rate, "% harvested=", show harvested, " goal=", goal])

  -- Curriculum advancement / fallback
  let cp = if pass_rate >= 20 then cp + 1 else 0
  let cz = if pass_rate == 0 then cz + 1 else 0

  let level = if cp >= 3 then
    let new_level = if level < 25 then level + 1 else 25
    let _ = print (cat ["\n  ADVANCING to level ", show new_level, "!"])
    new_level
  else if cz >= 4 then
    let fallback = if level > 1 then level - 1 else 1
    let _ = print (cat ["\n  PLATEAU: falling back to level ", show fallback])
    fallback
  else level

  -- Reset counters on level change
  let cp = if cp >= 3 then 0 else cp
  let cz = if cz >= 4 then 0 else cz

  -- Check retrain trigger
  let since_retrain = if since_retrain >= retrain_threshold then
    let _ = retrain model_dir
    0
  else since_retrain

  -- Save progress for next round
  let _ = write_progress (round + 1) level harvested since_retrain cp cz

  -- Report
  let _ = print (cat ["\n  State saved. Next: round ", show (round + 1), " level ", show level])
  0

-- ══════════════════════════════════════════════════════════════════════════════
-- DEMO — show one cycle: generate -> compile -> verify -> harvest
-- ══════════════════════════════════════════════════════════════════════════════

demo model_dir =
  let _ = print "\n--- DEMO: One generate-compile-verify-harvest cycle ---\n"
  let task = "Write a Rail program that defines fact n = if n <= 1 then 1 else n * fact (n - 1) and prints fact 10"
  let expected = "3628800"
  let _ = print (cat ["  Task: ", task])
  let _ = print (cat ["  Expected: ", expected])

  -- Step 1: Generate
  let _ = print "\n  [1/4] Generating code..."
  let code = model_generate model_dir task
  let _ = print (cat ["  Generated:\n", code])

  -- Step 2: Compile
  let _ = print "\n  [2/4] Compiling (the oracle speaks)..."
  let result = verify_code code expected
  let _ = print (cat ["  Result: ", result])

  -- Step 3: Score
  let _ = print "\n  [3/4] Scoring quality..."
  let score = score_generation code expected
  let _ = print (cat ["  Quality score: ", show score, "/4"])

  -- Step 4: Harvest
  let _ = print "\n  [4/4] Harvesting..."
  if result == "success" then
    let _ = append_harvest task code
    let _ = print "\n  Loop closed: generate -> compile -> verify -> harvest"
    let _ = print "  This example will improve the model on the next retrain."
    0
  else
    let _ = print (cat ["  Not harvested (result: ", result, ")"])
    let _ = print "  On failure, the error feedback improves the next attempt."
    0

-- ══════════════════════════════════════════════════════════════════════════════
-- MAIN
-- ══════════════════════════════════════════════════════════════════════════════

main =
  let _ = print "================================================================"
  let _ = print "  RailML Self-Improving Loop"
  let _ = print "  Phase 6: The loop that closes."
  let _ = print ""
  let _ = print "  Model generates Rail code"
  let _ = print "    -> Compiler verifies (the oracle)"
  let _ = print "    -> Harvest successes as training data"
  let _ = print "    -> Retrain the model"
  let _ = print "    -> Model improves"
  let _ = print "    -> Eventually: model improves the compiler itself"
  let _ = print "================================================================"
  let _ = print ""

  -- Default model directory
  let model_dir = "training/railml/model"
  let _ = shell "mkdir -p training/railml"
  let _ = shell (cat ["mkdir -p ", model_dir])

  -- Parse CLI mode (args[0] is the binary path, args[1] is the command)
  let mode = if length args <= 1 then "demo" else head (tail args)

  if mode == "demo" then
    -- Demo mode: show one cycle
    let _ = demo model_dir
    let _ = print "\n================================================================"
    let _ = print "  To run the full loop: ./rail_native run tools/railml/self_improve.rail loop"
    let _ = print "  To run meta-loop:     ./rail_native run tools/railml/self_improve.rail meta"
    let _ = print "================================================================"
    0

  else if mode == "loop" then
    -- Full self-improvement loop (one round, shell wrapper restarts)
    let _ = print "  Mode: self-improvement loop (one round)"
    let _ = self_improve model_dir
    0

  else if mode == "meta" then
    -- Meta-loop: model proposes compiler improvements
    let _ = print "  Mode: meta-loop (compiler self-improvement)"
    let _ = print ""
    let goals = load_goals 0
    let goal = if length goals > 0 then head goals else "improve compiler performance"
    let _ = print (cat ["  Goal: ", goal])
    let _ = print "  Asking model to propose a compiler improvement..."
    let (desc, patch) = propose_compiler_improvement model_dir goal
    if length desc < 5 then
      let _ = print "  No viable proposal generated."
      0
    else
      let _ = print (cat ["  Proposal: ", desc])
      let _ = print "  Verifying fixed point..."
      -- NOTE: In production, we would apply the patch, verify, then accept/reject.
      -- For safety, we only report the proposal here.
      let _ = print ""
      let _ = print "  [META-LOOP] This is where self-improvement becomes unprecedented:"
      let _ = print "    1. Model proposes a compiler change"
      let _ = print "    2. Compile the compiler with the proposed change"
      let _ = print "    3. Use the new compiler to compile itself"
      let _ = print "    4. Verify gen1 == gen2 (byte-identical fixed point)"
      let _ = print "    5. Run 98/98 test suite"
      let _ = print "    6. Accept if both pass, reject otherwise"
      let _ = print "    7. The compiler is its own proof checker."
      let _ = print ""
      let _ = write_line log_path (cat ["meta: proposal=", desc])
      0

  else if mode == "status" then
    -- Show current state
    let (round, level, harvested, since_retrain, cp, cz) = read_progress 0
    let _ = print (cat ["  Round:            ", show round])
    let _ = print (cat ["  Level:            ", show level, "/25"])
    let _ = print (cat ["  Total harvested:  ", show harvested])
    let _ = print (cat ["  Since retrain:    ", show since_retrain, " (threshold: ", show retrain_threshold, ")"])
    let _ = print (cat ["  Consecutive pass: ", show cp, " (advance at 3)"])
    let _ = print (cat ["  Consecutive zero: ", show cz, " (fallback at 4)"])
    let harvest_count = trim (shell (cat ["wc -l < ", harvest_path, " 2>/dev/null || echo 0"]))
    let repair_count = trim (shell (cat ["wc -l < ", repair_path, " 2>/dev/null || echo 0"]))
    let _ = print (cat ["  Harvest file:     ", harvest_count, " entries"])
    let _ = print (cat ["  Repair file:      ", repair_count, " entries"])
    let goals = load_goals 0
    let _ = print (cat ["  Goals:            ", show (length goals)])
    let _ = map (\g -> print (cat ["    - ", g])) goals
    0

  else
    let _ = print (cat ["  Unknown mode: ", mode])
    let _ = print "  Usage: self_improve.rail [demo|loop|meta|status]"
    0
