-- brain.rail — Mac Mini orchestration layer
-- Rail decides what to do. MLX does the thinking. Shell does the work.
-- Usage: ./rail_native run tools/apps/brain.rail

cat parts = join "" parts
trim s = head (split "\n" s)
q = "\""

-- JSON helpers
json_esc s = join "\\\"" (split "\"" s)
json_esc_nl s = join "\\n" (split "\n" s)

-- Call local MLX (Qwen on :8080)
llm system_prompt user_prompt =
  let body = cat [
    "{", q, "model", q, ":", q, "default", q, ",", q, "messages", q, ":[",
    "{", q, "role", q, ":", q, "system", q, ",", q, "content", q, ":", q, json_esc (json_esc_nl system_prompt), q, "},",
    "{", q, "role", q, ":", q, "user", q, ",", q, "content", q, ":", q, json_esc (json_esc_nl user_prompt), q, "}",
    "],", q, "max_tokens", q, ":2048}"]
  let cmd = cat ["curl -s -X POST http://localhost:8080/v1/chat/completions -H 'Content-Type: application/json' -d '", body, "'"]
  let resp = shell cmd
  let parts = split "\"content\":\"" resp
  if length parts >= 2 then
    let after = head (tail parts)
    head (split "\",\"" after)
  else resp

-- Gather system state
get_services =
  let raw = shell "launchctl list | grep ledatic 2>/dev/null"
  let lines = split "\n" raw
  cat ["Services: ", show (length lines), " registered"]

get_trader_status =
  let pid = trim (shell "launchctl list com.ledatic.trader2 2>&1 | grep PID | awk '{print $NF}'")
  if length pid > 0 then cat ["Trader: UP (PID ", pid, ")"]
  else "Trader: DOWN"

get_wallet =
  let bal = trim (shell "curl -s 'https://api.mainnet-beta.solana.com' -X POST -H 'Content-Type: application/json' -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"getBalance\",\"params\":[\"AAEvGUF8ahT9rinivbwS7YASMvyfM4f6iRwgYPjoRqaA\"]}' 2>/dev/null | grep -o '\"value\":[0-9]*' | cut -d: -f2")
  if length bal > 0 then cat ["Wallet: ", bal, " lamports"]
  else "Wallet: check failed"

get_disk =
  trim (shell "df -h / | tail -1 | awk '{print \"Disk: \" $4 \" free of \" $2}'")

get_memory =
  trim (shell "vm_stat | head -5 | tail -1 | awk '{printf \"Memory: %d MB free\", $3*4096/1048576}'")

get_load =
  let load = trim (shell "sysctl -n vm.loadavg | awk '{print $2}'")
  cat ["Load: ", load]

gather_state =
  let svc = get_services
  let trader = get_trader_status
  let wallet = get_wallet
  let disk = get_disk
  let mem = get_memory
  let load = get_load
  join "\n" [svc, trader, wallet, disk, mem, load]

-- Ask the LLM to analyze state and suggest actions
analyze state =
  let sys = "You are a system monitor for a Mac Mini M4 Pro running trading bots and ML inference. Given the current state, provide a brief assessment (2-3 sentences) and any recommended actions. Be concise."
  llm sys state

-- Run a health check cycle
health_check =
  let _ = print "=== Brain: Health Check ==="
  let state = gather_state
  let _ = print state
  let _ = print ""
  let _ = print "=== Analysis ==="
  let analysis = analyze state
  let _ = print analysis
  0

-- Dispatch
main =
  let a = args
  if length a >= 2 then
    let cmd = head (tail a)
    if cmd == "health" then health_check
    else if cmd == "state" then
      let _ = print (gather_state)
      0
    else if cmd == "ask" then
      if length a >= 3 then
        let question = head (tail (tail a))
        let state = gather_state
        let prompt = cat ["Current system state:\n", state, "\n\nQuestion: ", question]
        let answer = llm "You are a helpful system assistant for a Mac Mini running trading and ML workloads. Answer based on the system state provided." prompt
        let _ = print answer
        0
      else
        let _ = print "Usage: brain ask <question>"
        1
    else
      let _ = print "Commands: health | state | ask <question>"
      1
  else
    let _ = print "Usage: brain <health|state|ask>"
    1
