-- llm_call.rail — Call local LLM via HTTP
-- Replaces tools/llm_call.sh (31 lines of bash)
-- Usage: ./rail_native run tools/apps/llm_call.rail

cat parts = join "" parts
trim s = head (split "\n" s)

-- Escape double quotes in a string for JSON
json_esc s = join "\\\"" (split "\"" s)

-- Escape newlines for JSON
json_esc_nl s = join "\\n" (split "\n" s)

llm_call system_prompt user_prompt =
  let body = cat [
    "{\"model\":\"default\",\"messages\":[",
    "{\"role\":\"system\",\"content\":\"", json_esc (json_esc_nl system_prompt), "\"},",
    "{\"role\":\"user\",\"content\":\"", json_esc (json_esc_nl user_prompt), "\"}",
    "],\"max_tokens\":4096}"]
  let cmd = cat ["curl -s -X POST http://localhost:8080/v1/chat/completions -H 'Content-Type: application/json' -d '", body, "'"]
  let resp = shell cmd
  -- Extract content from response: find "content":" and grab until next "
  let parts = split "\"content\":\"" resp
  if length parts >= 2 then
    let after = head (tail parts)
    head (split "\",\"" after)
  else resp

main =
  let a = args
  if length a >= 3 then
    let sys = read_file (head (tail a))
    let usr = read_file (head (tail (tail a)))
    let result = llm_call sys usr
    let _ = print result
    0
  else
    let _ = print "Usage: llm_call <system_prompt_file> <user_prompt_file>"
    1
