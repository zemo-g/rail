-- Minimal test: float operations inside recursive functions
-- Tests whether float_arr_get * literal works correctly

cat parts = join "" parts

-- Test 1: multiply by literal in recursive function
scale_loop arr n i =
  if i >= n then 0
  else
    let _ = float_arr_set arr i (float_arr_get arr i * 0.5)
    scale_loop arr n (i + 1)

-- Test 2: float_arr_get a / literal in recursive function
div_loop arr n i =
  if i >= n then 0
  else
    let _ = float_arr_set arr i (float_arr_get arr i / 2.0)
    div_loop arr n (i + 1)

-- Test 3: accumulate sum using float_arr
sum_loop arr acc n i =
  if i >= n then 0
  else
    let _ = float_arr_set acc 0 (float_arr_get acc 0 + float_arr_get arr i)
    sum_loop arr acc n (i + 1)

-- Test 4: sum then divide (mimics the MSE pattern)
sum_and_scale arr acc n =
  let _ = sum_loop arr acc n 0
  let _ = float_arr_set acc 0 (float_arr_get acc 0 * 0.333333333333333)
  0

-- Test 5: same but called from ANOTHER recursive function
outer_loop arr acc n step =
  if step >= 3 then 0
  else
    let _ = float_arr_set acc 0 0.0
    let _ = sum_loop arr acc n 0
    let _ = float_arr_set acc 0 (float_arr_get acc 0 * 0.333333333333333)
    let _ = print (cat ["  outer step ", show step, " sum*0.333=", show_float (float_arr_get acc 0)])
    outer_loop arr acc n (step + 1)

main =
  let a = float_arr_new 3 0.0
  let _ = float_arr_set a 0 10.0
  let _ = float_arr_set a 1 20.0
  let _ = float_arr_set a 2 30.0

  -- Test 1: scale
  let _ = print "Test 1: scale_loop (multiply by 0.5)"
  let b = float_arr_new 3 0.0
  let _ = float_arr_set b 0 10.0
  let _ = float_arr_set b 1 20.0
  let _ = float_arr_set b 2 30.0
  let _ = scale_loop b 3 0
  let _ = print (cat ["  expected: 5.0  got: ", show_float (float_arr_get b 0)])

  -- Test 2: divide
  let _ = print "Test 2: div_loop (divide by 2.0)"
  let c = float_arr_new 3 0.0
  let _ = float_arr_set c 0 10.0
  let _ = float_arr_set c 1 20.0
  let _ = float_arr_set c 2 30.0
  let _ = div_loop c 3 0
  let _ = print (cat ["  expected: 5.0  got: ", show_float (float_arr_get c 0)])

  -- Test 3: sum
  let _ = print "Test 3: sum_loop"
  let acc = float_arr_new 1 0.0
  let _ = sum_loop a acc 3 0
  let _ = print (cat ["  expected: 60.0  got: ", show_float (float_arr_get acc 0)])

  -- Test 4: sum then scale (in same function)
  let _ = print "Test 4: sum_and_scale (non-recursive wrapper)"
  let acc2 = float_arr_new 1 0.0
  let _ = sum_and_scale a acc2 3
  let _ = print (cat ["  expected: 20.0  got: ", show_float (float_arr_get acc2 0)])

  -- Test 5: sum+scale INSIDE a recursive function
  let _ = print "Test 5: outer_loop (sum+scale inside recursion)"
  let acc3 = float_arr_new 1 0.0
  let _ = outer_loop a acc3 3 0

  -- Test 6: arr_get + float_arr_set/get pattern (mimics MLP training loop)
  let _ = print "Test 6: arr_get + float ops inside recursion"
  let ctx = arr_new 4 0
  let _ = arr_set ctx 0 (float_arr_new 10 0.0)
  let _ = arr_set ctx 1 (float_arr_new 1 0.0)
  let src = float_arr_new 10 0.0
  let _ = float_arr_set src 0 100.0
  let _ = float_arr_set src 1 200.0
  let _ = float_arr_set src 2 300.0
  let _ = arr_set ctx 2 src
  let _ = arr_set ctx 3 (float_arr_new 1 0.0)
  let _ = ctx_loop ctx 3 0

  -- Test 7: many function calls before float op (stress register pressure)
  let _ = print "Test 7: many calls then float multiply"
  let wa = float_arr_new 6 0.0
  let _ = float_arr_set wa 0 1.0
  let _ = float_arr_set wa 1 2.0
  let _ = float_arr_set wa 2 3.0
  let _ = float_arr_set wa 3 4.0
  let _ = float_arr_set wa 4 5.0
  let _ = float_arr_set wa 5 6.0
  let ra = float_arr_new 1 0.0
  let _ = stress_loop wa ra 6 0
  let _ = print (cat ["  expected: 91 * 0.1 = 9.1  got: ", show_float (float_arr_get ra 0)])

  let _ = print "Done."
  0

-- Test 6 helper: accumulate from arr_get source, multiply by literal
ctx_loop ctx n step =
  if step >= n then 0
  else
    let src = arr_get ctx 2
    let acc = arr_get ctx 3
    let _ = float_arr_set acc 0 0.0
    let _ = sum_loop src acc 3 0
    let _ = float_arr_set acc 0 (float_arr_get acc 0 * 0.1)
    let _ = print (cat ["  ctx step ", show step, " result=", show_float (float_arr_get acc 0)])
    ctx_loop ctx n (step + 1)

-- Test 7 helper: accumulate x[i]*x[i] then multiply by 0.1
stress_inner wa ra n i =
  if i >= n then 0
  else
    let v = float_arr_get wa i
    let _ = float_arr_set ra 0 (float_arr_get ra 0 + v * v)
    stress_inner wa ra n (i + 1)

stress_loop wa ra n step =
  let _ = float_arr_set ra 0 0.0
  let _ = stress_inner wa ra n 0
  let _ = float_arr_set ra 0 (float_arr_get ra 0 * 0.1)
  0
