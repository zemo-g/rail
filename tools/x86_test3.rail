-- Test 3: list literals, tuples, ADTs, match
-- Expected output: 10, 100, 200, 42, 0

type Option = | Some x | None

unwrap opt = match opt
  | Some x -> x
  | None -> 0

main =
  let xs = [10, 20, 30]
  let _ = print (head xs)
  let (a, b) = (100, 200)
  let _ = print a
  let _ = print b
  let v = Some 42
  let _ = print (unwrap v)
  let _ = print (unwrap None)
  0
