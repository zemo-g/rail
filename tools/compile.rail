self_compile _ =
  let _ = print "\n=== Self-compilation ==="
  let self_src = read_file "tools/compile.rail"
  let _ = print (cat ["  Source: ", show (length self_src), " chars"])
  let self_asm = compile_program self_src
  let _ = write_file "/tmp/rail_self.s" self_asm
  let _ = print "  Compiled to assembly"
  let sdk = trim (shell "xcrun --show-sdk-path")
  let as_res = trim (shell "as -o /tmp/rail_self.o /tmp/rail_self.s 2>&1")
  let _ = if as_res != "" then print (cat ["  as: ", as_res]) else print "  as: OK"
  let rtdir2 = get_runtime_dir 0
  let ld_res = trim (shell (cat ["ld -o /tmp/rail_self /tmp/rail_self.o -lSystem -syslibroot ", sdk, " -arch arm64 -stack_size 0x10000000 2>&1"]))
  let _ = if ld_res != "" then print (cat ["  ld: ", ld_res]) else print "  ld: OK"
  let _ = shell "codesign -s - /tmp/rail_self 2>&1"
  let _ = print "  Binary: /tmp/rail_self"
  0

join_args lst n =
  if n > 0 then
    if length lst == 0 then ""
    else join_args (tail lst) (n - 1)
  else join " " lst

compile_and_run path extra =
  let _ = compile_file path
  let cmd = if length extra > 0 then cat ["/tmp/rail_out ", extra, " 2>&1"] else "/tmp/rail_out 2>&1"
  let out = shell cmd
  let _ = if length out > 0 then print out else 0
  0

build_linux asm_text =
  let _ = write_file "/tmp/rail_macos.s" asm_text
  -- Transform macOS assembly to GNU/Linux ELF syntax
  let uname_check = trim (shell "uname -s 2>/dev/null")
  let has_transform = trim (shell "test -f /home/zemog/tools/transform.sh && echo yes || echo no")
  let _ = if uname_check == "Linux" && has_transform == "yes" then
    shell "/home/zemog/tools/transform.sh /tmp/rail_macos.s /tmp/rail_linux_code.s"
  else
    shell "sed -E -e 's/\\.section __TEXT,__text/.text/' -e 's/\\.section __DATA,__data/.data/' -e 's/([_a-zA-Z][_a-zA-Z0-9]*)@PAGEOFF/:lo12:\\1/g' -e 's/@PAGEOFF/RAIL_TMP_PGOFF/g' -e 's/@PAGE//g' -e 's/RAIL_TMP_PGOFF/@PAGEOFF/g' -e '/\\.zerofill/d' -e 's/\\.comm ([^,]+),(.+),3/.comm \\1,\\2,8/g' /tmp/rail_macos.s > /tmp/rail_linux_code.s"
  let start_wrapper = "\n.text\n.global _start\n_start:\n    mov x29, sp\n    ldr x0, [sp]\n    add x1, sp, #8\n    bl _main\n    mov x8, #93\n    svc #0\n\n"
  let bss = "\n.bss\n.p2align 3\n_rail_heap:\n    .space 536870912\n"
  let _ = write_file "/tmp/rail_linux_start.s" start_wrapper
  let _ = write_file "/tmp/rail_linux_bss.s" bss
  -- Find linux_libc.s (in cwd/tools/ or alongside binary)
  let libc_path = trim (shell "ls tools/linux_libc.s 2>/dev/null || ls ~/tools/linux_libc.s 2>/dev/null || ls ~/projects/rail/tools/linux_libc.s 2>/dev/null || echo MISSING")
  -- On native Linux, include data section fallback (compiler may not emit its own)
  let data_path = if uname_check == "Linux" then
    trim (shell "ls tools/linux_data.s 2>/dev/null || ls /home/zemog/tools/linux_data.s 2>/dev/null || echo ''")
  else ""
  let _ = shell (cat ["cat /tmp/rail_linux_code.s /tmp/rail_linux_start.s ", libc_path, " ", data_path, " /tmp/rail_linux_bss.s > /tmp/rail_linux.s"])
  -- Detect if running on Linux (native) or macOS (cross)
  let uname = trim (shell "uname -s 2>/dev/null")
  let as_cmd = if uname == "Linux" then "as" else "aarch64-elf-as"
  let ld_cmd = if uname == "Linux" then "ld" else "aarch64-elf-ld"
  -- On native Linux, strip leading underscores from all symbol references
  -- macOS requires _ prefix, Linux/ELF does not
  -- Preserve _start (ELF entry point) and .L labels (local)
  let _ = if uname == "Linux" then
    shell "perl -pi -e 's/(?<=\\b)_(?=(?!start\\b)[a-zA-Z]\\w*)//' /tmp/rail_linux.s"
  else 0
  let as_res = trim (shell (cat [as_cmd, " -o /tmp/rail_linux.o /tmp/rail_linux.s 2>&1"]))
  let _ = if as_res != "" then print (cat ["  as: ", as_res]) else print "  as: OK"
  let ld_res = trim (shell (cat [ld_cmd, " -o /tmp/rail_linux /tmp/rail_linux.o 2>&1"]))
  let _ = if ld_res != "" then print (cat ["  ld: ", ld_res]) else print "  ld: OK"
  0

gen_system_prompt =
  let grammar = read_file "grammar/rail.ebnf"
  cat ["You are a Rail language expert. Rail is a pure functional language that compiles to native ARM64.\n\nGRAMMAR (EBNF):\n", grammar, "\n\nRULES:\n- Top-level functions: name params = body\n- Let bindings use NEWLINES not 'in': let x = 5\\n  x + 1\n- If: if cond then expr else expr\n- Match: match expr | Pattern args -> expr\n- Lists: [1, 2, 3], head, tail, cons, map, filter, fold, length, reverse, range\n- Tuples: (a, b), destructure with let (x, y) = expr\n- ADTs: type Option = | Some x | None\n- Lambdas: \\x -> expr\n- print outputs a value, show converts int to string\n- join sep list concatenates strings, split sep str splits\n- main must exist and return an int\n- No negative literals — use (0 - n) or (-n) syntax\n- && and || do NOT short-circuit — use nested if/else\n- Every program needs a main function\n- Use let _ = print expr for side effects"]

gen_examples =
  cat ["Example 1:\nfact n = if n <= 1 then 1 else n * fact (n - 1)\nmain =\n  let _ = print (show (fact 10))\n  0\n\nExample 2:\nadd a b = a + b\nmain =\n  let _ = print (show (fold add 0 [1, 2, 3, 4, 5]))\n  0\n\nExample 3:\ntype Option = | Some x | None\nsafe_div a b = match b\n  | 0 -> None\n  | _ -> Some (a / b)\nmain = match (safe_div 10 2)\n  | Some x -> x\n  | None -> 0"]

gen_llm_call sys_msg user_msg =
  let escaped_sys = esc_json sys_msg
  let escaped_usr = esc_json user_msg
  let req = cat ["{\"model\": \"default\", \"messages\": [{\"role\": \"system\", \"content\": \"", escaped_sys, "\"}, {\"role\": \"user\", \"content\": \"", escaped_usr, "\"}], \"max_tokens\": 2048, \"temperature\": 0.3}"]
  let _ = write_file "/tmp/rail_gen_req.json" req
  let _ = shell "curl -s http://localhost:8080/v1/chat/completions -H 'Content-Type: application/json' -d @/tmp/rail_gen_req.json > /tmp/rail_gen_resp.json"
  let raw = read_file "/tmp/rail_gen_resp.json"
  let parts = split "\"content\":\"" raw
  let after = if length parts >= 2 then head (tail parts) else ""
  let code = head (split "\"},\"" after)
  let _ = write_file "/tmp/rail_gen_code.rail" code
  code

gen_try_compile code =
  let _ = write_file "/tmp/rail_gen_out.rail" code
  shell (cat [head args, " /tmp/rail_gen_out.rail 2>&1"])

gen_try_run dummy =
  let run_result = shell "/tmp/rail_out 2>&1; echo $?"
  let lines = split "\n" run_result
  let exit_code = last_elem lines
  let stdout = join "\n" (init_list lines)
  (stdout, exit_code)

generate_code desc =
  let sys = gen_system_prompt
  let examples = gen_examples
  let _ = print (cat ["-- Generating Rail code for: ", desc])
  generate_loop desc sys examples "" 1

generate_loop desc sys examples prev_error attempt =
  if attempt > 3 then
    let _ = print "-- FAILED: 3 attempts exhausted"
    1
  else
    let _ = print (cat ["-- Attempt ", show attempt, "/3"])
    let user_msg = if prev_error == "" then
      cat [examples, "\n\nNow write a Rail program for: ", desc, "\n\nOutput ONLY Rail code. No markdown, no explanation. Functions before main."]
    else
      cat [examples, "\n\nNow write a Rail program for: ", desc, "\n\nYour previous attempt had this error:\n", prev_error, "\n\nFix the error. Output ONLY Rail code. No markdown, no explanation. Functions before main."]
    let code = gen_llm_call sys user_msg
    let _ = print code
    let _ = print "\n-- Compiling..."
    let compile_out = gen_try_compile code
    let _ = print compile_out
    -- Check if compile produced a binary
    let check = trim (shell "test -f /tmp/rail_out && echo ok || echo fail")
    if check == "fail" then
      let _ = print "-- Compile FAILED, retrying..."
      generate_loop desc sys examples (cat ["Compile error: ", compile_out]) (attempt + 1)
    else
      let (stdout, exit_code) = gen_try_run 0
      let _ = if length stdout > 0 then print (cat ["-- Output: ", stdout]) else 0
      let _ = if exit_code != "0" then
        let _ = print (cat ["-- Runtime error (exit ", exit_code, "), retrying..."])
        0
      else
        let _ = print "-- SUCCESS"
        0
      if exit_code != "0" then
        generate_loop desc sys examples (cat ["Runtime error (exit code ", exit_code, "): ", stdout]) (attempt + 1)
      else 0

esc_json s = esc_json_acc (chars s) ""

esc_json_acc cs acc =
  if length cs == 0 then acc
  else
    let c = head cs
    let e = if c == "\"" then "\\\"" else if c == "\n" then "\\n" else if c == "\\" then "\\\\" else c
    esc_json_acc (tail cs) (append acc e)

compile_linux path =
  let src = read_file path
  let _ = print (cat ["Cross-compiling ", path, " for Linux ARM64..."])
  let asm = compile_program src
  let _ = build_linux asm
  let _ = print "  Binary: /tmp/rail_linux"
  let info = trim (shell "file /tmp/rail_linux 2>&1")
  let _ = print (cat ["  ", info])
  0

-- rail-safe: sandboxed compilation to WASM only
-- Rejects any AST node containing a banned identifier anywhere

is_banned name =
  if name == "shell" then true
  else if name == "read_file" then true
  else if name == "write_file" then true
  else if name == "import" then true
  else if name == "spawn" then true
  else if name == "thread" then true
  else if name == "arena_mark" then true
  else if name == "arena_reset" then true
  else if name == "ffi" then true
  else if name == "foreign" then true
  else if str_starts_with "_rail" name then true
  else false

-- safe_check with depth tracking: returns error count
safe_check node depth =
  if depth > 500 then 1
  else
    let tg = head node
    let d1 = depth + 1
    if tg == "V" then
      if is_banned (head (tail node)) then 1 else 0
    else if tg == "I" then 0
    else if tg == "FL" then 0
    else if tg == "S" then 0
    else if tg == "B" then 0
    else if tg == "NULL" then 0
    else if tg == "O" then
      safe_check (head (tail (tail node))) d1 + safe_check (head (tail (tail (tail node)))) d1
    else if tg == "?" then
      safe_check (head (tail node)) d1 + safe_check (head (tail (tail node))) d1 + safe_check (head (tail (tail (tail node)))) d1
    else if tg == "D" then
      if is_banned (head (tail node)) then 1
      else safe_check (head (tail (tail node))) d1 + safe_check (head (tail (tail (tail node)))) d1
    else if tg == "TD" then
      safe_check (head (tail (tail node))) d1 + safe_check (head (tail (tail (tail node)))) d1
    else if tg == "A" then
      let (fname, fargs) = flat node
      if is_banned fname then 1
      else safe_check_list (tail node) d1
    else if tg == "F" then
      safe_check (head (tail (tail node))) d1
    else if tg == "L" then
      safe_check_list (head (tail node)) d1
    else if tg == "T" then
      safe_check_list (head (tail node)) d1
    else if tg == "M" then
      safe_check (head (tail node)) d1 + safe_check_arms (head (tail (tail node))) d1
    else if tg == "E" then 0
    else 0

safe_check_list ns depth =
  if length ns == 0 then 0
  else safe_check (head ns) depth + safe_check_list (tail ns) depth

safe_check_arms arms depth =
  if length arms == 0 then 0
  else safe_check (head (tail (tail (head arms)))) depth + safe_check_arms (tail arms) depth

-- Count functions and check each body. Returns (banned_errors, fn_count)
safe_check_decls decls =
  safe_check_decls_acc decls 0 0

safe_check_decls_acc decls errs fcount =
  if length decls == 0 then errs
  else
    let d = head decls
    let tg = head d
    if tg == "TY" then safe_check_decls_acc (tail decls) errs fcount
    else if tg == "E" then safe_check_decls_acc (tail decls) errs fcount
    else if tg == "FN_EXT" then safe_check_decls_acc (tail decls) (errs + 1) fcount
    else if tg == "LINK" then safe_check_decls_acc (tail decls) (errs + 1) fcount
    else
      let fc = fcount + 1
      if fc > 100 then errs + 1
      else
        let body = head (tail (tail (tail d)))
        let e = safe_check body 0
        safe_check_decls_acc (tail decls) (errs + e) fc

-- Validate WASM output: check imports are only fd_write + proc_exit
safe_validate_wasm wat =
  let imports = safe_count_imports (str_split "(import" wat)
  if imports > 2 then false
  else
    let has_bad = str_contains "storage" wat
    if has_bad then false
    else true

safe_count_imports parts =
  if length parts <= 1 then 0
  else length parts - 1

dispatch_safe path =
  let src = read_file path
  if length src > 65536 then
    let _ = print "ERROR: source too large (max 64KB)"
    1
  else if length src == 0 then
    let _ = print "ERROR: empty source"
    1
  else
    let _ = print (cat ["Compiling ", path, " (safe mode)..."])
    let toks = tokenize src
    let decls = pprog toks
    let errs = safe_check_decls decls
    if errs > 0 then
      let _ = print (cat ["  REJECTED: ", show errs, " banned construct(s) found"])
      1
    else
      let wat = wasm_program decls
      if length wat > 262144 then
        let _ = print "ERROR: output too large (max 256KB WAT)"
        1
      else
        let valid = safe_validate_wasm wat
        if valid == false then
          let _ = print "ERROR: WASM validation failed — unexpected imports"
          1
        else
          let _ = write_file "/tmp/rail_safe.wat" wat
          let _ = print (cat ["  WAT: ", show (length wat), " bytes"])
          let w2w = trim (shell "wat2wasm /tmp/rail_safe.wat -o /tmp/rail_safe.wasm 2>&1")
          if w2w != "" then
            let _ = print (cat ["  wat2wasm: ", w2w])
            1
          else
            let _ = print "  wat2wasm: OK"
            let _ = print "  Binary: /tmp/rail_safe.wasm"
            0

dispatch_wasm path =
  let _ = print (cat ["Compiling ", path, " to WASM..."])
  let src = read_file path
  let toks = tokenize src
  let decls = pprog toks
  let wat = wasm_program decls
  let _ = write_file "/tmp/rail_out.wat" wat
  let _ = print (cat ["  WAT: ", show (length wat), " bytes"])
  let w2w = trim (shell "wat2wasm /tmp/rail_out.wat -o /tmp/rail_out.wasm 2>&1")
  let _ = if w2w != "" then print (cat ["  wat2wasm: ", w2w]) else print "  wat2wasm: OK"
  let wt = trim (shell "which wasmtime 2>/dev/null")
  if length wt > 0 then
    let r = shell "wasmtime /tmp/rail_out.wasm 2>&1"
    let _ = print r
    0
  else
    let _ = print "  Binary: /tmp/rail_out.wasm"
    0

wasm_program decls =
  let strs = wasm_strs_all decls
  let stab = wasm_stab strs 256
  let ar = get_arities decls
  let lams = wasm_collect_lambdas decls 0
  let nlams = length lams
  let hdr = "(module\n  (import \"wasi_snapshot_preview1\" \"fd_write\" (func $fd_write (param i32 i32 i32 i32) (result i32)))\n  (import \"wasi_snapshot_preview1\" \"proc_exit\" (func $proc_exit (param i32)))\n  (memory (export \"memory\") 16 1024)\n\n"
  let tbl = if nlams > 0 then cat ["  (type $clos_t (func (param i64 i64) (result i64)))\n  (table ", show nlams, " funcref)\n  (elem (i32.const 0)", wasm_elem_list nlams 0, ")\n\n"] else ""
  let rt = read_file "tools/wasm_runtime.wat"
  let fns = wasm_fns decls stab ar lams
  let lam_fns = wasm_lambda_fns lams stab ar
  let start = "  (func $_start (export \"_start\")\n    call $main\n    i64.const 1\n    i64.shr_s\n    i32.wrap_i64\n    call $proc_exit\n  )\n\n"
  let sd = wasm_sdata stab
  cat [hdr, tbl, rt, fns, lam_fns, start, sd, ")\n"]

wasm_elem_list n i =
  if i >= n then ""
  else cat [" $__lambda_", show i, wasm_elem_list n (i + 1)]

wasm_fns decls stab ar lams =
  if length decls == 0 then ""
  else
    let tg = head (head decls)
    if tg == "E" || tg == "TY" || tg == "FN_EXT" || tg == "LINK" then wasm_fns (tail decls) stab ar lams
    else cat [wasm_fn (head decls) stab ar lams, wasm_fns (tail decls) stab ar lams]

wasm_fn d stab ar lams =
  let nm = head (tail d)
  let ps = head (tail (tail d))
  let bd = head (tail (tail (tail d)))
  let pstr = if length ps == 0 then "" else join " " (wasm_plist ps)
  let env = wasm_env ps 0
  let locs = wasm_dedup (cons "__ptr" (cons "__scrut" (wasm_locs bd)))
  let rl = wasm_fltr locs ps
  let ld = if length rl == 0 then "" else join "" (wasm_llist rl)
  let body = wg bd env stab ar lams
  cat ["  (func $", nm, " ", pstr, " (result i64)\n", ld, body, "  )\n\n"]

wasm_plist ps =
  if length ps == 0 then []
  else cons (cat ["(param $", head ps, " i64)"]) (wasm_plist (tail ps))

wasm_llist ls =
  if length ls == 0 then []
  else cons (cat ["    (local $", head ls, " i64)\n"]) (wasm_llist (tail ls))

wasm_env ps i =
  if length ps == 0 then []
  else cons (head ps, i) (wasm_env (tail ps) (i + 1))

wasm_locs node =
  let tg = head node
  if tg == "D" then cons (head (tail node)) (append (wasm_locs (head (tail (tail node)))) (wasm_locs (head (tail (tail (tail node))))))
  else if tg == "TD" then append (head (tail node)) (append (wasm_locs (head (tail (tail node)))) (wasm_locs (head (tail (tail (tail node))))))
  else if tg == "?" then append (wasm_locs (head (tail node))) (append (wasm_locs (head (tail (tail node)))) (wasm_locs (head (tail (tail (tail node))))))
  else if tg == "O" then append (wasm_locs (head (tail (tail node)))) (wasm_locs (head (tail (tail (tail node)))))
  else if tg == "A" then wasm_locs_l (tail node)
  else if tg == "L" then wasm_locs_l (head (tail node))
  else if tg == "M" then cons "__scrut" (cons "__ptr" (append (wasm_locs (head (tail node))) (wasm_locs_arms (head (tail (tail node))))))
  else if tg == "F" then wasm_locs (head (tail (tail node)))
  else []

wasm_locs_arms arms =
  if length arms == 0 then []
  else append (head (tail (head arms))) (append (wasm_locs (head (tail (tail (head arms))))) (wasm_locs_arms (tail arms)))

wasm_locs_l ns =
  if length ns == 0 then []
  else append (wasm_locs (head ns)) (wasm_locs_l (tail ns))

wasm_has x ls =
  if length ls == 0 then false
  else if head ls == x then true
  else wasm_has x (tail ls)

wasm_dedup ls =
  if length ls == 0 then []
  else
    let h = head ls
    let r = wasm_dedup (tail ls)
    if wasm_has h r then r else cons h r

wasm_fltr ls ex =
  if length ls == 0 then []
  else if wasm_has (head ls) ex then wasm_fltr (tail ls) ex
  else cons (head ls) (wasm_fltr (tail ls) ex)

wasm_efind n env =
  if length env == 0 then 0 - 1
  else
    let (k, v) = head env
    if k == n then v
    else wasm_efind n (tail env)

wg node env stab ar lams =
  let tg = head node
  if tg == "I" then cat ["    i64.const ", show (str_to_int (head (tail node)) * 2 + 1), "\n"]
  else if tg == "S" then cat ["    i64.const ", show (wasm_sfind (head (tail node)) stab * 2), "\n"]
  else if tg == "B" then if head (tail node) == "true" then "    i64.const 3\n" else "    i64.const 1\n"
  else if tg == "V" then
    let nm = head (tail node)
    if wasm_efind nm env >= 0 then cat ["    local.get $", nm, "\n"]
    else
      let ar_val = afind nm ar
      let (cidx, carity) = decode_ctor ar_val
      if cidx != (0 - 1) then
        if carity == 0 then
          cat ["    i32.const 16\n    call $alloc\n    i64.extend_i32_u\n    local.set $__ptr\n    local.get $__ptr\n    i32.wrap_i64\n    i64.const 5\n    i64.store\n    local.get $__ptr\n    i32.wrap_i64\n    i32.const 8\n    i32.add\n    i64.const ", show cidx, "\n    i64.store\n    local.get $__ptr\n    i64.const 1\n    i64.shl\n"]
        else "    i64.const 1\n"
      else "    i64.const 1\n"
  else if tg == "O" then
    let op = head (tail node)
    cat [wg (head (tail (tail node))) env stab ar lams, "    i64.const 1\n    i64.shr_s\n", wg (head (tail (tail (tail node)))) env stab ar lams, "    i64.const 1\n    i64.shr_s\n", wasm_op op, "    i64.const 1\n    i64.shl\n    i64.const 1\n    i64.or\n"]
  else if tg == "?" then
    cat [wg (head (tail node)) env stab ar lams, "    i64.const 1\n    i64.shr_s\n    i32.wrap_i64\n    if (result i64)\n", wg (head (tail (tail node))) env stab ar lams, "    else\n", wg (head (tail (tail (tail node)))) env stab ar lams, "    end\n"]
  else if tg == "D" then
    let nm = head (tail node)
    cat [wg (head (tail (tail node))) env stab ar lams, "    local.set $", nm, "\n", wg (head (tail (tail (tail node)))) (cons (nm, length env) env) stab ar lams]
  else if tg == "TD" then cat [wg (head (tail (tail node))) env stab ar lams, "    drop\n", wg (head (tail (tail (tail node)))) env stab ar lams]
  else if tg == "L" then
    wg_list (head (tail node)) env stab ar lams
  else if tg == "M" then
    let scrut = head (tail node)
    let arms = head (tail (tail node))
    cat [wg scrut env stab ar lams, "    local.set $__scrut\n", wg_match arms env stab ar lams]
  else if tg == "F" then
    let param = head (tail node)
    let body = head (tail (tail node))
    let fvl = fvs body [param]
    let lam_idx = wasm_find_lambda node lams 0
    let ncap = length fvl
    let alloc_size = 16 + ncap * 8
    cat ["    i32.const ", show alloc_size, "\n    call $alloc\n    i64.extend_i32_u\n    local.set $__ptr\n    local.get $__ptr\n    i32.wrap_i64\n    i64.const 4\n    i64.store\n    local.get $__ptr\n    i32.wrap_i64\n    i32.const 8\n    i32.add\n    i64.const ", show lam_idx, "\n    i64.store\n", wg_store_caps fvl env 0, "    local.get $__ptr\n    i64.const 1\n    i64.shl\n"]
  else if tg == "A" then
    let (fname, fargs) = flat node
    if fname == "print" then cat [wg (head fargs) env stab ar lams, "    call $__rail_print\n    i64.const 1\n"]
    else if fname == "show" then cat [wg (head fargs) env stab ar lams, "    call $show\n"]
    else if fname == "head" then cat [wg (head fargs) env stab ar lams, "    call $head\n"]
    else if fname == "tail" then cat [wg (head fargs) env stab ar lams, "    call $tail\n"]
    else if fname == "length" then cat [wg (head fargs) env stab ar lams, "    call $length\n"]
    else if fname == "cons" then cat [wg (head fargs) env stab ar lams, wg (head (tail fargs)) env stab ar lams, "    call $cons\n"]
    else if fname == "append" then cat [wg (head fargs) env stab ar lams, wg (head (tail fargs)) env stab ar lams, "    call $append\n"]
    else if fname == "join" then cat [wg (head fargs) env stab ar lams, wg (head (tail fargs)) env stab ar lams, "    call $join\n"]
    else if fname == "reverse" then cat [wg (head fargs) env stab ar lams, "    call $reverse\n"]
    else
      let ar_val = afind fname ar
      let (cidx, carity) = decode_ctor ar_val
      if cidx != (0 - 1) then
        let nargs = length fargs
        let alloc_size = 16 + nargs * 8
        cat ["    i32.const ", show alloc_size, "\n    call $alloc\n    i64.extend_i32_u\n    local.set $__ptr\n    local.get $__ptr\n    i32.wrap_i64\n    i64.const 5\n    i64.store\n    local.get $__ptr\n    i32.wrap_i64\n    i32.const 8\n    i32.add\n    i64.const ", show cidx, "\n    i64.store\n", wg_store_fields fargs env stab ar lams 0, "    local.get $__ptr\n    i64.const 1\n    i64.shl\n"]
      else
        let voff = wasm_efind fname env
        if voff >= 0 then
          cat ["    local.get $", fname, "\n    i64.const 1\n    i64.shr_u\n    local.set $__ptr\n    local.get $__ptr\n    i32.wrap_i64\n    i32.const 8\n    i32.add\n    i64.load\n    local.set $__scrut\n    local.get $", fname, "\n", wg (head fargs) env stab ar lams, "    local.get $__scrut\n    i32.wrap_i64\n    call_indirect (type $clos_t)\n"]
        else cat [wg_args fargs env stab ar lams, "    call $", fname, "\n"]
  else if tg == "NULL" then "    i64.const 0\n"
  else "    i64.const 1\n"

wg_args fa env stab ar lams =
  if length fa == 0 then ""
  else cat [wg (head fa) env stab ar lams, wg_args (tail fa) env stab ar lams]

wg_list elems env stab ar lams =
  if length elems == 0 then "    call $nil\n"
  else cat [wg (head elems) env stab ar lams, wg_list (tail elems) env stab ar lams, "    call $cons\n"]

wg_match arms env stab ar lams =
  if length arms == 0 then "    unreachable\n"
  else
    let arm = head arms
    let ctor = head arm
    let binds = head (tail arm)
    let body = head (tail (tail arm))
    if ctor == "_" then
      wg body env stab ar lams
    else if str_starts_with "#int:" ctor then
      let val = str_after "#int:" ctor
      cat ["    local.get $__scrut\n    i64.const ", show (str_to_int val * 2 + 1), "\n    i64.eq\n    if (result i64)\n", wg body env stab ar lams, "    else\n", wg_match (tail arms) env stab ar lams, "    end\n"]
    else if str_starts_with "#str:" ctor then
      let val = str_after "#str:" ctor
      cat ["    local.get $__scrut\n    i64.const ", show (wasm_sfind val stab * 2), "\n    call $str_eq\n    if (result i64)\n", wg body env stab ar lams, "    else\n", wg_match (tail arms) env stab ar lams, "    end\n"]
    else
      let (cidx, _) = decode_ctor (afind ctor ar)
      let bind_code = wg_extract_fields binds 0
      let bind_env = wg_bind_env binds env
      let is_last = length (tail arms) == 0
      if is_last then
        cat ["    local.get $__scrut\n    i64.const 1\n    i64.shr_u\n    local.set $__ptr\n", bind_code, wg body bind_env stab ar lams]
      else
        cat ["    local.get $__scrut\n    i64.const 1\n    i64.shr_u\n    local.set $__ptr\n    local.get $__ptr\n    i32.wrap_i64\n    i32.const 8\n    i32.add\n    i64.load\n    i64.const ", show cidx, "\n    i64.eq\n    if (result i64)\n", bind_code, wg body bind_env stab ar lams, "    else\n", wg_match (tail arms) env stab ar lams, "    end\n"]

wg_extract_fields binds idx =
  if length binds == 0 then ""
  else
    let nm = head binds
    let off = 16 + idx * 8
    cat ["    local.get $__ptr\n    i32.wrap_i64\n    i32.const ", show off, "\n    i32.add\n    i64.load\n    local.set $", nm, "\n", wg_extract_fields (tail binds) (idx + 1)]


wg_bind_env binds env =
  if length binds == 0 then env
  else wg_bind_env (tail binds) (cons (head binds, length env) env)

wg_store_fields fargs env stab ar lams idx =
  if length fargs == 0 then ""
  else
    let off = 16 + idx * 8
    cat ["    local.get $__ptr\n    i32.wrap_i64\n    i32.const ", show off, "\n    i32.add\n", wg (head fargs) env stab ar lams, "    i64.store\n", wg_store_fields (tail fargs) env stab ar lams (idx + 1)]

wg_store_caps fvl env idx =
  if length fvl == 0 then ""
  else
    let nm = head fvl
    let off = 16 + idx * 8
    cat ["    local.get $__ptr\n    i32.wrap_i64\n    i32.const ", show off, "\n    i32.add\n    local.get $", nm, "\n    i64.store\n", wg_store_caps (tail fvl) env (idx + 1)]

wasm_collect_lambdas decls idx =
  if length decls == 0 then []
  else
    let tg = head (head decls)
    if tg == "E" || tg == "TY" || tg == "FN_EXT" || tg == "LINK" then wasm_collect_lambdas (tail decls) idx
    else
      let bd = head (tail (tail (tail (head decls))))
      let found = wcl_node bd
      let tagged = wcl_tag found idx
      append tagged (wasm_collect_lambdas (tail decls) (idx + length found))

wcl_node node =
  let tg = head node
  if tg == "F" then cons node (wcl_node (head (tail (tail node))))
  else if tg == "O" then append (wcl_node (head (tail (tail node)))) (wcl_node (head (tail (tail (tail node)))))
  else if tg == "?" then append (wcl_node (head (tail node))) (append (wcl_node (head (tail (tail node)))) (wcl_node (head (tail (tail (tail node))))))
  else if tg == "D" then append (wcl_node (head (tail (tail node)))) (wcl_node (head (tail (tail (tail node)))))
  else if tg == "TD" then append (wcl_node (head (tail (tail node)))) (wcl_node (head (tail (tail (tail node)))))
  else if tg == "A" then wcl_list (tail node)
  else if tg == "L" then wcl_list (head (tail node))
  else if tg == "M" then append (wcl_node (head (tail node))) (wcl_arms (head (tail (tail node))))
  else []

wcl_list ns =
  if length ns == 0 then []
  else append (wcl_node (head ns)) (wcl_list (tail ns))

wcl_arms arms =
  if length arms == 0 then []
  else append (wcl_node (head (tail (tail (head arms))))) (wcl_arms (tail arms))

wcl_tag found idx =
  if length found == 0 then []
  else cons (head found, idx) (wcl_tag (tail found) (idx + 1))

wasm_find_lambda node lams idx =
  if length lams == 0 then 0
  else
    let (lnode, lidx) = head lams
    let lp = head (tail lnode)
    let lb = head (tail (tail lnode))
    let np = head (tail node)
    let nb = head (tail (tail node))
    if lp == np then
      if join "," (fvs lb [lp]) == join "," (fvs nb [np]) then lidx
      else wasm_find_lambda node (tail lams) (idx + 1)
    else wasm_find_lambda node (tail lams) (idx + 1)

wasm_lambda_fns lams stab ar =
  if length lams == 0 then ""
  else
    let (lnode, lidx) = head lams
    let param = head (tail lnode)
    let body = head (tail (tail lnode))
    let fvl = fvs body [param]
    let locs = wasm_dedup (append fvl (cons "__ptr" (cons "__scrut" (wasm_locs body))))
    let rl = wasm_fltr locs [param, "__env"]
    let ld = if length rl == 0 then "" else join "" (wasm_llist rl)
    let cap_loads = wg_load_caps fvl 0
    let env = wasm_env (cons param fvl) 0
    let bd = wg body env stab ar lams
    cat ["  (func $__lambda_", show lidx, " (param $__env i64) (param $", param, " i64) (result i64)\n", ld, "    local.get $__env\n    i64.const 1\n    i64.shr_u\n    local.set $__ptr\n", cap_loads, bd, "  )\n\n", wasm_lambda_fns (tail lams) stab ar]

wg_load_caps fvl idx =
  if length fvl == 0 then ""
  else
    let nm = head fvl
    let off = 16 + idx * 8
    cat ["    local.get $__ptr\n    i32.wrap_i64\n    i32.const ", show off, "\n    i32.add\n    i64.load\n    local.set $", nm, "\n", wg_load_caps (tail fvl) (idx + 1)]

wasm_op op =
  if op == "+" then "    i64.add\n" else if op == "-" then "    i64.sub\n"
  else if op == "*" then "    i64.mul\n" else if op == "/" then "    i64.div_s\n"
  else if op == "%" then "    i64.rem_s\n"
  else if op == "==" then "    i64.eq\n    i64.extend_i32_u\n"
  else if op == "!=" then "    i64.ne\n    i64.extend_i32_u\n"
  else if op == "<" then "    i64.lt_s\n    i64.extend_i32_u\n"
  else if op == ">" then "    i64.gt_s\n    i64.extend_i32_u\n"
  else if op == "<=" then "    i64.le_s\n    i64.extend_i32_u\n"
  else if op == ">=" then "    i64.ge_s\n    i64.extend_i32_u\n"
  else "    i64.add\n"

wasm_strs node =
  let tg = head node
  if tg == "S" then [head (tail node)]
  else if tg == "O" then append (wasm_strs (head (tail (tail node)))) (wasm_strs (head (tail (tail (tail node)))))
  else if tg == "?" then append (wasm_strs (head (tail node))) (append (wasm_strs (head (tail (tail node)))) (wasm_strs (head (tail (tail (tail node))))))
  else if tg == "D" then append (wasm_strs (head (tail (tail node)))) (wasm_strs (head (tail (tail (tail node)))))
  else if tg == "A" then wasm_strs_l (tail node)
  else if tg == "L" then wasm_strs_l (head (tail node))
  else if tg == "TD" then append (wasm_strs (head (tail (tail node)))) (wasm_strs (head (tail (tail (tail node)))))
  else if tg == "M" then append (wasm_strs (head (tail node))) (wasm_strs_arms (head (tail (tail node))))
  else if tg == "F" then wasm_strs (head (tail (tail node)))
  else []

wasm_strs_arms arms =
  if length arms == 0 then []
  else append (wasm_strs (head (tail (tail (head arms))))) (wasm_strs_arms (tail arms))

wasm_strs_l ns =
  if length ns == 0 then []
  else append (wasm_strs (head ns)) (wasm_strs_l (tail ns))

wasm_strs_all decls =
  if length decls == 0 then []
  else
    let tg = head (head decls)
    if tg == "E" || tg == "TY" || tg == "FN_EXT" || tg == "LINK" then wasm_strs_all (tail decls)
    else wasm_dedup (append (wasm_strs (head (tail (tail (tail (head decls)))))) (wasm_strs_all (tail decls)))

wasm_stab strs off =
  if length strs == 0 then []
  else cons (head strs, off) (wasm_stab (tail strs) (off + 4 + length (head strs)))

wasm_sfind s tbl =
  if length tbl == 0 then 0
  else
    let (k, v) = head tbl
    if k == s then v else wasm_sfind s (tail tbl)

wasm_sdata tbl =
  if length tbl == 0 then ""
  else
    let (s, off) = head tbl
    let slen = length s
    cat ["  (data (i32.const ", show off, ") \"\\", wasm_h2 (slen % 256), "\\", wasm_h2 ((slen / 256) % 256), "\\00\\00", wasm_esc s, "\")\n", wasm_sdata (tail tbl)]

wasm_hd n =
  if n < 10 then show n
  else if n == 10 then "a" else if n == 11 then "b" else if n == 12 then "c" else if n == 13 then "d" else if n == 14 then "e" else "f"

wasm_h2 n = join "" [wasm_hd (n / 16), wasm_hd (n % 16)]

wasm_esc s = wasm_esc_c (chars s)

wasm_esc_c cs =
  if length cs == 0 then ""
  else cat ["\\", wasm_h2 (wasm_cc (head cs)), wasm_esc_c (tail cs)]

wasm_cc c =
  if c == "\n" then 10
  else if c == "\t" then 9
  else str_to_int (trim (shell (cat ["printf '%d' \"'", c, "\""])))

is_safe_pkg_name name =
  let check = trim (shell (cat ["printf '%s' '", name, "' | grep -qE '^[a-zA-Z0-9_./-]+$' && echo yes || echo no"]))
  check == "yes"

dispatch_get name =
  if is_safe_pkg_name name == false then
    let _ = print (cat ["Error: invalid package name: ", name])
    1
  else
    let _ = shell "mkdir -p ~/.rail/packages"
    let home = trim (shell "echo $HOME")
    if str_starts_with "github.com/" name then
      -- GitHub package: git clone to ~/.rail/packages/user/repo
      let rest = str_after "github.com/" name
      let dest_dir = cat [home, "/.rail/packages/", rest]
      let parent = trim (shell (cat ["dirname '", dest_dir, "'"]))
      let _ = shell (cat ["mkdir -p '", parent, "'"])
      let exists = trim (shell (cat ["test -d '", dest_dir, "' && echo yes || echo no"]))
      if exists == "yes" then
        let _ = print (cat ["Updating: ", name])
        let _ = shell (cat ["cd '", dest_dir, "' && git pull 2>&1"])
        let _ = print (cat ["Updated: ", name, " -> ", dest_dir])
        0
      else
        let _ = print (cat ["Cloning: ", name])
        let url = cat ["https://", name, ".git"]
        let res = trim (shell (cat ["git clone '", url, "' '", dest_dir, "' 2>&1"]))
        let _ = print res
        let _ = print (cat ["Installed: ", name, " -> ", dest_dir])
        0
    else
      -- Stdlib or local package
      let bindir = trim (shell (cat ["dirname '", head args, "'"]))
      let src_path = cat [bindir, "/stdlib/", name, ".rail"]
      let src = read_file src_path
      let src2 = if length src == 0 then read_file (cat ["stdlib/", name, ".rail"]) else src
      let dest_dir = cat [home, "/.rail/packages/", name]
      let _ = shell (cat ["mkdir -p '", dest_dir, "'"])
      let dest_path = cat [dest_dir, "/", name, ".rail"]
      if length src2 == 0 then
        let _ = print (cat ["Package not found: ", name])
        1
      else
        let _ = write_file dest_path src2
        let _ = print (cat ["Installed: ", name, " -> ", dest_path])
        0

dispatch_pkg _ =
  let toml = read_file "rail.toml"
  if length toml == 0 then
    let _ = print "No rail.toml found in current directory."
    1
  else
    let _ = print "=== rail pkg: installing dependencies from rail.toml ==="
    let lines = split "\n" toml
    let _ = pkg_process_lines lines false
    0

pkg_process_lines lines in_deps =
  if length lines == 0 then 0
  else
    let line = head lines
    let rest = tail lines
    if line == "[dependencies]" then pkg_process_lines rest true
    else if str_starts_with "[" line then pkg_process_lines rest false
    else if in_deps then
      if length line == 0 then pkg_process_lines rest in_deps
      else if str_starts_with "--" line then pkg_process_lines rest in_deps
      else if str_starts_with "#" line then pkg_process_lines rest in_deps
      else
        -- Parse: name = "source"
        let parts = split "=" line
        if length parts >= 2 then
          let dep_name = pkg_trim_str (head parts)
          let dep_src = pkg_trim_str (head (tail parts))
          let _ = if dep_src == "stdlib" then
            let _ = print (cat ["  Installing ", dep_name, " (stdlib)"])
            dispatch_get dep_name
          else
            let _ = print (cat ["  Installing ", dep_name, " from ", dep_src])
            dispatch_get dep_src
          pkg_process_lines rest in_deps
        else pkg_process_lines rest in_deps
    else pkg_process_lines rest in_deps

pkg_trim_str s =
  let cs = chars s
  let cs2 = pkg_drop_spaces cs
  let cs3 = reverse (pkg_drop_spaces (reverse cs2))
  let cs4 = pkg_drop_quotes cs3
  join "" cs4

pkg_drop_spaces cs =
  if length cs == 0 then []
  else if head cs == " " then pkg_drop_spaces (tail cs)
  else if head cs == "\t" then pkg_drop_spaces (tail cs)
  else cs

pkg_drop_quotes cs =
  if length cs == 0 then []
  else
    let first = head cs
    if first == "\"" then pkg_strip_end_quote (tail cs)
    else cs

pkg_strip_end_quote cs =
  if length cs == 0 then []
  else
    let r = reverse cs
    if head r == "\"" then reverse (tail r)
    else cs

dispatch_packages _ =
  let _ = shell "mkdir -p ~/.rail/packages"
  let home = trim (shell "echo $HOME")
  let out = shell (cat ["ls -1 ", home, "/.rail/packages/ 2>/dev/null"])
  if length out == 0 then
    let _ = print "No packages installed."
    0
  else
    let _ = print "Installed packages:"
    let _ = print out
    0

-- ═══════════════════════════════════════════════════════════════════════════════
-- x86_64 BACKEND (Linux, System V AMD64 ABI, glibc-linked)
-- Frame: push rbp; sub rsp,N; mov rbp,rsp → locals at [rbp+16], same offsets as ARM64
-- Tail call: add rsp,N; pop rbp; jmp func
-- ═══════════════════════════════════════════════════════════════════════════════

-- Direct operand for cmp (raw mode): register vars are raw, literals are raw values
direct_cmp_operand_raw node env =
  let tg = head node
  if tg == "I" then
    let v = str_to_int (head (tail node))
    if v >= 0 && v <= 4095 then cat ["#", show v] else ""
  else if tg == "V" then
    let off = efind (head (tail node)) env
    if off < 0 && off != (0 - 1) then cat ["x", show (0 - off)]
    else ""
  else ""

-- Direct operand for cmp (tagged mode): returns register name or #tagged_immediate, or "" if not simple
direct_cmp_operand node env =
  let tg = head node
  if tg == "I" then
    let tagged = str_to_int (head (tail node)) * 2 + 1
    if tagged >= 0 && tagged <= 4095 then cat ["#", show tagged] else ""
  else if tg == "V" then
    let off = efind (head (tail node)) env
    if off < 0 && off != (0 - 1) then cat ["x", show (0 - off)]
    else ""
  else ""

-- Direct value for self-loop: returns register/raw immediate string, or "" if complex
direct_self_operand node env =
  let tg = head node
  if tg == "I" then
    let v = str_to_int (head (tail node))
    cat ["#", show v]
  else if tg == "V" then
    let off = efind (head (tail node)) env
    if off < 0 && off != (0 - 1) then cat ["x", show (0 - off)]
    else ""
  else ""

x86_callee_reg n =
  if n == 19 then "rbx"
  else if n == 20 then "r12"
  else if n == 21 then "r13"
  else "rax"

x86_arg_reg n =
  if n == 0 then "rdi"
  else if n == 1 then "rsi"
  else if n == 2 then "rdx"
  else if n == 3 then "rcx"
  else if n == 4 then "r8"
  else if n == 5 then "r9"
  else "rax"

x86_emit_load_int v =
  cat ["    mov rax, ", v, "\n"]

x86_emit_rcx node env =
  let tg = head node
  if tg == "I" then
    let tagged = str_to_int (head (tail node)) * 2 + 1
    cat ["    mov rcx, ", show tagged, "\n"]
  else if tg == "V" then
    let nm = head (tail node)
    let off = efind nm env
    if off == 0 - 1 then "    mov rcx, rax\n"
    else if off < 0 then cat ["    mov rcx, ", x86_callee_reg (0 - off), "\n"]
    else cat ["    mov rcx, [rbp+", show off, "]\n"]
  else "    mov rcx, rax\n"

x86_get_opc_noguard op =
  if op == "+" then "    add rax, rcx\n    dec rax\n"
  else if op == "-" then "    sub rcx, rax\n    lea rax, [rcx+1]\n"
  else if op == "*" then "    sar rcx, 1\n    sar rax, 1\n    imul rax, rcx\n    lea rax, [rax*2+1]\n"
  else if op == "/" then "    mov r10, rax\n    sar r10, 1\n    mov rax, rcx\n    sar rax, 1\n    cqo\n    idiv r10\n    lea rax, [rax*2+1]\n"
  else if op == "%" then "    mov r10, rax\n    sar r10, 1\n    mov rax, rcx\n    sar rax, 1\n    cqo\n    idiv r10\n    lea rax, [rdx*2+1]\n"
  else if op == "<" then "    cmp rcx, rax\n    setl al\n    movzx rax, al\n    lea rax, [rax*2+1]\n"
  else if op == ">" then "    cmp rcx, rax\n    setg al\n    movzx rax, al\n    lea rax, [rax*2+1]\n"
  else if op == "<=" then "    cmp rcx, rax\n    setle al\n    movzx rax, al\n    lea rax, [rax*2+1]\n"
  else if op == ">=" then "    cmp rcx, rax\n    setge al\n    movzx rax, al\n    lea rax, [rax*2+1]\n"
  else if op == "==" then "    cmp rcx, rax\n    sete al\n    movzx rax, al\n    lea rax, [rax*2+1]\n"
  else if op == "!=" then "    cmp rcx, rax\n    setne al\n    movzx rax, al\n    lea rax, [rax*2+1]\n"
  else if op == "&&" then "    and rax, rcx\n"
  else if op == "||" then "    or rax, rcx\n"
  else "    ; unknown op\n"

x86_get_opc_inline op lc =
  let heap_lbl = cat [".Lx_op_heap_", show lc]
  let done_lbl = cat [".Lx_op_done_", show lc]
  let check = cat ["    test rcx, 1\n    jz ", heap_lbl, "\n"]
  let int_end = cat ["    jmp ", done_lbl, "\n"]
  let fb_end = cat [done_lbl, ":\n"]
  if op == "+" then cat [check, "    add rax, rcx\n    dec rax\n", int_end, heap_lbl, ":\n    mov rdi, rcx\n    mov rsi, rax\n    call _rail_add@PLT\n", fb_end]
  else if op == "-" then cat [check, "    sub rcx, rax\n    lea rax, [rcx+1]\n", int_end, heap_lbl, ":\n    mov rdi, rcx\n    mov rsi, rax\n    call _rail_sub@PLT\n", fb_end]
  else if op == "*" then cat [check, "    sar rcx, 1\n    sar rax, 1\n    imul rax, rcx\n    lea rax, [rax*2+1]\n", int_end, heap_lbl, ":\n    mov rdi, rcx\n    mov rsi, rax\n    call _rail_mul@PLT\n", fb_end]
  else if op == "/" then cat [check, "    mov r10, rax\n    sar r10, 1\n    mov rax, rcx\n    sar rax, 1\n    cqo\n    idiv r10\n    lea rax, [rax*2+1]\n", int_end, heap_lbl, ":\n    mov rdi, rcx\n    mov rsi, rax\n    call _rail_div@PLT\n", fb_end]
  else if op == "%" then cat [check, "    mov r10, rax\n    sar r10, 1\n    mov rax, rcx\n    sar rax, 1\n    cqo\n    idiv r10\n    lea rax, [rdx*2+1]\n", int_end, heap_lbl, ":\n    mov rdi, rcx\n    mov rsi, rax\n    call _rail_mod@PLT\n", fb_end]
  else if op == "<" then cat [check, "    cmp rcx, rax\n    setl al\n    movzx rax, al\n    lea rax, [rax*2+1]\n", int_end, heap_lbl, ":\n    mov rdi, rcx\n    mov rsi, rax\n    call _rail_lt@PLT\n", fb_end]
  else if op == ">" then cat [check, "    cmp rcx, rax\n    setg al\n    movzx rax, al\n    lea rax, [rax*2+1]\n", int_end, heap_lbl, ":\n    mov rdi, rcx\n    mov rsi, rax\n    call _rail_gt@PLT\n", fb_end]
  else if op == "<=" then cat [check, "    cmp rcx, rax\n    setle al\n    movzx rax, al\n    lea rax, [rax*2+1]\n", int_end, heap_lbl, ":\n    mov rdi, rcx\n    mov rsi, rax\n    call _rail_le@PLT\n", fb_end]
  else if op == ">=" then cat [check, "    cmp rcx, rax\n    setge al\n    movzx rax, al\n    lea rax, [rax*2+1]\n", int_end, heap_lbl, ":\n    mov rdi, rcx\n    mov rsi, rax\n    call _rail_ge@PLT\n", fb_end]
  else if op == "==" then "    mov rdi, rcx\n    mov rsi, rax\n    call _rail_eq@PLT\n"
  else if op == "!=" then "    mov rdi, rcx\n    mov rsi, rax\n    call _rail_ne@PLT\n"
  else if op == "&&" then "    and rax, rcx\n"
  else if op == "||" then "    or rax, rcx\n"
  else "    ; unknown op\n"

x86_save_params params idx =
  if length params == 0 then ""
  else
    let off = 16 + idx * 8
    cat ["    mov [rbp+", show off, "], ", x86_arg_reg idx, "\n", x86_save_params (tail params) (idx + 1)]

x86_save_params_reg params idx =
  if length params == 0 then ""
  else
    let off = 16 + idx * 8
    let cr = x86_callee_reg (19 + idx)
    cat ["    mov [rbp+", show off, "], ", cr, "\n    mov ", cr, ", ", x86_arg_reg idx, "\n", x86_save_params_reg (tail params) (idx + 1)]

x86_cg_push_args args env ar lc sl fs =
  if length args == 0 then ("", lc, sl)
  else
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    let (rest, lc2, sl2) = x86_cg_push_args (tail args) env ar lc1 sl1 fs
    (cat [aa, "    sub rsp, 16\n    mov [rsp], rax\n", rest], lc2, sl2)

x86_cg_pop_regs n i =
  if i >= n then ""
  else cat ["    mov ", x86_arg_reg (n - 1 - i), ", [rsp]\n    add rsp, 16\n", x86_cg_pop_regs n (i + 1)]

x86_cg_list elems env ar lc sl fs =
  if length elems == 0 then
    ("    lea rax, [rip+_rail_nil]\n", lc, sl)
  else
    let (ta, lc1, sl1) = x86_cg_list (tail elems) env ar lc sl fs
    let (ha, lc2, sl2) = x86_cg (head elems) env ar lc1 sl1 false fs
    (cat [ta, "    sub rsp, 16\n    mov [rsp], rax\n", ha, "    mov rdi, rax\n    mov rsi, [rsp]\n    add rsp, 16\n    call _rail_cons\n"], lc2, sl2)

x86_push_captured caps env =
  if length caps == 0 then ""
  else
    let off = efind (head caps) env
    let ld = if off < 0 && off != (0 - 1) then cat ["    mov rax, ", x86_callee_reg (0 - off), "\n"] else cat ["    mov rax, [rbp+", show off, "]\n"]
    cat [ld, "    sub rsp, 16\n    mov [rsp], rax\n", x86_push_captured (tail caps) env]

x86_pop_to_closure n i =
  if i >= n then ""
  else
    let off = 24 + (n - 1 - i) * 8
    cat ["    mov rcx, [rsp]\n    add rsp, 16\n    mov [rax+", show off, "], rcx\n", x86_pop_to_closure n (i + 1)]

x86_pop_to_adt n i =
  if i >= n then ""
  else
    let off = 16 + (n - 1 - i) * 8
    cat ["    mov rcx, [rsp]\n    add rsp, 16\n    mov [rax+", show off, "], rcx\n", x86_pop_to_adt n (i + 1)]

x86_pop_to_tuple n i =
  if i >= n then ""
  else
    let off = 8 + (n - 1 - i) * 8
    cat ["    mov rcx, [rsp]\n    add rsp, 16\n    mov [rax+", show off, "], rcx\n", x86_pop_to_tuple n (i + 1)]

x86_load_closure_caps base i lbl =
  if i >= 4 then cat [lbl, ":\n"]
  else if base + i > 4 then cat [lbl, ":\n"]
  else
    let load = cat ["    mov ", x86_arg_reg (base + i), ", [r15+", show (24 + i * 8), "]\n"]
    let check = cat ["    cmp r13, ", show (i + 1), "\n    je ", lbl, "\n"]
    cat [load, check, x86_load_closure_caps base (i + 1) lbl]

x86_gen_restore nregs =
  if nregs >= 3 then "    mov r13, [rbp+32]\n    mov r12, [rbp+24]\n    mov rbx, [rbp+16]\n"
  else if nregs >= 2 then "    mov r12, [rbp+24]\n    mov rbx, [rbp+16]\n"
  else if nregs >= 1 then "    mov rbx, [rbp+16]\n"
  else ""

x86_reg_restore env =
  let n = efind "__nregs" env
  if n == (0 - 1) || n == 0 then "" else x86_gen_restore n

x86_extract_adt_fields binds scrut_sl idx next_sl env =
  if length binds == 0 then ("", env, next_sl)
  else
    let nm = head binds
    let field_off = 16 + idx * 8
    let load = cat ["    mov rax, [rbp+", show scrut_sl, "]\n    mov rax, [rax+", show field_off, "]\n    mov [rbp+", show next_sl, "], rax\n"]
    let env2 = cons (nm, next_sl) env
    let (rest, env3, sl2) = x86_extract_adt_fields (tail binds) scrut_sl (idx + 1) (next_sl + 8) env2
    (cat [load, rest], env3, sl2)

x86_extract_tuple names tuple_sl idx next_sl env =
  if length names == 0 then ("", env, next_sl)
  else
    let nm = head names
    let elem_off = 8 + idx * 8
    let load = cat ["    mov rax, [rbp+", show tuple_sl, "]\n    mov rax, [rax+", show elem_off, "]\n    mov [rbp+", show next_sl, "], rax\n"]
    let env2 = cons (nm, next_sl) env
    let (rest, env3, sl2) = x86_extract_tuple (tail names) tuple_sl (idx + 1) (next_sl + 8) env2
    (cat [load, rest], env3, sl2)

x86_cg_let_binds params args env ar lc sl fs =
  if length params == 0 then ("", env, lc, sl)
  else
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    let env2 = cons (head params, sl) env
    let env2 = if is_int (head args) env then cons (cat ["__int_", head params], 1) env2 else env2
    let (rest, env3, lc2, sl2) = x86_cg_let_binds (tail params) (tail args) env2 ar lc1 (sl + 8) fs
    (cat [aa, "    mov [rbp+", show sl, "], rax\n", rest], env3, lc2, sl2)

-- x86_64 BUILTIN CODEGEN
x86_cg_bi fname args env ar lc sl tp fs =
  if fname == "print" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    mov rdi, rax\n    call _rail_print\n"], lc1, sl1)
  else if fname == "show" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    mov rdi, rax\n    call _rail_show\n"], lc1, sl1)
  else if fname == "append" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_append\n"], lc1, sl1)
  else if fname == "cons" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_cons\n"], lc1, sl1)
  else if fname == "head" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    mov rdi, rax\n    call _rail_head\n"], lc1, sl1)
  else if fname == "tail" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    mov rdi, rax\n    call _rail_tail\n"], lc1, sl1)
  else x86_cg_bi2 fname args env ar lc sl tp fs

x86_cg_bi2 fname args env ar lc sl tp fs =
  if fname == "length" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    mov rdi, rax\n    call _rail_length\n"], lc1, sl1)
  else if fname == "write_file" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_write_file\n"], lc1, sl1)
  else if fname == "shell" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    mov rdi, rax\n    call _rail_shell\n"], lc1, sl1)
  else if fname == "read_file" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    mov rdi, rax\n    call _rail_read_file\n"], lc1, sl1)
  else if fname == "not" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    xor rax, 2\n"], lc1, sl1)
  else if fname == "chars" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    mov rdi, rax\n    call _rail_chars\n"], lc1, sl1)
  else if fname == "split" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_split\n"], lc1, sl1)
  else if fname == "str_find" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_str_find\n"], lc1, sl1)
  else if fname == "str_contains" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_str_contains\n"], lc1, sl1)
  else if fname == "str_replace" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_str_replace\n"], lc1, sl1)
  else if fname == "str_split" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_str_split\n"], lc1, sl1)
  else if fname == "str_sub" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_str_sub\n"], lc1, sl1)
  else if fname == "read_line" then
    ("    call _rail_read_line\n", lc, sl)
  else if fname == "join" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_join\n"], lc1, sl1)
  else if fname == "cat" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_cat\n"], lc1, sl1)
  else if fname == "map" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_map\n"], lc1, sl1)
  else if fname == "filter" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_filter\n"], lc1, sl1)
  else if fname == "fold" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_fold\n"], lc1, sl1)
  else if fname == "reverse" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    mov rdi, rax\n    call _rail_reverse\n"], lc1, sl1)
  else if fname == "range" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    mov rdi, rax\n    call _rail_range\n"], lc1, sl1)
  else x86_cg_bi3 fname args env ar lc sl tp fs

x86_cg_bi3 fname args env ar lc sl tp fs =
  if fname == "arr_new" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    call _rail_arr_new\n"], lc1, sl1)
  else if fname == "arr_get" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    sar rsi, 1\n    add rsi, 2\n    mov rax, [rdi+rsi*8]\n"], lc1, sl1)
  else if fname == "arr_set" then
    let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
    (cat [pa, x86_cg_pop_regs (length args) 0, "    sar rsi, 1\n    add rsi, 2\n    mov [rdi+rsi*8], rdx\n    mov rax, 1\n"], lc1, sl1)
  else if fname == "arr_len" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    mov rax, [rax+8]\n    lea rax, [rax*2+1]\n"], lc1, sl1)
  else if fname == "error" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    mov rcx, rax\n    mov rdi, 16\n    call _rail_alloc\n    mov qword ptr [rax], 8\n    mov [rax+8], rcx\n"], lc1, sl1)
  else if fname == "is_error" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    let elbl = cat [".Lx_iserr_", show lc]
    let dlbl = cat [".Lx_iserd_", show lc]
    (cat [aa, "    test rax, 1\n    jnz ", elbl, "\n    mov rcx, [rax]\n    and rcx, 0x7fffffffffffffff\n    cmp rcx, 8\n    jne ", elbl, "\n    mov rax, 3\n    jmp ", dlbl, "\n", elbl, ":\n    mov rax, 1\n", dlbl, ":\n"], lc1 + 1, sl1)
  else if fname == "err_msg" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    mov rax, [rax+8]\n"], lc1, sl1)
  else if fname == "arena_mark" then
    ("    lea rax, [rip+_rail_heap_ptr]\n    mov rax, [rax]\n", lc, sl)
  else if fname == "arena_reset" then
    let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
    (cat [aa, "    lea rcx, [rip+_rail_heap_ptr]\n    mov [rcx], rax\n    call _rail_free_list_clear\n    mov rax, 1\n"], lc1, sl1)
  else
    -- Constructor or user-defined function call
    let (cidx, carity) = decode_ctor (afind fname ar)
    if cidx != (0 - 1) then
      let nargs = length args
      let alloc_size = 16 + nargs * 8
      let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
      (cat [pa, x86_emit_load_int (show alloc_size), "    mov rdi, rax\n    call _rail_alloc\n    mov qword ptr [rax], 5\n    mov qword ptr [rax+8], ", show cidx, "\n", x86_pop_to_adt nargs 0], lc1, sl1)
    else
    let ar_raw = afind fname ar
    if ar_raw >= 1000 then
      -- Foreign function
      -- Encoding: 1000=int, 2000=str, 3000=float, 4000=raw ptr
      let is_str_ret = ar_raw >= 2000 && ar_raw < 3000
      let is_raw_ret = ar_raw >= 4000
      let no_retag = is_str_ret || is_raw_ret
      let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
      let pop = x86_cg_pop_regs (length args) 0
      let retag = if no_retag then "" else "    lea rax, [rax*2+1]\n"
      (cat [pa, pop, "    call _", fname, "\n", retag], lc1, sl1)
    else
    let voff = efind fname env
    if voff != (0 - 1) then
      -- Closure call via variable
      let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
      let nargs = length args
      let pop = x86_cg_pop_regs nargs 0
      let load_clos = cat ["    mov r15, [rbp+", show voff, "]\n    mov r14, [r15+8]\n    mov r13, [r15+16]\n"]
      let clbl = cat [".Lx_call_", show lc1]
      let load_caps = cat ["    cmp r13, 0\n    je ", clbl, "\n", x86_load_closure_caps nargs 0 clbl]
      let rr = x86_reg_restore env
      let call = if tp then cat [rr, "    add rsp, ", fs, "\n    pop rbp\n    jmp r14\n"] else "    call r14\n"
      (cat [pa, pop, load_clos, load_caps, call], lc1 + 1, sl1)
    else if length args == 1 then
      let (aa, lc1, sl1) = x86_cg (head args) env ar lc sl false fs
      let rr = x86_reg_restore env
      let call = if tp then cat [rr, "    mov rdi, rax\n    add rsp, ", fs, "\n    pop rbp\n    jmp _", fname, "\n"] else cat ["    mov rdi, rax\n    call _", fname, "\n"]
      (cat [aa, call], lc1, sl1)
    else
      let (pa, lc1, sl1) = x86_cg_push_args args env ar lc sl fs
      let rr = x86_reg_restore env
      let call = if tp then cat [rr, x86_cg_pop_regs (length args) 0, "    add rsp, ", fs, "\n    pop rbp\n    jmp _", fname, "\n"] else cat [x86_cg_pop_regs (length args) 0, "    call _", fname, "\n"]
      (cat [pa, call], lc1, sl1)

-- x86_64 MAIN CODEGEN
x86_cg node env ar lc sl tp fs =
  let tg = head node
  if tg == "I" then
    let v = head (tail node)
    let tagged = str_to_int v * 2 + 1
    (x86_emit_load_int (show tagged), lc, sl)
  else if tg == "FL" then
    -- Float literal
    let v = head (tail node)
    let slbl = cat [".Lx_fl_str_", show lc]
    let albl = cat [".Lx_fl_after_", show lc]
    (cat ["    jmp ", albl, "\n", slbl, ":\n    .asciz \"", v, "\"\n    .p2align 3\n", albl, ":\n    lea rdi, ", slbl, "\n    call atof@PLT\n    mov rdi, 16\n    call _rail_alloc\n    mov qword ptr [rax], 6\n    movsd [rax+8], xmm0\n"], lc + 1, sl)
  else if tg == "NULL" then
    ("    xor rax, rax\n", lc, sl)
  else if tg == "B" then
    let v = head (tail node)
    (cat ["    mov rax, ", if v == "true" then "3" else "1", "\n"], lc, sl)
  else if tg == "S" then
    let v = head (tail node)
    let slbl = cat [".Lx_str_", show lc]
    let albl = cat [".Lx_after_", show lc]
    (cat ["    jmp ", albl, "\n", slbl, ":\n    .asciz \"", esc_asm v, "\"\n    .p2align 3\n", albl, ":\n    lea rax, [rip+", slbl, "]\n"], lc + 1, sl)
  else if tg == "V" then
    let nm = head (tail node)
    let off = efind nm env
    if off == 0 - 1 then
      if nm == "args" then
        ("    call _rail_args\n", lc, sl)
      else
        let ar_val = afind nm ar
        let (cidx, carity) = decode_ctor ar_val
        if cidx != (0 - 1) then
          if carity == 0 then
            (cat ["    mov rdi, 16\n    call _rail_alloc\n    mov qword ptr [rax], 5\n    mov qword ptr [rax+8], ", show cidx, "\n"], lc, sl)
          else
            (cat ["    ; TODO: constructor-as-value for ", nm, "\n    xor rax, rax\n"], lc, sl)
        else if ar_val == 0 then
          let rr = x86_reg_restore env
          let call = if tp then cat [rr, "    add rsp, ", fs, "\n    pop rbp\n    jmp _", nm, "\n"] else cat ["    call _", nm, "\n"]
          (call, lc, sl)
        else if ar_val != (0 - 1) then
          -- Function reference as closure value
          (cat ["    mov rdi, 24\n    call _rail_alloc\n    mov qword ptr [rax], 4\n    lea rcx, [rip+_", nm, "]\n    mov [rax+8], rcx\n    mov qword ptr [rax+16], 0\n"], lc, sl)
        else (cat ["    ; ERROR undefined: ", nm, "\n"], lc, sl)
    else if off < 0 then (cat ["    mov rax, ", x86_callee_reg (0 - off), "\n"], lc, sl)
    else (cat ["    mov rax, [rbp+", show off, "]\n"], lc, sl)
  else if tg == "O" then
    let op = head (tail node)
    let lnode = head (tail (tail node))
    let rnode = head (tail (tail (tail node)))
    let ltg = head lnode
    let rtg = head rnode
    let both_simple = (ltg == "V" || ltg == "I") && (rtg == "V" || rtg == "I")
    let both_int = is_int lnode env && is_int rnode env
    if both_simple then
      let la_rcx = x86_emit_rcx lnode env
      let (ra, lc1, sl1) = x86_cg rnode env ar (lc + 1) sl false fs
      let opc = if both_int then x86_get_opc_noguard op else x86_get_opc_inline op lc
      (cat [la_rcx, ra, opc], lc1 + 1, sl1)
    else
      let (la, lc1, sl1) = x86_cg lnode env ar lc sl false fs
      let (ra, lc2, sl2) = x86_cg rnode env ar lc1 sl1 false fs
      let opc = if both_int then x86_get_opc_noguard op else x86_get_opc_inline op lc2
      (cat [la, "    sub rsp, 16\n    mov [rsp], rax\n", ra, "    mov rcx, [rsp]\n    add rsp, 16\n", opc], lc2 + 1, sl2)
  else if tg == "?" then
    let cond = head (tail node)
    let ctg = head cond
    let elbl = cat [".Lx_else_", show lc]
    let dlbl = cat [".Lx_end_", show lc]
    if ctg == "O" then
      let cop = head (tail cond)
      let clnode = head (tail (tail cond))
      let crnode = head (tail (tail (tail cond)))
      let cltg = head clnode
      let crtg = head crnode
      let is_cmp = cop == "<" || cop == ">" || cop == "<=" || cop == ">=" || cop == "==" || cop == "!="
      let both_s = (cltg == "V" || cltg == "I") && (crtg == "V" || crtg == "I")
      let both_i = is_int clnode env && is_int crnode env
      if is_cmp && both_s && both_i then
        let la_rcx = x86_emit_rcx clnode env
        let (ra, lc1, sl1) = x86_cg crnode env ar (lc + 1) sl false fs
        let neg_br = if cop == "<" then cat ["jge ", elbl] else if cop == ">" then cat ["jle ", elbl] else if cop == "<=" then cat ["jg ", elbl] else if cop == ">=" then cat ["jl ", elbl] else if cop == "==" then cat ["jne ", elbl] else cat ["je ", elbl]
        let (ta, lc2, sl2) = x86_cg (head (tail (tail node))) env ar lc1 sl1 tp fs
        let (ea, lc3, sl3) = x86_cg (head (tail (tail (tail node)))) env ar lc2 sl tp fs
        (cat [la_rcx, ra, "    cmp rcx, rax\n    ", neg_br, "\n", ta, "    jmp ", dlbl, "\n", elbl, ":\n", ea, dlbl, ":\n"], lc3, sl)
      else
        let (ca, lc1, sl1) = x86_cg cond env ar (lc + 1) sl false fs
        let (ta, lc2, sl2) = x86_cg (head (tail (tail node))) env ar lc1 sl1 tp fs
        let (ea, lc3, sl3) = x86_cg (head (tail (tail (tail node)))) env ar lc2 sl tp fs
        (cat [ca, "    cmp rax, 1\n    je ", elbl, "\n", ta, "    jmp ", dlbl, "\n", elbl, ":\n", ea, dlbl, ":\n"], lc3, sl)
    else
      let (ca, lc1, sl1) = x86_cg cond env ar (lc + 1) sl false fs
      let (ta, lc2, sl2) = x86_cg (head (tail (tail node))) env ar lc1 sl1 tp fs
      let (ea, lc3, sl3) = x86_cg (head (tail (tail (tail node)))) env ar lc2 sl tp fs
      (cat [ca, "    cmp rax, 1\n    je ", elbl, "\n", ta, "    jmp ", dlbl, "\n", elbl, ":\n", ea, dlbl, ":\n"], lc3, sl)
  else x86_cg2 node env ar lc sl tg tp fs

x86_cg2 node env ar lc sl tg tp fs =
  if tg == "D" then
    let nm = head (tail node)
    let vl = head (tail (tail node))
    let bd = head (tail (tail (tail node)))
    let (va, lc1, sl1) = x86_cg vl env ar lc sl false fs
    let env2 = cons (nm, sl) env
    let env2 = if is_int vl env then cons (cat ["__int_", nm], 1) env2 else env2
    let (ba, lc2, sl2) = x86_cg bd env2 ar lc1 (sl + 8) tp fs
    (cat [va, "    mov [rbp+", show sl, "], rax\n", ba], lc2, sl2)
  else if tg == "L" then
    x86_cg_list (head (tail node)) env ar lc sl fs
  else if tg == "T" then
    let elems = head (tail node)
    let n = length elems
    let (pa, lc1, sl1) = x86_cg_push_args elems env ar lc sl fs
    (cat [pa, "    mov rdi, ", show (8 + n * 8), "\n    call _rail_alloc\n    mov qword ptr [rax], 3\n", x86_pop_to_tuple n 0], lc1, sl1)
  else if tg == "TD" then
    let names = head (tail node)
    let (va, lc1, sl1) = x86_cg (head (tail (tail node))) env ar lc sl false fs
    let (ext, env2, sl2) = x86_extract_tuple names sl 0 (sl + 8) env
    let (ba, lc2, sl3) = x86_cg (head (tail (tail (tail node)))) env2 ar lc1 sl2 tp fs
    (cat [va, "    mov [rbp+", show sl, "], rax\n", ext, ba], lc2, sl3)
  else if tg == "A" then
    let (fname, args) = flat node
    if fname == "_expr" then
      let fn_node = get_app_fn node
      if head fn_node == "F" then
        let (params, inner_body) = collect_lam_params fn_node
        let np = length params
        let na = length args
        if na == np then
          let (bind_asm, env2, lc2, sl2) = x86_cg_let_binds params args env ar lc sl fs
          let (body_asm, lc3, sl3) = x86_cg inner_body env2 ar lc2 sl2 tp fs
          (cat [bind_asm, body_asm], lc3, sl3)
        else
          let (fn_asm, lc1, sl1) = x86_cg fn_node env ar lc sl false fs
          let clos_sl = sl1
          let (pa, lc2, sl2) = x86_cg_push_args args env ar lc1 (sl1 + 8) fs
          let nargs2 = length args
          let pop = x86_cg_pop_regs nargs2 0
          let clbl = cat [".Lx_call_", show lc2]
          let load_clos = cat ["    mov r15, [rbp+", show clos_sl, "]\n    mov r14, [r15+8]\n    mov r13, [r15+16]\n"]
          let lcaps = cat ["    cmp r13, 0\n    je ", clbl, "\n", x86_load_closure_caps nargs2 0 clbl]
          let rr = x86_reg_restore env
          let call = if tp then cat [rr, "    add rsp, ", fs, "\n    pop rbp\n    jmp r14\n"] else "    call r14\n"
          (cat [fn_asm, "    mov [rbp+", show clos_sl, "], rax\n", pa, pop, load_clos, lcaps, call], lc2 + 1, sl2)
      else
        let (fn_asm, lc1, sl1) = x86_cg fn_node env ar lc sl false fs
        let clos_sl = sl1
        let (pa, lc2, sl2) = x86_cg_push_args args env ar lc1 (sl1 + 8) fs
        let nargs = length args
        let pop = x86_cg_pop_regs nargs 0
        let clbl = cat [".Lx_call_", show lc2]
        let load_clos = cat ["    mov r15, [rbp+", show clos_sl, "]\n    mov r14, [r15+8]\n    mov r13, [r15+16]\n"]
        let lcaps = cat ["    cmp r13, 0\n    je ", clbl, "\n", x86_load_closure_caps nargs 0 clbl]
        let rr = x86_reg_restore env
        let call = if tp then cat [rr, "    add rsp, ", fs, "\n    pop rbp\n    jmp r14\n"] else "    call r14\n"
        (cat [fn_asm, "    mov [rbp+", show clos_sl, "], rax\n", pa, pop, load_clos, lcaps, call], lc2 + 1, sl2)
    else
      x86_cg_bi fname args env ar lc sl tp fs
  else if tg == "F" then
    let (params, inner_body) = collect_lam_params node
    let free = fv_uniq (fvs inner_body params)
    let envns = env_names env
    let caps = fv_filter free envns
    let ncap = length caps
    let flbl = cat ["_x86_lambda_", show lc]
    let albl = cat [".Lx_after_lam_", show lc]
    let all_ps = append params caps
    let lam_env = mk_env all_ps 16
    let lam_first_sl = 16 + 8 * length all_ps
    let lam_final_sl = max_sl inner_body lam_first_sl
    let lam_raw_fs = if lam_final_sl < 48 then 48 else lam_final_sl
    let lam_frame_size = ((lam_raw_fs + 15) / 16) * 16
    let lam_fs = show lam_frame_size
    let (basm, lc1, _) = x86_cg inner_body lam_env ar (lc + 1) lam_first_sl true lam_fs
    let fasm = cat ["    jmp ", albl, "\n", flbl, ":\n    push rbp\n    sub rsp, ", lam_fs, "\n    mov rbp, rsp\n", x86_save_params all_ps 0, basm, "    add rsp, ", lam_fs, "\n    pop rbp\n    ret\n", albl, ":\n"]
    let pcaps = x86_push_captured caps env
    let casm = cat [pcaps, "    mov rdi, ", show (24 + ncap * 8), "\n    call _rail_alloc\n    mov qword ptr [rax], 4\n    lea rcx, [rip+", flbl, "]\n    mov [rax+8], rcx\n    mov qword ptr [rax+16], ", show ncap, "\n", x86_pop_to_closure ncap 0]
    (cat [fasm, casm], lc1, sl)
  else if tg == "M" then
    let scrut = head (tail node)
    let arms = head (tail (tail node))
    let end_lbl = cat [".Lx_match_end_", show lc]
    let (sa, lc1, sl1) = x86_cg scrut env ar (lc + 1) sl false fs
    let scrut_sl = sl1
    let (arms_asm, lc2, sl2) = x86_cg_arms arms scrut_sl env ar lc1 (scrut_sl + 8) end_lbl tp fs
    (cat [sa, "    mov [rbp+", show scrut_sl, "], rax\n", arms_asm, end_lbl, ":\n"], lc2, sl2)
  else (cat ["    ; unknown node: ", tg, "\n    xor rax, rax\n"], lc, sl)

x86_cg_arms arms scrut_sl env ar lc sl end_lbl tp fs =
  if length arms == 0 then ("    xor rax, rax\n", lc, sl)
  else
    let arm = head arms
    let ctor = head arm
    let binds = head (tail arm)
    let body = head (tail (tail arm))
    if ctor == "_" then
      let (ba, lc1, sl2) = x86_cg body env ar lc sl tp fs
      (ba, lc1, sl2)
    else if str_starts_with "#int:" ctor then
      let val = str_after "#int:" ctor
      let next_lbl = cat [".Lx_match_arm_", show lc]
      let tagged = str_to_int val * 2 + 1
      let check = cat ["    mov rcx, [rbp+", show scrut_sl, "]\n    cmp rcx, ", show tagged, "\n    jne ", next_lbl, "\n"]
      let (ba, lc1, sl2) = x86_cg body env ar (lc + 1) sl tp fs
      let (rest, lc2, sl3) = x86_cg_arms (tail arms) scrut_sl env ar lc1 sl end_lbl tp fs
      (cat [check, ba, "    jmp ", end_lbl, "\n", next_lbl, ":\n", rest], lc2, sl3)
    else if str_starts_with "#str:" ctor then
      let val = str_after "#str:" ctor
      let next_lbl = cat [".Lx_match_arm_", show lc]
      let slbl = cat [".Lx_mstr_", show lc]
      let albl = cat [".Lx_mstra_", show lc]
      let check = cat ["    jmp ", albl, "\n", slbl, ":\n    .asciz \"", esc_asm val, "\"\n    .p2align 3\n", albl, ":\n    mov rdi, [rbp+", show scrut_sl, "]\n    lea rsi, [rip+", slbl, "]\n    call _rail_eq\n    cmp rax, 1\n    je ", next_lbl, "\n"]
      let (ba, lc1, sl2) = x86_cg body env ar (lc + 1) sl tp fs
      let (rest, lc2, sl3) = x86_cg_arms (tail arms) scrut_sl env ar lc1 sl end_lbl tp fs
      (cat [check, ba, "    jmp ", end_lbl, "\n", next_lbl, ":\n", rest], lc2, sl3)
    else
    let (cidx, _) = decode_ctor (afind ctor ar)
    let is_last = length (tail arms) == 0
    if is_last then
      let (ext, env2, sl2) = x86_extract_adt_fields binds scrut_sl 0 sl env
      let (ba, lc1, sl3) = x86_cg body env2 ar lc sl2 tp fs
      (cat [ext, ba], lc1, sl3)
    else
      let next_lbl = cat [".Lx_match_arm_", show lc]
      let check = cat ["    mov rax, [rbp+", show scrut_sl, "]\n    mov rax, [rax+8]\n    cmp rax, ", show cidx, "\n    jne ", next_lbl, "\n"]
      let (ext, env2, sl2) = x86_extract_adt_fields binds scrut_sl 0 sl env
      let (ba, lc1, sl3) = x86_cg body env2 ar (lc + 1) sl2 tp fs
      let (rest, lc2, sl4) = x86_cg_arms (tail arms) scrut_sl env ar lc1 sl end_lbl tp fs
      (cat [check, ext, ba, "    jmp ", end_lbl, "\n", next_lbl, ":\n", rest], lc2, sl4)

-- x86_64 FUNCTION COMPILATION
x86_compile_func d ar lc =
  let nm = head (tail d)
  let ps = head (tail (tail d))
  let bd = head (tail (tail (tail d)))
  let save_args = if nm == "main" then cat ["    lea r10, [rip+_rail_argc]\n    lea rax, [rdi*2+1]\n    mov [r10], rax\n    lea r10, [rip+_rail_argv]\n    mov [r10], rsi\n"] else ""
  let use_regs = nm != "main" && length ps >= 1 && length ps <= 3 && all_params_int ps bd
  let nregs = if use_regs then length ps else 0
  let sv = if use_regs then x86_save_params_reg ps 0 else x86_save_params ps 0
  let env = if use_regs then mk_env_reg ps 16 0 else mk_env ps 16
  let env = if length ps <= 3 then mark_int_params ps bd env else env
  let env = cons ("__nregs", nregs) env
  let first_sl = 16 + 8 * length ps
  let is_tp = nm != "main"
  let final_sl = max_sl bd first_sl
  let raw_fs = if final_sl < 48 then 48 else final_sl
  let frame_size = ((raw_fs + 15) / 16) * 16
  let fs = show frame_size
  let base_int = if head bd == "?" then is_int (head (tail (tail bd))) env else false
  let env = if base_int then cons (cat ["__rt_", nm], 1) env else env
  let (body_asm, lc1, _) = x86_cg bd env ar lc first_sl is_tp fs
  let main_untag = if nm == "main" then "    sar rax, 1\n" else ""
  let restore = x86_gen_restore nregs
  let pro = cat ["_", nm, ":\n", save_args, "    push rbp\n    sub rsp, ", fs, "\n    mov rbp, rsp\n"]
  let epi = cat [main_untag, restore, "    add rsp, ", fs, "\n    pop rbp\n    ret\n\n"]
  (cat [pro, sv, body_asm, epi], lc1)

x86_compile_funcs decls ar lc =
  if length decls == 0 then ("", lc)
  else if head (head decls) == "TY" then x86_compile_funcs (tail decls) ar lc
  else if head (head decls) == "FN_EXT" then x86_compile_funcs (tail decls) ar lc
  else if head (head decls) == "LINK" then x86_compile_funcs (tail decls) ar lc
  else
    let (fasm, lc1) = x86_compile_func (head decls) ar lc
    let (rest, lc2) = x86_compile_funcs (tail decls) ar lc1
    (cat [fasm, rest], lc2)

x86_compile_checked_x86 decls =
  let decls = opt_decls decls
  let ar = get_arities decls
  let siblings = build_ctor_siblings decls
  let _ = check_exhaustiveness decls siblings
  let _ = tc_check_decls decls
  let hdr = ".intel_syntax noprefix\n.text\n.global main\n.global _main\n\n"
  let (funcs, _) = x86_compile_funcs decls ar 0
  -- Find x86_rt.s: try CWD/tools/ first, then binary dir/tools/
  let rt_cwd = read_file "tools/x86_rt.s"
  let rt = if length rt_cwd > 0 then rt_cwd
    else
      let bindir = trim (shell (cat ["dirname '", head args, "'"]))
      read_file (cat [bindir, "/tools/x86_rt.s"])
  cat [hdr, funcs, "\n", rt]

compile_x86 path =
  let src = read_file path
  let _ = print (cat ["Compiling ", path, " → x86_64 (", show (length src), " chars)..."])
  let (toks, positions) = tokenize_with_pos src
  let ntoks = length toks
  let decls = pprog toks
  let errs = ce_decls decls
  let nerrs = report_errors errs positions ntoks path
  if nerrs > 0 then
    let _ = print (cat [show nerrs, " error(s) found"])
    1
  else
    let asm = x86_compile_checked_x86 decls
    let _ = write_file "/tmp/rail_x86.s" asm
    let _ = print (cat ["  Assembly: /tmp/rail_x86.s (", show (length asm), " chars)"])
    -- Try local cross-assembler
    let local_as = trim (shell "which x86_64-elf-as 2>/dev/null || which x86_64-linux-gnu-as 2>/dev/null")
    if length local_as > 0 then
      let _ = print (cat ["  Assembler: ", local_as])
      let as_res = trim (shell (cat [local_as, " -o /tmp/rail_x86.o /tmp/rail_x86.s 2>&1"]))
      let _ = if length as_res > 0 then print (cat ["  as: ", as_res]) else print "  as: OK"
      let local_ld = trim (shell "which x86_64-elf-ld 2>/dev/null || which x86_64-linux-gnu-ld 2>/dev/null")
      let ld_res = trim (shell (cat [local_ld, " -o /tmp/rail_x86 /tmp/rail_x86.o -lc -dynamic-linker /lib64/ld-linux-x86-64.so.2 2>&1"]))
      let _ = if length ld_res > 0 then print (cat ["  ld: ", ld_res]) else print "  ld: OK"
      let _ = print "  Binary: /tmp/rail_x86"
      0
    else
      -- No local cross-tools — try building on Razer via scp
      let _ = print "  No local x86_64 assembler. scp to target and build with: gcc -o prog /tmp/rail_x86.s"
      let _ = print (cat ["  Try: scp /tmp/rail_x86.s Detro@100.109.63.37:~ && ssh Detro@100.109.63.37 'gcc -o rail_x86 rail_x86.s && ./rail_x86'"])
      0

main =
  let a = args
  if length a >= 2 then
    let cmd = head (tail a)
    if cmd == "test" then run_tests 0
    else if cmd == "self" then self_compile 0
    else if cmd == "generate" then
      if length a >= 3 then generate_code (join_args a 2)
      else let _ = print "Usage: rail generate \"description\""
      1
    else if cmd == "x86" then
      if length a >= 3 then compile_x86 (head (tail (tail a)))
      else let _ = print "Usage: rail x86 <file.rail>"
      1
    else if cmd == "linux" then
      if length a >= 3 then compile_linux (head (tail (tail a)))
      else let _ = print "Usage: rail linux <file.rail>"
      1
    else if cmd == "run" then
      if length a >= 3 then compile_and_run (head (tail (tail a))) (join_args a 3)
      else let _ = print "Usage: rail run <file.rail>"
      1
    else if cmd == "safe" then
      if length a >= 3 then dispatch_safe (head (tail (tail a)))
      else let _ = print "Usage: rail safe <file.rail>"
      1
    else if cmd == "wasm" then
      if length a >= 3 then dispatch_wasm (head (tail (tail a)))
      else let _ = print "Usage: rail wasm <file.rail>"
      1
    else if cmd == "get" then
      if length a >= 3 then dispatch_get (head (tail (tail a)))
      else let _ = print "Usage: rail get <package>"
      1
    else if cmd == "packages" then dispatch_packages 0
    else if cmd == "pkg" then dispatch_pkg 0
    else if cmd == "deploy" then dispatch_deploy a
    else compile_file cmd
  else
    let _ = run_tests 0
    self_compile 0

dispatch_deploy a =
  if length a >= 4 then
    let path = head (tail (tail a))
    let host = head (tail (tail (tail a)))
    let _ = print (cat ["=== Deploy ", path, " → ", host, " ==="])
    let src = read_file path
    let _ = print "  Cross-compiling for Linux ARM64..."
    let asm = compile_program src
    let _ = build_linux asm
    let _ = print "  Uploading..."
    let scp_res = trim (shell (cat ["scp -o ConnectTimeout=5 /tmp/rail_linux ", host, ":/tmp/rail_prog 2>&1"]))
    let _ = if length scp_res > 0 then print (cat ["  scp: ", scp_res]) else print "  scp: OK"
    let _ = print "  Running..."
    let out = shell (cat ["ssh -o ConnectTimeout=5 ", host, " 'chmod +x /tmp/rail_prog && /tmp/rail_prog' 2>&1"])
    let _ = if length out > 0 then print out else 0
    0
  else
    let _ = print "Usage: rail deploy <file.rail> <user@host>"
    1
