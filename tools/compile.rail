rt_list =
  let ralloc = "_rail_alloc:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x0, [x29, #16]\n    add x0, x0, #15\n    and x0, x0, #-8\n    adrp x1, _rail_heap_ptr@PAGE\n    add x1, x1, _rail_heap_ptr@PAGEOFF\n    ldr x2, [x1]\n    add x3, x2, x0\n    adrp x4, _rail_heap_end@PAGE\n    ldr x4, [x4, _rail_heap_end@PAGEOFF]\n    cmp x3, x4\n    b.hi .Lalloc_slow\n    str x3, [x1]\n    ldr x5, [x29, #16]\n    str x5, [x2]\n    add x0, x2, #8\n    ldp x29, x30, [sp], #32\n    ret\n.Lalloc_slow:\n    ldr x0, [x29, #16]\n    bl _rail_free_list_alloc\n    cbnz x0, .Lalloc_done\n    bl _rail_gc\n    ldr x0, [x29, #16]\n    bl _rail_free_list_alloc\n    cbnz x0, .Lalloc_done\n    ldr x0, [x29, #16]\n    add x0, x0, #7\n    and x0, x0, #-8\n    bl _malloc\n.Lalloc_done:\n    ldp x29, x30, [sp], #32\n    ret\n\n"
  let rcons = "_rail_cons:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x0, [x29, #16]\n    str x1, [x29, #24]\n    mov x0, #24\n    bl _rail_alloc\n    mov x1, #1\n    str x1, [x0]\n    ldr x1, [x29, #16]\n    str x1, [x0, #8]\n    ldr x1, [x29, #24]\n    str x1, [x0, #16]\n    ldp x29, x30, [sp], #32\n    ret\n\n"
  -- Guarded head: safe for nil (returns 0), safe for int/non-list (graceful)
  let rhead = "_rail_head:\n    tst x0, #1\n    b.ne .Lhd_int\n    ldr x1, [x0]\n    cmp x1, #2\n    b.eq .Lhd_int\n    ldr x0, [x0, #8]\n    ret\n.Lhd_int:\n    mov x0, #1\n    ret\n\n"
