rt_arith =
  let rsub = "_rail_sub:\n    tst x1, #1\n    b.eq .Lsub_float\n    asr x1, x1, #1\n    asr x0, x0, #1\n    sub x0, x1, x0\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n.Lsub_float:\n    stp x29, x30, [sp, #-16]!\n    mov x29, sp\n    ldr d0, [x1, #8]\n    ldr d1, [x0, #8]\n    fsub d0, d0, d1\n    mov x0, #16\n    bl _rail_alloc\n    mov x1, #6\n    str x1, [x0]\n    str d0, [x0, #8]\n    ldp x29, x30, [sp], #16\n    ret\n\n"
