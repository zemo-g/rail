  let rappend = "_rail_append:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x0, [x29, #16]\n    str x1, [x29, #24]\n    tst x0, #1\n    b.ne .Lapp_ret2\n    ldr x2, [x0]\n    cmp x2, #2\n    b.eq .Lapp_ret2\n    cmp x2, #1\n    b.eq .Lapp_list\n    bl _rail_str_append\n    ldp x29, x30, [sp], #32\n    ret\n.Lapp_ret2:\n    ldr x0, [x29, #24]\n    ldp x29, x30, [sp], #32\n    ret\n.Lapp_list:\n    ldr x0, [x29, #16]\n    ldr x1, [x0, #8]\n    str x1, [sp, #-16]!\n    ldr x0, [x0, #16]\n    ldr x1, [x29, #24]\n    bl _rail_append\n    mov x1, x0\n    ldr x0, [sp], #16\n    bl _rail_cons\n    ldp x29, x30, [sp], #32\n    ret\n\n"
