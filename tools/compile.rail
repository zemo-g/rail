   mov x0, #1\n    ldr x1, [x29, #24]\n    movz x16, #4\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    mov w0, #10\n    strb w0, [x29, #32]\n    mov x0, #1\n    add x1, x29, #32\n    mov x2, #1\n    movz x16, #4\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    ldr x0, [x29, #24]\n    bl _free\n.Lprnt_done:\n    mov x0, #1\n    ldp x29, x30, [sp], #64\n    ret\n\n"
  let rshow = "_rail_show:\n    stp x29, x30, [sp, #-16]!\n    mov x29, sp\n    bl _rail_show_inner\n    bl _rail_wrap_str\n    ldp x29, x30, [sp], #16\n    ret\n\n_rail_show_inner:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    tst x0, #1\n    b.eq .Lshow_heap\n    asr x0, x0, #1\n    str x0, [x29, #16]\n    mov x0, #24\n    bl _malloc\n    str x0, [x29, #24]\n    ldr x0, [x29, #16]\n    ldr x1, [x29, #24]\n    mov x6, #0\n    cmp x0, #0\n    b.ge .Lsi_pos\n    neg x0, x0\n    mov w7, #45\n    strb w7, [x1, x6]\n    add x6, x6, #1\n.Lsi_pos:\n    str x6, [x29, #16]\n    mov x2, #0\n    mov x3, #10\n.Lsi_div:\n    udiv x4, x0, x3\n    msub x5, x4, x3, x0\n    add x5, x5, #48\n    str x5, [sp, #-16]!\n    add x2, x2, #1\n    mov x0, x4\n    cbnz x0, .Lsi_div\n    cbz x2, .Lsi_zero\n    ldr x6, [x29, #16]\n    ldr x1, [x29, #24]\n.Lsi_rev:\n    ldr x5, [sp], #16\n    strb w5, [x1, x6]\n    add x6, x6, #1\n    sub x2, x2, #1\n    cbnz x2, .Lsi_rev\n    mov w5, #0\n    strb w5, [x1, x6]\n    ldr x0, [x29, #24]\n    ldp x29, x30, [sp], #32\n    ret\n.Lsi_zero:\n    ldr x6, [x29, #16]\n    ldr x1, [x29, #24]\n    mov w0, #48\n    strb w0, [x1, x6]\n    add x6, x6, #1\n    mov w0, #0\n    strb w0, [x1, x6]\n    ldr x0, [x29, #24]\n    ldp x29, x30, [sp], #32\n    ret\n.Lshow_heap:\n    ldr x1, [x0]\n    cmp x1, #6\n    b.eq .Lshow_float\n    cmp x1, #2\n    b.eq .Lshow_nil\n    cmp x1, #1\n    b.eq .Lshow_list\n    ldp x29, x30, [sp], #32\n    ret\n.Lshow_nil:\n    mov x0, #4\n    bl _malloc\n    mov w1, #91\n    strb w1, [x0]\n    mov w1, #93\n    strb w1, [x0, #1]\n    mov w1, #0\n    strb w1, [x0, #2]\n    ldp x29, x30, [sp], #32\n    ret\n.Lshow_list:\n    bl _rail_show_list\n    ldp x29, x30, [sp], #32\n    ret\n.Lshow_float:\n    ldr d0, [x0, #8]\n    str d0, [x29, #24]\n    mov x0, #32\n    bl _malloc\n    str x0, [x29, #16]\n    ldr d0, [x29, #24]\n    str d0, [sp, #-16]!\n    ldr x0, [x29, #16]\n    mov x1, #32\n    adrp x2, _fmt_gbare@PAGE\n    add x2, x2, _fmt_gbare@PAGEOFF\n    bl _snprintf\n    add sp, sp, #16\n    ldr x0, [x29, #16]\n    ldp x29, x30, [sp], #32\n    ret\n\n_rail_show_list:\n    stp x29, x30, [sp, #-64]!\n    mov x29, sp\n    str x0, [x29, #16]\n    mov x0, #4\n    bl _malloc\n    mov w1, #91\n    strb w1, [x0]\n    mov w1, #0\n    strb w1, [x0, #1]\n    str x0, [x29, #24]\n    mov x0, #4\n    bl _malloc\n    mov w1, #44\n    strb w1, [x0]\n    mov w1, #32\n    strb w1, [x0, #1]\n    mov w1, #0\n    strb w1, [x0, #2]\n    str x0, [x29, #32]\n    mov x0, #4\n    bl _malloc\n    mov w1, #93\n    strb w1, [x0]\n    mov w1, #0\n    strb w1, [x0, #1]\n    str x0, [x29, #40]\n    mov x0, #1\n    str x0, [x29, #48]\n.Lshowl_loop:\n    ldr x0, [x29, #16]\n    tst x0, #1\n    b.ne .Lshowl_done\n    ldr x1, [x0]\n    cmp x1, #2\n    b.eq .Lshowl_done\n    cmp x1, #1\n    b.ne .Lshowl_done\n    ldr x0, [x29, #48]\n    cbnz x0, .Lshowl_skip_sep\n    ldr x0, [x29, #24]\n    ldr x1, [x29, #32]\n    bl _rail_str_append\n    str x0, [x29, #24]\n.Lshowl_skip_sep:\n    str xzr, [x29, #48]\n    ldr x0, [x29, #16]\n    ldr x0, [x0, #8]\n    bl _rail_show\n    mov x1, x0\n    ldr x0, [x29, #24]\n    bl _rail_str_append\n    str x0, [x29, #24]\n    ldr x0, [x29, #16]\n    ldr x0, [x0, #16]\n    str x0, [x29, #16]\n    b .Lshowl_loop\n.Lshowl_done:\n    ldr x0, [x29, #24]\n    ldr x1, [x29, #40]\n    bl _rail_str_append\n    ldp x29, x30, [sp], #64\n    ret\n\n"
