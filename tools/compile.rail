  let rdiv = "_rail_div:\n    tst x1, #1\n    b.eq .Ldiv_float\n    asr x1, x1, #1\n    asr x0, x0, #1\n    sdiv x0, x1, x0\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n.Ldiv_float:\n    stp x29, x30, [sp, #-16]!\n    mov x29, sp\n    ldr d0, [x1, #8]\n    ldr d1, [x0, #8]\n    fdiv d0, d0, d1\n    mov x0, #16\n    bl _rail_alloc\n    mov x1, #6\n    str x1, [x0]\n    str d0, [x0, #8]\n    ldp x29, x30, [sp], #16\n    ret\n\n"
  let rmod = "_rail_mod:\n    asr x1, x1, #1\n    asr x0, x0, #1\n    sdiv x2, x1, x0\n    msub x0, x2, x0, x1\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n\n"
  let rlt = "_rail_lt:\n    tst x1, #1\n    b.eq .Llt_float\n    cmp x1, x0\n    cset x0, lt\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n.Llt_float:\n    ldr d0, [x1, #8]\n    ldr d1, [x0, #8]\n    fcmp d0, d1\n    cset x0, lo\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n\n"
  let rgt = "_rail_gt:\n    tst x1, #1\n    b.eq .Lgt_float\n    cmp x1, x0\n    cset x0, gt\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n.Lgt_float:\n    ldr d0, [x1, #8]\n    ldr d1, [x0, #8]\n    fcmp d0, d1\n    cset x0, gt\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n\n"
  let rle = "_rail_le:\n    tst x1, #1\n    b.eq .Lle_float\n    cmp x1, x0\n    cset x0, le\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n.Lle_float:\n    ldr d0, [x1, #8]\n    ldr d1, [x0, #8]\n    fcmp d0, d1\n    cset x0, ls\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n\n"
  let rge = "_rail_ge:\n    tst x1, #1\n    b.eq .Lge_float\n    cmp x1, x0\n    cset x0, ge\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n.Lge_float:\n    ldr d0, [x1, #8]\n    ldr d1, [x0, #8]\n    fcmp d0, d1\n    cset x0, ge\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n\n"
  -- rc_alloc: allocate refcounted object. x0 = size (tagged). Returns ptr to data (refcount at ptr-8)
  let rrcalloc = "_rail_rc_alloc:\n    stp x29, x30, [sp, #-16]!\n    mov x29, sp\n    asr x0, x0, #1\n    add x0, x0, #8\n    bl _malloc\n    mov x1, #1\n    str x1, [x0]\n    add x0, x0, #8\n    ldp x29, x30, [sp], #16\n    ret\n\n"
  -- rc_release: decrement refcount, free if zero
  let rrcrelease = "_rail_rc_release:\n    stp x29, x30, [sp, #-16]!\n    mov x29, sp\n    ldr x1, [x0, #-8]\n    sub x1, x1, #1\n    str x1, [x0, #-8]\n    cbnz x1, .Lrc_keep\n    sub x0, x0, #8\n    bl _free\n.Lrc_keep:\n    ldp x29, x30, [sp], #16\n    ret\n\n"
  cat [rsub, rmul, rdiv, rmod, rlt, rgt, rle, rge, rrcalloc, rrcrelease]

-- Async fiber runtime (true stack-switching)
-- Fiber struct: [state(8), sp(8), closure(8), result(8)] = 32 bytes
-- States: 0=pending, 2=done
-- spawn saves closure + allocates private stack
-- await: saves main context, switches to fiber stack, runs closure, switches back
rt_fiber =
  let rspawn = "_rail_spawn:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x0, [x29, #16]\n    mov x0, #32\n    bl _rail_alloc\n    str x0, [x29, #24]\n    str xzr, [x0]\n    ldr x1, [x29, #16]\n    str x1, [x0, #16]\n    str xzr, [x0, #24]\n    movz x0, #1, lsl #16\n    bl _rail_alloc\n    add x0, x0, #16, lsl #12\n    and x0, x0, #-16\n    ldr x1, [x29, #24]\n    str x0, [x1, #8]\n    ldr x0, [x29, #24]\n    ldp x29, x30, [sp], #32\n    ret\n\n"
  let rawait = "_rail_await:\n    stp x29, x30, [sp, #-16]!\n    mov x29, sp\n    mov x20, x0\n    stp x19, x20, [sp, #-16]!\n    stp x21, x22, [sp, #-16]!\n    stp x23, x24, [sp, #-16]!\n    stp x25, x26, [sp, #-16]!\n    stp x27, x28, [sp, #-16]!\n    mov x19, sp\n    ldr x4, [x20, #8]\n    mov sp, x4\n    ldr x0, [x20, #16]\n    ldr x5, [x0, #8]\n    ldr x3, [x0, #16]\n    mov x0, #1\n    cmp x3, #0\n    b.eq .Lawait_call\n    ldr x1, [x0, #24]\n.Lawait_call:\n    blr x5\n    str x0, [x20, #24]\n    mov x1, #2\n    str x1, [x20]\n    mov sp, x19\n    ldp x27, x28, [sp], #16\n    ldp x25, x26, [sp], #16\n    ldp x23, x24, [sp], #16\n    ldp x21, x22, [sp], #16\n    ldp x19, x20, [sp], #16\n    ldr x0, [x20, #24]\n    ldp x29, x30, [sp], #16\n    ret\n\n"
  let ryield = "_rail_yield:\n    ret\n\n"
  let rinit = "_rail_fiber_init:\n    ret\n\n"
  -- Channel: a cons cell where head = list of values. send appends, recv takes head.
  let rchansend = "_rail_chan_send:\n    stp x29, x30, [sp, #-48]!\n    mov x29, sp\n    str x0, [x29, #16]\n    str x1, [x29, #24]\n    ldr x0, [x0, #8]\n    str x0, [x29, #32]\n    ldr x0, [x29, #24]\n    adrp x1, _rail_nil@PAGE\n    add x1, x1, _rail_nil@PAGEOFF\n    bl _rail_cons\n    mov x1, x0\n    ldr x0, [x29, #32]\n    bl _rail_append\n    ldr x1, [x29, #16]\n    str x0, [x1, #8]\n    mov x0, #1\n    ldp x29, x30, [sp], #48\n    ret\n\n"
  let rchanrecv = "_rail_chan_recv:\n    stp x29, x30, [sp, #-16]!\n    mov x29, sp\n    ldr x1, [x0, #8]\n    ldr x2, [x1]\n    cmp x2, #2\n    b.eq .Lrecv_empty\n    ldr x3, [x1, #8]\n    ldr x4, [x1, #16]\n    str x4, [x0, #8]\n    mov x0, x3\n    ldp x29, x30, [sp], #16\n    ret\n.Lrecv_empty:\n    mov x0, #1\n    ldp x29, x30, [sp], #16\n    ret\n\n"
  cat [rspawn, rawait, ryield, rinit, rchansend, rchanrecv]

-- GPU map runtime: write Metal source, compile, run gpu_host, parse output to Rail list
-- x0 = Metal kernel source string, x1 = data list
rt_gpu =
  let rgpumap = "_rail_gpu_map:\n    stp x29, x30, [sp, #-64]!\n    mov x29, sp\n    str x0, [x29, #16]\n    str x1, [x29, #24]\n    mov x0, x1\n    bl _rail_length\n    str x0, [x29, #32]\n    b .Lgm_ap\n.Lgm_mp:\n    .asciz \"/tmp/rail_gpu.metal\"\n    .p2align 2\n.Lgm_ap:\n    adr x0, .Lgm_mp\n    ldr x1, [x29, #16]\n    bl _rail_write_file\n    b .Lgm_ac\n.Lgm_cc:\n    .asciz \"xcrun metal -c /tmp/rail_gpu.metal -o /tmp/rail_gpu.air 2>/dev/null && xcrun metallib /tmp/rail_gpu.air -o /tmp/rail_gpu.metallib 2>/dev/null\"\n    .p2align 2\n.Lgm_ac:\n    adr x0, .Lgm_cc\n    bl _rail_shell\n    ldr x0, [x29, #32]\n    bl _rail_show\n    str x0, [x29, #40]\n    b .Lgm_ahp\n.Lgm_hp:\n    .asciz \"/tmp/gpu_host /tmp/rail_gpu.metallib rail_kernel \"\n    .p2align 2\n.Lgm_ahp:\n    adr x0, .Lgm_hp\n    ldr x1, [x29, #40]\n    bl _rail_str_append\n    bl _rail_shell\n    str x0, [x29, #48]\n    b .Lgm_arf\n.Lgm_rf:\n    .asciz \"/tmp/rail_gpu_out.csv\"\n    .p2align 2\n.Lgm_arf:\n    adr x0, .Lgm_rf\n    bl _rail_read_file\n    str x0, [x29, #48]\n    b .Lgm_acm\n.Lgm_cm:\n    .asciz \",\"\n    .p2align 2\n.Lgm_acm:\n    adr x0, .Lgm_cm\n    ldr x1, [x29, #48]\n    bl _rail_split\n    bl _rail_parse_int_list\n    ldp x29, x30, [sp], #64\n    ret\n\n"
  let rparselist = "_rail_parse_int_list:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x0, [x29, #16]\n    ldr x1, [x0]\n    cmp x1, #2\n    b.eq .Lpil_nil\n    ldr x1, [x0, #8]\n    str x1, [x29, #24]\n    ldr x0, [x0, #16]\n    bl _rail_parse_int_list\n    str x0, [sp, #-16]!\n    ldr x0, [x29, #24]\n    bl _atoi\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ldr x1, [sp], #16\n    bl _rail_cons\n    ldp x29, x30, [sp], #32\n    ret\n.Lpil_nil:\n    adrp x0, _rail_nil@PAGE\n    add x0, x0, _rail_nil@PAGEOFF\n    ldp x29, x30, [sp], #32\n    ret\n\n"
  cat [rgpumap, rparselist]

runtime_asm = cat [rt_core, rt_list, rt_closure, rt_io, rt_args, rt_arith, rt_fiber, rt_gpu]

-- ══════════════════════════════════════════════════════════════════════════════
-- OPTIMIZATION PASSES
-- ══════════════════════════════════════════════════════════════════════════════

-- Check if AST node is (map f data): returns (true, f, data) or (false, [], [])
is_map_app node =
  if head node != "A" then (false, [], [])
  else
    let fp = head (tail node)
    if head fp != "A" then (false, [], [])
    else
      let iv = head (tail fp)
      if head iv != "V" then (false, [], [])
      else if head (tail iv) != "map" then (false, [], [])
      else (true, head (tail (tail fp)), head (tail (tail node)))

-- Optimize expression: map fusion (map f (map g data) → single map)
opt node =
  let tg = head node
  if tg == "I" || tg == "FL" || tg == "NULL" || tg == "B" || tg == "S" || tg == "V" || tg == "E" then node
  else if tg == "O" then ["O", head (tail node), opt (head (tail (tail node))), opt (head (tail (tail (tail node))))]
  else if tg == "?" then ["?", opt (head (tail node)), opt (head (tail (tail node))), opt (head (tail (tail (tail node))))]
  else if tg == "D" then ["D", head (tail node), opt (head (tail (tail node))), opt (head (tail (tail (tail node))))]
  else if tg == "TD" then ["TD", head (tail node), opt (head (tail (tail node))), opt (head (tail (tail (tail node))))]
  else opt2 node tg

opt2 node tg =
  if tg == "F" then ["F", head (tail node), opt (head (tail (tail node)))]
  else if tg == "L" then ["L", opt_l (head (tail node))]
  else if tg == "T" then ["T", opt_l (head (tail node))]
  else if tg == "M" then ["M", opt (head (tail node)), opt_ms (head (tail (tail node)))]
  else if tg == "A" then
    let onode = ["A", opt (head (tail node)), opt (head (tail (tail node)))]
    let (im, f, inner) = is_map_app onode
    if im then
      let (im2, g, d) = is_map_app inner
      if im2 then opt ["A", ["A", ["V", "map"], ["F", "_fx", ["A", f, ["A", g, ["V", "_fx"]]]]], d]
      else if head f == "F" then
        let fparam = head (tail f)
        let fbody = head (tail (tail f))
        if is_gpu_safe fbody fparam then
          if head inner != "V" then
            ["D", "_gd", inner, ["?", ["O", ">=", ["A", ["V", "length"], ["V", "_gd"]], ["I", "50000"]], ["A", ["A", ["V", "gpu_map"], f], ["V", "_gd"]], ["A", ["A", ["V", "map"], f], ["V", "_gd"]]]]
          else onode
        else onode
      else onode
    else onode
  else node

opt_l lst = if length lst == 0 then [] else cons (opt (head lst)) (opt_l (tail lst))

opt_ms arms =
  if length arms == 0 then []
  else
    let arm = head arms
    let g = if length arm > 3 then head (tail (tail (tail arm))) else []
    cons [head arm, head (tail arm), opt (head (tail (tail arm))), if length g == 0 then [] else opt g] (opt_ms (tail arms))

opt_decls decls =
  if length decls == 0 then []
  else
    let d = head decls
    if head d == "fn" then
      cons ["fn", head (tail d), head (tail (tail d)), opt (head (tail (tail (tail d))))] (opt_decls (tail decls))
    else cons d (opt_decls (tail decls))

-- ══════════════════════════════════════════════════════════════════════════════
-- GPU AUTO-DISPATCH
-- ══════════════════════════════════════════════════════════════════════════════

-- Check if AST is GPU-safe: pure arithmetic on param + int literals only
is_gpu_safe node param =
  let tg = head node
  if tg == "I" then true
  else if tg == "V" then head (tail node) == param
  else if tg == "O" then
    let op = head (tail node)
    if op == "+" || op == "-" || op == "*" || op == "/" || op == "%" then
      if is_gpu_safe (head (tail (tail node))) param then
        is_gpu_safe (head (tail (tail (tail node)))) param
      else false
    else false
  else false

-- Convert AST to Metal Shading Language expression
ast_to_metal node param =
  let tg = head node
  if tg == "I" then head (tail node)
  else if tg == "V" then "x"
  else if tg == "O" then
    let op = head (tail node)
    let left = ast_to_metal (head (tail (tail node))) param
    let right = ast_to_metal (head (tail (tail (tail node)))) param
    cat ["(", left, " ", op, " ", right, ")"]
  else "0"

-- Generate complete Metal compute kernel source
gen_metal_kernel body_expr =
  cat ["#include <metal_stdlib>\nusing namespace metal;\nkernel void rail_kernel(device int *data [[buffer(0)]], uint id [[thread_position_in_grid]]) {\n    int x = data[id];\n    data[id] = ", body_expr, ";\n}\n"]

-- Exhaustiveness checking for match expressions
-- Build map: ctor_name → [all ctor names in same type]
build_ctor_siblings decls =
  if length decls == 0 then []
  else
    let d = head decls
    if head d == "TY" then
      let variants = head (tail (tail d))
      let names = get_ctor_names variants
      append (tag_siblings variants names) (build_ctor_siblings (tail decls))
    else build_ctor_siblings (tail decls)

get_ctor_names variants =
  if length variants == 0 then []
  else cons (head (head variants)) (get_ctor_names (tail variants))

tag_siblings variants names =
  if length variants == 0 then []
  else cons (head (head variants), names) (tag_siblings (tail variants) names)

-- Check if a list contains a string
str_in item lst =
  if length lst == 0 then false
  else if head lst == item then true
  else str_in item (tail lst)

-- Find missing constructors from arms
find_missing all_ctors arm_ctors =
  if length all_ctors == 0 then []
  else
    let c = head all_ctors
    if str_in c arm_ctors then find_missing (tail all_ctors) arm_ctors
    else cons c (find_missing (tail all_ctors) arm_ctors)

-- Extract constructor names from match arms
arm_ctors arms =
  if length arms == 0 then []
  else
    let ctor = head (head arms)
    cons ctor (arm_ctors (tail arms))

-- Safe sibling lookup (returns [] on not found, avoids afind's -1 vs list issue)
find_sibs ctor siblings =
  if length siblings == 0 then []
  else
    let (k, v) = head siblings
    if k == ctor then v
    else find_sibs ctor (tail siblings)

-- Check a single match expression for exhaustiveness
check_match_exhaustive arms siblings =
  let ctors = arm_ctors arms
  if str_in "_" ctors then 0
  else if length ctors == 0 then 0
  else
    let first = head ctors
    let sibs = find_sibs first siblings
    if length sibs == 0 then 0
    else
      let missing = find_missing sibs ctors
      if length missing == 0 then 0
      else
        let _ = print (cat ["  WARNING: non-exhaustive match — missing: ", join ", " missing])
        0

-- Walk AST node looking for match expressions
check_node node siblings =
  let tg = head node
  if tg == "M" then
    let arms = head (tail (tail node))
    let _ = check_match_exhaustive arms siblings
    let _ = check_node (head (tail node)) siblings
    check_arms_nodes arms siblings
  else if tg == "A" then
    let _ = check_node (head (tail node)) siblings
    check_node (head (tail (tail node))) siblings
  else if tg == "O" then
    let _ = check_node (head (tail (tail node))) siblings
    check_node (head (tail (tail (tail node)))) siblings
  else if tg == "?" then
    let _ = check_node (head (tail node)) siblings
    let _ = check_node (head (tail (tail node))) siblings
    check_node (head (tail (tail (tail node)))) siblings
  else if tg == "D" then
    let _ = check_node (head (tail (tail node))) siblings
    check_node (head (tail (tail (tail node)))) siblings
  else if tg == "F" then
    check_node (head (tail (tail node))) siblings
  else 0

check_arms_nodes arms siblings =
  if length arms == 0 then 0
  else
    let body = head (tail (tail (head arms)))
    let _ = check_node body siblings
    check_arms_nodes (tail arms) siblings

-- Check all function bodies
check_exhaustiveness decls siblings =
  if length decls == 0 then 0
  else
    let d = head decls
    if head d == "fn" then
      let nm = head (tail d)
      let body = head (tail (tail (tail d)))
      let _ = check_node body siblings
      check_exhaustiveness (tail decls) siblings
    else check_exhaustiveness (tail decls) siblings

-- Compile full program to assembly text
compile_program src =
  let toks = tokenize src
  let decls = pprog toks
  let decls = opt_decls decls
  let ar = get_arities decls
  let siblings = build_ctor_siblings decls
  let _ = check_exhaustiveness decls siblings
  let hdr = ".section __TEXT,__text\n.global _main\n.p2align 2\n\n"
  let (funcs, _) = compile_funcs decls ar 0
  let rt = runtime_asm
  -- Data section: format strings for printf/snprintf
  -- _fmt_int: "%ld\n"  _fmt_str: "%s\n"  _fmt_ld: "%ld"
  let data = "\n.section __DATA,__data\n_fmt_int:\n    .byte 37, 108, 100, 10, 0\n_fmt_str:\n    .byte 37, 115, 10, 0\n_fmt_ld:\n    .byte 37, 108, 100, 0\n_fmt_g:\n    .asciz \"%g\\n\"\n_fmt_gbare:\n    .asciz \"%.15g\"\n.p2align 3\n_rail_empty_str:\n    .byte 0\n_mode_w:\n    .asciz \"w\"\n_mode_r:\n    .asciz \"r\"\n.p2align 3\n_rail_nil:\n    .quad 2\n.p2align 3\n.global _rail_heap_ptr\n_rail_heap_ptr:\n    .quad _rail_heap\n.p2align 3\n.global _rail_heap_end\n_rail_heap_end:\n    .quad _rail_heap + 1073741824\n.p2align 3\n_rail_argc:\n    .quad 0\n_rail_argv:\n    .quad 0\n.global _rail_heap\n.zerofill __DATA,__bss,_rail_heap,1073741824,3\n"
  cat [hdr, funcs, rt, data]

-- ══════════════════════════════════════════════════════════════════════════════
-- BUILD: assemble + link
-- ══════════════════════════════════════════════════════════════════════════════

-- Find runtime dir: try dirname of argv[0], fall back to ./runtime
get_runtime_dir _ =
  let bindir = trim (shell (cat ["dirname '", head args, "'"]))
  let probe = trim (shell (cat ["test -f '", bindir, "/runtime/gc.o' && echo '", bindir, "/runtime' || echo runtime"]))
  probe

build asm_text =
  let _ = write_file "/tmp/rail_out.s" asm_text
  let sdk = trim (shell "xcrun --show-sdk-path")
  let rtdir = get_runtime_dir 0
  let as_result = trim (shell "as -o /tmp/rail_out.o /tmp/rail_out.s 2>&1")
  let _ = if as_result != "" then print (cat ["  as: ", as_result]) else print "  as: OK"
  let ld_cmd = cat ["ld -o /tmp/rail_out /tmp/rail_out.o ", rtdir, "/llm.o ", rtdir, "/gc.o -lSystem -syslibroot ", sdk, " -arch arm64 2>&1"]
  let ld_result = trim (shell ld_cmd)
  let _ = if ld_result != "" then print (cat ["  ld: ", ld_result]) else print "  ld: OK"
  let _ = shell "codesign -s - /tmp/rail_out 2>&1"
  0

trim s = head (split "\n" s)

-- ══════════════════════════════════════════════════════════════════════════════
-- TESTS
-- ══════════════════════════════════════════════════════════════════════════════

run_test name src expected =
  let _ = print (cat ["  --- ", name, " ---"])
  let asm = compile_program src
  let _ = build asm
  let output = trim (shell "/tmp/rail_out 2>&1 ; echo $?")
  let lines = split "\n" output
  -- Get the last line (exit code) and everything before it (stdout)
  let result = get_test_result lines expected
  result

-- Parse test output: stdout lines + exit code
get_test_result lines expected =
  let exit_code = last_elem lines
  let stdout_lines = init_list lines
  let stdout = join "\n" stdout_lines
  let actual = if length stdout_lines > 0 then stdout else exit_code
  let pass = actual == expected
  let _ = if pass then print (cat ["  PASS: ", actual]) else print (cat ["  FAIL: got [", actual, "] expected [", expected, "]"])
  pass

last_elem lst =
  if length lst == 1 then head lst
  else last_elem (tail lst)

init_list lst =
  if length lst <= 1 then []
  else cons (head lst) (init_list (tail lst))

-- args stub: returns [] under Rust interpreter, overridden by _rail_args in native binary
args = []

-- Compile a file to native binary
compile_file path =
  let src = read_file path
  let _ = print (cat ["Compiling ", path, " (", show (length src), " chars)..."])
  let asm = compile_program src
  let _ = build asm
  0

-- Test suite
run_tests _ =
  let _ = print "=== Rail ARM64 Compiler ==="
  let _ = print ""
  let t1 = run_test "main=42" "main = 42" "42"
  let t2 = run_test "3+4" "main = 3 + 4" "7"
  let t3 = run_test "if" "main = if 1 == 1 then 42 else 0" "42"
  let t4 = run_test "double" "double x = x * 2\nmain = double 21" "42"
  let t5 = run_test "fact" "fact n =\n  if n <= 1 then 1\n  else n * fact (n - 1)\nmain = fact 5" "120"
  let t6 = run_test "print" "main =\n  let _ = print 42\n  0" "42"
  let t7 = run_test "add" "add x y = x + y\nmain = add 17 25" "42"
  let t8 = run_test "lets" "main =\n  let a = 7\n  let b = a * a\n  b - 1" "48"
  let t9 = run_test "strprint" "main =\n  let _ = print \"hello\"\n  0" "hello"
  let t10 = run_test "streq" "main = if \"ab\" == \"ab\" then 1 else 0" "1"
  let t11 = run_test "strne" "main = if \"ab\" == \"cd\" then 1 else 0" "0"
  let t12 = run_test "show" "main =\n  let _ = print (show 42)\n  0" "42"
  let t13 = run_test "append" "main =\n  let _ = print (append \"hel\" \"lo\")\n  0" "hello"
  let t14 = run_test "str+" "main =\n  let _ = print (\"foo\" + \"bar\")\n  0" "foobar"
  let t15 = run_test "listlen" "main = length [10, 20, 30]" "3"
  let t16 = run_test "headtail" "main = head (tail [10, 20, 30])" "20"
  let t17 = run_test "cons" "main = head (cons 42 [1, 2])" "42"
  let t18 = run_test "listapp" "main = length (append [1, 2] [3, 4, 5])" "5"
  let t19 = run_test "empty" "main = length []" "0"
  let t20 = run_test "strlen" "main = length \"hello\"" "5"
  let t21 = run_test "mapfn" "double x = x * 2\nmain = head (map double [3, 5, 7])" "6"
  let t22 = run_test "maplam" "main = head (map (\\x -> x + 10) [5, 6, 7])" "15"
  let t23 = run_test "closure" "main =\n  let n = 100\n  head (map (\\x -> x + n) [1, 2, 3])" "101"
  let t24 = run_test "join" "main =\n  let _ = print (join \"-\" [\"a\", \"b\", \"c\"])\n  0" "a-b-c"
  let t25 = run_test "tuple" "main =\n  let (a, b) = (10, 32)\n  a + b" "42"
  let t26 = run_test "tupret" "swap a b = (b, a)\nmain =\n  let (x, y) = swap 1 2\n  x * 10 + y" "21"
  let t27 = run_test "tup3" "main =\n  let (a, b, c) = (100, 20, 3)\n  a + b + c" "123"
  let t28 = run_test "chars" "main =\n  let cs = chars \"abc\"\n  let _ = print (head cs)\n  length cs" "a"
  let t29 = run_test "split" "main =\n  let _ = print (head (tail (split \",\" \"a,b,c\")))\n  0" "b"
  let t30 = run_test "fileio" "main =\n  let _ = write_file \"/tmp/rail_test.txt\" \"hello42\"\n  let s = read_file \"/tmp/rail_test.txt\"\n  let _ = print s\n  0" "hello42"
  let t31 = run_test "shell" "main =\n  let _ = print (head (split \"\\n\" (shell \"echo hi\")))\n  0" "hi"
  let t32 = run_test "integ" "cat parts = join \"\" parts\ndbl x = x * 2\nmain =\n  let xs = map dbl [3, 5, 7]\n  let (a, b) = (head xs, length xs)\n  let _ = print (cat [\"sum=\", show (a + b)])\n  0" "sum=9"
  let t33 = run_test "tco" "loop n = if n == 0 then 42 else loop (n - 1)\nmain =\n  let _ = print (show (loop 50000))\n  0" "42"
  let t34 = run_test "bigint" "main =\n  let x = 100000\n  x - 99958" "42"
  let t35 = run_test "adt_none" "type Option = | Some x | None\nmain = match None | Some x -> x | None -> 42" "42"
  let t36 = run_test "adt_some" "type Option = | Some x | None\nmain = match (Some 42) | Some x -> x | None -> 0" "42"
  let t37 = run_test "adt_pair" "type Pair = | MkPair a b\nfst p = match p | MkPair a b -> a\nmain = fst (MkPair 10 32)" "10"
  let t38 = run_test "neg" "main =\n  let _ = print (show (-42))\n  0" "-42"
  let t39 = run_test "escape" "main =\n  let _ = print \"\\{hello\\}\"\n  0" "{hello}"
  let t40 = run_test "float" "main =\n  let _ = print (show (1.5 + 2.25))\n  0" "3.75"
  let t41 = run_test "float_mul" "main =\n  let _ = print (show (3.0 * 2.5))\n  0" "7.5"
  let t42 = run_test "float_cmp" "main = if 3.14 > 2.71 then 1 else 0" "1"
  let t43 = run_test "ffi_abs" "foreign abs n\nmain =\n  let _ = print (show (abs (-5)))\n  0" "5"
  let t44 = run_test "ffi_strlen" "foreign strlen s\nmain =\n  let _ = print (show (strlen \"hello\"))\n  0" "5"
  let home = trim (shell "echo $HOME")
  let t45 = run_test "ffi_getenv" "foreign getenv s -> str\nmain =\n  let _ = print (getenv \"HOME\")\n  0" home
  let t46 = run_test "wildcard" "type T = | A x | B x | C\nmain = match (B 99)\n  | A x -> 0\n  | _ -> 42" "42"
  let _ = write_file "/tmp/rail_importlib.rail" "double x = x * 2\ntriple x = x * 3\n"
  let t47 = run_test "import" "import \"/tmp/rail_importlib.rail\"\nmain = double 21 + triple 1" "45"
  let t48 = run_test "arena" "main =\n  let m = arena_mark 0\n  let _ = cons 1 [2, 3]\n  let _ = arena_reset m\n  42" "42"
  let t49 = run_test "filter" "gt2 x = if x > 2 then true else false\nmain = length (filter gt2 [1, 2, 3, 4, 5])" "3"
  let t50 = run_test "fold" "add a b = a + b\nmain = fold add 0 [1, 2, 3, 4, 5]" "15"
  let t51 = run_test "reverse" "main =\n  let xs = reverse [1, 2, 3]\n  head xs" "3"
  let t52 = run_test "to_float" "main =\n  let _ = print (show (to_float 42))\n  0" "42"
  let t53 = run_test "not" "main = if not false then 1 else 0" "1"
  let t54 = run_test "range" "main = length (range 10)" "10"
  let t55 = run_test "fold_sum" "add a b = a + b\nmain =\n  let _ = print (show (fold add 0 (range 101)))\n  0" "5050"
  let t56 = run_test "neg_arith" "main = 10 + (-3)" "7"
  let t57 = run_test "spawn" "work x = x * 2\nmain =\n  let f = spawn (\\x -> work 21)\n  fiber_await f" "42"
  let t58 = run_test "match_int" "classify n = match n\n  | 0 -> \"zero\"\n  | 1 -> \"one\"\n  | _ -> \"other\"\nmain =\n  let _ = print (classify 1)\n  0" "one"
  let t59 = run_test "guard" "type Option = | Some x | None\nsafe_div a b = match b\n  | 0 -> None\n  | _ -> Some (a / b)\nmain = match (safe_div 10 2)\n  | Some x -> x\n  | None -> 0" "5"
  let _ = write_file "/tmp/rail_quallib.rail" "double x = x * 2\n_private x = x\n"
  let t60 = run_test "qual_import" "import \"/tmp/rail_quallib.rail\" as M\nmain = M_double 21" "42"
  let t61 = run_test "rc" "foreign free p\nmain =\n  let p = rc_alloc 16\n  let _ = rc_retain p\n  let _ = rc_release p\n  let _ = rc_release p\n  42" "42"
  let t62 = run_test "channel" "main =\n  let ch = channel 0\n  let _ = send ch 10\n  let _ = send ch 20\n  let _ = send ch 30\n  let a = recv ch\n  let b = recv ch\n  a + b" "30"
  let t63 = run_test "ffi_float" "foreign sqrt x -> float\nmain =\n  let _ = print (show (to_int (sqrt (to_float 144))))\n  0" "12"
  let t64 = run_test "map_fusion" "double x = x * 2\ntriple x = x * 3\nmain = head (map double (map triple [1, 2, 3]))" "6"
  let _ = write_file "/tmp/rail_gen_code.rail" "fact n = if n <= 1 then 1 else n * fact (n - 1)\n"
  let t65 = run_test "generate_ct" "#generate \"factorial\"\nmain =\n  let _ = print (show (fact 10))\n  0" "3628800"
  let _ = shell "ls /tmp/gpu_host >/dev/null 2>&1 && echo ok || clang -framework Metal -framework Foundation tools/gpu_host.m -o /tmp/gpu_host 2>/dev/null"
  let t66 = run_test "gpu_map" "main =\n  let r = gpu_map (\\x -> x * 3 + 1) (range 8)\n  let _ = print (show (head r))\n  0" "1"
  let t67 = run_test "gpu_auto" "main =\n  let r = map (\\x -> x * 2 + 1) (range 8)\n  let _ = print (show (head r))\n  0" "1"
  let t68 = run_test "nested_lam" "main = (\\a -> \\b -> a + b) 3 4" "7"
  let t69 = run_test "nested_lam_let" "main =\n  let f = \\a -> \\b -> a + b\n  f 3 4" "7"
  let t70 = run_test "nested_lam_cap" "main =\n  let n = 10\n  let f = \\a -> \\b -> a + b + n\n  f 3 4" "17"
  let total = (if t1 then 1 else 0) + (if t2 then 1 else 0) + (if t3 then 1 else 0) + (if t4 then 1 else 0) + (if t5 then 1 else 0) + (if t6 then 1 else 0) + (if t7 then 1 else 0) + (if t8 then 1 else 0) + (if t9 then 1 else 0) + (if t10 then 1 else 0) + (if t11 then 1 else 0) + (if t12 then 1 else 0) + (if t13 then 1 else 0) + (if t14 then 1 else 0) + (if t15 then 1 else 0) + (if t16 then 1 else 0) + (if t17 then 1 else 0) + (if t18 then 1 else 0) + (if t19 then 1 else 0) + (if t20 then 1 else 0) + (if t21 then 1 else 0) + (if t22 then 1 else 0) + (if t23 then 1 else 0) + (if t24 then 1 else 0) + (if t25 then 1 else 0) + (if t26 then 1 else 0) + (if t27 then 1 else 0) + (if t28 then 1 else 0) + (if t29 then 1 else 0) + (if t30 then 1 else 0) + (if t31 then 1 else 0) + (if t32 then 1 else 0) + (if t33 then 1 else 0) + (if t34 then 1 else 0) + (if t35 then 1 else 0) + (if t36 then 1 else 0) + (if t37 then 1 else 0) + (if t38 then 1 else 0) + (if t39 then 1 else 0) + (if t40 then 1 else 0) + (if t41 then 1 else 0) + (if t42 then 1 else 0) + (if t43 then 1 else 0) + (if t44 then 1 else 0) + (if t45 then 1 else 0) + (if t46 then 1 else 0) + (if t47 then 1 else 0) + (if t48 then 1 else 0) + (if t49 then 1 else 0) + (if t50 then 1 else 0) + (if t51 then 1 else 0) + (if t52 then 1 else 0) + (if t53 then 1 else 0) + (if t54 then 1 else 0) + (if t55 then 1 else 0) + (if t56 then 1 else 0) + (if t57 then 1 else 0) + (if t58 then 1 else 0) + (if t59 then 1 else 0) + (if t60 then 1 else 0) + (if t61 then 1 else 0) + (if t62 then 1 else 0) + (if t63 then 1 else 0) + (if t64 then 1 else 0) + (if t65 then 1 else 0) + (if t66 then 1 else 0) + (if t67 then 1 else 0) + (if t68 then 1 else 0) + (if t69 then 1 else 0) + (if t70 then 1 else 0)
  let _ = print (cat [show total, "/70 tests passed"])
  if total == 70 then 0 else 1

self_compile _ =
  let _ = print "\n=== Self-compilation ==="
  let self_src = read_file "tools/compile.rail"
  let _ = print (cat ["  Source: ", show (length self_src), " chars"])
  let self_asm = compile_program self_src
  let _ = write_file "/tmp/rail_self.s" self_asm
  let _ = print "  Compiled to assembly"
  let sdk = trim (shell "xcrun --show-sdk-path")
  let as_res = trim (shell "as -o /tmp/rail_self.o /tmp/rail_self.s 2>&1")
  let _ = if as_res != "" then print (cat ["  as: ", as_res]) else print "  as: OK"
  let rtdir2 = get_runtime_dir 0
  let ld_res = trim (shell (cat ["ld -o /tmp/rail_self /tmp/rail_self.o ", rtdir2, "/gc.o -lSystem -syslibroot ", sdk, " -arch arm64 2>&1"]))
  let _ = if ld_res != "" then print (cat ["  ld: ", ld_res]) else print "  ld: OK"
  let _ = shell "codesign -s - /tmp/rail_self 2>&1"
  let _ = print "  Binary: /tmp/rail_self"
  0

-- Join args after position N into a space-separated string
join_args lst n =
  if n > 0 then
    if length lst == 0 then ""
    else join_args (tail lst) (n - 1)
  else join " " lst

compile_and_run path extra =
  let _ = compile_file path
  let cmd = if length extra > 0 then cat ["/tmp/rail_out ", extra, " 2>&1"] else "/tmp/rail_out 2>&1"
  let out = shell cmd
  let _ = if length out > 0 then print out else 0
  0

-- Linux ARM64 cross-compilation support
build_linux asm_text =
  let _ = write_file "/tmp/rail_macos.s" asm_text
  -- Transform macOS assembly to GNU/Linux ELF syntax
  let uname_check = trim (shell "uname -s 2>/dev/null")
  let _ = if uname_check == "Linux" then
    shell "/home/zemog/tools/transform.sh /tmp/rail_macos.s /tmp/rail_linux_code.s"
  else
    shell "sed -E -e 's/\\.section __TEXT,__text/.text/' -e 's/\\.section __DATA,__data/.data/' -e 's/([_a-zA-Z][_a-zA-Z0-9]*)@PAGEOFF/:lo12:\\1/g' -e 's/@PAGE//g' -e '/\\.zerofill/d' /tmp/rail_macos.s > /tmp/rail_linux_code.s"
  let start_wrapper = "\n.text\n.global _start\n_start:\n    mov x29, sp\n    ldr x0, [sp]\n    add x1, sp, #8\n    bl _main\n    mov x8, #93\n    svc #0\n\n"
  let bss = "\n.bss\n.p2align 3\n_rail_heap:\n    .space 268435456\n"
  let _ = write_file "/tmp/rail_linux_start.s" start_wrapper
  let _ = write_file "/tmp/rail_linux_bss.s" bss
  -- Find linux_libc.s (in cwd/tools/ or alongside binary)
  let libc_path = trim (shell "ls tools/linux_libc.s 2>/dev/null || ls ~/tools/linux_libc.s 2>/dev/null || ls ~/projects/rail/tools/linux_libc.s 2>/dev/null || echo MISSING")
  -- On native Linux, include data section fallback (compiler may not emit its own)
  let data_path = if uname_check == "Linux" then
    trim (shell "ls tools/linux_data.s 2>/dev/null || ls /home/zemog/tools/linux_data.s 2>/dev/null || echo ''")
  else ""
  let _ = shell (cat ["cat /tmp/rail_linux_code.s /tmp/rail_linux_start.s ", libc_path, " ", data_path, " /tmp/rail_linux_bss.s > /tmp/rail_linux.s"])
  -- Detect if running on Linux (native) or macOS (cross)
  let uname = trim (shell "uname -s 2>/dev/null")
  let as_cmd = if uname == "Linux" then "as" else "aarch64-elf-as"
  let ld_cmd = if uname == "Linux" then "ld" else "aarch64-elf-ld"
  -- On native Linux, strip leading underscores from all symbol references
  -- macOS requires _ prefix, Linux/ELF does not
  -- Preserve _start (ELF entry point) and .L labels (local)
  let _ = if uname == "Linux" then
    shell "perl -pi -e 's/(?<=\\b)_(?=(?!start\\b)[a-zA-Z]\\w*)//' /tmp/rail_linux.s"
  else 0
  let as_res = trim (shell (cat [as_cmd, " -o /tmp/rail_linux.o /tmp/rail_linux.s 2>&1"]))
  let _ = if as_res != "" then print (cat ["  as: ", as_res]) else print "  as: OK"
  let ld_res = trim (shell (cat [ld_cmd, " -o /tmp/rail_linux /tmp/rail_linux.o 2>&1"]))
  let _ = if ld_res != "" then print (cat ["  ld: ", ld_res]) else print "  ld: OK"
  0

-- AI code generation via local LLM with validation loop (PROPOSAL_v2)
-- Strategy: unconstrained reasoning → compile → retry with error context (up to 3 attempts)
-- Grammar is used as system prompt context, NOT API-level constraint (MLX doesn't support GBNF)

gen_system_prompt =
  let grammar = read_file "grammar/rail.ebnf"
  cat ["You are a Rail language expert. Rail is a pure functional language that compiles to native ARM64.\n\nGRAMMAR (EBNF):\n", grammar, "\n\nRULES:\n- Top-level functions: name params = body\n- Let bindings use NEWLINES not 'in': let x = 5\\n  x + 1\n- If: if cond then expr else expr\n- Match: match expr | Pattern args -> expr\n- Lists: [1, 2, 3], head, tail, cons, map, filter, fold, length, reverse, range\n- Tuples: (a, b), destructure with let (x, y) = expr\n- ADTs: type Option = | Some x | None\n- Lambdas: \\x -> expr\n- print outputs a value, show converts int to string\n- join sep list concatenates strings, split sep str splits\n- main must exist and return an int\n- No negative literals — use (0 - n) or (-n) syntax\n- && and || do NOT short-circuit — use nested if/else\n- Every program needs a main function\n- Use let _ = print expr for side effects"]

gen_examples =
  cat ["Example 1:\nfact n = if n <= 1 then 1 else n * fact (n - 1)\nmain =\n  let _ = print (show (fact 10))\n  0\n\nExample 2:\nadd a b = a + b\nmain =\n  let _ = print (show (fold add 0 [1, 2, 3, 4, 5]))\n  0\n\nExample 3:\ntype Option = | Some x | None\nsafe_div a b = match b\n  | 0 -> None\n  | _ -> Some (a / b)\nmain = match (safe_div 10 2)\n  | Some x -> x\n  | None -> 0"]

gen_llm_call sys_msg user_msg =
  let escaped_sys = esc_json sys_msg
  let escaped_usr = esc_json user_msg
  let req = cat ["{\"model\": \"default\", \"messages\": [{\"role\": \"system\", \"content\": \"", escaped_sys, "\"}, {\"role\": \"user\", \"content\": \"", escaped_usr, "\"}], \"max_tokens\": 2048, \"temperature\": 0.3}"]
  let _ = write_file "/tmp/rail_gen_req.json" req
  let _ = shell "curl -s http://localhost:8080/v1/chat/completions -H 'Content-Type: application/json' -d @/tmp/rail_gen_req.json > /tmp/rail_gen_resp.json"
  let raw = read_file "/tmp/rail_gen_resp.json"
  let parts = split "\"content\":\"" raw
  let after = if length parts >= 2 then head (tail parts) else ""
  let code = head (split "\"},\"" after)
  let _ = write_file "/tmp/rail_gen_code.rail" code
  code

gen_try_compile code =
  let _ = write_file "/tmp/rail_gen_out.rail" code
  shell (cat [head args, " /tmp/rail_gen_out.rail 2>&1"])

gen_try_run dummy =
  let run_result = shell "/tmp/rail_out 2>&1; echo $?"
  let lines = split "\n" run_result
  let exit_code = last_elem lines
  let stdout = join "\n" (init_list lines)
  (stdout, exit_code)

generate_code desc =
  let sys = gen_system_prompt
  let examples = gen_examples
  let _ = print (cat ["-- Generating Rail code for: ", desc])
  generate_loop desc sys examples "" 1

generate_loop desc sys examples prev_error attempt =
  if attempt > 3 then
    let _ = print "-- FAILED: 3 attempts exhausted"
    1
  else
    let _ = print (cat ["-- Attempt ", show attempt, "/3"])
    let user_msg = if prev_error == "" then
      cat [examples, "\n\nNow write a Rail program for: ", desc, "\n\nOutput ONLY Rail code. No markdown, no explanation. Functions before main."]
    else
      cat [examples, "\n\nNow write a Rail program for: ", desc, "\n\nYour previous attempt had this error:\n", prev_error, "\n\nFix the error. Output ONLY Rail code. No markdown, no explanation. Functions before main."]
    let code = gen_llm_call sys user_msg
    let _ = print code
    let _ = print "\n-- Compiling..."
    let compile_out = gen_try_compile code
    let _ = print compile_out
    -- Check if compile produced a binary
    let check = trim (shell "test -f /tmp/rail_out && echo ok || echo fail")
    if check == "fail" then
      let _ = print "-- Compile FAILED, retrying..."
      generate_loop desc sys examples (cat ["Compile error: ", compile_out]) (attempt + 1)
    else
      let (stdout, exit_code) = gen_try_run 0
      let _ = if length stdout > 0 then print (cat ["-- Output: ", stdout]) else 0
      let _ = if exit_code != "0" then
        let _ = print (cat ["-- Runtime error (exit ", exit_code, "), retrying..."])
        0
      else
        let _ = print "-- SUCCESS"
        0
      if exit_code != "0" then
        generate_loop desc sys examples (cat ["Runtime error (exit code ", exit_code, "): ", stdout]) (attempt + 1)
      else 0

-- Escape string for JSON (minimal: handle quotes and newlines)
esc_json s = esc_json_acc (chars s) ""

esc_json_acc cs acc =
  if length cs == 0 then acc
  else
    let c = head cs
    let e = if c == "\"" then "\\\"" else if c == "\n" then "\\n" else if c == "\\" then "\\\\" else c
    esc_json_acc (tail cs) (append acc e)

compile_linux path =
  let src = read_file path
  let _ = print (cat ["Cross-compiling ", path, " for Linux ARM64..."])
  let asm = compile_program src
  let _ = build_linux asm
  let _ = print "  Binary: /tmp/rail_linux"
  let info = trim (shell "file /tmp/rail_linux 2>&1")
  let _ = print (cat ["  ", info])
  0

-- Dispatch: wasm via tools/wasm_compile.sh (Python parser + WAT codegen)
dispatch_wasm path =
  let _ = print (cat ["Compiling ", path, " to WASM..."])
  let out = shell (cat ["bash tools/wasm_compile.sh ", path, " 2>&1"])
  let _ = print out
  0

-- Package manager (inline — small enough)
dispatch_get name =
  let _ = shell "mkdir -p ~/.rail/packages"
  let src_path = cat ["stdlib/", name, ".rail"]
  let home = trim (shell "echo $HOME")
  let dest_dir = cat [home, "/.rail/packages/", name]
  let _ = shell (cat ["mkdir -p ", dest_dir])
  let dest_path = cat [dest_dir, "/", name, ".rail"]
  let src = read_file src_path
  if length src == 0 then
    let _ = print (cat ["Package not found: ", name])
    1
  else
    let _ = write_file dest_path src
    let _ = print (cat ["Installed: ", name, " -> ", dest_path])
    0

dispatch_packages _ =
  let _ = shell "mkdir -p ~/.rail/packages"
  let home = trim (shell "echo $HOME")
  let out = shell (cat ["ls -1 ", home, "/.rail/packages/ 2>/dev/null"])
  if length out == 0 then
    let _ = print "No packages installed."
    0
  else
    let _ = print "Installed packages:"
    let _ = print out
    0

main =
  let a = args
  if length a >= 2 then
    let cmd = head (tail a)
    if cmd == "test" then run_tests 0
    else if cmd == "self" then self_compile 0
    else if cmd == "generate" then
      if length a >= 3 then generate_code (join_args a 2)
      else let _ = print "Usage: rail generate \"description\""
      1
    else if cmd == "linux" then
      if length a >= 3 then compile_linux (head (tail (tail a)))
      else let _ = print "Usage: rail linux <file.rail>"
      1
    else if cmd == "run" then
      if length a >= 3 then compile_and_run (head (tail (tail a))) (join_args a 3)
      else let _ = print "Usage: rail run <file.rail>"
      1
    else if cmd == "wasm" then
      if length a >= 3 then dispatch_wasm (head (tail (tail a)))
      else let _ = print "Usage: rail wasm <file.rail>"
      1
    else if cmd == "get" then
      if length a >= 3 then dispatch_get (head (tail (tail a)))
      else let _ = print "Usage: rail get <package>"
      1
    else if cmd == "packages" then dispatch_packages 0
    else if cmd == "deploy" then dispatch_deploy a
    else compile_file cmd
  else
    let _ = run_tests 0
    self_compile 0

dispatch_deploy a =
  if length a >= 4 then
    let path = head (tail (tail a))
    let host = head (tail (tail (tail a)))
    let _ = print (cat ["=== Deploy ", path, " → ", host, " ==="])
    let src = read_file path
    let _ = print "  Cross-compiling for Linux ARM64..."
    let asm = compile_program src
    let _ = build_linux asm
    let _ = print "  Uploading..."
    let scp_res = trim (shell (cat ["scp -o ConnectTimeout=5 /tmp/rail_linux ", host, ":/tmp/rail_prog 2>&1"]))
    let _ = if length scp_res > 0 then print (cat ["  scp: ", scp_res]) else print "  scp: OK"
    let _ = print "  Running..."
    let out = shell (cat ["ssh -o ConnectTimeout=5 ", host, " 'chmod +x /tmp/rail_prog && /tmp/rail_prog' 2>&1"])
    let _ = if length out > 0 then print out else 0
    0
  else
    let _ = print "Usage: rail deploy <file.rail> <user@host>"
    1
