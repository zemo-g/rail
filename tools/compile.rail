  let rgt = "_rail_gt:\n    tst x1, #1\n    b.eq .Lgt_float\n    cmp x1, x0\n    cset x0, gt\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n.Lgt_float:\n    ldr d0, [x1, #8]\n    ldr d1, [x0, #8]\n    fcmp d0, d1\n    cset x0, gt\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n\n"
  let rle = "_rail_le:\n    tst x1, #1\n    b.eq .Lle_float\n    cmp x1, x0\n    cset x0, le\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n.Lle_float:\n    ldr d0, [x1, #8]\n    ldr d1, [x0, #8]\n    fcmp d0, d1\n    cset x0, ls\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n\n"
  let rge = "_rail_ge:\n    tst x1, #1\n    b.eq .Lge_float\n    cmp x1, x0\n    cset x0, ge\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n.Lge_float:\n    ldr d0, [x1, #8]\n    ldr d1, [x0, #8]\n    fcmp d0, d1\n    cset x0, ge\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n\n"
  -- rc_alloc: allocate refcounted object. x0 = size (tagged). Returns ptr to data (refcount at ptr-8)
  let rrcalloc = "_rail_rc_alloc:\n    stp x29, x30, [sp, #-16]!\n    mov x29, sp\n    asr x0, x0, #1\n    add x0, x0, #8\n    bl _malloc\n    mov x1, #1\n    str x1, [x0]\n    add x0, x0, #8\n    ldp x29, x30, [sp], #16\n    ret\n\n"
  -- rc_release: decrement refcount, free if zero
  let rrcrelease = "_rail_rc_release:\n    stp x29, x30, [sp, #-16]!\n    mov x29, sp\n    ldr x1, [x0, #-8]\n    sub x1, x1, #1\n    str x1, [x0, #-8]\n    cbnz x1, .Lrc_keep\n    sub x0, x0, #8\n    bl _free\n.Lrc_keep:\n    ldp x29, x30, [sp], #16\n    ret\n\n"
  cat [rsub, rmul, rdiv, rmod, rlt, rgt, rle, rge, rrcalloc, rrcrelease]

rt_fiber =
  let rspawn = "_rail_spawn:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x0, [x29, #16]\n    mov x0, #32\n    bl _rail_alloc\n    str x0, [x29, #24]\n    str xzr, [x0]\n    ldr x1, [x29, #16]\n    str x1, [x0, #16]\n    str xzr, [x0, #24]\n    movz x0, #1, lsl #16\n    bl _rail_alloc\n    add x0, x0, #16, lsl #12\n    and x0, x0, #-16\n    ldr x1, [x29, #24]\n    str x0, [x1, #8]\n    ldr x0, [x29, #24]\n    ldp x29, x30, [sp], #32\n    ret\n\n"
  let rawait = "_rail_await:\n    stp x29, x30, [sp, #-16]!\n    mov x29, sp\n    mov x20, x0\n    stp x19, x20, [sp, #-16]!\n    stp x21, x22, [sp, #-16]!\n    stp x23, x24, [sp, #-16]!\n    stp x25, x26, [sp, #-16]!\n    stp x27, x28, [sp, #-16]!\n    mov x19, sp\n    ldr x4, [x20, #8]\n    mov sp, x4\n    ldr x0, [x20, #16]\n    ldr x5, [x0, #8]\n    ldr x3, [x0, #16]\n    mov x0, #1\n    cmp x3, #0\n    b.eq .Lawait_call\n    ldr x1, [x0, #24]\n.Lawait_call:\n    blr x5\n    str x0, [x20, #24]\n    mov x1, #2\n    str x1, [x20]\n    mov sp, x19\n    ldp x27, x28, [sp], #16\n    ldp x25, x26, [sp], #16\n    ldp x23, x24, [sp], #16\n    ldp x21, x22, [sp], #16\n    ldp x19, x20, [sp], #16\n    ldr x0, [x20, #24]\n    ldp x29, x30, [sp], #16\n    ret\n\n"
  let ryield = "_rail_yield:\n    ret\n\n"
  let rinit = "_rail_fiber_init:\n    ret\n\n"
  -- Channel: a cons cell where head = list of values. send appends, recv takes head.
  let rchansend = "_rail_chan_send:\n    stp x29, x30, [sp, #-48]!\n    mov x29, sp\n    str x0, [x29, #16]\n    str x1, [x29, #24]\n    ldr x0, [x0, #8]\n    str x0, [x29, #32]\n    ldr x0, [x29, #24]\n    adrp x1, _rail_nil@PAGE\n    add x1, x1, _rail_nil@PAGEOFF\n    bl _rail_cons\n    mov x1, x0\n    ldr x0, [x29, #32]\n    bl _rail_append\n    ldr x1, [x29, #16]\n    str x0, [x1, #8]\n    mov x0, #1\n    ldp x29, x30, [sp], #48\n    ret\n\n"
  let rchanrecv = "_rail_chan_recv:\n    stp x29, x30, [sp, #-16]!\n    mov x29, sp\n    ldr x1, [x0, #8]\n    ldr x2, [x1]\n    cmp x2, #2\n    b.eq .Lrecv_empty\n    ldr x3, [x1, #8]\n    ldr x4, [x1, #16]\n    str x4, [x0, #8]\n    mov x0, x3\n    ldp x29, x30, [sp], #16\n    ret\n.Lrecv_empty:\n    mov x0, #1\n    ldp x29, x30, [sp], #16\n    ret\n\n"
  cat [rspawn, rawait, ryield, rinit, rchansend, rchanrecv]

rt_gpu =
  let rgpumap = "_rail_gpu_map:\n    stp x29, x30, [sp, #-64]!\n    mov x29, sp\n    str x0, [x29, #16]\n    str x1, [x29, #24]\n    mov x0, x1\n    bl _rail_length\n    str x0, [x29, #32]\n    b .Lgm_ap\n.Lgm_mp:\n    .asciz \"/tmp/rail_gpu.metal\"\n    .p2align 2\n.Lgm_ap:\n    adr x0, .Lgm_mp\n    ldr x1, [x29, #16]\n    bl _rail_write_file\n    b .Lgm_ac\n.Lgm_cc:\n    .asciz \"xcrun metal -c /tmp/rail_gpu.metal -o /tmp/rail_gpu.air 2>/dev/null && xcrun metallib /tmp/rail_gpu.air -o /tmp/rail_gpu.metallib 2>/dev/null\"\n    .p2align 2\n.Lgm_ac:\n    adr x0, .Lgm_cc\n    bl _rail_shell\n    ldr x0, [x29, #32]\n    bl _rail_show\n    str x0, [x29, #40]\n    b .Lgm_ahp\n.Lgm_hp:\n    .asciz \"/tmp/gpu_host /tmp/rail_gpu.metallib rail_kernel \"\n    .p2align 2\n.Lgm_ahp:\n    adr x0, .Lgm_hp\n    ldr x1, [x29, #40]\n    bl _rail_str_append\n    bl _rail_shell\n    str x0, [x29, #48]\n    b .Lgm_arf\n.Lgm_rf:\n    .asciz \"/tmp/rail_gpu_out.csv\"\n    .p2align 2\n.Lgm_arf:\n    adr x0, .Lgm_rf\n    bl _rail_read_file\n    str x0, [x29, #48]\n    b .Lgm_acm\n.Lgm_cm:\n    .asciz \",\"\n    .p2align 2\n.Lgm_acm:\n    adr x0, .Lgm_cm\n    ldr x1, [x29, #48]\n    bl _rail_split\n    bl _rail_parse_int_list\n    ldp x29, x30, [sp], #64\n    ret\n\n"
  let rparselist = "_rail_parse_int_list:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x0, [x29, #16]\n    ldr x1, [x0]\n    cmp x1, #2\n    b.eq .Lpil_nil\n    ldr x1, [x0, #8]\n    str x1, [x29, #24]\n    ldr x0, [x0, #16]\n    bl _rail_parse_int_list\n    str x0, [sp, #-16]!\n    ldr x0, [x29, #24]\n    bl _str_unwrap\n    bl _atoi\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ldr x1, [sp], #16\n    bl _rail_cons\n    ldp x29, x30, [sp], #32\n    ret\n.Lpil_nil:\n    adrp x0, _rail_nil@PAGE\n    add x0, x0, _rail_nil@PAGEOFF\n    ldp x29, x30, [sp], #32\n    ret\n\n"
  cat [rgpumap, rparselist]

rt_str_gc =
  -- _str_unwrap: if x0 points to tagged string [9,len,bytes...], return x0+16. Else return x0 as-is.
  let unwrap = "_str_unwrap:\n    tst x0, #1\n    b.ne .Luw_ret\n    adrp x1, _rail_heap@PAGE\n    add x1, x1, _rail_heap@PAGEOFF\n    cmp x0, x1\n    b.lo .Luw_ret\n    adrp x1, _rail_heap_ptr@PAGE\n    ldr x1, [x1, _rail_heap_ptr@PAGEOFF]\n    cmp x0, x1\n    b.hs .Luw_ret\n    ldr x1, [x0]\n    cmp x1, #9\n    b.ne .Luw_ret\n    add x0, x0, #16\n.Luw_ret:\n    ret\n\n"
  -- _rail_wrap_str: x0=raw C string. Copy to GC heap as tagged string [9,len,bytes]. Returns tagged ptr.
  let wrap = "_rail_wrap_str:\n    tst x0, #1\n    b.ne .Lwrap_do\n    adrp x1, _rail_heap@PAGE\n    add x1, x1, _rail_heap@PAGEOFF\n    cmp x0, x1\n    b.lo .Lwrap_do\n    adrp x1, _rail_heap_ptr@PAGE\n    ldr x1, [x1, _rail_heap_ptr@PAGEOFF]\n    cmp x0, x1\n    b.hs .Lwrap_do\n    ldr x1, [x0]\n    cmp x1, #9\n    b.eq .Lwrap_noop\n.Lwrap_do:\n    stp x29, x30, [sp, #-48]!\n    mov x29, sp\n    str x0, [x29, #16]\n    bl _strlen\n    str x0, [x29, #24]\n    add x0, x0, #17\n    bl _rail_alloc\n    str x0, [x29, #32]\n    mov x1, #9\n    str x1, [x0]\n    ldr x1, [x29, #24]\n    str x1, [x0, #8]\n    add x0, x0, #16\n    ldr x1, [x29, #16]\n    ldr x2, [x29, #24]\n    add x2, x2, #1\n.Lwrap_cp:\n    cbz x2, .Lwrap_done\n    ldrb w3, [x1], #1\n    strb w3, [x0], #1\n    sub x2, x2, #1\n    b .Lwrap_cp\n.Lwrap_done:\n    ldr x0, [x29, #32]\n    ldp x29, x30, [sp], #48\n.Lwrap_noop:\n    ret\n\n"
  cat [unwrap, wrap]

rt_gc_1 =
  -- Free list globals + mark stack globals
  cat [".data\n.global _rail_free_list\n_rail_free_list:\n    .quad 0\n",
  "_gc_mark_stack:\n    .quad 0\n_gc_mark_top:\n    .quad 0\n_gc_mark_cap:\n    .quad 0\n",
  "_rail_malloc_ptr:\n    .quad 0\n_rail_malloc_end:\n    .quad 0\n.text\n\n",
  -- rail_free_list_alloc: first-fit search. x0=size, returns ptr or 0
  "_rail_free_list_alloc:\n    adrp x1, _rail_free_list@PAGE\n    add x1, x1, _rail_free_list@PAGEOFF\n",
  ".Lfla_loop:\n    ldr x2, [x1]\n    cbz x2, .Lfla_fail\n    ldr x3, [x2]\n    cmp x3, x0\n    b.ge .Lfla_found\n    add x1, x2, #8\n    b .Lfla_loop\n",
  ".Lfla_found:\n    ldr x3, [x2, #8]\n    str x3, [x1]\n    mov x0, x2\n    ret\n",
  ".Lfla_fail:\n    mov x0, #0\n    ret\n\n",
  -- rail_free_list_clear
  "_rail_free_list_clear:\n    adrp x0, _rail_free_list@PAGE\n    str xzr, [x0, _rail_free_list@PAGEOFF]\n    ret\n\n"]

rt_gc_2 =
  -- _gc_try_mark: x0=value. Check if heap ptr, mark if valid object, push children.
  cat ["_gc_try_mark:\n    stp x29, x30, [sp, #-48]!\n    mov x29, sp\n",
  -- Check: not tagged int (bit 0), in heap range [_rail_heap..heap_ptr), 8-byte aligned
  "    tst x0, #1\n    b.ne .Ltm_ret\n",
  "    adrp x1, _rail_heap@PAGE\n    add x1, x1, _rail_heap@PAGEOFF\n    cmp x0, x1\n    b.lo .Ltm_ret\n",
  "    adrp x1, _rail_heap_ptr@PAGE\n    ldr x1, [x1, _rail_heap_ptr@PAGEOFF]\n    cmp x0, x1\n    b.hs .Ltm_ret\n",
  "    tst x0, #7\n    b.ne .Ltm_ret\n",
  -- Load tag, mask mark bit, check valid range 1-9
  "    ldr x1, [x0]\n    and x2, x1, #0x7fffffffffffffff\n    cmp x2, #1\n    b.lo .Ltm_ret\n    cmp x2, #9\n    b.hi .Ltm_ret\n",
  -- Check not already marked (bit 63)
  "    tbnz x1, #63, .Ltm_ret\n",
  -- Set mark bit
  "    orr x1, x1, #0x8000000000000000\n    str x1, [x0]\n",
  -- Push to mark stack
  "    str x0, [x29, #16]\n",
  "    adrp x1, _gc_mark_top@PAGE\n    add x1, x1, _gc_mark_top@PAGEOFF\n    ldr x3, [x1]\n",
  "    adrp x4, _gc_mark_cap@PAGE\n    ldr x4, [x4, _gc_mark_cap@PAGEOFF]\n    cmp x3, x4\n    b.hs .Ltm_ret\n",
  "    adrp x5, _gc_mark_stack@PAGE\n    ldr x5, [x5, _gc_mark_stack@PAGEOFF]\n",
  "    ldr x0, [x29, #16]\n    str x0, [x5, x3, lsl #3]\n    add x3, x3, #1\n    str x3, [x1]\n",
  ".Ltm_ret:\n    ldp x29, x30, [sp], #48\n    ret\n\n"]

rt_gc_3 =
  -- _gc_drain: process mark stack, call try_mark on children
  cat ["_gc_drain:\n    stp x29, x30, [sp, #-64]!\n    mov x29, sp\n",
  ".Ldrain_loop:\n",
  "    adrp x0, _gc_mark_top@PAGE\n    add x0, x0, _gc_mark_top@PAGEOFF\n    ldr x1, [x0]\n    cbz x1, .Ldrain_done\n",
  "    sub x1, x1, #1\n    str x1, [x0]\n",
  "    adrp x2, _gc_mark_stack@PAGE\n    ldr x2, [x2, _gc_mark_stack@PAGEOFF]\n    ldr x3, [x2, x1, lsl #3]\n",
  -- x3 = object ptr. Load tag.
  "    str x3, [x29, #16]\n    ldr x4, [x3]\n    and x4, x4, #0x7fffffffffffffff\n",
  -- Case 1: Cons — mark head and tail
  "    cmp x4, #1\n    b.ne .Ldrain_c3\n    ldr x0, [x3, #8]\n    bl _gc_try_mark\n    ldr x3, [x29, #16]\n    ldr x0, [x3, #16]\n    bl _gc_try_mark\n    b .Ldrain_loop\n",
  -- Case 3: Tuple — mark all elements
  ".Ldrain_c3:\n    cmp x4, #3\n    b.ne .Ldrain_c4\n",
  "    ldr x5, [x3, #-8]\n    sub x5, x5, #8\n    lsr x5, x5, #3\n    mov x6, #0\n    str x5, [x29, #24]\n",
  ".Ldrain_t_loop:\n    ldr x5, [x29, #24]\n    cmp x6, x5\n    b.hs .Ldrain_loop\n    str x6, [x29, #32]\n    ldr x3, [x29, #16]\n    add x7, x6, #1\n    ldr x0, [x3, x7, lsl #3]\n    bl _gc_try_mark\n    ldr x6, [x29, #32]\n    add x6, x6, #1\n    b .Ldrain_t_loop\n",
  -- Case 4: Closure — mark captures
  ".Ldrain_c4:\n    cmp x4, #4\n    b.ne .Ldrain_c5\n",
  "    ldr x5, [x3, #16]\n    mov x6, #0\n    str x5, [x29, #24]\n",
  ".Ldrain_cl_loop:\n    ldr x5, [x29, #24]\n    cmp x6, x5\n    b.hs .Ldrain_loop\n    str x6, [x29, #32]\n    ldr x3, [x29, #16]\n    add x7, x6, #3\n    ldr x0, [x3, x7, lsl #3]\n    bl _gc_try_mark\n    ldr x6, [x29, #32]\n    add x6, x6, #1\n    b .Ldrain_cl_loop\n",
  -- Case 5: ADT — mark fields
  ".Ldrain_c5:\n    cmp x4, #5\n    b.ne .Ldrain_c7\n",
  "    ldr x5, [x3, #-8]\n    sub x5, x5, #16\n    lsr x5, x5, #3\n    mov x6, #0\n    str x5, [x29, #24]\n",
  ".Ldrain_a_loop:\n    ldr x5, [x29, #24]\n    cmp x6, x5\n    b.hs .Ldrain_loop\n    str x6, [x29, #32]\n    ldr x3, [x29, #16]\n    add x7, x6, #2\n    ldr x0, [x3, x7, lsl #3]\n    bl _gc_try_mark\n    ldr x6, [x29, #32]\n    add x6, x6, #1\n    b .Ldrain_a_loop\n",
  -- Case 7: Array — mark all elements
  ".Ldrain_c7:\n    cmp x4, #7\n    b.ne .Ldrain_c8\n",
  "    ldr x5, [x3, #8]\n    mov x6, #0\n    str x5, [x29, #24]\n",
  ".Ldrain_ar_loop:\n    ldr x5, [x29, #24]\n    cmp x6, x5\n    b.hs .Ldrain_loop\n    str x6, [x29, #32]\n    ldr x3, [x29, #16]\n    add x7, x6, #2\n    ldr x0, [x3, x7, lsl #3]\n    bl _gc_try_mark\n    ldr x6, [x29, #32]\n    add x6, x6, #1\n    b .Ldrain_ar_loop\n",
  -- Case 8: Error — mark message string
  ".Ldrain_c8:\n    cmp x4, #8\n    b.ne .Ldrain_loop\n    ldr x0, [x3, #8]\n    bl _gc_try_mark\n    b .Ldrain_loop\n",
  ".Ldrain_done:\n    ldp x29, x30, [sp], #64\n    ret\n\n"]

rt_gc_4 =
  -- _rail_gc: main entry point. Walk stack frames, mark, sweep.
  cat ["_rail_gc:\n    stp x29, x30, [sp, #-80]!\n    mov x29, sp\n    stp x19, x20, [x29, #48]\n    stp x21, x22, [x29, #64]\n",
  -- Allocate mark stack: 512K entries * 8 = 4MB
  "    mov x0, #4194304\n    bl _malloc\n    cbz x0, .Lgc_ret\n",
  "    adrp x1, _gc_mark_stack@PAGE\n    str x0, [x1, _gc_mark_stack@PAGEOFF]\n",
  "    adrp x1, _gc_mark_top@PAGE\n    str xzr, [x1, _gc_mark_top@PAGEOFF]\n",
  "    mov x0, #524288\n    adrp x1, _gc_mark_cap@PAGE\n    str x0, [x1, _gc_mark_cap@PAGEOFF]\n",
  -- Walk stack frames via x29 chain
  "    mov x19, x29\n",
  ".Lgc_frame_loop:\n    cbz x19, .Lgc_sweep\n",
  "    ldr x20, [x19]\n",
  -- Scan frame: slots from fp+16 to fp+2048 (or parent frame)
  "    add x21, x19, #16\n    add x22, x19, #2048\n",
  "    cmp x20, #0\n    b.eq .Lgc_scan\n    cmp x20, x22\n    b.hs .Lgc_scan\n    mov x22, x20\n",
  ".Lgc_scan:\n    cmp x21, x22\n    b.hs .Lgc_scan_done\n    ldr x0, [x21]\n    str x21, [x29, #16]\n    str x22, [x29, #24]\n    bl _gc_try_mark\n    ldr x21, [x29, #16]\n    ldr x22, [x29, #24]\n    add x21, x21, #8\n    b .Lgc_scan\n",
  ".Lgc_scan_done:\n    bl _gc_drain\n    mov x19, x20\n    b .Lgc_frame_loop\n",
  -- Sweep phase
  ".Lgc_sweep:\n",
  "    adrp x0, _rail_free_list@PAGE\n    str xzr, [x0, _rail_free_list@PAGEOFF]\n",
  -- pos = heap start, end = heap_ptr
  "    adrp x19, _rail_heap@PAGE\n    add x19, x19, _rail_heap@PAGEOFF\n",
  "    adrp x20, _rail_heap_ptr@PAGE\n    ldr x20, [x20, _rail_heap_ptr@PAGEOFF]\n",
  ".Lsweep_loop:\n    add x1, x19, #8\n    cmp x1, x20\n    b.hi .Lsweep_done\n",
  "    ldr x2, [x19]\n",
  "    add x3, x1, x2\n    cmp x3, x20\n    b.hi .Lsweep_done\n",
  -- x1=obj, x2=size. Load tag.
  "    ldr x4, [x1]\n    and x5, x4, #0x7fffffffffffffff\n",
  "    cmp x5, #1\n    b.lo .Lsweep_next\n    cmp x5, #9\n    b.hi .Lsweep_next\n",
  -- Marked? Clear mark.
  "    tbnz x4, #63, .Lsweep_clear\n",
  -- Unmarked: add to free list
  "    str x2, [x1]\n",
  "    adrp x6, _rail_free_list@PAGE\n    add x6, x6, _rail_free_list@PAGEOFF\n    ldr x7, [x6]\n    str x7, [x1, #8]\n    str x1, [x6]\n",
  "    b .Lsweep_next\n",
  ".Lsweep_clear:\n    and x4, x4, #0x7fffffffffffffff\n    str x4, [x1]\n",
  ".Lsweep_next:\n    add x2, x2, #7\n    and x2, x2, #-8\n    add x19, x19, x2\n    add x19, x19, #8\n    b .Lsweep_loop\n",
  ".Lsweep_done:\n",
  -- Free mark stack
  "    adrp x0, _gc_mark_stack@PAGE\n    add x0, x0, _gc_mark_stack@PAGEOFF\n    ldr x0, [x0]\n    bl _free\n",
  "    adrp x1, _gc_mark_stack@PAGE\n    str xzr, [x1, _gc_mark_stack@PAGEOFF]\n",
  ".Lgc_ret:\n    ldp x19, x20, [x29, #48]\n    ldp x21, x22, [x29, #64]\n    ldp x29, x30, [sp], #80\n    ret\n\n"]

rt_thread =
  cat ["_rail_spawn_thread:\n    stp x29, x30, [sp, #-48]!\n    mov x29, sp\n    str x0, [x29, #16]\n    str x1, [x29, #24]\n    mov x0, #40\n    bl _malloc\n    str x0, [x29, #32]\n    ldr x1, [x29, #16]\n    str x1, [x0]\n    ldr x1, [x29, #24]\n    str x1, [x0, #8]\n    str xzr, [x0, #16]\n    ldr x3, [x29, #32]\n    add x0, x3, #24\n    mov x1, #0\n    adr x2, _rail_thread_tramp\n    mov x3, x3\n    bl _pthread_create\n    ldr x0, [x29, #32]\n    ldp x29, x30, [sp], #48\n    ret\n\n",
  "_rail_thread_tramp:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x0, [x29, #16]\n    ldr x1, [x0, #8]\n    ldr x2, [x0]\n    tst x2, #1\n    b.ne .Ltt_done\n    ldr x3, [x2]\n    and x3, x3, #0x7fffffffffffffff\n    cmp x3, #4\n    b.ne .Ltt_fn\n    ldr x6, [x2, #8]\n    mov x0, x1\n    blr x6\n    b .Ltt_store\n.Ltt_fn:\n    mov x0, x1\n    blr x2\n    b .Ltt_store\n.Ltt_done:\n    mov x0, #1\n.Ltt_store:\n    ldr x1, [x29, #16]\n    str x0, [x1, #16]\n    mov x0, #0\n    ldp x29, x30, [sp], #32\n    ret\n\n",
  "_rail_join_thread:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x0, [x29, #16]\n    ldr x0, [x0, #24]\n    mov x1, #0\n    bl _pthread_join\n    ldr x0, [x29, #16]\n    ldr x0, [x0, #16]\n    ldp x29, x30, [sp], #32\n    ret\n\n",
  "_rail_mutex_new:\n    stp x29, x30, [sp, #-16]!\n    mov x29, sp\n    mov x0, #64\n    bl _malloc\n    mov x1, x0\n    mov x0, x1\n    mov x1, #0\n    bl _pthread_mutex_init\n    ldp x29, x30, [sp], #16\n    ret\n\n"]

rt_array =
  cat ["_rail_arr_new:\n    stp x29, x30, [sp, #-48]!\n    mov x29, sp\n    asr x2, x0, #1\n    str x2, [x29, #16]\n    str x1, [x29, #24]\n    lsl x0, x2, #3\n    add x0, x0, #16\n    bl _rail_alloc\n    str x0, [x29, #32]\n    mov x3, #7\n    str x3, [x0]\n    ldr x2, [x29, #16]\n    str x2, [x0, #8]\n    ldr x1, [x29, #24]\n    mov x3, #0\n.Larn_loop:\n    cmp x3, x2\n    b.hs .Larn_done\n    add x4, x3, #2\n    ldr x5, [x29, #32]\n    str x1, [x5, x4, lsl #3]\n    add x3, x3, #1\n    b .Larn_loop\n.Larn_done:\n    ldr x0, [x29, #32]\n    ldp x29, x30, [sp], #48\n    ret\n\n"]

rt_string =
  -- str_find needle haystack → tagged int index (-1 if not found)
  let sfind = "_rail_str_find:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x1, [x29, #16]\n    bl _str_unwrap\n    str x0, [x29, #24]\n    ldr x0, [x29, #16]\n    bl _str_unwrap\n    str x0, [x29, #16]\n    ldr x1, [x29, #24]\n    bl _strstr\n    cbz x0, .Lsf_notfound\n    ldr x1, [x29, #16]\n    sub x0, x0, x1\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ldp x29, x30, [sp], #32\n    ret\n.Lsf_notfound:\n    mov x0, #-1\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ldp x29, x30, [sp], #32\n    ret\n\n"
  -- str_contains needle haystack → tagged bool (3=true, 1=false)
  let scont = "_rail_str_contains:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x1, [x29, #16]\n    bl _str_unwrap\n    str x0, [x29, #24]\n    ldr x0, [x29, #16]\n    bl _str_unwrap\n    ldr x1, [x29, #24]\n    bl _strstr\n    cmp x0, #0\n    cset x0, ne\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ldp x29, x30, [sp], #32\n    ret\n\n"
  -- str_sub string start len → new string
  let ssub = "_rail_str_sub:\n    stp x29, x30, [sp, #-48]!\n    mov x29, sp\n    str x1, [x29, #24]\n    str x2, [x29, #32]\n    bl _str_unwrap\n    str x0, [x29, #16]\n    ldr x1, [x29, #24]\n    asr x1, x1, #1\n    str x1, [x29, #24]\n    ldr x2, [x29, #32]\n    asr x2, x2, #1\n    str x2, [x29, #32]\n    add x0, x2, #1\n    bl _malloc\n    str x0, [x29, #40]\n    ldr x1, [x29, #16]\n    ldr x2, [x29, #24]\n    add x1, x1, x2\n    ldr x2, [x29, #32]\n    mov x3, x2\n.Lss_cp:\n    cbz x3, .Lss_done\n    ldrb w4, [x1], #1\n    strb w4, [x0], #1\n    sub x3, x3, #1\n    b .Lss_cp\n.Lss_done:\n    mov w4, #0\n    strb w4, [x0]\n    ldr x0, [x29, #40]\n    bl _rail_wrap_str\n    str x0, [x29, #16]\n    ldr x0, [x29, #40]\n    bl _free\n    ldr x0, [x29, #16]\n    ldp x29, x30, [sp], #48\n    ret\n\n"
  -- str_replace old new string → new string (replaces all occurrences)
  -- Uses strstr loop with proper frame management
  let srepl = "_rail_str_replace:\n    stp x29, x30, [sp, #-96]!\n    mov x29, sp\n    str x1, [x29, #24]\n    str x2, [x29, #32]\n    bl _str_unwrap\n    str x0, [x29, #16]\n    ldr x0, [x29, #24]\n    bl _str_unwrap\n    str x0, [x29, #24]\n    ldr x0, [x29, #32]\n    bl _str_unwrap\n    str x0, [x29, #32]\n    bl _strlen\n    str x0, [x29, #40]\n    ldr x0, [x29, #16]\n    bl _strlen\n    str x0, [x29, #48]\n    ldr x0, [x29, #24]\n    bl _strlen\n    str x0, [x29, #56]\n    ldr x0, [x29, #40]\n    lsl x0, x0, #2\n    add x0, x0, #64\n    bl _malloc\n    str x0, [x29, #64]\n    str xzr, [x29, #72]\n    ldr x0, [x29, #32]\n    str x0, [x29, #80]\n.Lsr_loop:\n    ldr x0, [x29, #80]\n    ldr x1, [x29, #16]\n    bl _strstr\n    cbz x0, .Lsr_rest\n    str x0, [x29, #88]\n    ldr x1, [x29, #80]\n    sub x2, x0, x1\n    ldr x3, [x29, #64]\n    ldr x4, [x29, #72]\n    add x5, x3, x4\n    mov x6, x2\n.Lsr_cp1:\n    cbz x6, .Lsr_cp1d\n    ldrb w7, [x1], #1\n    strb w7, [x5], #1\n    sub x6, x6, #1\n    b .Lsr_cp1\n.Lsr_cp1d:\n    ldr x4, [x29, #72]\n    add x4, x4, x2\n    ldr x1, [x29, #24]\n    ldr x6, [x29, #56]\n.Lsr_cp2:\n    cbz x6, .Lsr_cp2d\n    ldrb w7, [x1], #1\n    strb w7, [x5], #1\n    sub x6, x6, #1\n    b .Lsr_cp2\n.Lsr_cp2d:\n    ldr x6, [x29, #56]\n    add x4, x4, x6\n    str x4, [x29, #72]\n    ldr x0, [x29, #88]\n    ldr x1, [x29, #48]\n    add x0, x0, x1\n    str x0, [x29, #80]\n    b .Lsr_loop\n.Lsr_rest:\n    ldr x1, [x29, #80]\n    ldr x3, [x29, #64]\n    ldr x4, [x29, #72]\n    add x5, x3, x4\n.Lsr_cp3:\n    ldrb w7, [x1], #1\n    strb w7, [x5], #1\n    cbnz w7, .Lsr_cp3\n    ldr x0, [x29, #64]\n    bl _rail_wrap_str\n    str x0, [x29, #16]\n    ldr x0, [x29, #64]\n    bl _free\n    ldr x0, [x29, #16]\n    ldp x29, x30, [sp], #96\n    ret\n\n"
  -- str_split delim string → list (multi-char delimiter)
  let ssplit = "_rail_str_split:\n    stp x29, x30, [sp, #-64]!\n    mov x29, sp\n    str x1, [x29, #24]\n    bl _str_unwrap\n    str x0, [x29, #16]\n    ldr x0, [x29, #24]\n    bl _str_unwrap\n    str x0, [x29, #24]\n    ldr x0, [x29, #16]\n    bl _strlen\n    str x0, [x29, #32]\n    adrp x0, _rail_nil@PAGE\n    add x0, x0, _rail_nil@PAGEOFF\n    str x0, [x29, #40]\n    ldr x0, [x29, #24]\n    str x0, [x29, #48]\n.Lssp_loop:\n    ldr x0, [x29, #48]\n    ldr x1, [x29, #16]\n    bl _strstr\n    cbz x0, .Lssp_last\n    str x0, [x29, #56]\n    ldr x1, [x29, #48]\n    sub x2, x0, x1\n    add x0, x2, #1\n    bl _malloc\n    str x0, [sp, #-16]!\n    ldr x1, [x29, #48]\n    ldr x3, [x29, #56]\n    sub x2, x3, x1\n    mov x4, x2\n.Lssp_cp:\n    cbz x4, .Lssp_cpd\n    ldrb w5, [x1], #1\n    strb w5, [x0], #1\n    sub x4, x4, #1\n    b .Lssp_cp\n.Lssp_cpd:\n    mov w5, #0\n    strb w5, [x0]\n    ldr x0, [sp], #16\n    bl _rail_wrap_str\n    ldr x1, [x29, #40]\n    bl _rail_cons\n    str x0, [x29, #40]\n    ldr x0, [x29, #56]\n    ldr x1, [x29, #32]\n    add x0, x0, x1\n    str x0, [x29, #48]\n    b .Lssp_loop\n.Lssp_last:\n    ldr x0, [x29, #48]\n    bl _strlen\n    add x0, x0, #1\n    bl _malloc\n    str x0, [sp, #-16]!\n    ldr x1, [x29, #48]\n    bl _strcpy\n    ldr x0, [sp], #16\n    bl _rail_wrap_str\n    ldr x1, [x29, #40]\n    bl _rail_cons\n    str x0, [x29, #40]\n    ldr x0, [x29, #40]\n    bl _rail_reverse\n    ldp x29, x30, [sp], #64\n    ret\n\n"
  -- read_line → string (reads one line from stdin)
  --
  -- Restored 2026-04-08 via raw libc `read` on fd 0. Avoids the macOS-only
  -- `___stdinp@GOTPAGE` indirection that broke the Linux asm transform on
  -- 2026-04-07. `read` is in libSystem (macOS) and libc (Linux) under the
  -- same name, so the asm-transform underscore strip handles both targets.
  -- Reads one byte at a time until newline, EOF, or 1023 bytes. Result is a
  -- malloc'd null-terminated string with the trailing newline stripped.
  let readline = "_rail_read_line:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x19, [x29, #16]\n    str x20, [x29, #24]\n    mov x0, #1024\n    bl _malloc\n    mov x19, x0\n    mov x20, #0\n.Lrl_loop:\n    cmp x20, #1023\n    b.ge .Lrl_done\n    mov x0, #0\n    add x1, x19, x20\n    mov x2, #1\n    bl _read\n    cmp x0, #1\n    b.lt .Lrl_done\n    ldrb w0, [x19, x20]\n    cmp w0, #10\n    b.eq .Lrl_done\n    add x20, x20, #1\n    b .Lrl_loop\n.Lrl_done:\n    mov w0, #0\n    strb w0, [x19, x20]\n    mov x0, x19\n    bl _rail_wrap_str\n    ldr x19, [x29, #16]\n    ldr x20, [x29, #24]\n    ldp x29, x30, [sp], #32\n    ret\n\n"
  cat [sfind, scont, ssub, srepl, ssplit, readline]

rt_float =
  -- show_float: d0 = double, returns string pointer in x0
  let rshowf = "_rail_show_float:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str d0, [x29, #16]\n    mov x0, #32\n    bl _malloc\n    str x0, [x29, #24]\n    ldr d0, [x29, #16]\n    str d0, [sp, #-16]!\n    ldr x0, [x29, #24]\n    mov x1, #32\n    adrp x2, _fmt_gbare@PAGE\n    add x2, x2, _fmt_gbare@PAGEOFF\n    bl _snprintf\n    add sp, sp, #16\n    ldr x0, [x29, #24]\n    bl _rail_wrap_str\n    str x0, [x29, #16]\n    ldr x0, [x29, #24]\n    bl _free\n    ldr x0, [x29, #16]\n    ldp x29, x30, [sp], #32\n    ret\n\n"
  -- print_float: d0 = double, prints with newline
  let rprintf = "_rail_print_float:\n    stp x29, x30, [sp, #-48]!\n    mov x29, sp\n    str d0, [x29, #16]\n    mov x0, #32\n    bl _malloc\n    str x0, [x29, #24]\n    ldr d0, [x29, #16]\n    str d0, [sp, #-16]!\n    ldr x0, [x29, #24]\n    mov x1, #32\n    adrp x2, _fmt_gbare@PAGE\n    add x2, x2, _fmt_gbare@PAGEOFF\n    bl _snprintf\n    add sp, sp, #16\n    ldr x0, [x29, #24]\n    bl _strlen\n    mov x2, x0\n    mov x0, #1\n    ldr x1, [x29, #24]\n    movz x16, #4\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    mov w0, #10\n    strb w0, [x29, #32]\n    mov x0, #1\n    add x1, x29, #32\n    mov x2, #1\n    movz x16, #4\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    ldr x0, [x29, #24]\n    bl _free\n    mov x0, #1\n    ldp x29, x30, [sp], #48\n    ret\n\n"
  -- float_arr_new: x0 = size (tagged), d0 = init value (from x1 as raw bits)
  let rfarrnew = "_rail_float_arr_new:\n    stp x29, x30, [sp, #-48]!\n    mov x29, sp\n    asr x2, x0, #1\n    str x2, [x29, #16]\n    fmov d0, x1\n    str d0, [x29, #24]\n    lsl x0, x2, #3\n    add x0, x0, #8\n    bl _malloc\n    str x0, [x29, #32]\n    ldr x2, [x29, #16]\n    str x2, [x0]\n    ldr d0, [x29, #24]\n    mov x3, #0\n    ldr x4, [x29, #32]\n.Lfan_loop:\n    cmp x3, x2\n    b.hs .Lfan_done\n    add x5, x3, #1\n    str d0, [x4, x5, lsl #3]\n    add x3, x3, #1\n    b .Lfan_loop\n.Lfan_done:\n    ldr x0, [x29, #32]\n    ldp x29, x30, [sp], #48\n    ret\n\n"
  -- float_arr_get: x0 = arr, x1 = idx (tagged) → raw double bits in x0
  let rfarrget = "_rail_float_arr_get:\n    asr x1, x1, #1\n    add x1, x1, #1\n    ldr d0, [x0, x1, lsl #3]\n    fmov x0, d0\n    ret\n\n"
  -- float_arr_set: x0 = arr, x1 = idx (tagged), x2 = val (raw double bits) → 1
  let rfarrset = "_rail_float_arr_set:\n    asr x1, x1, #1\n    add x1, x1, #1\n    fmov d0, x2\n    str d0, [x0, x1, lsl #3]\n    mov x0, #3\n    ret\n\n"
  -- float_arr_len: x0 = arr → tagged int
  let rfarrlen = "_rail_float_arr_len:\n    ldr x0, [x0]\n    lsl x0, x0, #1\n    orr x0, x0, #1\n    ret\n\n"
  cat [rshowf, rprintf, rfarrnew, rfarrget, rfarrset, rfarrlen]

-- Effect handlers: try/catch with setjmp/longjmp
-- Handler frame: malloc'd block [prev_handler(8), jmp_buf(25*8=200), error_val(8)]
-- _rail_try: x0=body_closure, x1=handler_closure → result
-- If body calls error, longjmp unwinds to handler
rt_effects =
  let rtry = "_rail_try:\n    stp x29, x30, [sp, #-64]!\n    mov x29, sp\n    str x0, [x29, #16]\n    str x1, [x29, #24]\n    mov x0, #216\n    bl _malloc\n    str x0, [x29, #32]\n    adrp x1, _rail_handler_top@PAGE\n    add x1, x1, _rail_handler_top@PAGEOFF\n    ldr x2, [x1]\n    str x2, [x0]\n    str x0, [x1]\n    add x0, x0, #8\n    bl _setjmp\n    cbnz x0, .Ltry_caught\n    ldr x0, [x29, #16]\n    ldr x5, [x0, #8]\n    mov x0, #1\n    blr x5\n    str x0, [x29, #40]\n    ldr x0, [x29, #32]\n    ldr x1, [x0]\n    adrp x2, _rail_handler_top@PAGE\n    add x2, x2, _rail_handler_top@PAGEOFF\n    str x1, [x2]\n    ldr x0, [x29, #32]\n    bl _free\n    ldr x0, [x29, #40]\n    ldp x29, x30, [sp], #64\n    ret\n.Ltry_caught:\n    ldr x0, [x29, #32]\n    ldr x3, [x0, #208]\n    str x3, [x29, #48]\n    ldr x1, [x0]\n    adrp x2, _rail_handler_top@PAGE\n    add x2, x2, _rail_handler_top@PAGEOFF\n    str x1, [x2]\n    ldr x0, [x29, #32]\n    bl _free\n    ldr x0, [x29, #24]\n    ldr x5, [x0, #8]\n    ldr x1, [x0, #16]\n    cmp x1, #0\n    b.eq .Ltry_nocap\n    ldr x2, [x0, #24]\n    ldr x0, [x29, #48]\n    blr x5\n    ldp x29, x30, [sp], #64\n    ret\n.Ltry_nocap:\n    ldr x0, [x29, #48]\n    blr x5\n    ldp x29, x30, [sp], #64\n    ret\n\n"
  -- _rail_raise: x0=error_msg_string → noreturn (longjmp to handler)
  let rraise = "_rail_raise:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x0, [x29, #16]\n    adrp x1, _rail_handler_top@PAGE\n    add x1, x1, _rail_handler_top@PAGEOFF\n    ldr x2, [x1]\n    cbz x2, .Lraise_nohandler\n    ldr x0, [x29, #16]\n    str x0, [x2, #208]\n    add x0, x2, #8\n    mov x1, #1\n    bl _longjmp\n.Lraise_nohandler:\n    mov x0, #16\n    bl _rail_alloc\n    mov x1, #8\n    str x1, [x0]\n    ldr x1, [x29, #16]\n    str x1, [x0, #8]\n    ldp x29, x30, [sp], #32\n    ret\n\n"
  cat [rtry, rraise]

-- setjmp/longjmp + malloc/free: final libc eliminations
rt_syscall =
  -- Batch 1: string functions (inline ARM64 loops)
  let nstrlen = "_strlen:\n    mov x1, x0\n    mov x0, #0\n.Lsl_loop:\n    ldrb w2, [x1, x0]\n    cbz w2, .Lsl_done\n    add x0, x0, #1\n    b .Lsl_loop\n.Lsl_done:\n    ret\n\n"
  let nstrcmp = "_strcmp:\n    mov x2, #0\n.Lsc_loop:\n    ldrb w3, [x0, x2]\n    ldrb w4, [x1, x2]\n    cmp w3, w4\n    b.ne .Lsc_diff\n    cbz w3, .Lsc_eq\n    add x2, x2, #1\n    b .Lsc_loop\n.Lsc_diff:\n    sub x0, x3, x4\n    ret\n.Lsc_eq:\n    mov x0, #0\n    ret\n\n"
  let nstrcpy = "_strcpy:\n    mov x2, x0\n    mov x3, #0\n.Lscp_loop:\n    ldrb w4, [x1, x3]\n    strb w4, [x0, x3]\n    cbz w4, .Lscp_done\n    add x3, x3, #1\n    b .Lscp_loop\n.Lscp_done:\n    mov x0, x2\n    ret\n\n"
  let nstrcat = "_strcat:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    str x0, [x29, #16]\n    str x1, [x29, #24]\n    bl _strlen\n    ldr x1, [x29, #24]\n    ldr x2, [x29, #16]\n    add x0, x2, x0\n    bl _strcpy\n    ldr x0, [x29, #16]\n    ldp x29, x30, [sp], #32\n    ret\n\n"
  let natoi = "_atoi:\n    mov x1, #0\n    mov x2, #0\n    ldrb w3, [x0]\n    cmp w3, #45\n    b.ne .Latoi_loop\n    mov x2, #1\n    add x0, x0, #1\n.Latoi_loop:\n    ldrb w3, [x0], #1\n    cbz w3, .Latoi_done\n    cmp w3, #48\n    b.lt .Latoi_done\n    cmp w3, #57\n    b.gt .Latoi_done\n    sub w3, w3, #48\n    mov x4, #10\n    mul x1, x1, x4\n    add x1, x1, x3\n    b .Latoi_loop\n.Latoi_done:\n    cbz x2, .Latoi_pos\n    neg x1, x1\n.Latoi_pos:\n    mov x0, x1\n    ret\n\n"
  let nstrstr = "_strstr:\n    ldrb w2, [x1]\n    cbz w2, .Lstrstr_match\n.Lstrstr_outer:\n    ldrb w2, [x0]\n    cbz w2, .Lstrstr_notfound\n    mov x3, x0\n    mov x4, x1\n.Lstrstr_inner:\n    ldrb w5, [x4]\n    cbz w5, .Lstrstr_match\n    ldrb w6, [x3]\n    cbz w6, .Lstrstr_advance\n    cmp w5, w6\n    b.ne .Lstrstr_advance\n    add x3, x3, #1\n    add x4, x4, #1\n    b .Lstrstr_inner\n.Lstrstr_advance:\n    add x0, x0, #1\n    b .Lstrstr_outer\n.Lstrstr_match:\n    ret\n.Lstrstr_notfound:\n    mov x0, #0\n    ret\n\n"
  -- Batch 4+5: file I/O (Darwin syscalls)
  let nfopen = "_fopen:\n    stp x29, x30, [sp, #-16]!\n    mov x29, sp\n    ldrb w2, [x1]\n    cmp w2, #119\n    b.eq .Lfop_w\n    cmp w2, #97\n    b.eq .Lfop_a\n    mov x1, #0\n    mov x2, #0\n    movz x16, #5\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    b .Lfop_done\n.Lfop_w:\n    mov x1, #0x601\n    mov x2, #0x1A4\n    movz x16, #5\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    b .Lfop_done\n.Lfop_a:\n    mov x1, #0x209\n    mov x2, #0x1A4\n    movz x16, #5\n    movk x16, #0x200, lsl #16\n    svc #0x80\n.Lfop_done:\n    cmp x0, #0\n    b.ge .Lfop_ok\n    mov x0, #0\n.Lfop_ok:\n    ldp x29, x30, [sp], #16\n    ret\n\n"
  let nfread = "_fread:\n    mul x2, x1, x2\n    mov x1, x0\n    mov x0, x3\n    movz x16, #3\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    ret\n\n"
  let nfwrite = "_fwrite:\n    mul x2, x1, x2\n    mov x1, x0\n    mov x0, x3\n    movz x16, #4\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    ret\n\n"
  let nfclose = "_fclose:\n    movz x16, #6\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    ret\n\n"
  let nfseek = "_fseek:\n    movz x16, #199\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    mov x0, #0\n    ret\n\n"
  let nftell = "_ftell:\n    mov x1, #0\n    mov x2, #1\n    movz x16, #199\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    ret\n\n"
  let nread = "_read:\n    movz x16, #3\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    ret\n\n"
  let nfflush = "_fflush:\n    ret\n\n"
  -- setjmp/longjmp + malloc/free
  let nsetjmp = "_setjmp:\n    stp x19, x20, [x0]\n    stp x21, x22, [x0, #16]\n    stp x23, x24, [x0, #32]\n    stp x25, x26, [x0, #48]\n    stp x27, x28, [x0, #64]\n    stp x29, x30, [x0, #80]\n    mov x1, sp\n    str x1, [x0, #96]\n    stp d8, d9, [x0, #104]\n    stp d10, d11, [x0, #120]\n    stp d12, d13, [x0, #136]\n    stp d14, d15, [x0, #152]\n    mov x0, #0\n    ret\n\n"
  let nlongjmp = "_longjmp:\n    ldp x19, x20, [x0]\n    ldp x21, x22, [x0, #16]\n    ldp x23, x24, [x0, #32]\n    ldp x25, x26, [x0, #48]\n    ldp x27, x28, [x0, #64]\n    ldp x29, x30, [x0, #80]\n    ldr x2, [x0, #96]\n    mov sp, x2\n    ldp d8, d9, [x0, #104]\n    ldp d10, d11, [x0, #120]\n    ldp d12, d13, [x0, #136]\n    ldp d14, d15, [x0, #152]\n    mov x0, x1\n    cbnz x0, .Llj_done\n    mov x0, #1\n.Llj_done:\n    ret\n\n"
  let nmalloc = "_malloc:\n    stp x29, x30, [sp, #-32]!\n    mov x29, sp\n    add x0, x0, #15\n    and x0, x0, #-16\n    str x0, [x29, #16]\n    cmp x0, #65536\n    b.hi .Lmal_large\n    adrp x1, _rail_malloc_ptr@PAGE\n    add x1, x1, _rail_malloc_ptr@PAGEOFF\n    ldr x2, [x1]\n    cbz x2, .Lmal_newpage\n    ldr x3, [x29, #16]\n    add x4, x2, x3\n    adrp x5, _rail_malloc_end@PAGE\n    ldr x5, [x5, _rail_malloc_end@PAGEOFF]\n    cmp x4, x5\n    b.hi .Lmal_newpage\n    str x4, [x1]\n    mov x0, x2\n    ldp x29, x30, [sp], #32\n    ret\n.Lmal_newpage:\n    mov x0, #0\n    mov x1, #0x400000\n    mov x2, #3\n    mov x3, #0x1002\n    mov x4, #-1\n    mov x5, #0\n    movz x16, #197\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    b.cs .Lmal_fail\n    adrp x1, _rail_malloc_ptr@PAGE\n    add x1, x1, _rail_malloc_ptr@PAGEOFF\n    ldr x2, [x29, #16]\n    add x3, x0, x2\n    str x3, [x1]\n    add x5, x0, #0x400000\n    adrp x6, _rail_malloc_end@PAGE\n    add x6, x6, _rail_malloc_end@PAGEOFF\n    str x5, [x6]\n    ldp x29, x30, [sp], #32\n    ret\n.Lmal_large:\n    ldr x1, [x29, #16]\n    mov x0, #0\n    mov x2, #3\n    mov x3, #0x1002\n    mov x4, #-1\n    mov x5, #0\n    movz x16, #197\n    movk x16, #0x200, lsl #16\n    svc #0x80\n    b.cs .Lmal_fail\n    ldp x29, x30, [sp], #32\n    ret\n.Lmal_fail:\n    mov x0, #0\n    ldp x29, x30, [sp], #32\n    ret\n\n"
  let nfree = "_free:\n    ret\n\n"
  cat [nstrlen, nstrcmp, nstrcpy, nstrcat, natoi, nstrstr, nfopen, nfread, nfwrite, nfclose, nfseek, nftell, nread, nfflush, nsetjmp, nlongjmp, nmalloc, nfree]

runtime_asm = cat [rt_core, rt_list, rt_closure, rt_io, rt_args, rt_arith, rt_fiber, rt_thread, rt_array, rt_gpu, rt_string, rt_float, rt_effects, rt_str_gc, rt_gc_1, rt_gc_2, rt_gc_3, rt_gc_4, rt_syscall]

-- Check if variable name appears in AST node
uses_var node name =
  let tg = head node
  if tg == "V" then head (tail node) == name
  else if tg == "I" || tg == "S" || tg == "B" || tg == "FL" || tg == "NULL" || tg == "E" then false
  else if tg == "O" then uses_var (head (tail (tail node))) name || uses_var (head (tail (tail (tail node)))) name
  else if tg == "A" then uses_var (head (tail node)) name || uses_var (head (tail (tail node))) name
  else if tg == "F" then
    if head (tail node) == name then false
    else uses_var (head (tail (tail node))) name
  else if tg == "?" then uses_var (head (tail node)) name || uses_var (head (tail (tail node))) name || uses_var (head (tail (tail (tail node)))) name
  else if tg == "D" || tg == "TD" then
    if head (tail node) == name then uses_var (head (tail (tail node))) name
    else uses_var (head (tail (tail node))) name || uses_var (head (tail (tail (tail node)))) name
  else false

-- Match fold f init (range n) pattern
-- Returns (matched, f, init, n)
is_fold_range_app node =
  if head node != "A" then (false, [], [], [])
  else
    let fi_pair = head (tail node)
    let list_arg = head (tail (tail node))
    if head list_arg != "A" then (false, [], [], [])
    else
      let range_fn = head (tail list_arg)
      if head range_fn != "V" then (false, [], [], [])
      else if head (tail range_fn) != "range" then (false, [], [], [])
      else
        let n = head (tail (tail list_arg))
        if head fi_pair != "A" then (false, [], [], [])
        else
          let fold_f_pair = head (tail fi_pair)
          let init = head (tail (tail fi_pair))
          if head fold_f_pair != "A" then (false, [], [], [])
          else
            let fold_v = head (tail fold_f_pair)
            if head fold_v != "V" then (false, [], [], [])
            else if head (tail fold_v) != "fold" then (false, [], [], [])
            else (true, head (tail (tail fold_f_pair)), init, n)

-- Check if lambda is \a -> \b -> a + b
is_add_lambda f =
  if head f != "F" then false
  else
    let a_nm = head (tail f)
    let inner = head (tail (tail f))
    if head inner != "F" then false
    else
      let b_nm = head (tail inner)
      let body = head (tail (tail inner))
      if head body != "O" then false
      else if head (tail body) != "+" then false
      else
        let lft = head (tail (tail body))
        let rgt = head (tail (tail (tail body)))
        if head lft == "V" && head rgt == "V" then
          let lv = head (tail lft)
          let rv = head (tail rgt)
          (lv == a_nm && rv == b_nm) || (lv == b_nm && rv == a_nm)
        else false

-- Check if lambda ignores the list element (dead element)
-- Returns (dead, acc_name, body)
lambda_ignores_elem f =
  if head f != "F" then (false, "", [])
  else
    let a_nm = head (tail f)
    let inner = head (tail (tail f))
    if head inner != "F" then (false, "", [])
    else
      let b_nm = head (tail inner)
      let body = head (tail (tail inner))
      if b_nm == "_" then (true, a_nm, body)
      else if uses_var body b_nm then (false, "", [])
      else (true, a_nm, body)

is_map_app node =
  if head node != "A" then (false, [], [])
  else
    let fp = head (tail node)
    if head fp != "A" then (false, [], [])
    else
      let iv = head (tail fp)
      if head iv != "V" then (false, [], [])
      else if head (tail iv) != "map" then (false, [], [])
      else (true, head (tail (tail fp)), head (tail (tail node)))

opt node =
  let tg = head node
  if tg == "I" || tg == "FL" || tg == "NULL" || tg == "B" || tg == "S" || tg == "V" || tg == "E" then node
  else if tg == "O" then
    let op = head (tail node)
    let la = opt (head (tail (tail node)))
    let ra = opt (head (tail (tail (tail node))))
    if head la == "I" then
      if head ra == "I" then
        let lv = str_to_int (head (tail la))
        let rv = str_to_int (head (tail ra))
        if op == "+" then ["I", show (lv + rv)]
        else if op == "-" then ["I", show (lv - rv)]
        else if op == "*" then ["I", show (lv * rv)]
        else if op == "/" then if rv != 0 then ["I", show (lv / rv)] else ["O", op, la, ra]
        else if op == "%" then if rv != 0 then ["I", show (lv % rv)] else ["O", op, la, ra]
        else ["O", op, la, ra]
      else ["O", op, la, ra]
    else ["O", op, la, ra]
  else if tg == "?" then ["?", opt (head (tail node)), opt (head (tail (tail node))), opt (head (tail (tail (tail node))))]
  else if tg == "D" then ["D", head (tail node), opt (head (tail (tail node))), opt (head (tail (tail (tail node))))]
  else if tg == "TD" then ["TD", head (tail node), opt (head (tail (tail node))), opt (head (tail (tail (tail node))))]
  else opt2 node tg

opt2 node tg =
  if tg == "F" then ["F", head (tail node), opt (head (tail (tail node)))]
  else if tg == "L" then ["L", opt_l (head (tail node))]
  else if tg == "T" then ["T", opt_l (head (tail node))]
  else if tg == "M" then ["M", opt (head (tail node)), opt_ms (head (tail (tail node)))]
  else if tg == "A" then
    let onode = ["A", opt (head (tail node)), opt (head (tail (tail node)))]
    let (im, f, inner) = is_map_app onode
    if im then
      let (im2, g, d) = is_map_app inner
      if im2 then opt ["A", ["A", ["V", "map"], ["F", "_fx", ["A", f, ["A", g, ["V", "_fx"]]]]], d]
      else if head f == "F" then
        let fparam = head (tail f)
        let fbody = head (tail (tail f))
        if is_gpu_safe fbody fparam then
          if head inner != "V" then
            ["D", "_gd", inner, ["?", ["O", ">=", ["A", ["V", "length"], ["V", "_gd"]], ["I", "50000"]], ["A", ["A", ["V", "gpu_map"], f], ["V", "_gd"]], ["A", ["A", ["V", "map"], f], ["V", "_gd"]]]]
          else onode
        else onode
      else onode
    else
      -- fold f init (range n) algebraic optimizations
      let (ifr, fold_f, fold_init, range_n) = is_fold_range_app onode
      if ifr then
        if is_add_lambda fold_f then
          -- Triangular sum: fold (\a b -> a+b) init (range n) → init + n*(n-1)/2
          opt ["O", "+", fold_init, ["O", "/", ["O", "*", range_n, ["O", "-", range_n, ["I", "1"]]], ["I", "2"]]]
        else
          let (dead, a_nm, body) = lambda_ignores_elem fold_f
          if dead then
            if head body == "O" && head (tail body) == "+" then
              let lft = head (tail (tail body))
              let rgt = head (tail (tail (tail body)))
              if head lft == "V" && head (tail lft) == a_nm then
                -- fold (\a _ -> a + k) init (range n) → init + n * k
                opt ["O", "+", fold_init, ["O", "*", range_n, rgt]]
              else if head rgt == "V" && head (tail rgt) == a_nm then
                -- fold (\a _ -> k + a) init (range n) → init + n * k
                opt ["O", "+", fold_init, ["O", "*", range_n, lft]]
              else onode
            else onode
          else onode
      else onode
  else node

opt_l lst = if length lst == 0 then [] else cons (opt (head lst)) (opt_l (tail lst))

opt_ms arms =
  if length arms == 0 then []
  else
    let arm = head arms
    let g = if length arm > 3 then head (tail (tail (tail arm))) else []
    cons [head arm, head (tail arm), opt (head (tail (tail arm))), if length g == 0 then [] else opt g] (opt_ms (tail arms))

opt_decls decls =
  if length decls == 0 then []
  else
    let d = head decls
    if head d == "fn" then
      cons ["fn", head (tail d), head (tail (tail d)), opt (head (tail (tail (tail d))))] (opt_decls (tail decls))
    else cons d (opt_decls (tail decls))

-- GPU AUTO-DISPATCH

is_gpu_safe node param =
  let tg = head node
  if tg == "I" then true
  else if tg == "V" then head (tail node) == param
  else if tg == "O" then
    let op = head (tail node)
    if op == "+" || op == "-" || op == "*" || op == "/" || op == "%" then
      if is_gpu_safe (head (tail (tail node))) param then
        is_gpu_safe (head (tail (tail (tail node)))) param
      else false
    else false
  else false

ast_to_metal node param =
  let tg = head node
  if tg == "I" then head (tail node)
  else if tg == "V" then "x"
  else if tg == "O" then
    let op = head (tail node)
    let left = ast_to_metal (head (tail (tail node))) param
    let right = ast_to_metal (head (tail (tail (tail node)))) param
    cat ["(", left, " ", op, " ", right, ")"]
  else "0"

gen_metal_kernel body_expr =
  cat ["#include <metal_stdlib>\nusing namespace metal;\nkernel void rail_kernel(device int *data [[buffer(0)]], uint id [[thread_position_in_grid]]) {\n    int x = data[id];\n    data[id] = ", body_expr, ";\n}\n"]

build_ctor_siblings decls =
  if length decls == 0 then []
  else
    let d = head decls
    if head d == "TY" then
      let variants = head (tail (tail d))
      let names = get_ctor_names variants
      append (tag_siblings variants names) (build_ctor_siblings (tail decls))
    else build_ctor_siblings (tail decls)

get_ctor_names variants =
  if length variants == 0 then []
  else cons (head (head variants)) (get_ctor_names (tail variants))

tag_siblings variants names =
  if length variants == 0 then []
  else cons (head (head variants), names) (tag_siblings (tail variants) names)

str_in item lst =
  if length lst == 0 then false
  else if head lst == item then true
  else str_in item (tail lst)

find_missing all_ctors arm_ctors =
  if length all_ctors == 0 then []
  else
    let c = head all_ctors
    if str_in c arm_ctors then find_missing (tail all_ctors) arm_ctors
    else cons c (find_missing (tail all_ctors) arm_ctors)

arm_ctors arms =
  if length arms == 0 then []
  else
    let ctor = head (head arms)
    cons ctor (arm_ctors (tail arms))

find_sibs ctor siblings =
  if length siblings == 0 then []
  else
    let (k, v) = head siblings
    if k == ctor then v
    else find_sibs ctor (tail siblings)

check_match_exhaustive arms siblings =
  let ctors = arm_ctors arms
  if str_in "_" ctors then 0
  else if length ctors == 0 then 0
  else
    let first = head ctors
    let sibs = find_sibs first siblings
    if length sibs == 0 then 0
    else
      let missing = find_missing sibs ctors
      if length missing == 0 then 0
      else
        let _ = print (cat ["  error: non-exhaustive match -- missing: ", join ", " missing])
        1

check_node node siblings =
  let tg = head node
  if tg == "M" then
    let arms = head (tail (tail node))
    let e1 = check_match_exhaustive arms siblings
    let e2 = check_node (head (tail node)) siblings
    let e3 = check_arms_nodes arms siblings
    e1 + e2 + e3
  else if tg == "A" then
    let e1 = check_node (head (tail node)) siblings
    let e2 = check_node (head (tail (tail node))) siblings
    e1 + e2
  else if tg == "O" then
    let e1 = check_node (head (tail (tail node))) siblings
    let e2 = check_node (head (tail (tail (tail node)))) siblings
    e1 + e2
  else if tg == "?" then
    let e1 = check_node (head (tail node)) siblings
    let e2 = check_node (head (tail (tail node))) siblings
    let e3 = check_node (head (tail (tail (tail node)))) siblings
    e1 + e2 + e3
  else if tg == "D" then
    let e1 = check_node (head (tail (tail node))) siblings
    let e2 = check_node (head (tail (tail (tail node)))) siblings
    e1 + e2
  else if tg == "F" then
    check_node (head (tail (tail node))) siblings
  else 0

check_arms_nodes arms siblings =
  if length arms == 0 then 0
  else
    let body = head (tail (tail (head arms)))
    let e1 = check_node body siblings
    let e2 = check_arms_nodes (tail arms) siblings
    e1 + e2

check_exhaustiveness decls siblings =
  if length decls == 0 then 0
  else
    let d = head decls
    if head d == "fn" then
      let nm = head (tail d)
      let body = head (tail (tail (tail d)))
      let e1 = check_node body siblings
      let e2 = check_exhaustiveness (tail decls) siblings
      e1 + e2
    else check_exhaustiveness (tail decls) siblings

tc_lookup name tenv =
  if length tenv == 0 then "any"
  else
    let (k, v) = head tenv
    if k == name then v
    else tc_lookup name (tail tenv)

tc_builtin_ret fname =
  if fname == "head" then ("list", "any", 1)
  else if fname == "tail" then ("list", "list", 1)
  else if fname == "reverse" then ("list", "list", 1)
  else if fname == "range" then ("int", "list", 1)
  else if fname == "length" then ("any", "int", 1)
  else if fname == "show" then ("any", "string", 1)
  else if fname == "print" then ("any", "int", 1)
  else if fname == "read_file" then ("string", "string", 1)
  else if fname == "shell" then ("string", "string", 1)
  else if fname == "chars" then ("string", "list", 1)
  else if fname == "char_to_int" then ("string", "int", 1)
  else if fname == "byte_at" then ("any", "int", 2)
  else if fname == "byte_set" then ("any", "int", 3)
  else if fname == "not" then ("bool", "bool", 1)
  else if fname == "to_float" then ("int", "float", 1)
  else if fname == "parse_float" then ("string", "float", 1)
  else if fname == "to_int" then ("float", "int", 1)
  else tc_builtin_ret2 fname

tc_builtin_ret2 fname =
  if fname == "cons" then ("any", "list", 2)
  else if fname == "append" then ("any", "any", 2)
  else if fname == "write_file" then ("string", "int", 2)
  else if fname == "split" then ("string", "list", 2)
  else if fname == "join" then ("string", "string", 2)
  else if fname == "map" then ("fun", "list", 2)
  else if fname == "filter" then ("fun", "list", 2)
  else if fname == "fold" then ("fun", "any", 3)
  else if fname == "llm" then ("any", "string", 3)  -- llm is now in stdlib/llm.rail but keep type info
  else ("any", "any", 0 - 1)

tc_infer node tenv fname_ctx =
  let tg = head node
  if tg == "I" then "int"
  else if tg == "FL" then "float"
  else if tg == "S" then "string"
  else if tg == "B" then "bool"
  else if tg == "NULL" then "any"
  else if tg == "V" then tc_lookup (head (tail node)) tenv
  else if tg == "L" then "list"
  else if tg == "T" then "tuple"
  else if tg == "F" then "fun"
  else if tg == "O" then tc_infer_op node tenv fname_ctx
  else if tg == "?" then tc_infer_if node tenv fname_ctx
  else if tg == "D" then tc_infer_let node tenv fname_ctx
  else if tg == "TD" then tc_infer_td node tenv fname_ctx
  else if tg == "A" then tc_infer_app node tenv fname_ctx
  else if tg == "M" then "any"
  else "any"

tc_infer_op node tenv fname_ctx =
  let op = head (tail node)
  let lt = tc_infer (head (tail (tail node))) tenv fname_ctx
  let rt = tc_infer (head (tail (tail (tail node)))) tenv fname_ctx
  if op == "+" then
    if lt == "string" || rt == "string" then "string"
    else if lt == "float" || rt == "float" then "float"
    else "int"
  else if op == "-" || op == "*" || op == "/" || op == "%" then
    let _ = if lt == "string" then print (cat ["  WARNING [typecheck] in ", fname_ctx, ": arithmetic '", op, "' on string value"]) else 0
    let _ = if rt == "string" then print (cat ["  WARNING [typecheck] in ", fname_ctx, ": arithmetic '", op, "' on string value"]) else 0
    let _ = if lt == "list" then print (cat ["  WARNING [typecheck] in ", fname_ctx, ": arithmetic '", op, "' on list value"]) else 0
    let _ = if rt == "list" then print (cat ["  WARNING [typecheck] in ", fname_ctx, ": arithmetic '", op, "' on list value"]) else 0
    let _ = if lt == "bool" then print (cat ["  WARNING [typecheck] in ", fname_ctx, ": arithmetic '", op, "' on bool value"]) else 0
    let _ = if rt == "bool" then print (cat ["  WARNING [typecheck] in ", fname_ctx, ": arithmetic '", op, "' on bool value"]) else 0
    if lt == "float" || rt == "float" then "float" else "int"
  else if op == "&&" || op == "||" then "bool"
  else if op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" then
    let _ = if op == "<" || op == ">" || op == "<=" || op == ">=" then
      if lt != "any" then
        if rt != "any" then
          if lt != rt then
            print (cat ["  WARNING [typecheck] in ", fname_ctx, ": comparison '", op, "' on mismatched types '", lt, "' and '", rt, "'"])
          else 0
        else 0
      else 0
    else 0
    "bool"
  else "any"

tc_infer_if node tenv fname_ctx =
  let _ = tc_infer (head (tail node)) tenv fname_ctx
  let then_t = tc_infer (head (tail (tail node))) tenv fname_ctx
  let else_t = tc_infer (head (tail (tail (tail node)))) tenv fname_ctx
  if then_t == else_t then then_t
  else if then_t == "any" then else_t
  else if else_t == "any" then then_t
  else "any"

tc_infer_let node tenv fname_ctx =
  let nm = head (tail node)
  let val_t = tc_infer (head (tail (tail node))) tenv fname_ctx
  let tenv2 = cons (nm, val_t) tenv
  tc_infer (head (tail (tail (tail node)))) tenv2 fname_ctx

tc_infer_td node tenv fname_ctx =
  let names = head (tail node)
  let _ = tc_infer (head (tail (tail node))) tenv fname_ctx
  let tenv2 = tc_add_names names tenv
  tc_infer (head (tail (tail (tail node)))) tenv2 fname_ctx

tc_add_names names tenv =
  if length names == 0 then tenv
  else tc_add_names (tail names) (cons (head names, "any") tenv)

tc_infer_app node tenv fname_ctx =
  let (fname, fargs) = flat node
  let nargs = length fargs
  if fname == "_expr" then
    let fn_node = get_app_fn node
    if head fn_node == "F" then "any"
    else
      let fn_t = tc_infer fn_node tenv fname_ctx
      let _ = if fn_t != "any" then
        if fn_t != "fun" then
          print (cat ["  WARNING [typecheck] in ", fname_ctx, ": calling non-function value of type '", fn_t, "'"])
        else 0
      else 0
      "any"
  else
    let (exp_arg_t, ret_t, bi_arity) = tc_builtin_ret fname
    if bi_arity != (0 - 1) then
      -- Check arity for builtins
      let _ = if bi_arity != nargs then
        if bi_arity > 0 then
          print (cat ["  WARNING [typecheck] in ", fname_ctx, ": '", fname, "' expects ", show bi_arity, " argument(s), got ", show nargs])
        else 0
      else 0
      -- Check first argument type for single-arg builtins that expect list
      let _ = if nargs >= 1 then
        if exp_arg_t == "list" then
          let arg_t = tc_infer (head fargs) tenv fname_ctx
          if arg_t != "any" then
            if arg_t != "list" then
              print (cat ["  WARNING [typecheck] in ", fname_ctx, ": '", fname, "' expects list argument, got '", arg_t, "'"])
            else 0
          else 0
        else 0
      else 0
      ret_t
    else
      -- User-defined or local variable: check if calling a non-function
      let var_t = tc_lookup fname tenv
      let _ = if var_t != "any" then
        if var_t != "fun" then
          print (cat ["  WARNING [typecheck] in ", fname_ctx, ": calling non-function '", fname, "' of type '", var_t, "'"])
        else 0
      else 0
      let _ = tc_infer_args fargs tenv fname_ctx
      "any"

tc_infer_args fargs tenv fname_ctx =
  if length fargs == 0 then 0
  else
    let _ = tc_infer (head fargs) tenv fname_ctx
    tc_infer_args (tail fargs) tenv fname_ctx

tc_param_env params =
  if length params == 0 then []
  else cons (head params, "any") (tc_param_env (tail params))

tc_check_decls decls =
  if length decls == 0 then 0
  else
    let d = head decls
    if head d == "fn" then
      let nm = head (tail d)
      let ps = head (tail (tail d))
      let body = head (tail (tail (tail d)))
      let tenv = tc_param_env ps
      let _ = tc_infer body tenv nm
      tc_check_decls (tail decls)
    else tc_check_decls (tail decls)

list_nth lst n =
  if length lst == 0 then (0, 0)
  else if n == 0 then head lst
  else list_nth (tail lst) (n - 1)

ce_node node =
  let tg = head node
  if tg == "E" then [(head (tail node), if length node > 2 then head (tail (tail node)) else "0")]
  else if tg == "I" || tg == "FL" || tg == "NULL" || tg == "B" || tg == "S" || tg == "V" then []
  else if tg == "O" then append (ce_node (head (tail (tail node)))) (ce_node (head (tail (tail (tail node)))))
  else if tg == "?" then append (ce_node (head (tail node))) (append (ce_node (head (tail (tail node)))) (ce_node (head (tail (tail (tail node))))))
  else if tg == "D" then append (ce_node (head (tail (tail node)))) (ce_node (head (tail (tail (tail node)))))
  else if tg == "TD" then append (ce_node (head (tail (tail node)))) (ce_node (head (tail (tail (tail node)))))
  else if tg == "A" then append (ce_node (head (tail node))) (ce_node (head (tail (tail node))))
  else if tg == "F" then ce_node (head (tail (tail node)))
  else if tg == "L" then ce_list (head (tail node))
  else if tg == "T" then ce_list (head (tail node))
  else if tg == "M" then append (ce_node (head (tail node))) (ce_arms (head (tail (tail node))))
  else []

ce_list elems =
  if length elems == 0 then []
  else append (ce_node (head elems)) (ce_list (tail elems))

ce_arms arms =
  if length arms == 0 then []
  else
    let arm = head arms
    let body = head (tail (tail arm))
    append (ce_node body) (ce_arms (tail arms))

ce_decls decls =
  if length decls == 0 then []
  else
    let d = head decls
    let tg = head d
    if tg == "E" then cons (head (tail d), if length d > 2 then head (tail (tail d)) else "0") (ce_decls (tail decls))
    else if tg == "fn" then
      let body = head (tail (tail (tail d)))
      append (ce_node body) (ce_decls (tail decls))
    else ce_decls (tail decls)

report_errors errs positions ntoks fname =
  if length errs == 0 then 0
  else
    let (msg, rem_str) = head errs
    let rem = str_to_int rem_str
    let idx = if ntoks > rem then ntoks - rem else 0
    let (ln, col) = list_nth positions idx
    let _ = print (cat [fname, ":", show ln, ":", show col, ": error: ", msg])
    1 + report_errors (tail errs) positions ntoks fname

-- Data section: format strings for printf/snprintf, runtime globals,
-- 512MB BSS heap. Single source — both compile_program paths share it.
-- _fmt_int: "%ld\n"  _fmt_str: "%s\n"  _fmt_ld: "%ld"
data_section_asm = "\n.section __DATA,__data\n_fmt_int:\n    .byte 37, 108, 100, 10, 0\n_fmt_str:\n    .byte 37, 115, 10, 0\n_fmt_ld:\n    .byte 37, 108, 100, 0\n_fmt_g:\n    .asciz \"%g\\n\"\n_fmt_gbare:\n    .asciz \"%.15g\"\n.p2align 3\n_rail_empty_str:\n    .byte 0\n_mode_w:\n    .asciz \"w\"\n_mode_r:\n    .asciz \"r\"\n.p2align 3\n_rail_nil:\n    .quad 2\n.p2align 3\n.global _rail_heap_ptr\n_rail_heap_ptr:\n    .quad _rail_heap\n.p2align 3\n.global _rail_heap_end\n_rail_heap_end:\n    .quad _rail_heap + 536870912\n.p2align 3\n_rail_argc:\n    .quad 0\n_rail_argv:\n    .quad 0\n.p2align 3\n_rail_handler_top:\n    .quad 0\n.global _rail_heap\n.zerofill __DATA,__bss,_rail_heap,536870912,3\n"

compile_program_with_file src fname =
  let (toks, positions) = tokenize_with_pos src
  let ntoks = length toks
  let decls = pprog toks
  let errs = ce_decls decls
  let nerrs = report_errors errs positions ntoks fname
  if nerrs > 0 then
    let _ = print (cat [show nerrs, " error(s) found"])
    ""
  else compile_checked decls

compile_checked decls =
  let decls = opt_decls decls
  let ar = get_arities decls
  let siblings = build_ctor_siblings decls
  let match_errs = check_exhaustiveness decls siblings
  if match_errs > 0 then
    let _ = print (cat [show match_errs, " non-exhaustive match error(s) -- add missing arms or wildcard _"])
    ""
  else
  let _ = tc_check_decls decls
  let hdr = ".section __TEXT,__text\n.global _main\n.p2align 2\n\n"
  let (funcs, _) = compile_funcs decls ar 0
  let rt = runtime_asm
  cat [hdr, funcs, rt, data_section_asm]

compile_program src =
  let toks = tokenize src
  let decls = pprog toks
  let decls = opt_decls decls
  let ar = get_arities decls
  let siblings = build_ctor_siblings decls
  let match_errs = check_exhaustiveness decls siblings
  if match_errs > 0 then
    let _ = print (cat [show match_errs, " non-exhaustive match error(s) -- add missing arms or wildcard _"])
    ""
  else
  let _ = tc_check_decls decls
  let hdr = ".section __TEXT,__text\n.global _main\n.p2align 2\n\n"
  let (funcs, _) = compile_funcs decls ar 0
  let rt = runtime_asm
  cat [hdr, funcs, rt, data_section_asm]

-- BUILD: assemble + link

get_runtime_dir _ =
  let bindir = trim (shell (cat ["dirname '", head args, "'"]))
  let probe = trim (shell (cat ["test -f '", bindir, "/runtime/gc.o' && echo '", bindir, "/runtime' || echo runtime"]))
  probe

build asm_text =
  let _ = write_file "/tmp/rail_out.s" asm_text
  let uname = trim (shell "uname -s 2>/dev/null")
  if uname == "Linux" then build_native_linux asm_text
  else
    let sdk = trim (shell "xcrun --show-sdk-path")
    let rtdir = get_runtime_dir 0
    let as_result = trim (shell "as -o /tmp/rail_out.o /tmp/rail_out.s 2>&1")
    let _ = if as_result != "" then print (cat ["  as: ", as_result]) else print "  as: OK"
    let has_llm = trim (shell "grep -c 'b _llm' /tmp/rail_out.s 2>/dev/null || echo 0")
    let _ = if has_llm != "0" then
      let tramp = ".global _llm\n_llm:\n    b _rail_llm\n"
      let _ = shell (cat ["echo '", tramp, "' > /tmp/rail_llm_tramp.s && as -o /tmp/rail_llm_tramp.o /tmp/rail_llm_tramp.s 2>&1"])
      0
    else 0
    let rt_objs = if has_llm != "0" then cat [" ", rtdir, "/llm.o /tmp/rail_llm_tramp.o"] else ""
    let ld_cmd = cat ["ld -o /tmp/rail_out /tmp/rail_out.o", rt_objs, " -lSystem -syslibroot ", sdk, " -arch arm64 -stack_size 0x10000000 2>&1"]
    let ld_result = trim (shell ld_cmd)
    let _ = if ld_result != "" then print (cat ["  ld: ", ld_result]) else print "  ld: OK"
    let _ = shell "codesign -s - /tmp/rail_out 2>&1"
    0

build_native_linux asm_text =
  -- On native Linux: use build_linux pipeline (transform macOS asm → Linux ELF).
  -- asm_text is the buffer the caller already wrote to /tmp/rail_out.s; pass it
  -- straight through so we don't bounce through disk twice.
  let _ = build_linux asm_text
  let _ = shell "cp /tmp/rail_linux /tmp/rail_out 2>&1"
  0

trim s = head (split "\n" s)

run_test name src expected =
  let _ = print (cat ["  --- ", name, " ---"])
  let asm = compile_program src
  let _ = build asm
  let output = trim (shell "/tmp/rail_out 2>&1 ; echo $?")
  let lines = split "\n" output
  -- Get the last line (exit code) and everything before it (stdout)
  let result = get_test_result lines expected
  result

get_test_result lines expected =
  let exit_code = last_elem lines
  let stdout_lines = init_list lines
  let stdout = join "\n" stdout_lines
  let actual = if length stdout_lines > 0 then stdout else exit_code
  let pass = actual == expected
  let _ = if pass then print (cat ["  PASS: ", actual]) else print (cat ["  FAIL: got [", actual, "] expected [", expected, "]"])
  pass

last_elem lst =
  if length lst == 1 then head lst
  else last_elem (tail lst)

init_list lst =
  if length lst <= 1 then []
  else cons (head lst) (init_list (tail lst))

args = []

compile_file path =
  let src = read_file path
  let _ = print (cat ["Compiling ", path, " (", show (length src), " chars)..."])
  let asm = compile_program_with_file src path
  if length asm == 0 then 1
  else
    let _ = build asm
    0

run_tests _ =
  let _ = print "=== Rail ARM64 Compiler ==="
  let _ = print ""
  let t1 = run_test "main=42" "main = 42" "42"
  let t2 = run_test "3+4" "main = 3 + 4" "7"
  let t3 = run_test "if" "main = if 1 == 1 then 42 else 0" "42"
  let t4 = run_test "double" "double x = x * 2\nmain = double 21" "42"
  let t5 = run_test "fact" "fact n =\n  if n <= 1 then 1\n  else n * fact (n - 1)\nmain = fact 5" "120"
  let t6 = run_test "print" "main =\n  let _ = print 42\n  0" "42"
  let t7 = run_test "add" "add x y = x + y\nmain = add 17 25" "42"
  let t8 = run_test "lets" "main =\n  let a = 7\n  let b = a * a\n  b - 1" "48"
  let t9 = run_test "strprint" "main =\n  let _ = print \"hello\"\n  0" "hello"
  let t10 = run_test "streq" "main = if \"ab\" == \"ab\" then 1 else 0" "1"
  let t11 = run_test "strne" "main = if \"ab\" == \"cd\" then 1 else 0" "0"
  let t12 = run_test "show" "main =\n  let _ = print (show 42)\n  0" "42"
  let t13 = run_test "append" "main =\n  let _ = print (append \"hel\" \"lo\")\n  0" "hello"
  let t14 = run_test "str+" "main =\n  let _ = print (\"foo\" + \"bar\")\n  0" "foobar"
  let t15 = run_test "listlen" "main = length [10, 20, 30]" "3"
  let t16 = run_test "headtail" "main = head (tail [10, 20, 30])" "20"
  let t17 = run_test "cons" "main = head (cons 42 [1, 2])" "42"
  let t18 = run_test "listapp" "main = length (append [1, 2] [3, 4, 5])" "5"
  let t19 = run_test "empty" "main = length []" "0"
  let t20 = run_test "strlen" "main = length \"hello\"" "5"
  let t21 = run_test "mapfn" "double x = x * 2\nmain = head (map double [3, 5, 7])" "6"
  let t22 = run_test "maplam" "main = head (map (\\x -> x + 10) [5, 6, 7])" "15"
  let t23 = run_test "closure" "main =\n  let n = 100\n  head (map (\\x -> x + n) [1, 2, 3])" "101"
  let t24 = run_test "join" "main =\n  let _ = print (join \"-\" [\"a\", \"b\", \"c\"])\n  0" "a-b-c"
  let t25 = run_test "tuple" "main =\n  let (a, b) = (10, 32)\n  a + b" "42"
  let t26 = run_test "tupret" "swap a b = (b, a)\nmain =\n  let (x, y) = swap 1 2\n  x * 10 + y" "21"
  let t27 = run_test "tup3" "main =\n  let (a, b, c) = (100, 20, 3)\n  a + b + c" "123"
  let t28 = run_test "chars" "main =\n  let cs = chars \"abc\"\n  let _ = print (head cs)\n  length cs" "a"
  let t29 = run_test "split" "main =\n  let _ = print (head (tail (split \",\" \"a,b,c\")))\n  0" "b"
  let t30 = run_test "fileio" "main =\n  let _ = write_file \"/tmp/rail_test.txt\" \"hello42\"\n  let s = read_file \"/tmp/rail_test.txt\"\n  let _ = print s\n  0" "hello42"
  let t31 = run_test "shell" "main =\n  let _ = print (head (split \"\\n\" (shell \"echo hi\")))\n  0" "hi"
  let t32 = run_test "integ" "cat parts = join \"\" parts\ndbl x = x * 2\nmain =\n  let xs = map dbl [3, 5, 7]\n  let (a, b) = (head xs, length xs)\n  let _ = print (cat [\"sum=\", show (a + b)])\n  0" "sum=9"
  let t33 = run_test "tco" "loop n = if n == 0 then 42 else loop (n - 1)\nmain =\n  let _ = print (show (loop 50000))\n  0" "42"
  let t34 = run_test "bigint" "main =\n  let x = 100000\n  x - 99958" "42"
  let t35 = run_test "adt_none" "type Option = | Some x | None\nmain = match None | Some x -> x | None -> 42" "42"
  let t36 = run_test "adt_some" "type Option = | Some x | None\nmain = match (Some 42) | Some x -> x | None -> 0" "42"
  let t37 = run_test "adt_pair" "type Pair = | MkPair a b\nfst p = match p | MkPair a b -> a\nmain = fst (MkPair 10 32)" "10"
  let t38 = run_test "neg" "main =\n  let _ = print (show (-42))\n  0" "-42"
  let t39 = run_test "escape" "main =\n  let _ = print \"\\{hello\\}\"\n  0" "{hello}"
  let t40 = run_test "float" "main =\n  let _ = print (show (1.5 + 2.25))\n  0" "3.75"
  let t41 = run_test "float_mul" "main =\n  let _ = print (show (3.0 * 2.5))\n  0" "7.5"
  let t42 = run_test "float_cmp" "main = if 3.14 > 2.71 then 1 else 0" "1"
  let t43 = run_test "ffi_abs" "foreign abs n\nmain =\n  let _ = print (show (abs (-5)))\n  0" "5"
  let t44 = run_test "ffi_strlen" "foreign strlen s\nmain =\n  let _ = print (show (strlen \"hello\"))\n  0" "5"
  let home = trim (shell "echo $HOME")
  let t45 = run_test "ffi_getenv" "foreign getenv s -> str\nmain =\n  let _ = print (getenv \"HOME\")\n  0" home
  let t46 = run_test "wildcard" "type T = | A x | B x | C\nmain = match (B 99)\n  | A x -> 0\n  | _ -> 42" "42"
  let _ = write_file "/tmp/rail_importlib.rail" "double x = x * 2\ntriple x = x * 3\n"
  let t47 = run_test "import" "import \"/tmp/rail_importlib.rail\"\nmain = double 21 + triple 1" "45"
  let t48 = run_test "arena" "main =\n  let m = arena_mark 0\n  let _ = cons 1 [2, 3]\n  let _ = arena_reset m\n  42" "42"
  let t49 = run_test "filter" "gt2 x = if x > 2 then true else false\nmain = length (filter gt2 [1, 2, 3, 4, 5])" "3"
  let t50 = run_test "fold" "add a b = a + b\nmain = fold add 0 [1, 2, 3, 4, 5]" "15"
  let t51 = run_test "reverse" "main =\n  let xs = reverse [1, 2, 3]\n  head xs" "3"
  let t52 = run_test "to_float" "main =\n  let _ = print (show (to_float 42))\n  0" "42"
  let t53 = run_test "not" "main = if not false then 1 else 0" "1"
  let t54 = run_test "range" "main = length (range 10)" "10"
  let t55 = run_test "fold_sum" "add a b = a + b\nmain =\n  let _ = print (show (fold add 0 (range 101)))\n  0" "5050"
  let t56 = run_test "neg_arith" "main = 10 + (-3)" "7"
  let t57 = run_test "spawn" "work x = x * 2\nmain =\n  let f = spawn (\\x -> work 21)\n  fiber_await f" "42"
  let t58 = run_test "match_int" "classify n = match n\n  | 0 -> \"zero\"\n  | 1 -> \"one\"\n  | _ -> \"other\"\nmain =\n  let _ = print (classify 1)\n  0" "one"
  let t59 = run_test "guard" "type Option = | Some x | None\nsafe_div a b = match b\n  | 0 -> None\n  | _ -> Some (a / b)\nmain = match (safe_div 10 2)\n  | Some x -> x\n  | None -> 0" "5"
  let _ = write_file "/tmp/rail_quallib.rail" "double x = x * 2\n_private x = x\n"
  let t60 = run_test "qual_import" "import \"/tmp/rail_quallib.rail\" as M\nmain = M_double 21" "42"
  let t61 = run_test "rc" "foreign free p\nmain =\n  let p = rc_alloc 16\n  let _ = rc_retain p\n  let _ = rc_release p\n  let _ = rc_release p\n  42" "42"
  let t62 = run_test "channel" "main =\n  let ch = channel 0\n  let _ = send ch 10\n  let _ = send ch 20\n  let _ = send ch 30\n  let a = recv ch\n  let b = recv ch\n  a + b" "30"
  let t63 = run_test "ffi_float" "foreign sqrt x -> float\nmain =\n  let _ = print (show (to_int (sqrt (to_float 144))))\n  0" "12"
  let t64 = run_test "map_fusion" "double x = x * 2\ntriple x = x * 3\nmain = head (map double (map triple [1, 2, 3]))" "6"
  let _ = write_file "/tmp/rail_gen_code.rail" "fact n = if n <= 1 then 1 else n * fact (n - 1)\n"
  let t65 = run_test "generate_ct" "#generate \"factorial\"\nmain =\n  let _ = print (show (fact 10))\n  0" "3628800"
  let _ = shell "ls /tmp/gpu_host >/dev/null 2>&1 && echo ok || clang -framework Metal -framework Foundation tools/gpu_host.m -o /tmp/gpu_host 2>/dev/null"
  let t66 = run_test "gpu_map" "main =\n  let r = gpu_map (\\x -> x * 3 + 1) (range 8)\n  let _ = print (show (head r))\n  0" "1"
  let t67 = run_test "gpu_auto" "main =\n  let r = map (\\x -> x * 2 + 1) (range 8)\n  let _ = print (show (head r))\n  0" "1"
  let t68 = run_test "nested_lam" "main = (\\a -> \\b -> a + b) 3 4" "7"
  let t69 = run_test "nested_lam_let" "main =\n  let f = \\a -> \\b -> a + b\n  f 3 4" "7"
  let t70 = run_test "nested_lam_cap" "main =\n  let n = 10\n  let f = \\a -> \\b -> a + b + n\n  f 3 4" "17"
  -- v1.5.0: bare imports
  let _ = write_file "baremod.rail" "square x = x * x\n"
  let t71 = run_test "bare_import" "import baremod\nmain = square 7" "49"
  let t72 = run_test "bare_import_as" "import baremod as B\nmain = B_square 6" "36"
  let _ = shell "rm -f baremod.rail"
  -- v1.5.0: pipe operator
  let t73 = run_test "pipe" "inc x = x + 1\ndbl x = x * 2\nmain = 3 |> inc |> dbl" "8"
  -- v1.5.0: multi-match-int
  let t74 = run_test "match_str" "greet s = match s\n  | \"hi\" -> \"hello\"\n  | _ -> \"huh\"\nmain =\n  let _ = print (greet \"hi\")\n  0" "hello"
  -- v1.5.0: list literal in fold
  let t75 = run_test "fold_str" "cat a b = append a b\nmain =\n  let _ = print (fold cat \"\" [\"a\", \"b\", \"c\"])\n  0" "abc"
  -- v1.5.0: hash maps
  let t76 = run_test "map_new" "import \"stdlib/map.rail\"\nmain = map_size (map_new 0)" "0"
  let t77 = run_test "map_put_get" "import \"stdlib/map.rail\"\nmain =\n  let m = map_new 0\n  let m = map_put m \"x\" 42\n  map_get m \"x\"" "42"
  let t78 = run_test "map_has" "import \"stdlib/map.rail\"\nmain =\n  let m = map_put (map_new 0) \"a\" 1\n  if map_has m \"a\" then 1 else 0" "1"
  let t79 = run_test "map_keys" "import \"stdlib/map.rail\"\nmain =\n  let m = map_put (map_new 0) \"k\" 9\n  length (map_keys m)" "1"
  let t80 = run_test "map_int_key" "import \"stdlib/map.rail\"\nmain =\n  let m = map_put (map_new 0) 10 99\n  map_get m 10" "99"
  -- v1.5.0: string buffers
  let t81 = run_test "buf_new" "import \"stdlib/strbuf.rail\"\nmain = buf_len (buf_new 0)" "0"
  let t82 = run_test "buf_append" "import \"stdlib/strbuf.rail\"\nmain =\n  let b = buf_append (buf_new 0) \"hello\"\n  let _ = print (buf_str b)\n  0" "hello"
  let t83 = run_test "buf_multi" "import \"stdlib/strbuf.rail\"\nmain =\n  let b = buf_append (buf_append (buf_append (buf_new 0) \"a\") \"b\") \"c\"\n  let _ = print (buf_str b)\n  0" "abc"
  let t84 = run_test "buf_int" "import \"stdlib/strbuf.rail\"\nmain =\n  let b = buf_append_int (buf_append (buf_new 0) \"x=\") 42\n  let _ = print (buf_str b)\n  0" "x=42"
  let t85 = run_test "buf_big" "import \"stdlib/strbuf.rail\"\nhelper b n = if n == 0 then b else helper (buf_append b \"x\") (n - 1)\nmain = buf_len (helper (buf_new 0) 100)" "100"
  let t86 = run_test "arr_new" "main =\n  let a = arr_new 3 42\n  arr_get a 1" "42"
  let t87 = run_test "arr_set" "main =\n  let a = arr_new 3 0\n  let _ = arr_set a 1 99\n  arr_get a 1" "99"
  let t88 = run_test "arr_len" "main =\n  let a = arr_new 10 0\n  arr_len a" "10"
  let t89 = run_test "arr_sum" "sum a i = if i >= arr_len a then 0 else arr_get a i + sum a (i + 1)\nmain =\n  let a = arr_new 5 10\n  sum a 0" "50"
  let t90 = run_test "error" "main =\n  let e = error \"oops\"\n  let ok = is_error e\n  let bad = is_error 42\n  ok - bad" "1"
  let t91 = run_test "thread" "double x = x * 2\nmain =\n  let t = spawn_thread double 21\n  join_thread t" "42"
  let t92 = run_test "thread_par" "add10 x = x + 10\nmain =\n  let t1 = spawn_thread add10 5\n  let t2 = spawn_thread add10 20\n  let a = join_thread t1\n  let b = join_thread t2\n  a + b" "45"
  let t93 = run_test "char_to_int" "main = char_to_int \"A\"" "65"
  let t94 = run_test "set_basic" "import \"stdlib/hash.rail\"\nmain =\n  let s = set_add (set_new 0) \"foo\"\n  if set_contains s \"foo\" then 42 else 0" "42"
  let t95 = run_test "set_absent" "import \"stdlib/hash.rail\"\nmain =\n  let s = set_add (set_new 0) \"foo\"\n  if set_contains s \"bar\" then 1 else 99" "99"
  let t96 = run_test "ht_map" "import \"stdlib/hash.rail\"\nmain =\n  let h = ht_put (ht_new 0) \"x\" 42\n  ht_get h \"x\"" "42"
  let t97 = run_test "set_many" "import \"stdlib/hash.rail\"\nadd_many s n = if n == 0 then s else add_many (set_add s (join \"\" [\"k\", show n])) (n - 1)\ncheck_all s n = if n == 0 then 1 else if set_contains s (join \"\" [\"k\", show n]) then check_all s (n - 1) else 0\nmain =\n  let s = add_many (set_new 0) 100\n  check_all s 100" "1"
  let t98 = run_test "byte_rw" "foreign malloc size -> ptr\nmain =\n  let p = malloc 16\n  let _ = byte_set p 0 65\n  let _ = byte_set p 1 66\n  let _ = byte_set p 2 67\n  let a = byte_at p 0\n  let b = byte_at p 1\n  let c = byte_at p 2\n  a + b + c" "198"
  let s1 = (if t1 then 1 else 0) + (if t2 then 1 else 0) + (if t3 then 1 else 0) + (if t4 then 1 else 0) + (if t5 then 1 else 0) + (if t6 then 1 else 0) + (if t7 then 1 else 0) + (if t8 then 1 else 0) + (if t9 then 1 else 0) + (if t10 then 1 else 0)
