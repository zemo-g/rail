-- seq_crash_repro.rail — minimal repro for the seq>=1499 cumulative
-- termination bug. No transformer, no gradients — just allocate at the
-- same per-step scale training uses, with arena_mark/arena_reset bracketing.
--
-- Observed in training: lm_xval.rail at seq=1499 silently terminates at
-- step ~600 (~4.5 min). Not OOM. Process exits.
--
-- Baseline A (allocate-only, no matmul): does bump + arena_reset alone
-- sustain 2000 steps at seq=1499?
--
-- Test: `./rail_native run tools/test/seq_crash_repro.rail`
--
-- To probe dimensions individually, set the constants below. seq*V=106429
-- floats ≈ 851KB per one-hot. seq*d=95936 floats ≈ 768KB per activation.
-- The seq×seq attention-score matrix is 1499×1499=2.25M floats ≈ 18MB.

loop step seq V d =
  if step >= 2000 then 0
  else
    let mk = arena_mark 0

    -- Emulate per-step allocation shape:
    --   x onehot        [seq*V]      ~0.85MB
    --   embedding       [seq*d]      ~0.77MB
    --   q,k,v           [seq*d] x3   ~2.3MB
    --   attn scores     [seq*seq]    ~18MB   ← dominant
    --   attn weights    [seq*seq]    ~18MB
    --   ffn hidden      [seq*4d]     ~3MB
    --   logits          [seq*V]      ~0.85MB
    let _ = float_arr_new (seq * V) 0.0
    let _ = float_arr_new (seq * d) 0.0
    let _ = float_arr_new (seq * d) 0.0
    let _ = float_arr_new (seq * d) 0.0
    let _ = float_arr_new (seq * d) 0.0
    let _ = float_arr_new (seq * seq) 0.0
    let _ = float_arr_new (seq * seq) 0.0
    let _ = float_arr_new (seq * 4 * d) 0.0
    let _ = float_arr_new (seq * V) 0.0

    let _ = arena_reset mk

    let _ = if step % 50 == 0 then
              print (cat ["step ", show step])
            else 0

    loop (step + 1) seq V d

main =
  let seq = 1499
  let V = 71
  let d = 64
  let _ = print (cat ["seq_crash_repro: seq=", show seq, " V=", show V, " d=", show d])
  let _ = print "expect crash at step ~600 if bug reproduces"
  let _ = loop 0 seq V d
  let _ = print "completed 2000 steps cleanly"
  0
