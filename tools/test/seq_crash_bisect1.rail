-- Bisect 1: Tensor-wrapping matmul only (not direct tgl_matmul_f64).
-- matmul-only with direct `mm` wrapper was clean (2000 steps).
-- If this leaks → Tensor-ADT + cons-chain churn is implicated.
-- If not → softmax / layernorm / Adam is the culprit.

import "stdlib/optim.rail"
import "stdlib/transformer.rail"

step_loop step seq V d d_ff x w_e w_q w_k w_v w_o w_f1 w_f2 =
  if step >= 700 then 0
  else
    let mk = arena_mark 0

    let e_t = matmul x w_e
    let q_t = matmul e_t w_q
    let k_t = matmul e_t w_k
    let v_t = matmul e_t w_v
    let scores_t = matmul q_t k_t
    let attn_out_t = matmul scores_t v_t
    let f1_t = matmul e_t w_f1
    let f2_t = matmul f1_t w_f2
    let logits_t = matmul f2_t w_o

    let _ = arena_reset mk
    let _ = if step % 50 == 0 then print (cat ["step ", show step]) else 0
    step_loop (step + 1) seq V d d_ff x w_e w_q w_k w_v w_o w_f1 w_f2

main =
  let seq = 1499
  let V = 71
  let d = 64
  let d_ff = 256
  let _ = print "bisect1: matmul Tensor-wrapper only, 700 steps"

  let x_data = float_arr_new (seq * V) 0.0
  let x = Tensor x_data (cons seq (cons V [])) (compute_strides (cons seq (cons V [])))
  let we_d = float_arr_new (V * d) 0.01
  let w_e = Tensor we_d (cons V (cons d [])) (compute_strides (cons V (cons d [])))
  let wq_d = float_arr_new (d * d) 0.01
  let w_q = Tensor wq_d (cons d (cons d [])) (compute_strides (cons d (cons d [])))
  let wk_d = float_arr_new (d * d) 0.01
  let w_k = Tensor wk_d (cons d (cons d [])) (compute_strides (cons d (cons d [])))
  let wv_d = float_arr_new (d * d) 0.01
  let w_v = Tensor wv_d (cons d (cons d [])) (compute_strides (cons d (cons d [])))
  let wo_d = float_arr_new (d * V) 0.01
  let w_o = Tensor wo_d (cons d (cons V [])) (compute_strides (cons d (cons V [])))
  let wf1_d = float_arr_new (d * d_ff) 0.01
  let w_f1 = Tensor wf1_d (cons d (cons d_ff [])) (compute_strides (cons d (cons d_ff [])))
  let wf2_d = float_arr_new (d_ff * d) 0.01
  let w_f2 = Tensor wf2_d (cons d_ff (cons d [])) (compute_strides (cons d_ff (cons d [])))

  let _ = step_loop 0 seq V d d_ff x w_e w_q w_k w_v w_o w_f1 w_f2
  let _ = print "completed 700 steps"
  0
