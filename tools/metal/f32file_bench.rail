file_loop arr n iters i =
  if i >= iters then 0
  else
    let _ = float_arr_to_f32_file "/tmp/bench.f32" arr n
    let _ = float_arr_from_f32_file "/tmp/bench.f32" arr n
    file_loop arr n iters (i + 1)

main =
  let sz = 128
  let nel = sz * sz
  let a = float_arr_new nel 0.0
  let _ = print "50x (write+read 64KB f32 to /tmp):"
  let _ = file_loop a nel 50 0
  let _ = print "DONE"
  0
