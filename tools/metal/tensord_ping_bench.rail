import "stdlib/tensord.rail"

ping_loop fd iters i =
  if i >= iters then 0
  else
    let _ = tensord_exec_on fd "PING\n"
    ping_loop fd iters (i + 1)

main =
  let fd = tensord_open 0
  let _ = print (cat ["fd=", show fd])
  let _ = print "1000 pings:"
  let _ = ping_loop fd 1000 0
  let _ = print "DONE"
  let _ = tensord_close_fd fd
  0
