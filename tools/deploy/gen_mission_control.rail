-- gen_mission_control.rail — ledatic.org/system, rebuilt from zero.
--
-- Matches the blank-slate homepage. One column, editorial, green as
-- signal. Content shift: /system is for people who want to know how
-- the thing is actually built — compiler pipeline, runtime, compute
-- fleet, training oracle, language. No CRT scanlines, no VT323
-- cosplay, no boot overlay.

cat parts = join "" parts
trim s = head (split "\n" s)

w path s =
  let _ = write_file "/tmp/_rc.txt" s
  shell (cat ["cat /tmp/_rc.txt >> ", path])

main =
  let date = trim (shell "date -u '+%Y-%m-%d'")
  let lines_compile = trim (shell "wc -l < tools/compile.rail | tr -d ' '")
  let bin_kb = trim (shell "wc -c < rail_native | awk '{print int($1/1024)}'")
  let binary_sha = trim (shell "shasum -a 256 rail_native | awk '{print substr($1,1,24)}'")
  let harvest_n = trim (shell "wc -l < training/self_train/harvest.jsonl 2>/dev/null | tr -d ' '")
  let stdlib_n = trim (shell "ls stdlib/*.rail 2>/dev/null | wc -l | tr -d ' '")

  let f = "/tmp/mission_control.html"
  let css = "/tmp/system_main.css"
  let _ = shell (cat ["rm -f ", f, " ", css])

  -- ── HEAD ────────────────────────────────────────────────────────
  let _ = w f "<!DOCTYPE html><html lang='en'><head>"
  let _ = w f "<meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1.0'>"
  let _ = w f "<title>System &mdash; LEDATIC</title>"
  let _ = w f "<meta name='description' content='How Rail is actually built. Compiler pipeline, runtime, compute fleet, training oracle, language.'>"
  let _ = w f "<meta property='og:title' content='System &mdash; LEDATIC'>"
  let _ = w f "<meta property='og:description' content='How Rail is actually built.'>"
  let _ = w f "<meta property='og:url' content='https://ledatic.org/system'>"
  let _ = w f "<link rel='canonical' href='https://ledatic.org/system'>"
  let _ = w f "<link rel='icon' href='data:image/svg+xml,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 100 100\"><text y=\".9em\" font-size=\"90\">%3E</text></svg>'>"
  let _ = w f "<link rel='stylesheet' href='/system.css'>"
  let _ = w f "</head>"

  -- ── CSS (matches homepage vocabulary) ───────────────────────────
  let _ = w css "*\{margin:0;padding:0;box-sizing:border-box\}"
  let _ = w css "html\{scroll-behavior:smooth;font-size:16px\}"
  let _ = w css "@media(min-width:900px)\{html\{font-size:17px\}\}"
  let _ = w css "body\{background:#08080a;color:#cfcfd4;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;font-weight:400;line-height:1.65;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;min-height:100vh\}"
  let _ = w css ".mono\{font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace\}"
  let _ = w css "::selection\{background:#00ff4128;color:#fff\}"
  let _ = w css ".g\{color:#00ff41\}.d\{color:#5f5f68\}.w\{color:#e8e8ec\}"
  let _ = w css "a\{color:inherit;text-decoration:none;border-bottom:1px solid #242429;transition:border-color .15s,color .15s\}a:hover\{color:#00ff41;border-bottom-color:#00ff41\}"
  let _ = w css ".page\{max-width:680px;margin:0 auto;padding:0 28px\}"
  let _ = w css "@media(min-width:900px)\{.page\{max-width:720px;padding:0 40px\}\}"

  -- crown
  let _ = w css ".crown\{position:fixed;top:0;left:0;right:0;display:flex;justify-content:space-between;align-items:center;padding:18px 28px;z-index:40;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:11px;letter-spacing:3px;text-transform:uppercase;pointer-events:none\}"
  let _ = w css "@media(min-width:900px)\{.crown\{padding:22px 40px\}\}"
  let _ = w css ".crown a,.crown .block\{pointer-events:auto\}"
  let _ = w css ".crown .logo\{color:#e8e8ec\}.crown .logo a\{border:none\}.crown .logo span\{color:#00ff41\}"
  let _ = w css ".crown .clock\{color:#5f5f68;font-variant-numeric:tabular-nums\}"
  let _ = w css ".crown .clock .dot\{display:inline-block;width:6px;height:6px;border-radius:50%;background:#00ff41;box-shadow:0 0 8px #00ff41;margin-right:8px;animation:beat 2.4s ease-in-out infinite;vertical-align:middle\}"
  let _ = w css "@keyframes beat\{0%,100%\{opacity:.4\}50%\{opacity:1\}\}"

  -- hero
  let _ = w css ".hero\{padding:30vh 0 16vh;min-height:80vh\}"
  let _ = w css "@media(max-width:720px)\{.hero\{padding:26vh 0 12vh\}\}"
  let _ = w css ".hero h1\{font-size:clamp(38px,7vw,84px);line-height:1;letter-spacing:-.03em;font-weight:600;color:#f2f2f5;margin-bottom:32px\}"
  let _ = w css ".hero h1 .period\{color:#00ff41\}"
  let _ = w css ".hero .credit\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:12px;letter-spacing:3px;text-transform:uppercase;color:#5f5f68;display:flex;gap:14px;flex-wrap:wrap\}"
  let _ = w css ".hero .credit .sep\{color:#242429\}"

  -- section frame
  let _ = w css "section\{padding:60px 0;border-top:1px solid #17171c\}"
  let _ = w css ".slab\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:11px;letter-spacing:4px;text-transform:uppercase;color:#5f5f68;margin-bottom:28px;display:flex;align-items:center;gap:14px\}"
  let _ = w css ".slab .chip\{color:#00ff41;font-weight:500\}"
  let _ = w css ".slab .fill\{flex:1;height:1px;background:#17171c\}"
  let _ = w css "section p\{font-size:17px;line-height:1.7;color:#cfcfd4;margin-bottom:18px\}"
  let _ = w css "section p.big\{font-size:clamp(19px,2.2vw,24px);line-height:1.55;color:#e8e8ec;margin-bottom:24px\}"
  let _ = w css "section p b\{color:#f2f2f5;font-weight:500\}"
  let _ = w css "section p em\{color:#00ff41;font-style:normal;font-weight:500\}"
  let _ = w css "section h2\{font-size:clamp(26px,3.8vw,42px);line-height:1.1;font-weight:600;color:#f2f2f5;letter-spacing:-.02em;margin-bottom:20px\}"
  let _ = w css "section h2 .g\{font-weight:700\}"

  -- pipeline stages
  let _ = w css ".pipeline\{margin:28px 0;border-left:1px solid #17171c\}"
  let _ = w css ".stage\{display:grid;grid-template-columns:28px 1fr;gap:14px;padding:14px 0 14px 18px;border-left:2px solid transparent;margin-left:-1px;transition:border-color .2s\}"
  let _ = w css ".stage:hover\{border-left-color:#00ff41\}"
  let _ = w css ".stage .n\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:12px;color:#5f5f68;padding-top:4px\}"
  let _ = w css ".stage .body h4\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:12px;letter-spacing:2px;text-transform:uppercase;color:#00ff41;font-weight:500;margin-bottom:4px\}"
  let _ = w css ".stage .body p\{color:#9090a0;font-size:14px;margin:0\}"

  -- fleet rows
  let _ = w css ".fleet\{margin:24px 0\}"
  let _ = w css ".node\{display:grid;grid-template-columns:1fr;gap:4px;padding:18px 0;border-top:1px solid #17171c\}"
  let _ = w css "@media(min-width:620px)\{.node\{grid-template-columns:200px 140px 1fr\}\}"
  let _ = w css ".node .name\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:12px;letter-spacing:2px;text-transform:uppercase;color:#e8e8ec\}"
  let _ = w css ".node .role\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#00ff41\}"
  let _ = w css ".node .detail\{color:#9090a0;font-size:14px\}"

  -- oracle loop
  let _ = w css ".loop\{margin:32px 0;border:1px solid #17171c;border-radius:4px;padding:22px 24px;display:grid;grid-template-columns:1fr;gap:14px;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:13px\}"
  let _ = w css "@media(min-width:720px)\{.loop\{grid-template-columns:1fr auto 1fr auto 1fr\}\}"
  let _ = w css ".loop-node\{background:#0b0b0e;border:1px solid #17171c;border-radius:3px;padding:14px 16px;text-align:center\}"
  let _ = w css ".loop-node .t\{color:#00ff41;letter-spacing:2px;text-transform:uppercase;font-size:11px;margin-bottom:6px\}"
  let _ = w css ".loop-node .v\{color:#cfcfd4;font-size:13px;line-height:1.5\}"
  let _ = w css ".loop-arr\{color:#5f5f68;text-align:center;font-size:20px;align-self:center\}"
  let _ = w css "@media(max-width:719px)\{.loop-arr\{transform:rotate(90deg)\}\}"

  -- nums-row (shared)
  let _ = w css ".nums-row\{display:grid;grid-template-columns:160px 1fr;gap:18px;padding:14px 0;border-top:1px solid #17171c;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:13px;line-height:1.7\}"
  let _ = w css ".nums-row .k\{color:#5f5f68;letter-spacing:2px;text-transform:uppercase;font-size:11px;padding-top:3px\}"
  let _ = w css ".nums-row .v\{color:#e8e8ec\}"
  let _ = w css ".nums-row .v .g\{color:#00ff41\}"
  let _ = w css ".nums-row .v b\{color:#f2f2f5;font-weight:500\}"

  -- code
  let _ = w css ".code\{background:#0b0b0e;border:1px solid #17171c;border-radius:4px;padding:18px 22px;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:13px;line-height:1.85;color:#cfcfd4;margin:24px 0;overflow-x:auto;white-space:pre\}"
  let _ = w css ".code .c\{color:#5f5f68\}.code .k\{color:#00ff41\}"

  -- links
  let _ = w css ".links\{display:flex;gap:22px;flex-wrap:wrap;margin:32px 0 8px;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:12px;letter-spacing:2px;text-transform:uppercase\}"
  let _ = w css ".links a\{border-bottom:1px solid #242429;padding-bottom:2px\}"

  -- footer
  let _ = w css "footer\{padding:60px 0 80px;border-top:1px solid #17171c;margin-top:40px\}"
  let _ = w css "footer .mantra\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:11px;letter-spacing:4px;text-transform:uppercase;color:#5f5f68;text-align:center\}"
  let _ = w css "footer .mantra .bright\{color:#00ff41\}"
  let _ = w css "footer .sig\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:10px;letter-spacing:2px;color:#40404a;text-align:center;margin-top:16px\}"
  let _ = w css "footer .sig code\{color:#5f5f68\}"

  -- ── BODY ────────────────────────────────────────────────────────
  let _ = w f "<body>"
  let _ = w f "<div class='crown'>"
  let _ = w f "<div class='logo block'><a href='/'>LEDATIC<span>.</span></a></div>"
  let _ = w f "<div class='clock block'><span class='dot'></span><span id='clock'>&mdash; UTC</span></div>"
  let _ = w f "</div>"
  let _ = w f "<main>"

  -- HERO
  let _ = w f "<section class='hero'><div class='page'>"
  let _ = w f "<h1>How the thing is <span class='g'>actually built</span><span class='period'>.</span></h1>"
  let _ = w f "<div class='credit'>"
  let _ = w f "<span>System</span><span class='sep'>&middot;</span><span>the bones under ledatic.org</span><span class='sep'>&middot;</span>"
  let _ = w f (cat ["<span>", date, "</span>"])
  let _ = w f "</div></div></section>"

  -- /01 COMPILER
  let _ = w f "<section id='compiler'><div class='page'>"
  let _ = w f "<div class='slab'><span class='chip'>/01</span><span>the compiler</span><span class='fill'></span></div>"
  let _ = w f "<h2>Five passes, one file.</h2>"
  let _ = w f (cat ["<p class='big'><b>tools/compile.rail</b> is <span class='g'>", lines_compile, "</span> lines of Rail. It runs itself. What comes out is a <b>", bin_kb, " KB</b> ARM64 binary that compiles the same source again and produces the same bytes back.</p>"])
  let _ = w f "<div class='pipeline'>"
  let _ = w f "<div class='stage'><div class='n'>/1</div><div class='body'><h4>Lexer</h4><p>Tokenises Rail source with position tracking. Comments drop; layout-sensitive whitespace becomes column info.</p></div></div>"
  let _ = w f "<div class='stage'><div class='n'>/2</div><div class='body'><h4>Parser</h4><p>Recursive descent. Emits AST as tagged lists. Errors halt with <span class='mono'>file:line:col: error: message</span> &mdash; never segfault.</p></div></div>"
  let _ = w f "<div class='stage'><div class='n'>/3</div><div class='body'><h4>Type checker</h4><p>Forward inference pass. Warnings (not errors) on head/tail-of-non-list, arity mismatches, calling non-functions. Exhaustiveness is enforced for <span class='mono'>match</span>.</p></div></div>"
  let _ = w f "<div class='stage'><div class='n'>/4</div><div class='body'><h4>Codegen</h4><p>Walks the AST, emits ARM64 or x86_64 or WASM assembly directly. Self-loops lower to <span class='mono'>subs + b.gt</span> tight loops &mdash; matches <span class='mono'>gcc -O2</span>.</p></div></div>"
  let _ = w f "<div class='stage'><div class='n'>/5</div><div class='body'><h4>Build</h4><p>Shells out to <span class='mono'>as</span> + <span class='mono'>ld</span>. No other tools, no makefile, no linker script.</p></div></div>"
  let _ = w f "</div></div></section>"

  -- /02 RUNTIME
  let _ = w f "<section id='runtime'><div class='page'>"
  let _ = w f "<div class='slab'><span class='chip'>/02</span><span>the runtime</span><span class='fill'></span></div>"
  let _ = w f "<h2>Zero C. <span class='g'>GC in assembly.</span></h2>"
  let _ = w f "<p class='big'>The garbage collector is ARM64 assembly embedded in the compiler itself. Conservative mark-sweep, 512 MB bump arena, free-list, malloc fallback. Tagged pointers: bit 0 distinguishes int from heap. Eight ADT tags. Mark bit at bit 63.</p>"
  let _ = w f "<div class='nums-row'><div class='k'>Allocator</div><div class='v'><span class='g'>512 MB</span> bump arena + free list + malloc fallback</div></div>"
  let _ = w f "<div class='nums-row'><div class='k'>GC</div><div class='v'>conservative mark-sweep &middot; scans stack frames &middot; all ARM64 assembly</div></div>"
  let _ = w f "<div class='nums-row'><div class='k'>Floats</div><div class='v'>unboxed IEEE 754 in <span class='g'>d-registers</span> &middot; <span class='mono'>fadd/fmul/fdiv</span> direct, no heap boxing</div></div>"
  let _ = w f "<div class='nums-row'><div class='k'>Effect handlers</div><div class='v'><span class='mono'>try body handler</span> &middot; setjmp/longjmp &middot; deep unwinding, nested handlers</div></div>"
  let _ = w f "<div class='nums-row'><div class='k'>Tail recursion</div><div class='v'>self-loop becomes <span class='mono'>subs + b.gt</span> &mdash; <span class='g'>5 instructions</span> per iteration, matches C <span class='mono'>-O2</span></div></div>"
  let _ = w f "</div></section>"

  -- /03 FLEET
  let _ = w f "<section id='fleet'><div class='page'>"
  let _ = w f "<div class='slab'><span class='chip'>/03</span><span>the fleet</span><span class='fill'></span></div>"
  let _ = w f "<h2>Four nodes, one control plane.</h2>"
  let _ = w f "<p>Compute is distributed across four boxes. A pure-Rail control plane (<span class='mono'>fleet_agent_v3</span> on port 9101) lets any node run commands or read logs on any other. State is file-based so v2 (Pi, Python transport) and v3 (Mac, pure Rail TCP) coexist seamlessly.</p>"
  let _ = w f "<div class='fleet'>"
  let _ = w f "<div class='node'><div class='name'>Mac Mini M4 Pro</div><div class='role'>primary &middot; 24 gb</div><div class='detail'>Inference, compilation, orchestration. LaunchAgents for trading, oversight, site deploy. Where the compiler lives.</div></div>"
  let _ = w f "<div class='node'><div class='name'>Mac Studio M1 Ultra</div><div class='role'>reasoning &middot; 64 gb</div><div class='detail'>Production MLX reasoning over Tailscale. Second MLX server for long-context work.</div></div>"
  let _ = w f "<div class='node'><div class='name'>Pi Zero 2 W (fleet0)</div><div class='role'>edge &middot; 416 mb</div><div class='detail'>ARM64 Linux control-plane node. DNS sinkhole, observatory, fleet v2 agent. Static ELF, no libc drama.</div></div>"
  let _ = w f "<div class='node'><div class='name'>MacBook Air M1</div><div class='role'>orchestrator &middot; 8 gb</div><div class='detail'>Screen-shares to the others, hits the fleet HTTP API at <span class='mono'>:9101</span>. The human-in-the-loop terminal.</div></div>"
  let _ = w f "</div></div></section>"

  -- /04 ORACLE
  let _ = w f "<section id='oracle'><div class='page'>"
  let _ = w f "<div class='slab'><span class='chip'>/04</span><span>the oracle</span><span class='fill'></span></div>"
  let _ = w f "<h2>The compiler is the <span class='g'>fitness function</span>.</h2>"
  let _ = w f "<p class='big'>If generated code compiles, it&rsquo;s right. If it doesn&rsquo;t, it&rsquo;s wrong. No LLM-as-judge, no reward model, no vibe check &mdash; the compiler&rsquo;s acceptance IS the reward signal. Three lineages run on the same oracle.</p>"
  let _ = w f "<div class='loop'>"
  let _ = w f "<div class='loop-node'><div class='t'>generate</div><div class='v'>LLM &middot; MLP &middot; PCFG<br>all emit Rail source</div></div>"
  let _ = w f "<div class='loop-arr'>&rarr;</div>"
  let _ = w f "<div class='loop-node'><div class='t'>verify</div><div class='v'>rail_native compiles<br>the source</div></div>"
  let _ = w f "<div class='loop-arr'>&rarr;</div>"
  let _ = w f "<div class='loop-node'><div class='t'>harvest</div><div class='v'>passes become<br>next round&rsquo;s data</div></div>"
  let _ = w f "</div>"
  let _ = w f "<div class='nums-row'><div class='k'>LoRA on Gemma</div><div class='v'>4B parameters, Rail LoRA adapter &middot; <span class='g'>14/30</span> on the README bench, up from 1/30 baseline</div></div>"
  let _ = w f "<div class='nums-row'><div class='k'>Metal-GPU MLP</div><div class='v'>plasma surrogate &middot; 30&rarr;128&rarr;6 &middot; runs forward pass <b>every cell, every frame</b> &mdash; the MLP IS the physics engine</div></div>"
  let _ = w f "<div class='nums-row'><div class='k'>PCFG-REINFORCE</div><div class='v'>23 integers, ~120 bytes total &middot; <span class='g'>92%</span> strict pass in 30 ticks &middot; discovered runtime tolerances by trial</div></div>"
  let harvest_display = if length harvest_n > 0 then harvest_n else "1,636"
  let _ = w f (cat ["<div class='nums-row'><div class='k'>Harvest</div><div class='v'><span class='g'>", harvest_display, "</span> compiler-verified examples &middot; all real Rail, all compile clean</div></div>"])
  let _ = w f "</div></section>"

  -- /05 LANGUAGE
  let _ = w f "<section id='language'><div class='page'>"
  let _ = w f "<div class='slab'><span class='chip'>/05</span><span>the language</span><span class='fill'></span></div>"
  let _ = w f "<h2>Small shape, sharp edges.</h2>"
  let _ = w f "<p>ADTs with exhaustive pattern matching. Higher-order functions. Native floats in d-registers. Effect handlers. No implicit conversions &mdash; the type system warns, never silently casts.</p>"
  let _ = w f "<div class='code'>"
  let _ = w f "<span class='c'>-- ADTs + pattern matching</span>\n"
  let _ = w f "<span class='k'>type</span> Expr = | Num x | Add a b | Mul a b\n\n"
  let _ = w f "eval e = <span class='k'>match</span> e\n"
  let _ = w f "  | Num x &nbsp;&nbsp;-&gt; x\n"
  let _ = w f "  | Add a b -&gt; eval a + eval b\n"
  let _ = w f "  | Mul a b -&gt; eval a * eval b\n\n"
  let _ = w f "main = <span class='k'>let</span> _ = print (show (eval (Add (Num 3) (Mul (Num 4) (Num 5)))))\n"
  let _ = w f "       0\n"
  let _ = w f "<span class='c'>-- -> 23</span>"
  let _ = w f "</div>"
  let _ = w f (cat ["<div class='nums-row'><div class='k'>Stdlib</div><div class='v'><span class='g'>", stdlib_n, "</span> modules &middot; pure Rail &middot; crypto, TLS, HTTP, MLX, sockets, sqlite, tensors, autograd, transformer</div></div>"])
  let _ = w f "<div class='nums-row'><div class='k'>Backends</div><div class='v'>ARM64 macOS &middot; ARM64 Linux &middot; x86_64 Linux &middot; <span class='g'>WASM</span> &middot; Metal GPU</div></div>"
  let _ = w f "<div class='nums-row'><div class='k'>Tests</div><div class='v'><span class='g'>116</span> core &middot; <span class='g'>23</span> TLS &middot; all green &middot; self-compile fixed point held</div></div>"
  let _ = w f "</div></section>"

  -- LINKS
  let _ = w f "<section><div class='page'>"
  let _ = w f "<div class='links'>"
  let _ = w f "<a href='/'>home</a>"
  let _ = w f "<a href='/#tls'>v3.0.0 release</a>"
  let _ = w f "<a href='/plasma/'>plasma</a>"
  let _ = w f "<a href='https://github.com/zemo-g/rail'>source</a>"
  let _ = w f "<a href='https://github.com/zemo-g/rail/blob/master/CHANGELOG.md'>changelog</a>"
  let _ = w f "</div></div></section>"

  -- FOOTER
  let _ = w f "<footer><div class='page'>"
  let _ = w f "<div class='mantra'>rail runs on rail &nbsp;<span class='bright'>&middot;</span>&nbsp; the rest runs on physics</div>"
  let _ = w f (cat ["<div class='sig'>this page was built by rail_native &middot; <code>sha256 = ", binary_sha, "&hellip;</code> &middot; fixed point held</div>"])
  let _ = w f "</div></footer>"

  let _ = w f "</main>"
  let _ = w f "<script>"
  let _ = w f "function tick()\{var d=new Date();var h=String(d.getUTCHours()).padStart(2,'0');var m=String(d.getUTCMinutes()).padStart(2,'0');var s=String(d.getUTCSeconds()).padStart(2,'0');document.getElementById('clock').textContent=h+':'+m+':'+s+' UTC';\}"
  let _ = w f "tick();setInterval(tick,1000);"
  let _ = w f "</script>"
  let _ = w f "</body></html>"

  let _ = print "Done."
  let size_html = trim (shell "wc -c < /tmp/mission_control.html | tr -d ' '")
  let size_css = trim (shell "wc -c < /tmp/system_main.css | tr -d ' '")
  let _ = print (cat ["  html: ", size_html, " bytes"])
  let _ = print (cat ["  css : ", size_css, " bytes"])
  0
