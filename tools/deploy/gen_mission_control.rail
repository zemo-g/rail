  let _ = w f "</div>"

  -- ═══ JS — boot, typing, counters ═══

  -- Boot sequence: fade out after 2s
  let _ = w js_file "setTimeout(function(){document.getElementById('boot').classList.add('done')},2000);"

  -- Typing effect on the terminal demo
  let _ = w js_file "var typed=document.getElementById('typedemo');"
  let _ = w js_file "if(typed){var lines=typed.getAttribute('data-lines').split('|');"
  let _ = w js_file "var i=0,j=0,el=typed;"
  let _ = w js_file "function typeNext(){if(i>=lines.length)return;"
  let _ = w js_file "if(j<=lines[i].length){el.innerHTML+=lines[i][j-1]||'';j++;"
  let _ = w js_file "setTimeout(typeNext,Math.random()*30+15)}else{el.innerHTML+='<br>';i++;j=0;"
  let _ = w js_file "setTimeout(typeNext,200)}}typeNext()}"

  -- Stat counter scroll animation
  let _ = w js_file "var obs=new IntersectionObserver(function(entries){"
  let _ = w js_file "entries.forEach(function(e){if(e.isIntersecting)"
  let _ = w js_file "e.target.classList.add('visible')})},{threshold:0.3});"
  let _ = w js_file "document.querySelectorAll('.stat .num').forEach(function(el){obs.observe(el)});"

  -- Close dropdown on link click
  let _ = w js_file "document.querySelectorAll('.dropdown a').forEach(function(a){"
  let _ = w js_file "a.addEventListener('click',function(){document.getElementById('dd').classList.remove('open')})});"

