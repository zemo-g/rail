  let _ = w f "<div class='fly-node' data-s='ms0d0ef0'>1. AI writes<br>code<small>proposes a recipe</small></div>"
  let _ = w f "<div class='fly-node' data-s='ms23949d'>2. Rail<br>tries it<small>the oven</small></div>"
