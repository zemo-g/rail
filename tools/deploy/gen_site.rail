-- gen_site.rail — Generate ledatic.org
-- v2: interactive charts + diagrams, technical detail on /system
-- Usage: ./rail_native run tools/deploy/gen_site.rail

cat parts = join "" parts
trim s = head (split "\n" s)

w path s =
  let _ = write_file "/tmp/_rc.txt" s
  shell (cat ["cat /tmp/_rc.txt >> ", path])

main =
  let date = trim (shell "date -u '+%Y-%m-%d'")
  -- Single source of truth for numbers used across the page.
  -- Pulled from the actual repo state at generation time.
  let lines_compile = trim (shell "wc -l < tools/compile.rail | tr -d ' '")
  let bin_kb = trim (shell "wc -c < rail_native | awk '{print int($1/1024)}'")
  let version = "v2.23.0"
  let f = "/tmp/ledatic.html"
  let _ = shell (cat ["rm -f ", f])
  let css_file = "/tmp/ledatic_main.css"
  let _ = shell (cat ["rm -f ", css_file])
  let js_file = "/tmp/ledatic_main.js"
  let _ = shell (cat ["rm -f ", js_file])

  -- HEAD
  let _ = w f "<!DOCTYPE html><html lang='en'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1.0'>"
  let _ = w f "<title>Reilly Gomez — LEDATIC</title>"
  let _ = w f (cat ["<meta name='description' content='Self-hosting language. ", lines_compile, " lines compile to ARM64, x86_64, Linux, WASM, and Metal GPU. Native floats. Live 2D ideal MHD runs to t=pi in your browser. Zero C dependencies.'>"])
  let _ = w f "<meta property='og:title' content='Reilly Gomez — LEDATIC'>"
  let _ = w f "<meta property='og:description' content='A language that deleted its own compiler.'>"
  let _ = w f "<meta property='og:image' content='https://pub-e9d7c87d3a1b43bea50d3bd0d8ba9ffb.r2.dev/og-image.png'>"
  let _ = w f "<meta property='og:url' content='https://ledatic.org'>"
  let _ = w f "<meta property='og:type' content='website'>"
  let _ = w f "<meta name='twitter:card' content='summary_large_image'>"
  let _ = w f "<meta name='twitter:title' content='Reilly Gomez — LEDATIC'>"
  let _ = w f "<meta name='twitter:description' content='A language that deleted its own compiler.'>"
  let _ = w f "<meta name='twitter:image' content='https://pub-e9d7c87d3a1b43bea50d3bd0d8ba9ffb.r2.dev/og-image.png'>"
  let _ = w f "<link rel='icon' href='data:image/svg+xml,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 100 100\"><text y=\".9em\" font-size=\"90\">%3E</text></svg>'>"
  let _ = w f "<link rel='canonical' href='https://ledatic.org/'>"
  -- Performance hints: preload our own assets
  let _ = w f "<link rel='preload' as='style' href='/main.css'>"
  let _ = w f "<link rel='preload' as='script' href='/main.js'>"
  -- JSON-LD structured data: Person + WebSite + SoftwareApplication
  let _ = w f "<script type=\"application/ld+json\">"
  let _ = w f "{\"@context\":\"https://schema.org\",\"@graph\":["
  let _ = w f "{\"@type\":\"Person\",\"@id\":\"https://ledatic.org/#person\",\"name\":\"Reilly Gomez\",\"url\":\"https://ledatic.org\",\"email\":\"reillygomez13@icloud.com\",\"jobTitle\":\"Systems Engineer\",\"sameAs\":[\"https://github.com/zemo-g\"],\"knowsAbout\":[\"Programming Languages\",\"Compiler Engineering\",\"Self-Hosting Languages\",\"Machine Learning\",\"LoRA Fine-Tuning\",\"Apple Silicon Inference\",\"WebAssembly\",\"Autonomous Systems\"]},"
  let _ = w f "{\"@type\":\"WebSite\",\"@id\":\"https://ledatic.org/#website\",\"url\":\"https://ledatic.org\",\"name\":\"LEDATIC\",\"description\":\"Intelligence services from Reilly Gomez. Self-hosting programming language, compiler-verified self-training AI, autonomous neural control.\",\"publisher\":{\"@id\":\"https://ledatic.org/#person\"}},"
  let _ = w f (cat ["{\"@type\":\"SoftwareApplication\",\"name\":\"Rail\",\"url\":\"https://github.com/zemo-g/rail\",\"applicationCategory\":\"DeveloperApplication\",\"operatingSystem\":\"macOS, Linux, WebAssembly, Metal\",\"author\":{\"@id\":\"https://ledatic.org/#person\"},\"description\":\"Self-hosting programming language. ", lines_compile, " lines compile to ARM64, x86_64, Linux, WebAssembly, and Metal GPU. Zero C dependencies.\"}"])
  let _ = w f "]}</script>"
  let _ = w f "<link rel='stylesheet' href='/main.css'>"
  let _ = w css_file ".skip-link{position:absolute;top:-40px;left:0;background:#00ff41;color:#09090b;padding:8px 16px;z-index:10001;text-decoration:none;font-family:ui-monospace,Menlo,Monaco,monospace;font-size:12px;font-weight:600;border-radius:0 0 4px 0}.skip-link:focus{top:0;outline:2px solid #00ff41}"
  -- Generated utility classes from former inline style='...' attributes.
  -- Refactored 2026-04-07 to drop CSP style-src 'unsafe-inline'.
  let _ = w css_file "[data-s='sc451fd']{position:relative}[data-s='sc5b2e9']{grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px}[data-s='sbc5252']{border-color:#00ff4120}[data-s='s3b1cff']{color:#00ff41}[data-s='s463a85']{border-color:#3b82f620}[data-s='sd294e9']{color:#3b82f6}[data-s='s33a05d']{border-color:#f9731620}[data-s='sc7492c']{color:#f97316}[data-s='sb6e460']{border-color:#c084fc20}[data-s='seed815']{color:#c084fc}[data-s='s0f873e']{margin-top:48px}[data-s='s823d07']{grid-template-columns:repeat(3,1fr)}[data-s='s04dc4f']{text-align:center;border-color:#00ff4120}[data-s='s96c8b6']{color:#00ff41;font-size:14px}[data-s='s0385d5']{text-align:center;border-color:#3b82f620}[data-s='sf46ca3']{color:#3b82f6;font-size:14px}[data-s='sd5268f']{text-align:center;border-color:#c084fc20}[data-s='sf38f84']{color:#c084fc;font-size:14px}[data-s='s2b6c7e']{text-align:center;margin-top:24px;font-family:ui-monospace,Menlo,Monaco,monospace,monospace;font-size:11px;color:#8b8b94}[data-s='scf70c3']{color:#00ff41;text-decoration:none}[data-s='sea04bb']{margin-bottom:16px;font-size:12px}[data-s='sb135ce']{animation-delay:0.5s}[data-s='s02291a']{animation-delay:1s}[data-s='s6da6b4']{animation-delay:1.5s}[data-s='s195b84']{grid-template-columns:repeat(3,1fr);margin-top:32px}[data-s='s13076d']{text-align:center}[data-s='s35a13a']{color:#00ff41;font-size:28px;font-family:ui-monospace,Menlo,Monaco,monospace}[data-s='s324a75']{color:#3b82f6;font-size:28px;font-family:ui-monospace,Menlo,Monaco,monospace}[data-s='sabe8b7']{color:#f97316;font-size:28px;font-family:ui-monospace,Menlo,Monaco,monospace}[data-s='s3939bb']{grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:16px}[data-s='s52eed5']{color:#f97316;font-size:16px;margin-bottom:8px}[data-s='sf29072']{color:#a1a1aa;font-size:14px;line-height:1.6}[data-s='s2c8d47']{color:#3b82f6;font-size:16px;margin-bottom:8px}[data-s='saceff4']{color:#c084fc;font-size:16px;margin-bottom:8px}[data-s='s45c6f4']{color:#00ff41;font-size:16px;margin-bottom:8px}[data-s='sc98cf7']{margin-top:64px;padding:40px 32px;background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px}[data-s='s1b57a8']{color:#e4e4e7;font-size:22px;font-weight:700;margin-bottom:8px;text-align:center}[data-s='s29e6f9']{color:#8b8b94;font-size:14px;margin-bottom:32px;text-align:center;max-width:560px;margin-left:auto;margin-right:auto}[data-s='s59ed2b']{grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px}[data-s='s50cfb2']{color:#3b82f6;font-size:15px}[data-s='s8e8697']{margin-bottom:16px}[data-s='s99387d']{color:#3b82f6;font-size:12px;font-family:ui-monospace,Menlo,Monaco,monospace}[data-s='s8875db']{color:#00ff41;font-size:15px}[data-s='sc72f5e']{color:#00ff41;font-size:12px;font-family:ui-monospace,Menlo,Monaco,monospace}[data-s='s9222cd']{color:#f97316;font-size:15px}[data-s='sd3d997']{color:#f97316;font-size:12px;font-family:ui-monospace,Menlo,Monaco,monospace}[data-s='s0b5985']{color:#c084fc;font-size:15px}[data-s='s227d70']{color:#c084fc;font-size:12px;font-family:ui-monospace,Menlo,Monaco,monospace}[data-s='s4a35e3']{margin-top:32px;padding-top:24px;border-top:1px solid #1c1c1e;text-align:center}[data-s='s16fc22']{color:#8b8b94;font-size:13px;margin-bottom:12px}[data-s='s704101']{color:#8b8b94;font-size:12px;font-family:ui-monospace,Menlo,Monaco,monospace;text-decoration:none}[data-s='s225182']{color:#8b8b94}[data-s='s084a55']{animation:fadein 0.1s 0.1s forwards}[data-s='sf5afb9']{color:#8b8b94}[data-s='sc68261']{animation:fadein 0.1s 0.3s forwards;color:#8b8b94}[data-s='s4a317b']{animation:fadein 0.1s 0.5s forwards;color:#8b8b94}[data-s='seb77ad']{animation:fadein 0.1s 0.7s forwards;color:#8b8b94}[data-s='s31b218']{animation:fadein 0.1s 1.0s forwards;color:#00ff41}"

  -- CSS: reset + base
  let _ = w css_file "*{margin:0;padding:0;box-sizing:border-box}html{scroll-behavior:smooth}"
  let _ = w css_file "body{background:#09090b;color:#e4e4e7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;-webkit-font-smoothing:antialiased}"
  let _ = w css_file "::selection{background:#00ff4130;color:#fff}"
  let _ = w css_file "body::before{content:'';position:fixed;top:0;left:0;width:100%;height:100%;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,255,65,0.006) 3px,rgba(0,255,65,0.006) 6px);pointer-events:none;z-index:9999}"

  -- CSS: layout
  let _ = w css_file ".wrap{max-width:1080px;margin:0 auto;padding:0 28px}"
  let _ = w css_file "section{padding:80px 0;border-bottom:1px solid #18181b}section:last-of-type{border-bottom:none}"
  let _ = w css_file ".reveal{opacity:0;transform:translateY(20px);transition:all 0.7s ease-out}.reveal.visible{opacity:1;transform:translateY(0)}"

  -- CSS: nav
  let _ = w css_file "nav{position:fixed;top:0;left:0;right:0;z-index:10000;background:rgba(9,9,11,0.85);backdrop-filter:blur(16px);border-bottom:1px solid #18181b;padding:16px 28px;font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:12px;display:flex;justify-content:space-between;align-items:center}"
  let _ = w css_file "nav a{color:#8b8b94;text-decoration:none;transition:color 0.2s}nav a:hover{color:#00ff41}"
  let _ = w css_file "nav .links{display:flex;gap:24px}.logo{color:#e4e4e7;font-weight:600;letter-spacing:2px;font-size:13px}.logo span{color:#00ff41}"
  let _ = w css_file ".burger{display:none;background:none;border:1px solid #27272a;color:#e4e4e7;font-size:20px;padding:8px 14px;border-radius:4px;cursor:pointer;font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;min-height:44px;min-width:44px}"
  let _ = w css_file ".dropdown{display:none;position:absolute;top:100%;right:16px;background:#0a0a0a;border:1px solid #27272a;border-radius:8px;padding:8px 0;min-width:160px;z-index:101}"
  let _ = w css_file ".dropdown a{display:block;padding:10px 20px;color:#a1a1aa;font-size:13px}.dropdown a:hover{color:#00ff41;background:#111}"
  let _ = w css_file ".dropdown.open{display:block}"

  -- CSS: hero
  let _ = w css_file "#hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding-top:60px}"
  let _ = w css_file ".hero-tag{font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:11px;letter-spacing:4px;color:#8b8b94;text-transform:uppercase;margin-bottom:20px}"
  let _ = w css_file "h1{font-size:clamp(40px,7vw,80px);font-weight:700;line-height:1.05;letter-spacing:-2px;margin-bottom:24px}"
  let _ = w css_file "h1 .g{color:#00ff41}h1 .b{color:#3b82f6}h1 .o{color:#f97316}"
  let _ = w css_file ".hero-sub{color:#a1a1aa;font-size:18px;line-height:1.7;max-width:640px;margin-bottom:40px}"
  let _ = w css_file ".btn{font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:12px;padding:14px 24px;border-radius:4px;text-decoration:none;transition:all 0.2s;letter-spacing:0.5px;display:inline-block;margin-right:12px;margin-bottom:12px;min-height:44px;line-height:1.1}"
  let _ = w css_file ".btn-g{background:#00ff41;color:#09090b;font-weight:600}.btn-g:hover{background:#00cc33;box-shadow:0 0 24px rgba(0,255,65,0.2)}"
  let _ = w css_file ".btn-o{border:1px solid #27272a;color:#a1a1aa}.btn-o:hover{border-color:#00ff41;color:#00ff41}"

  -- CSS: sections
  let _ = w css_file "h2{font-size:clamp(28px,4vw,44px);font-weight:700;letter-spacing:-1px;margin-bottom:16px}"
  let _ = w css_file ".section-sub{color:#8b8b94;font-size:15px;line-height:1.7;max-width:640px;margin-bottom:40px}"
  let _ = w css_file ".grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin:32px 0}"
  let _ = w css_file ".card{background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px;padding:28px;transition:all 0.3s ease}.card:hover{border-color:#8b8b94;box-shadow:0 0 20px rgba(0,255,65,0.06);transform:translateY(-2px)}"
  let _ = w css_file ".card h3{font-size:16px;font-weight:600;margin-bottom:8px}.card p{color:#8b8b94;font-size:13px;line-height:1.7}"

  -- CSS: reduction bar
  let _ = w css_file ".bar-wrap{margin:48px 0}.bar-row{display:flex;align-items:center;gap:16px;margin-bottom:16px}"
  let _ = w css_file ".bar-label{font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:12px;color:#8b8b94;width:100px;text-align:right;flex-shrink:0}"
  let _ = w css_file ".bar-track{flex:1;height:36px;background:#111;border-radius:4px;position:relative;display:flex;align-items:center}"
  let _ = w css_file ".bar-fill{height:100%;border-radius:4px;transition:width 1.5s cubic-bezier(0.25,1,0.5,1);width:0;position:absolute;left:0;top:0}"
  let _ = w css_file ".bar-text{position:relative;z-index:1;padding-left:12px;font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:12px;font-weight:600;color:#e4e4e7;white-space:nowrap}"
  let _ = w css_file ".bar-fill.rust{background:linear-gradient(90deg,#f9731640,#f97316)}.bar-fill.rail{background:linear-gradient(90deg,#00ff4140,#00ff41)}"
  let _ = w css_file "@media(max-width:640px){.bar-label{width:70px;font-size:11px}}"

  -- CSS: flywheel
  let _ = w css_file ".flywheel-wrap{display:flex;justify-content:center;margin:48px 0}"
  let _ = w css_file ".flywheel-svg{width:400px;height:400px;max-width:100%}"
  let _ = w css_file "@keyframes fw-spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}"
  let _ = w css_file "@keyframes fw-pulse{0%,100%{opacity:0.4}50%{opacity:1}}"
  let _ = w css_file ".fw-orbit{animation:fw-spin 20s linear infinite;transform-origin:200px 200px}"
  let _ = w css_file ".fw-node{font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:11px;font-weight:600}"
  let _ = w css_file ".fw-arrow{animation:fw-pulse 2s ease-in-out infinite}"

  -- CSS: timeline compact
  let _ = w css_file ".tl-compact{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:2px;margin:48px 0}"
  let _ = w css_file ".tl-c{background:#0c0c0e;padding:20px;border-left:3px solid #1c1c1e;transition:all 0.3s}.tl-c:hover{border-left-color:#00ff41;background:#111}"
  let _ = w css_file ".tl-c.active{border-left-color:#00ff41;background:#0d1a0e}"
  let _ = w css_file ".tl-c-date{font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:10px;color:#8b8b94;letter-spacing:1px;margin-bottom:4px}"
  let _ = w css_file ".tl-c-title{font-size:13px;font-weight:600;color:#e4e4e7;margin-bottom:4px}"
  let _ = w css_file ".tl-c-desc{font-size:11px;color:#8b8b94;line-height:1.4}"

  -- CSS: about
  let _ = w css_file ".about{display:flex;gap:48px;align-items:center;flex-wrap:wrap}"
  let _ = w css_file ".about-photo{width:140px;height:140px;border-radius:50%;border:2px solid #27272a;object-fit:cover;flex-shrink:0}"
  let _ = w css_file ".about-text{flex:1;min-width:280px}"
  let _ = w css_file ".about-name{font-size:28px;font-weight:700;margin-bottom:4px}"
  let _ = w css_file ".about-role{font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:13px;color:#00ff41;margin-bottom:16px}"
  let _ = w css_file ".about-bio{color:#a1a1aa;font-size:15px;line-height:1.8;margin-bottom:20px}"
  let _ = w css_file ".about-links{display:flex;gap:16px;font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:12px}"
  let _ = w css_file ".about-links a{color:#8b8b94;text-decoration:none;transition:color 0.2s}.about-links a:hover{color:#00ff41}"
  let _ = w css_file "@media(max-width:640px){.about{flex-direction:column;text-align:center}.about-text{min-width:0;max-width:100%}.about-links{justify-content:center}}"
  -- Very-narrow viewport fixes (320–400px phones)
  let _ = w css_file "@media(max-width:400px){.wrap{padding:0 16px}.pg-demos{grid-template-columns:1fr}.tl-compact{grid-template-columns:1fr}.grid{grid-template-columns:1fr}.bar-label{width:60px;font-size:10px}h1{font-size:36px}h2{font-size:24px}.btn{display:block;text-align:center;margin-right:0}}"

  -- CSS: other work
  let _ = w css_file ".ow-card{background:#111;border:1px solid #222;border-radius:8px;padding:24px;transition:all 0.3s}"
  let _ = w css_file ".ow-card:hover{transform:translateY(-3px);border-color:#333}"
  let _ = w css_file ".ow-card.c-orange:hover{box-shadow:0 4px 24px rgba(249,115,22,0.1)}"
  let _ = w css_file ".ow-card.c-blue:hover{box-shadow:0 4px 24px rgba(59,130,246,0.1)}"
  let _ = w css_file ".ow-card.c-purple:hover{box-shadow:0 4px 24px rgba(192,132,252,0.1)}"
  let _ = w css_file ".ow-card.c-green:hover{box-shadow:0 4px 24px rgba(0,255,65,0.1)}"

  -- CSS: arch flow
  let _ = w css_file ".arch-flow{display:flex;align-items:center;justify-content:center;gap:0;margin:48px 0;flex-wrap:wrap}"
  let _ = w css_file ".arch-node{background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px;padding:16px 20px;text-align:center;font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:12px;transition:all 0.3s;min-width:100px}"
  let _ = w css_file ".arch-node:hover{border-color:#00ff41;box-shadow:0 0 16px rgba(0,255,65,0.1)}"
  let _ = w css_file ".arch-node .label{color:#e4e4e7;font-weight:600;margin-bottom:4px}.arch-node .sub{color:#8b8b94;font-size:10px}"
  let _ = w css_file ".arch-arrow{color:#8b8b94;font-size:18px;padding:0 8px;flex-shrink:0}"

  -- CSS: footer + responsive
  let _ = w css_file "footer{text-align:center;padding:64px 28px;color:#8b8b94;font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:11px;line-height:2}"
  let _ = w css_file "footer a{color:#8b8b94;text-decoration:none}footer a:hover{color:#00ff41}"
  let _ = w css_file "#particles{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:0.3}"
  let _ = w css_file "section,nav,footer,#boot{position:relative;z-index:1}"
  let _ = w css_file "@media(max-width:768px){nav .links{display:none}.burger{display:block}.arch-arrow{display:none}.arch-flow{gap:8px}}"

  -- Boot overlay
  let _ = w css_file "#boot{position:fixed;top:0;left:0;width:100%;height:100%;background:#09090b;z-index:50000;display:flex;align-items:center;justify-content:center;flex-direction:column;font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:13px;transition:opacity 0.6s}"
  let _ = w css_file "#boot.done{opacity:0;pointer-events:none}"
  let _ = w css_file "#boot .line{opacity:0;margin:3px 0;color:#00ff41}"
  let _ = w css_file "@keyframes fadein{to{opacity:1}}"

  let _ = w f "</head><body>"
  let _ = w f "<a class='skip-link' href='#main'>Skip to main content</a>"
  let _ = w f "<canvas id='particles'></canvas>"

  -- NAV
  let _ = w f "<nav data-s='sc451fd'><div class='logo'><span>&gt;</span> LEDATIC</div>"
  let _ = w f "<div class='links'><a href='#work'>Work</a><a href='#about'>About</a><a href='#playground'>Playground</a><a href='#story'>Story</a><a href='#technical'>Technical</a><a href='https://github.com/zemo-g/rail'>GitHub</a></div>"
  let _ = w f "<button class='burger' aria-label='Menu'>&#9776;</button>"
  let _ = w f "<div class='dropdown' id='dd'><a href='#work'>Work</a><a href='#about'>About</a><a href='#playground'>Playground</a><a href='#story'>Story</a><a href='#technical'>Technical</a><a href='https://github.com/zemo-g/rail'>GitHub</a></div></nav>"

  -- HERO — accessible first, technical second
  let _ = w f "<main id='main'><section id='hero'><div class='wrap'>"
  let _ = w f "<h1>I build software that<br><span class='g'>builds</span> itself.</h1>"
  let _ = w f "<p class='hero-sub'>I make programming languages, self-flying drones, and AI that writes code and checks its own work. I like building things that do a lot with very little.</p>"
  let _ = w f "<a href='#work' class='btn btn-g'>See what I build</a>"
  let _ = w f "<a href='#about' class='btn btn-o'>About me</a>"
  let _ = w f "</div></section>"

  -- WHAT I BUILD — outcomes, not implementation
  let _ = w f "<section id='work' class='reveal'><div class='wrap'>"
  let _ = w f "<h2>What I <span class='g'>build</span></h2>"
  let _ = w f "<div class='grid' data-s='sc5b2e9'>"
  let _ = w f "<div class='card' data-s='sbc5252'><h3 data-s='s3b1cff'>A Programming Language</h3><p>I built a language called Rail from scratch this year. It builds itself &mdash; like a carpenter whose only tool is a hammer he also made. It runs on phones, laptops, Linux boxes, in your browser, and even on your graphics card. No shortcuts, no dependencies. <a href='#playground' data-s='s3b1cff'>Try it live below.</a></p></div>"
  let _ = w f "<div class='card' data-s='s463a85'><h3 data-s='sd294e9'>Plasma Simulation</h3><p>Physics in your browser. A full toolkit for designing electric rocket engines and watching plasma (the hot, glowing stuff inside neon signs and lightning bolts) behave in real time. 11 tools, all written in Rail, all running live. <a href='/plasma' data-s='sd294e9'>Poke around &rarr;</a></p></div>"
  let _ = w f "<div class='card' data-s='s33a05d'><h3 data-s='sc7492c'>A Drone that Flies Itself</h3><p>A small quadcopter with a brain written in Rail. No Python, no cloud &mdash; it decides what to do in 31 microseconds (about one-thirty-thousandth of a second) and does it again, hundreds of times per second. Headed to a competition.</p></div>"
  let _ = w f "<div class='card' data-s='sb6e460'><h3 data-s='seed815'>AI that Teaches Itself</h3><p>Instead of hiring people to grade AI-written code, I let the compiler do it. If the code runs, it's right. The AI writes, Rail checks, the good ones become next week's lessons. 1,636 verified lessons so far. <a href='/system#flywheel' data-s='seed815'>See the loop &rarr;</a></p></div>"
  let _ = w f "</div></div></section>"

  -- TECHNICAL HERO (for engineers who scroll)
  let _ = w f "<section id='technical' class='reveal'><div class='wrap'>"
  let _ = w f (cat ["<p class='hero-tag'>", version, " // ", date, "</p>"])
  let _ = w f "<h2>The <span class='b'>numbers</span></h2>"
  let _ = w f (cat ["<p class='section-sub'>", lines_compile, " lines of Rail compile to ARM64, x86_64, Linux, WASM, and Metal GPU. Native IEEE 754 floats. Conservative mark-sweep GC in assembly. Closures, ADTs, pattern matching &mdash; all running in your browser. Zero C dependencies.</p>"])
  let _ = w f "<a href='https://github.com/zemo-g/rail' class='btn btn-g'>View on GitHub</a>"
  let _ = w f "<a href='#story' class='btn btn-o'>Read the story</a>"

  -- Animated reduction bars
  let _ = w f "<div class='bar-wrap' id='bars'>"
  let _ = w f "<div class='bar-row'><div class='bar-label'>Rust</div><div class='bar-track'><div class='bar-fill rust' data-w='100'></div><div class='bar-text'>21,086 lines</div></div></div>"
  let _ = w f (cat ["<div class='bar-row'><div class='bar-label'>Rail</div><div class='bar-track'><div class='bar-fill rail' data-w='20'></div><div class='bar-text' data-s='s3b1cff'>", lines_compile, " lines</div></div></div>"])
  let _ = w f "<div class='bar-row'><div class='bar-label'>Binary</div><div class='bar-track'><div class='bar-fill rust' data-w='100'></div><div class='bar-text'>~8 MB</div></div></div>"
  let _ = w f (cat ["<div class='bar-row'><div class='bar-label'>Binary</div><div class='bar-track'><div class='bar-fill rail' data-w='9'></div><div class='bar-text' data-s='s3b1cff'>", bin_kb, " KB</div></div></div>"])
  let _ = w f "<div class='bar-row'><div class='bar-label'>Targets</div><div class='bar-track'><div class='bar-fill rust' data-w='25'></div><div class='bar-text'>1 (native)</div></div></div>"
  let _ = w f "<div class='bar-row'><div class='bar-label'>Targets</div><div class='bar-track'><div class='bar-fill rail' data-w='70'></div><div class='bar-text' data-s='s3b1cff'>ARM64 + x86 + Linux + WASM + Metal</div></div></div>"
  let _ = w f "<div class='bar-row'><div class='bar-label'>Tests</div><div class='bar-track'><div class='bar-fill rail' data-w='50'></div><div class='bar-text' data-s='s3b1cff'>116/116</div></div></div>"
  let _ = w f "<div class='bar-row'><div class='bar-label'>Deps</div><div class='bar-track'><div class='bar-fill rail' data-w='8'></div><div class='bar-text' data-s='s3b1cff'>as + ld (zero C deps)</div></div></div>"
  let _ = w f "</div>"
  let _ = w f "</div></section>"

  -- ABOUT
  let _ = w f "<section id='about' class='reveal'><div class='wrap'>"
  let _ = w f "<div class='about'>"
  let _ = w f "<img class='about-photo' src='https://pub-e9d7c87d3a1b43bea50d3bd0d8ba9ffb.r2.dev/og-image.png' alt='Reilly Gomez'>"
  let _ = w f "<div class='about-text'>"
  let _ = w f "<div class='about-name'>Reilly Gomez</div>"
  let _ = w f "<div class='about-role'>Systems Engineer</div>"
  let _ = w f "<p class='about-bio'>I like building things that work with minimal resources. Most of my time goes into Rail and the infrastructure around it. Before that I spent nine years running a food production business, which taught me that systems need to be reliable before they can be clever.</p>"
  let _ = w f "<div class='about-links'>"
  let _ = w f "<a href='https://github.com/zemo-g'>github</a>"
  let _ = w f "<a href='mailto:reillygomez13@icloud.com'>email</a>"
  let _ = w f "</div></div></div></div></section>"

  -- STORY (compact timeline)
  let _ = w f "<section id='story' class='reveal'><div class='wrap'>"
  let _ = w f "<h2>The <span class='g'>story</span></h2>"
  let _ = w f "<p class='section-sub'>I started Rail in January, writing it in a different language first (the way you'd sketch a house in pencil before building it). Four months later Rail can build itself, runs on five different kinds of hardware, uses your graphics card for math, and simulates rocket-engine physics in your browser.</p>"
  let _ = w f "<div class='tl-compact'>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>JAN</div><div class='tl-c-title'>Wrote Rail's guts</div><div class='tl-c-desc'>The parts that read code, understand it, and run it. 21,000 lines, in another language (for now).</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>FEB</div><div class='tl-c-title'>Talks to Apple chips directly</div><div class='tl-c-desc'>No translator in the middle &mdash; Rail speaks the machine's native tongue.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>MAR 16</div><div class='tl-c-title'>Rail builds itself</div><div class='tl-c-desc'>Kicked away the ladder. Didn't need the other language anymore.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>MAR 20</div><div class='tl-c-title'>The teaching loop starts</div><div class='tl-c-desc'>AI writes code, Rail grades it, the good ones become tomorrow's lessons.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>MAR 25</div><div class='tl-c-title'>Fast as the gold standard</div><div class='tl-c-desc'>Matched C &mdash; a fifty-year-old language everyone measures speed against.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>APR 2</div><div class='tl-c-title'>Real decimals, zero penalty</div><div class='tl-c-desc'>Rail handles fractional numbers (3.14, not 3) at full speed.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>APR 3</div><div class='tl-c-title'>Runs in your browser</div><div class='tl-c-desc'>Rail can now run inside a web tab. Errors handled, live prompt, tiny web server &mdash; all included.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>APR 4</div><div class='tl-c-title'>Memory cleanup fixed</div><div class='tl-c-desc'>Rail now builds itself every time, no flukes. The garbage collector (the janitor) stopped making mistakes.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>APR 4</div><div class='tl-c-title'>Real Rail in the browser</div><div class='tl-c-desc'>Full-featured Rail programs running inside a browser tab. Seven live demos &mdash; see below.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>APR 6</div><div class='tl-c-title'>Crown jewels moved over</div><div class='tl-c-desc'>Four critical pieces of my old trading code, rewritten in pure Rail.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>APR 7</div><div class='tl-c-title'>Website polish</div><div class='tl-c-desc'>Made this site fast, search-friendly, and safer. Most of what you're looking at was done this day.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>APR 10</div><div class='tl-c-title'>Machine-learning kit</div><div class='tl-c-desc'>Built the math that powers ChatGPT-style AI, in pure Rail. The same attention-and-layers architecture, from scratch.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>APR 12</div><div class='tl-c-title'>Decimals in the browser too</div><div class='tl-c-desc'>Rail in a browser tab can now do real math &mdash; square roots, trig, full precision.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>APR 14</div><div class='tl-c-title'>Plasma physics, in a browser</div><div class='tl-c-desc'>Simulates how ionized gas swirls under magnetic fields. Energy and mass stay exactly balanced.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>APR 15</div><div class='tl-c-title'>Using the graphics card for math</div><div class='tl-c-desc'>Rail now offloads heavy math to your GPU &mdash; nearly half a trillion operations per second on a laptop chip. The plasma toolkit also shipped: 11 tools for designing rocket engines.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>APR 16</div><div class='tl-c-title'>Smarter memory janitor</div><div class='tl-c-desc'>Taught the garbage collector exactly what's what, instead of making it guess. Fewer mistakes, faster cleanup.</div></div>"
  let _ = w f "<div class='tl-c active'><div class='tl-c-date'>APR 16</div><div class='tl-c-title'>Rail writes its own lessons</div><div class='tl-c-desc'>The first 1,636 AI lessons landed &mdash; every one of them runs. Browser version of Rail also got stricter about remembering things.</div></div>"
  let _ = w f "</div></div></section>"

  -- ARCHITECTURE (interactive flow diagram)
  let _ = w f "<section id='arch' class='reveal'><div class='wrap'>"
  let _ = w f "<h2>How it <span class='b'>works</span></h2>"
  let _ = w f (cat ["<p class='section-sub'>You write Rail code. It gets read, understood, translated to instructions the machine knows, and linked into an app you can run. Same pipeline, five different kinds of machine at the end. <span style='color:#8b8b94'>(", lines_compile, " lines make up the whole compiler.)</span></p>"])
  let _ = w f "<div class='arch-flow'>"
  let _ = w f "<div class='arch-node'><div class='label'>.rail</div><div class='sub'>source</div></div>"
  let _ = w f "<div class='arch-arrow' aria-hidden='true'>&rarr;</div>"
  let _ = w f "<div class='arch-node'><div class='label' data-s='seed815'>Lexer</div><div class='sub'>tokens</div></div>"
  let _ = w f "<div class='arch-arrow' aria-hidden='true'>&rarr;</div>"
  let _ = w f "<div class='arch-node'><div class='label' data-s='sd294e9'>Parser</div><div class='sub'>AST</div></div>"
  let _ = w f "<div class='arch-arrow' aria-hidden='true'>&rarr;</div>"
  let _ = w f "<div class='arch-node'><div class='label' data-s='sc7492c'>Codegen</div><div class='sub'>ARM64 / x86 / WASM / Metal</div></div>"
  let _ = w f "<div class='arch-arrow' aria-hidden='true'>&rarr;</div>"
  let _ = w f (cat ["<div class='arch-node'><div class='label' data-s='s3b1cff'>as + ld</div><div class='sub'>", bin_kb, "K binary</div></div>"])
  let _ = w f "</div>"

  -- Runtime diagram
  let _ = w f "<div data-s='s0f873e'>"
  let _ = w f "<div class='grid' data-s='s823d07'>"
  let _ = w f "<div class='card' data-s='s04dc4f'><h3 data-s='s96c8b6'>Allocator</h3><p>512MB bump arena<br>+ GC + free list</p></div>"
  let _ = w f "<div class='card' data-s='s0385d5'><h3 data-s='sf46ca3'>GC</h3><p>Conservative<br>mark-sweep</p></div>"
  let _ = w f "<div class='card' data-s='sd5268f'><h3 data-s='sf38f84'>Runtime</h3><p>Tagged pointers<br>TCO + closures</p></div>"
  let _ = w f "</div>"
  let _ = w f "<p data-s='s2b6c7e'>Full technical details on <a href='/system' data-s='scf70c3'>/system</a></p>"
  let _ = w f "</div></div></section>"

  -- PLAYGROUND — WASM demos that run in-browser
  let _ = w f "<section id='playground' class='reveal'><div class='wrap'>"
  let _ = w f "<h2>Try it <span class='g'>live</span></h2>"
  let _ = w f "<p class='section-sub'>Real Rail programs, running right here in your browser tab. No server, no download, no install &mdash; just click Run and see what comes out.</p>"
  let _ = w f "<button id='run-all' class='btn btn-g' data-s='sea04bb'>Run all demos</button>"
  let _ = w f "<div class='pg-demos'>"

  -- Demo 1: Hello
  let _ = w f "<div class='pg-demo'>"
  let _ = w f "<div class='pg-src'><pre><code>main =\n  let _ = print \"Hello from Rail!\"\n  let _ = print \"Running as WebAssembly.\"\n  0</code></pre></div>"
  let _ = w f "<button class='pg-run' data-run='0'>Run</button>"
  let _ = w f "<pre class='pg-out' id='out0'></pre></div>"

  -- Demo 2: Fibonacci
  let _ = w f "<div class='pg-demo'>"
  let _ = w f "<div class='pg-src'><pre><code>fib n =\n  if n < 2 then n\n  else fib (n - 1) + fib (n - 2)\n\nmain =\n  let _ = print (fib 10)\n  let _ = print (fib 20)\n  let _ = print (fib 30)\n  0</code></pre></div>"
  let _ = w f "<button class='pg-run' data-run='1'>Run</button>"
  let _ = w f "<pre class='pg-out' id='out1'></pre></div>"

  -- Demo 3: Math
  let _ = w f "<div class='pg-demo'>"
  let _ = w f "<div class='pg-src'><pre><code>square x = x * x\ncube x = x * x * x\n\nmain =\n  let _ = print (square 7)\n  let _ = print (cube 5)\n  let _ = print (square 12 + cube 3)\n  0</code></pre></div>"
  let _ = w f "<button class='pg-run' data-run='2'>Run</button>"
  let _ = w f "<pre class='pg-out' id='out2'></pre></div>"

  -- Demo 4: Lists
  let _ = w f "<div class='pg-demo'>"
  let _ = w f "<div class='pg-src'><pre><code>main =\n  let xs = [10, 20, 30, 40]\n  let _ = print (show (head xs))\n  let _ = print (show (length xs))\n  let _ = print (show (head (tail (tail xs))))\n  0</code></pre></div>"
  let _ = w f "<button class='pg-run' data-run='3'>Run</button>"
  let _ = w f "<pre class='pg-out' id='out3'></pre></div>"

  -- Demo 5: ADTs + Pattern Matching
  let _ = w f "<div class='pg-demo'>"
  let _ = w f "<div class='pg-src'><pre><code>type Shape =\n  | Circle r\n  | Rect w h\n\narea s = match s\n  | Circle r -> r * r * 3\n  | Rect w h -> w * h\n\nmain =\n  let _ = print (show (area (Circle 5)))\n  let _ = print (show (area (Rect 4 7)))\n  let _ = print (show (area (Circle 10)))\n  0</code></pre></div>"
  let _ = w f "<button class='pg-run' data-run='4'>Run</button>"
  let _ = w f "<pre class='pg-out' id='out4'></pre></div>"

  -- Demo 6: Closures
  let _ = w f "<div class='pg-demo'>"
  let _ = w f "<div class='pg-src'><pre><code>apply f x = f x\n\nmain =\n  let scale = 10\n  let mul = \\x -> x * scale\n  let _ = print (show (apply mul 7))\n  let offset = 100\n  let add = \\x -> x + offset\n  let _ = print (show (apply add 42))\n  0</code></pre></div>"
  let _ = w f "<button class='pg-run' data-run='5'>Run</button>"
  let _ = w f "<pre class='pg-out' id='out5'></pre></div>"

  -- Demo 7: FizzBuzz (recursion + conditionals)
  let _ = w f "<div class='pg-demo'>"
  let _ = w f "<div class='pg-src'><pre><code>fizzbuzz n = if n > 20 then 0\n  else\n    let _ = if (n % 15) == 0\n      then print \"FizzBuzz\"\n      else if (n % 3) == 0\n      then print \"Fizz\"\n      else if (n % 5) == 0\n      then print \"Buzz\"\n      else print (show n)\n    fizzbuzz (n + 1)\n\nmain =\n  let _ = fizzbuzz 1\n  0</code></pre></div>"
  let _ = w f "<button class='pg-run' data-run='6'>Run</button>"
  let _ = w f "<pre class='pg-out' id='out6'></pre></div>"

  -- Demo 8: GC stress — 100K cons in a 1MB heap (proves the collector reclaims)
  let _ = w f "<div class='pg-demo'>"
  let _ = w f "<div class='pg-src'><pre><code>loop n =\n  if n == 0 then 0\n  else\n    let _ = cons n []\n    loop (n - 1)\n\nmain =\n  let _ = print \"GC stress: 100000 cons in 1MB heap...\"\n  let _ = loop 100000\n  let _ = print \"Done — GC reclaimed garbage.\"\n  0</code></pre></div>"
  let _ = w f "<button class='pg-run' data-run='7'>Run</button>"
  let _ = w f "<pre class='pg-out' id='out7'></pre></div>"

  let _ = w f "</div>"

  -- Embed WASM binaries as base64
  let hello_b64 = trim (shell "base64 -i /tmp/demo_hello.wasm | tr -d '\\n'")
  let fib_b64 = trim (shell "base64 -i /tmp/demo_fib.wasm | tr -d '\\n'")
  let math_b64 = trim (shell "base64 -i /tmp/demo_math.wasm | tr -d '\\n'")
  let list_b64 = trim (shell "base64 -i /tmp/demo_list.wasm | tr -d '\\n'")
  let adt_b64 = trim (shell "base64 -i /tmp/demo_adt.wasm | tr -d '\\n'")
  let clos_b64 = trim (shell "base64 -i /tmp/demo_closure.wasm | tr -d '\\n'")
  let fizz_b64 = trim (shell "base64 -i /tmp/demo_fizz.wasm | tr -d '\\n'")
  let loop_b64 = trim (shell "base64 -i /tmp/demo_loop.wasm | tr -d '\\n'")

  let _ = w js_file (cat ["var WASM_BINS=[\"", hello_b64, "\",\"", fib_b64, "\",\"", math_b64, "\",\"", list_b64, "\",\"", adt_b64, "\",\"", clos_b64, "\",\"", fizz_b64, "\",\"", loop_b64, "\"];"])
  let _ = w js_file "function b64toBytes(b){var r=atob(b),a=new Uint8Array(r.length);for(var i=0;i<r.length;i++)a[i]=r.charCodeAt(i);return a}"
  let _ = w js_file "async function runWasm(idx){var el=document.getElementById('out'+idx);el.textContent='Running...\\n';try{"
  let _ = w js_file "var bytes=b64toBytes(WASM_BINS[idx]);var out='';var M={m:null};"
  let _ = w js_file "var imports={wasi_snapshot_preview1:{"
  let _ = w js_file "fd_write:function(fd,iovs,cnt,pw){var v=new DataView(M.m.buffer);var p=v.getUint32(iovs,true);var l=v.getUint32(iovs+4,true);out+=new TextDecoder().decode(new Uint8Array(M.m.buffer,p,l));v.setUint32(pw,l,true);return 0},"
  let _ = w js_file "proc_exit:function(code){}}};"
  let _ = w js_file "var{instance}=await WebAssembly.instantiate(bytes,imports);"
  let _ = w js_file "M.m=instance.exports.memory;"
  let _ = w js_file "out='';instance.exports._start();el.textContent=out||'(no output)';el.style.borderColor='#00ff41'"
  let _ = w js_file "}catch(e){el.textContent='Error: '+e.message;el.style.borderColor='#f97316'}}"

  -- Playground CSS
  let _ = w css_file ".pg-demos{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;margin-top:24px}"
  let _ = w css_file ".pg-demo{background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px;overflow:hidden}"
  let _ = w css_file ".pg-src{padding:16px;border-bottom:1px solid #1c1c1e}.pg-src pre{margin:0;font-size:12px;line-height:1.5;color:#a1a1aa;overflow-x:auto}.pg-src code{font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace}"
  let _ = w css_file ".pg-run{display:block;width:100%;padding:10px;background:#111;border:none;color:#00ff41;font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:13px;cursor:pointer;border-bottom:1px solid #1c1c1e;transition:background 0.2s}.pg-run:hover{background:#1a1a1a}"
  let _ = w css_file ".pg-out{margin:0;padding:16px;font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace;font-size:12px;color:#e4e4e7;min-height:40px;border-left:2px solid #27272a;transition:border-color 0.3s}"
  let _ = w f "</div></section>"

  -- FLYWHEEL (SVG diagram)
  let _ = w f "<section id='flywheel' class='reveal'><div class='wrap'>"
  let _ = w f "<h2>The <span class='g'>flywheel</span></h2>"
  let _ = w f "<p class='section-sub'>The compiler is the oracle. If it compiles, the code is correct. The model gets better at writing the language it is verified by. <span data-s='sc7492c'>[Loop proven, currently dormant &mdash; numbers below are the achieved high-water mark.]</span></p>"

  let _ = w f "<div class='flywheel-wrap'>"
  let _ = w f "<svg class='flywheel-svg' viewBox='0 0 400 400'>"
  -- Center circle
  let _ = w f "<circle cx='200' cy='200' r='60' fill='none' stroke='#1c1c1e' stroke-width='1'/>"
  let _ = w f "<text x='200' y='195' text-anchor='middle' fill='#00ff41' font-family='ui-monospace,Menlo,monospace' font-size='11' font-weight='600'>COMPILER</text>"
  let _ = w f "<text x='200' y='212' text-anchor='middle' fill='#52525b' font-family='ui-monospace,Menlo,monospace' font-size='9'>oracle</text>"
  -- Orbit ring
  let _ = w f "<circle cx='200' cy='200' r='140' fill='none' stroke='#1c1c1e' stroke-width='1' stroke-dasharray='4,8'/>"
  -- Nodes
  let _ = w f "<g>"
  let _ = w f "<rect x='162' y='28' width='76' height='36' rx='6' fill='#0c0c0e' stroke='#00ff41' stroke-width='1'/>"
  let _ = w f "<text x='200' y='51' text-anchor='middle' fill='#00ff41' font-family='ui-monospace,Menlo,monospace' font-size='11' font-weight='600'>Generate</text>"
  let _ = w f "<rect x='308' y='162' width='76' height='36' rx='6' fill='#0c0c0e' stroke='#3b82f6' stroke-width='1'/>"
  let _ = w f "<text x='346' y='185' text-anchor='middle' fill='#3b82f6' font-family='ui-monospace,Menlo,monospace' font-size='11' font-weight='600'>Compile</text>"
  let _ = w f "<rect x='162' y='336' width='76' height='36' rx='6' fill='#0c0c0e' stroke='#f97316' stroke-width='1'/>"
  let _ = w f "<text x='200' y='359' text-anchor='middle' fill='#f97316' font-family='ui-monospace,Menlo,monospace' font-size='11' font-weight='600'>Harvest</text>"
  let _ = w f "<rect x='16' y='162' width='76' height='36' rx='6' fill='#0c0c0e' stroke='#c084fc' stroke-width='1'/>"
  let _ = w f "<text x='54' y='185' text-anchor='middle' fill='#c084fc' font-family='ui-monospace,Menlo,monospace' font-size='11' font-weight='600'>Train</text>"
