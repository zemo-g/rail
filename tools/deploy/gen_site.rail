  -- OTHER WORK
  let _ = w f "<section id='other' class='reveal'><div class='wrap'>"
  let _ = w f "<h2>Other <span class='o'>work</span></h2>"
  let _ = w f "<div class='grid' data-s='s3939bb'>"
  let _ = w f "<div class='ow-card c-orange'><h3 data-s='s52eed5'>A drone that flies itself</h3><p data-s='sf29072'>A little quadcopter brain, written entirely in Rail. It decides what to do in microseconds &mdash; no Python, no cloud, no waiting for a server to answer.</p></div>"
  let _ = w f "<div class='ow-card c-blue'><h3 data-s='s2c8d47'>Four machines on my desk</h3><p data-s='sf29072'>Each has a different job: one for day-to-day work, one for heavy thinking, a gaming PC for training AI, and a tiny Raspberry Pi at the edge. All four speak Rail.</p></div>"
  let _ = w f "<div class='ow-card c-purple'><h3 data-s='saceff4'>Rail everywhere</h3><p data-s='sf29072'>Same Rail programs run in a browser tab, on a server, on a laptop, and on a GPU. The plasma demo above? That's Rail running live in your browser.</p></div>"
  let _ = w f "<div class='ow-card c-green'><h3 data-s='s45c6f4'>Nanoversight</h3><p data-s='sf29072'>A tiny AI that watches something and writes down what it thinks. One file, one loop. <a href='https://github.com/zemo-g/nanoversight' data-s='s3b1cff'>Open source</a>.</p></div>"
  let _ = w f "</div>"
  -- HIRE — explicit service tiers, scoped CTAs
  let _ = w f "<div data-s='sc98cf7'>"
  let _ = w f "<h3 data-s='s1b57a8'>Hire LEDATIC</h3>"
  let _ = w f "<p data-s='s29e6f9'>Engagements where footprint and reliability matter more than convenience. Pick the closest match and send a one-line inquiry &mdash; the subject is pre-filled.</p>"
  let _ = w f "<div class='grid' data-s='s59ed2b'>"
  let _ = w f "<div class='card' data-s='s463a85'><h3 data-s='s50cfb2'>Compiler-verified AI training</h3><p data-s='s8e8697'>Self-training loops where the compiler is the oracle. LoRA / QLoRA on Apple Silicon and consumer GPUs. Strict eval design.</p><a href='mailto:reillygomez13@icloud.com?subject=LEDATIC%20%E2%80%94%20Compiler-verified%20AI%20training' data-s='s99387d'>Email &rarr;</a></div>"
  let _ = w f "<div class='card' data-s='sbc5252'><h3 data-s='s8875db'>Custom inference stacks</h3><p data-s='s8e8697'>MLX servers, CUDA QLoRA training nodes, tiered routing, prompt caching, structured outputs. Production-ready, no Python at runtime if you don't want it.</p><a href='mailto:reillygomez13@icloud.com?subject=LEDATIC%20%E2%80%94%20Custom%20inference%20stack' data-s='sc72f5e'>Email &rarr;</a></div>"
  let _ = w f "<div class='card' data-s='s33a05d'><h3 data-s='s9222cd'>Autonomous control systems</h3><p data-s='s8e8697'>Real-time neural autopilots in pure Rail. Microsecond inference. Sim-to-real, MAVLink, oracle-imitation training pipelines.</p><a href='mailto:reillygomez13@icloud.com?subject=LEDATIC%20%E2%80%94%20Autonomous%20control' data-s='sd3d997'>Email &rarr;</a></div>"
  let _ = w f "<div class='card' data-s='sb6e460'><h3 data-s='s0b5985'>Language &amp; tooling design</h3><p data-s='s8e8697'>Self-hosting compilers, embedded DSLs, distributed compute fleets, where minimal footprint and zero dependencies are non-negotiable.</p><a href='mailto:reillygomez13@icloud.com?subject=LEDATIC%20%E2%80%94%20Language%20design' data-s='s227d70'>Email &rarr;</a></div>"
  let _ = w f "</div>"
  let _ = w f "<div data-s='s4a35e3'>"
  let _ = w f "<p data-s='s16fc22'>Not sure which fits? <a href='mailto:reillygomez13@icloud.com?subject=LEDATIC%20%E2%80%94%20Inquiry' data-s='s3b1cff'>Send a one-liner</a> and we'll figure it out.</p>"
  let _ = w f "<a href='https://github.com/zemo-g' data-s='s704101'>github.com/zemo-g</a>"
  let _ = w f "</div>"
  let _ = w f "</div></div></section>"

  -- FOOTER
  let _ = w f (cat ["</main><footer><span data-s='s3b1cff'>&gt;</span> LEDATIC // ", version, "<br><br>"])
