-- gen_site.rail — ledatic.org, rebuilt from zero on v3.0.0.
--
-- One column. Type is the architecture. Green is signal, not wallpaper.
-- No cards, no boot overlay, no scanline, no burger nav. Read top to
-- bottom and you've read the site. The page measures itself with
-- shell() at gen time — every number you see is captured from the
-- repo at compile time, not typed.

cat parts = join "" parts
trim s = head (split "\n" s)

w path s =
  let _ = write_file "/tmp/_rc.txt" s
  shell (cat ["cat /tmp/_rc.txt >> ", path])

main =
  -- live numbers — captured from the repo at the moment the page is built
  let date = trim (shell "date -u '+%Y-%m-%d'")
  let lines_compile = trim (shell "wc -l < tools/compile.rail | tr -d ' '")
  let bin_kb = trim (shell "wc -c < rail_native | awk '{print int($1/1024)}'")
  let binary_sha = trim (shell "shasum -a 256 rail_native | awk '{print substr($1,1,24)}'")
  let tls_lines = trim (shell "(wc -l stdlib/sha256.rail stdlib/sha512.rail stdlib/hmac.rail stdlib/hkdf.rail stdlib/chacha20.rail stdlib/poly1305.rail stdlib/aead.rail stdlib/x25519.rail stdlib/bignum_n.rail stdlib/ecdsa_p256.rail stdlib/ecdsa_p384.rail stdlib/rsa_pss.rail stdlib/asn1.rail stdlib/b64.rail stdlib/pem.rail stdlib/tls13.rail stdlib/tls13_hs.rail stdlib/tls13_record.rail stdlib/tls13_cert_verify.rail stdlib/tls13_client.rail stdlib/cert_chain.rail stdlib/cert_p384.rail stdlib/https_client.rail stdlib/dns.rail stdlib/anthropic_client.rail stdlib/slack_client.rail 2>/dev/null | tail -1 | awk '{print $1}')")
  let tls_tests = trim (shell "ls tools/tls/*.rail 2>/dev/null | wc -l | tr -d ' '")
  let commits_v3 = trim (shell "git log --oneline v2.23.0-rc1..HEAD 2>/dev/null | wc -l | tr -d ' '")

  let f = "/tmp/ledatic.html"
  let css = "/tmp/ledatic_main.css"
  let _ = shell (cat ["rm -f ", f, " ", css])

  -- ── HEAD ────────────────────────────────────────────────────────
  let _ = w f "<!DOCTYPE html><html lang='en'><head>"
  let _ = w f "<meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1.0'>"
  let _ = w f "<title>LEDATIC — Reilly Gomez</title>"
  let _ = w f "<meta name='description' content='A language that builds itself and now speaks TLS alone. Rail v3.0.0 — pure-Rail TLS 1.3, zero C dependencies.'>"
  let _ = w f "<meta name='author' content='Reilly Gomez'>"
  let _ = w f "<meta property='og:title' content='LEDATIC'>"
  let _ = w f "<meta property='og:description' content='A language that builds itself and speaks TLS alone.'>"
  let _ = w f "<meta property='og:url' content='https://ledatic.org'>"
  let _ = w f "<meta property='og:type' content='website'>"
  let _ = w f "<meta name='twitter:card' content='summary_large_image'>"
  let _ = w f "<meta name='twitter:title' content='LEDATIC'>"
  let _ = w f "<meta name='twitter:description' content='A language that builds itself and speaks TLS alone.'>"
  let _ = w f "<link rel='canonical' href='https://ledatic.org/'>"
  let _ = w f "<link rel='icon' href='data:image/svg+xml,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 100 100\"><text y=\".9em\" font-size=\"90\">%3E</text></svg>'>"
  let _ = w f "<link rel='stylesheet' href='/main.css'>"
  let _ = w f "</head>"

  -- ── CSS ─────────────────────────────────────────────────────────
  let _ = w css "*\{margin:0;padding:0;box-sizing:border-box\}"
  let _ = w css "html\{scroll-behavior:smooth;font-size:16px\}"
  let _ = w css "@media(min-width:900px)\{html\{font-size:17px\}\}"

  -- fonts + base
  let _ = w css "body\{background:#08080a;color:#cfcfd4;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;font-weight:400;line-height:1.65;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;min-height:100vh\}"
  let _ = w css ".mono\{font-family:ui-monospace,'SF Mono',Menlo,Monaco,'Cascadia Mono',monospace\}"
  let _ = w css "::selection\{background:#00ff4128;color:#fff\}"

  -- colour accents used for SIGNAL, not background
  let _ = w css ".g\{color:#00ff41\}"
  let _ = w css ".d\{color:#5f5f68\}"
  let _ = w css ".w\{color:#e8e8ec\}"

  -- links
  let _ = w css "a\{color:inherit;text-decoration:none;border-bottom:1px solid #242429;transition:border-color .15s ease,color .15s ease\}"
  let _ = w css "a:hover\{color:#00ff41;border-bottom-color:#00ff41\}"

  -- single vertical rhythm container
  let _ = w css ".page\{max-width:680px;margin:0 auto;padding:0 28px\}"
  let _ = w css "@media(min-width:900px)\{.page\{max-width:720px;padding:0 40px\}\}"

  -- tiny fixed-position crown: logo top-left, live clock top-right
  let _ = w css ".crown\{position:fixed;top:0;left:0;right:0;display:flex;justify-content:space-between;align-items:center;padding:18px 28px;z-index:40;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:11px;letter-spacing:3px;text-transform:uppercase;pointer-events:none\}"
  let _ = w css "@media(min-width:900px)\{.crown\{padding:22px 40px\}\}"
  let _ = w css ".crown a,.crown .block\{pointer-events:auto\}"
  let _ = w css ".crown .logo\{color:#e8e8ec\}.crown .logo span\{color:#00ff41\}"
  let _ = w css ".crown .clock\{color:#5f5f68;font-variant-numeric:tabular-nums\}"
  let _ = w css ".crown .clock .dot\{display:inline-block;width:6px;height:6px;border-radius:50%;background:#00ff41;box-shadow:0 0 8px #00ff41;margin-right:8px;animation:beat 2.4s ease-in-out infinite;vertical-align:middle\}"
  let _ = w css "@keyframes beat\{0%,100%\{opacity:.4\}50%\{opacity:1\}\}"

  -- first paint: massive editorial hero
  let _ = w css ".hero\{padding:38vh 0 22vh;min-height:100vh\}"
  let _ = w css "@media(max-width:720px)\{.hero\{padding:32vh 0 16vh\}\}"
  let _ = w css ".hero h1\{font-size:clamp(44px,8.2vw,104px);line-height:.98;letter-spacing:-.03em;font-weight:600;color:#f2f2f5;margin-bottom:40px\}"
  let _ = w css ".hero h1 .g\{font-weight:700\}"
  let _ = w css ".hero h1 .period\{color:#00ff41\}"
  let _ = w css ".hero .credit\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:12px;letter-spacing:3px;text-transform:uppercase;color:#5f5f68;display:flex;gap:14px;flex-wrap:wrap;align-items:center\}"
  let _ = w css ".hero .credit .sep\{color:#242429\}"

  -- section — horizontal rule label + flowing body text
  let _ = w css "section\{padding:60px 0;border-top:1px solid #17171c\}"
  let _ = w css ".slab\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:11px;letter-spacing:4px;text-transform:uppercase;color:#5f5f68;margin-bottom:28px;display:flex;align-items:center;gap:14px\}"
  let _ = w css ".slab .chip\{color:#00ff41;font-weight:500\}"
  let _ = w css ".slab .fill\{flex:1;height:1px;background:#17171c\}"

  -- body prose
  let _ = w css "section p\{font-size:17px;line-height:1.7;color:#cfcfd4;margin-bottom:18px\}"
  let _ = w css "section p.big\{font-size:clamp(20px,2.4vw,26px);line-height:1.5;color:#e8e8ec;font-weight:400;margin-bottom:28px\}"
  let _ = w css "section p b\{color:#f2f2f5;font-weight:500\}"
  let _ = w css "section p em\{color:#00ff41;font-style:normal;font-weight:500\}"
  let _ = w css "section h2\{font-size:clamp(28px,4.2vw,46px);line-height:1.08;font-weight:600;color:#f2f2f5;letter-spacing:-.02em;margin-bottom:22px\}"
  let _ = w css "section h2 .g\{font-weight:700\}"

  -- three-line bootstrap proof
  let _ = w css ".proof\{background:transparent;border:1px solid #17171c;border-radius:3px;padding:18px 22px;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:13px;line-height:1.8;color:#9090a0;margin:24px 0\}"
  let _ = w css ".proof .c\{color:#5f5f68\}.proof .v\{color:#e8e8ec\}.proof .g\{color:#00ff41\}"

  -- handshake log — the centerpiece of v3.0.0
  let _ = w css ".log\{background:#0b0b0e;border:1px solid #17171c;border-radius:4px;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:13px;margin:28px 0\}"
  let _ = w css ".log .bar\{padding:10px 18px;border-bottom:1px solid #17171c;display:flex;justify-content:space-between;align-items:center;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#5f5f68\}"
  let _ = w css ".log .body\{padding:18px 22px;line-height:1.85;overflow-x:auto\}"
  let _ = w css ".log .ln\{display:flex;gap:16px;white-space:pre;opacity:0;animation:in .2s ease-out forwards\}"
  let _ = w css ".log .t\{color:#40404a;font-variant-numeric:tabular-nums;min-width:48px\}"
  let _ = w css ".log .p\{color:#00ff41;min-width:10px;display:inline-block\}"
  let _ = w css ".log .k\{color:#70707a;min-width:72px;display:inline-block\}"
  let _ = w css ".log .v\{color:#cfcfd4\}"
  let _ = w css ".log .hex\{color:#c9a84c\}"
  let _ = w css ".log .ok\{color:#00ff41\}"
  let _ = w css ".log .dim\{color:#40404a\}"
  let _ = w css "@keyframes in\{from\{opacity:0;transform:translateX(-4px)\}to\{opacity:1;transform:translateX(0)\}\}"
  let _ = w css ".log .ln:nth-child(1)\{animation-delay:.08s\}.log .ln:nth-child(2)\{animation-delay:.22s\}.log .ln:nth-child(3)\{animation-delay:.36s\}.log .ln:nth-child(4)\{animation-delay:.48s\}.log .ln:nth-child(5)\{animation-delay:.60s\}.log .ln:nth-child(6)\{animation-delay:.74s\}.log .ln:nth-child(7)\{animation-delay:.86s\}.log .ln:nth-child(8)\{animation-delay:.98s\}.log .ln:nth-child(9)\{animation-delay:1.10s\}.log .ln:nth-child(10)\{animation-delay:1.26s\}.log .ln:nth-child(11)\{animation-delay:1.40s\}.log .ln:nth-child(12)\{animation-delay:1.58s\}"

  -- trust gates — inline list with green LEDs
  let _ = w css ".gates\{display:grid;grid-template-columns:1fr;gap:1px;background:#17171c;border:1px solid #17171c;border-radius:3px;margin:28px 0;overflow:hidden\}"
  let _ = w css "@media(min-width:620px)\{.gates\{grid-template-columns:1fr 1fr\}\}"
  let _ = w css ".gate\{background:#0b0b0e;padding:16px 18px;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:12px;display:flex;gap:14px;align-items:flex-start\}"
  let _ = w css ".gate .led\{width:7px;height:7px;border-radius:50%;background:#00ff41;box-shadow:0 0 8px #00ff41;margin-top:6px;flex-shrink:0\}"
  let _ = w css ".gate .lab\{color:#e8e8ec;letter-spacing:1px;text-transform:uppercase;font-size:11px;display:block;margin-bottom:4px\}"
  let _ = w css ".gate .desc\{color:#70707a;font-size:12px;line-height:1.55\}"

  -- count line — four big numbers on one row
  let _ = w css ".counts\{display:grid;grid-template-columns:repeat(2,1fr);gap:0;margin:32px 0\}"
  let _ = w css "@media(min-width:620px)\{.counts\{grid-template-columns:repeat(4,1fr)\}\}"
  let _ = w css ".cnt\{padding:18px 0;border-top:1px solid #17171c\}"
  let _ = w css "@media(min-width:620px)\{.cnt:not(:last-child)\{border-right:1px solid #17171c\}\}"
  let _ = w css ".cnt .n\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:clamp(30px,4vw,40px);font-weight:300;color:#f2f2f5;letter-spacing:-1px;font-variant-numeric:tabular-nums;line-height:1\}"
  let _ = w css ".cnt .l\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:#5f5f68;margin-top:10px;line-height:1.5\}"
  let _ = w css ".cnt.live .n\{color:#00ff41\}"

  -- release row (three links)
  let _ = w css ".links\{display:flex;gap:22px;flex-wrap:wrap;margin:32px 0 8px;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:12px;letter-spacing:2px;text-transform:uppercase\}"
  let _ = w css ".links a\{border-bottom:1px solid #242429;padding-bottom:2px\}"

  -- work list — no cards, prose with right-anchored links
  let _ = w css ".work-item\{display:grid;grid-template-columns:1fr;gap:6px;padding:22px 0;border-top:1px solid #17171c\}"
  let _ = w css "@media(min-width:620px)\{.work-item\{grid-template-columns:140px 1fr\}\}"
  let _ = w css ".work-item .name\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#00ff41;padding-top:6px\}"
  let _ = w css ".work-item .body\{color:#cfcfd4;font-size:16px;line-height:1.7\}"
  let _ = w css ".work-item .body b\{color:#f2f2f5;font-weight:500\}"
  let _ = w css ".work-item .body a\{color:#70707a;margin-left:10px;font-size:12px;font-family:ui-monospace,'SF Mono',Menlo,monospace;letter-spacing:1px;text-transform:uppercase\}"

  -- numbers block — tight tabular row
  let _ = w css ".nums-row\{display:grid;grid-template-columns:160px 1fr;gap:18px;padding:14px 0;border-top:1px solid #17171c;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:13px;line-height:1.7\}"
  let _ = w css ".nums-row .k\{color:#5f5f68;letter-spacing:2px;text-transform:uppercase;font-size:11px;padding-top:3px\}"
  let _ = w css ".nums-row .v\{color:#e8e8ec\}"
  let _ = w css ".nums-row .v .g\{color:#00ff41\}"

  -- about row
  let _ = w css ".about-line\{display:flex;gap:18px;flex-wrap:wrap;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:12px;letter-spacing:2px;text-transform:uppercase;color:#70707a;margin-top:10px\}"
  let _ = w css ".about-line a\{color:#cfcfd4\}"

  -- footer
  let _ = w css "footer\{padding:60px 0 80px;border-top:1px solid #17171c;margin-top:40px\}"
  let _ = w css "footer .mantra\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:11px;letter-spacing:4px;text-transform:uppercase;color:#5f5f68;text-align:center\}"
  let _ = w css "footer .mantra .bright\{color:#00ff41\}"
  let _ = w css "footer .sig\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:10px;letter-spacing:2px;color:#40404a;text-align:center;margin-top:16px\}"
  let _ = w css "footer .sig code\{color:#5f5f68\}"

  -- ── BODY ────────────────────────────────────────────────────────
  let _ = w f "<body>"

  -- fixed crown
  let _ = w f "<div class='crown'>"
  let _ = w f "<div class='logo block'>LEDATIC<span>.</span></div>"
  let _ = w f "<div class='clock block'><span class='dot'></span><span id='clock'>— UTC</span></div>"
  let _ = w f "</div>"

  -- HERO
  let _ = w f "<main>"
  let _ = w f "<section class='hero'><div class='page'>"
  let _ = w f "<h1>I build things that <span class='g'>build themselves</span><span class='period'>.</span></h1>"
  let _ = w f "<div class='credit'>"
  let _ = w f "<span>Reilly Gomez</span><span class='sep'>·</span><span>systems engineer</span><span class='sep'>·</span>"
  let _ = w f (cat ["<span>", date, "</span>"])
  let _ = w f "</div>"
  let _ = w f "</div></section>"

  -- RAIL — the language itself
  let _ = w f "<section><div class='page'>"
  let _ = w f "<div class='slab'><span class='chip'>/01</span><span>the language</span><span class='fill'></span></div>"
  let _ = w f "<h2><span class='g'>Rail</span> compiles itself.</h2>"
  let _ = w f (cat ["<p class='big'>Rail is a systems language I wrote from scratch this year. <b>", lines_compile, " lines</b> of Rail compile to a <b>", bin_kb, " KB</b> ARM64 binary. That binary compiles the compiler again, byte-identical. Zero C dependencies &mdash; the garbage collector is ARM64 assembly.</p>"])
  let _ = w f "<div class='proof'>"
  let _ = w f "<div><span class='c'>$</span> <span class='v'>./rail_native self</span> <span class='c'>&amp;&amp; cp /tmp/rail_self ./rail_native</span></div>"
  let _ = w f "<div><span class='c'>$</span> <span class='v'>./rail_native self</span> <span class='c'>&amp;&amp; cmp rail_native /tmp/rail_self</span></div>"
  let _ = w f "<div><span class='c'>$</span> <span class='v'>./rail_native test</span> <span class='c'>&nbsp;&nbsp;# 116/116</span> <span class='g'>&#10003;</span></div>"
  let _ = w f "</div>"
  let _ = w f "<p>Four backends travel with the language: ARM64 macOS, ARM64 Linux, x86_64 Linux, WebAssembly. Same compiler, same stdlib.</p>"
  let _ = w f "</div></section>"

  -- v3.0.0 RELEASE — the newest thing
  let _ = w f "<section id='tls'><div class='page'>"
  let _ = w f (cat ["<div class='slab'><span class='chip'>/02</span><span>v3.0.0 &middot; ", date, " &middot; ", commits_v3, " commits</span><span class='fill'></span></div>"])
  let _ = w f "<h2>Rail now <span class='g'>speaks TLS</span>.</h2>"
  let _ = w f "<p class='big'>Pure-Rail TLS 1.3. X.509 chain validation against the system trust store. HTTPS clients to <b>api.anthropic.com</b>, <b>slack.com</b>, anywhere. Zero OpenSSL on the wire. Zero curl. Zero socat.</p>"

  -- handshake log
  let _ = w f "<div class='log'>"
  let _ = w f "<div class='bar'><span>rail_native /tmp/launch.rail</span><span>2026-04-18 15:44:07 UTC</span></div>"
  let _ = w f "<div class='body'>"
  let _ = w f "<div class='ln'><span class='t'>07.102</span><span class='p'>+</span><span class='k'>dns</span><span class='v'>api.anthropic.com <span class='dim'>&rarr;</span> <span class='ok'>160.79.104.10</span></span></div>"
  let _ = w f "<div class='ln'><span class='t'>07.289</span><span class='p'>+</span><span class='k'>tcp</span><span class='v'>connect 160.79.104.10:443 &nbsp;<span class='ok'>ok</span></span></div>"
  let _ = w f "<div class='ln'><span class='t'>07.294</span><span class='p'>+</span><span class='k'>tls</span><span class='v'>ClientHello &nbsp;cipher=CHACHA20_POLY1305 &nbsp;group=x25519</span></div>"
  let _ = w f "<div class='ln'><span class='t'>07.318</span><span class='p'>+</span><span class='k'>tls</span><span class='v'>ServerHello &nbsp;random=<span class='hex'>a6af06a4&hellip;</span></span></div>"
  let _ = w f "<div class='ln'><span class='t'>07.319</span><span class='p'>+</span><span class='k'>ecdhe</span><span class='v'>x25519 shared = <span class='hex'>8bd4054fb55b9d63&hellip;</span></span></div>"
  let _ = w f "<div class='ln'><span class='t'>07.401</span><span class='p'>+</span><span class='k'>cert</span><span class='v'>ECDSA-P256-SHA256 &nbsp;<span class='ok'>verified</span></span></div>"
  let _ = w f "<div class='ln'><span class='t'>07.402</span><span class='p'>+</span><span class='k'>san</span><span class='v'>api.anthropic.com &nbsp;<span class='ok'>match</span></span></div>"
  let _ = w f "<div class='ln'><span class='t'>07.402</span><span class='p'>+</span><span class='k'>valid</span><span class='v'>[2026-03-28, 2026-06-26] &nbsp;<span class='ok'>in window</span></span></div>"
  let _ = w f "<div class='ln'><span class='t'>07.419</span><span class='p'>+</span><span class='k'>finished</span><span class='v'>HMAC over transcript &nbsp;<span class='ok'>ok</span></span></div>"
  let _ = w f "<div class='ln'><span class='t'>13.980</span><span class='p'>+</span><span class='k'>http</span><span class='v'>POST /v1/messages &nbsp;<span class='ok'>200</span></span></div>"
  let _ = w f "<div class='ln'><span class='t'>13.982</span><span class='p'>+</span><span class='k'>reply</span><span class='v'>&ldquo;hello from pure rail&rdquo;</span></div>"
  let _ = w f "<div class='ln'><span class='t'>13.983</span><span class='p'>&minus;</span><span class='k'></span><span class='v dim'>6.88 s end-to-end &middot; zero C on the wire</span></div>"
  let _ = w f "</div></div>"

  -- four trust gates
  let _ = w f "<div class='gates'>"
  let _ = w f "<div class='gate'><div class='led'></div><div><span class='lab'>cert sig</span><span class='desc'>ECDSA-P256-SHA256 or RSA-PSS-SHA256 verified against the leaf&rsquo;s SubjectPublicKey.</span></div></div>"
  let _ = w f "<div class='gate'><div class='led'></div><div><span class='lab'>san match</span><span class='desc'>dNSName entries matched against the SNI you asked for, RFC 6125 wildcard supported.</span></div></div>"
  let _ = w f "<div class='gate'><div class='led'></div><div><span class='lab'>validity</span><span class='desc'>The current time must fall within the leaf&rsquo;s notBefore / notAfter window.</span></div></div>"
  let _ = w f "<div class='gate'><div class='led'></div><div><span class='lab'>finished mac</span><span class='desc'>HMAC-SHA-256 over the full handshake transcript. Server proves it computed the same thing.</span></div></div>"
  let _ = w f "</div>"

  -- counts
  let _ = w f "<div class='counts'>"
  let _ = w f (cat ["<div class='cnt live'><div class='n'>", tls_lines, "</div><div class='l'>lines of<br>pure Rail</div></div>"])
  let _ = w f (cat ["<div class='cnt live'><div class='n'>", tls_tests, "</div><div class='l'>TLS tests<br>all green</div></div>"])
  let _ = w f "<div class='cnt'><div class='n'>116</div><div class='l'>core tests<br>fixed point</div></div>"
  let _ = w f "<div class='cnt'><div class='n'>0</div><div class='l'>C deps<br>linked</div></div>"
  let _ = w f "</div>"

  -- honest limits — plain prose, no panel
  let _ = w f "<p>Honest limits: Rail v3.0.0 is <b>not constant-time</b>, <b>not side-channel hardened</b>, <b>not audited</b>. One cipher suite (<span class='mono'>TLS_CHACHA20_POLY1305_SHA256</span>), one ECDHE group (<span class='mono'>x25519</span>), three sig-algs. A connection is 5&ndash;8 seconds wall, dominated by public-key verify. If it matters, use <span class='mono'>rustls</span> or <span class='mono'>BoringSSL</span>. This is for Rail to talk to the world &mdash; not for the world to talk through Rail.</p>"

  -- links row
  let _ = w f "<div class='links'>"
  let _ = w f "<a href='https://github.com/zemo-g/rail/releases/tag/v3.0.0'>Release notes &rarr;</a>"
  let _ = w f "<a href='https://github.com/zemo-g/rail/blob/master/CHANGELOG.md'>Changelog</a>"
  let _ = w f "<a href='https://github.com/zemo-g/rail'>Source</a>"
  let _ = w f "</div>"
  let _ = w f "</div></section>"

  -- THE OTHER WORK — plasma, drone, oracle
  let _ = w f "<section><div class='page'>"
