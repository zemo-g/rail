  let _ = w f "<div class='name'>Plasma</div>"
  let _ = w f "<div class='body'>A simulation toolkit: live 2D ideal MHD in your browser, a 256&times;512 Metal GPU solver on device, an SI-calibrated MPD thruster design engine. <b>11 tools across 7 languages.</b> Physics as the product. <a href='/plasma/'>explore &rarr;</a></div>"
  let _ = w f "</div>"
  let _ = w f "<div class='work-item'>"
