  -- Flywheel stats
  let _ = w f "<div class='grid' data-s='s195b84'>"
  let _ = w f "<div class='card' data-s='s13076d'><h3 data-s='s35a13a'>1,636</h3><p>corpus v1 examples (compile-verified)</p></div>"
  let _ = w f "<div class='card' data-s='s13076d'><h3 data-s='s324a75'>25</h3><p>curriculum levels</p></div>"
