-- gen_site.rail — Generate ledatic.org
-- Writes sections to file incrementally to avoid memory limits
-- Usage: ./rail_native run tools/deploy/gen_site.rail

cat parts = join "" parts
trim s = head (split "\n" s)

-- append string to file
w path s =
  let _ = write_file "/tmp/_rc.txt" s
  shell (cat ["cat /tmp/_rc.txt >> ", path])

main =
  let date = trim (shell "date -u '+%Y-%m-%d'")
  let f = "/tmp/ledatic.html"
  let _ = shell (cat ["rm -f ", f])

  -- HEAD
  let _ = w f "<!DOCTYPE html><html lang='en'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1.0'>"
  let _ = w f "<title>Reilly Gomez — LEDATIC</title>"
  let _ = w f "<meta name='description' content='Reilly Gomez — AI Infrastructure Engineer. Built Rail, a self-hosting programming language. 1,762 lines. Zero dependencies.'>"
  let _ = w f "<meta property='og:title' content='Reilly Gomez — LEDATIC'>"
  let _ = w f "<meta property='og:description' content='AI Infrastructure Engineer. Built a language that deleted its own compiler.'>"
  let _ = w f "<meta property='og:image' content='https://pub-e9d7c87d3a1b43bea50d3bd0d8ba9ffb.r2.dev/og-image.png'>"
  let _ = w f "<link rel='preconnect' href='https://fonts.googleapis.com'>"
  let _ = w f "<link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap' rel='stylesheet'>"
  let _ = w f "<style>"

  -- CSS: base
  let _ = w f "* {margin:0;padding:0;box-sizing:border-box} html {scroll-behavior:smooth}"
  let _ = w f " body {background:#09090b;color:#e4e4e7;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}"
  let _ = w f " ::selection {background:#00ff4130;color:#fff}"
  let _ = w f " .wrap {max-width:1080px;margin:0 auto;padding:0 28px}"
  let _ = w f " section {padding:80px 0;border-bottom:1px solid #18181b} section:last-of-type {border-bottom:none}"

  -- CSS: nav
  let _ = w f " nav {position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(9,9,11,0.85);backdrop-filter:blur(16px);border-bottom:1px solid #18181b;padding:16px 28px;font-family:'JetBrains Mono',monospace;font-size:12px;display:flex;justify-content:space-between;align-items:center}"
  let _ = w f " nav a {color:#71717a;text-decoration:none;transition:color 0.2s} nav a:hover {color:#00ff41}"
  let _ = w f " nav .links {display:flex;gap:24px} .logo {color:#e4e4e7;font-weight:600;letter-spacing:2px;font-size:13px} .logo span {color:#00ff41}"

  -- CSS: hero
  let _ = w f " #hero {min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding-top:60px}"
  let _ = w f " .hero-tag {font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:4px;color:#52525b;text-transform:uppercase;margin-bottom:20px}"
  let _ = w f " h1 {font-size:clamp(40px,7vw,80px);font-weight:700;line-height:1.05;letter-spacing:-2px;margin-bottom:24px}"
  let _ = w f " h1 .g {color:#00ff41} h1 .b {color:#3b82f6} h1 .o {color:#f97316}"
  let _ = w f " .hero-sub {color:#a1a1aa;font-size:18px;line-height:1.7;max-width:640px;margin-bottom:40px}"
  let _ = w f " .btn {font-family:'JetBrains Mono',monospace;font-size:12px;padding:12px 24px;border-radius:4px;text-decoration:none;transition:all 0.2s;letter-spacing:0.5px;display:inline-block;margin-right:12px;margin-bottom:12px}"
  let _ = w f " .btn-g {background:#00ff41;color:#09090b;font-weight:600} .btn-g:hover {background:#00cc33;box-shadow:0 0 24px rgba(0,255,65,0.2)}"
  let _ = w f " .btn-o {border:1px solid #27272a;color:#a1a1aa} .btn-o:hover {border-color:#00ff41;color:#00ff41}"

  -- CSS: stats
  let _ = w f " .stats {display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:#27272a;border:1px solid #27272a;border-radius:8px;overflow:hidden;margin:48px 0}"
  let _ = w f " .stat {background:#09090b;padding:28px 20px;text-align:center}"
  let _ = w f " .stat-v {font-family:'JetBrains Mono',monospace;font-size:clamp(28px,4vw,42px);font-weight:700;display:block;line-height:1}"
  let _ = w f " .stat-l {font-family:'JetBrains Mono',monospace;font-size:10px;color:#52525b;letter-spacing:2px;text-transform:uppercase;margin-top:8px;display:block}"
  let _ = w f " @media(max-width:768px){.stats{grid-template-columns:repeat(3,1fr)} nav .links{display:none}} @media(max-width:480px){.stats{grid-template-columns:repeat(2,1fr)}}"

  -- CSS: sections + timeline
  let _ = w f " h2 {font-size:clamp(28px,4vw,44px);font-weight:700;letter-spacing:-1px;margin-bottom:16px}"
  let _ = w f " .section-sub {color:#71717a;font-size:15px;line-height:1.7;max-width:640px;margin-bottom:40px}"
  let _ = w f " .timeline {position:relative;padding-left:32px;border-left:2px solid #27272a}"
  let _ = w f " .tl-item {position:relative;margin-bottom:40px}"
  let _ = w f " .tl-item::before {content:'';position:absolute;left:-37px;top:6px;width:10px;height:10px;border-radius:50%;border:2px solid #27272a;background:#09090b}"
  let _ = w f " .tl-item.active::before {border-color:#00ff41;background:#00ff41;box-shadow:0 0 12px rgba(0,255,65,0.3)}"
  let _ = w f " .tl-date {font-family:'JetBrains Mono',monospace;font-size:11px;color:#52525b;letter-spacing:1px;margin-bottom:4px}"
  let _ = w f " .tl-title {font-size:18px;font-weight:600;color:#e4e4e7;margin-bottom:4px}"
  let _ = w f " .tl-desc {color:#71717a;font-size:14px;line-height:1.6}"

  -- CSS: code + grid + cards
  let _ = w f " .code {background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px;padding:24px;font-family:'JetBrains Mono',monospace;font-size:13px;line-height:1.9;overflow-x:auto;white-space:pre;color:#a1a1aa;margin:24px 0}"
  let _ = w f " .code .kw {color:#c084fc} .code .fn {color:#00ff41} .code .str {color:#f97316} .code .cm {color:#3f3f46} .code .num {color:#3b82f6} .code .op {color:#71717a}"
  let _ = w f " .grid {display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin:32px 0}"
  let _ = w f " .card {background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px;padding:28px;transition:border-color 0.2s} .card:hover {border-color:#27272a}"
  let _ = w f " .card h3 {font-size:16px;font-weight:600;margin-bottom:8px} .card p {color:#71717a;font-size:13px;line-height:1.7}"
  let _ = w f " .card .icon {font-family:'JetBrains Mono',monospace;font-size:20px;margin-bottom:12px;display:block}"

  -- CSS: pipe + lib + table + footer
  let _ = w f " .pipe {background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px;padding:28px;font-family:'JetBrains Mono',monospace;font-size:13px;line-height:2.2;margin:24px 0}"
  let _ = w f " .pipe .step {display:flex;align-items:center;gap:12px} .pipe .arrow {color:#27272a}"
  let _ = w f " .lib-grid {display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:8px}"
  let _ = w f " .lib {background:#0c0c0e;border:1px solid #1c1c1e;border-radius:6px;padding:12px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;color:#a1a1aa;transition:border-color 0.2s}"
  let _ = w f " .lib:hover {border-color:#00ff41;color:#00ff41} .lib span {color:#52525b;font-size:10px;display:block;margin-top:2px}"
  let _ = w f " .tbl {width:100%;border-collapse:collapse;margin:24px 0;font-size:14px}"
  let _ = w f " .tbl th {text-align:left;padding:12px 16px;border-bottom:1px solid #27272a;color:#52525b;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:1px;text-transform:uppercase}"
  let _ = w f " .tbl td {padding:12px 16px;border-bottom:1px solid #18181b} .tbl .old {color:#52525b;text-decoration:line-through} .tbl .new {color:#00ff41;font-weight:600}"
  let _ = w f " footer {text-align:center;padding:64px 28px;color:#3f3f46;font-family:'JetBrains Mono',monospace;font-size:11px;line-height:2}"
  let _ = w f " footer a {color:#52525b;text-decoration:none} footer a:hover {color:#00ff41}"

  -- CSS: about section
  let _ = w f " .about {display:flex;gap:48px;align-items:center;flex-wrap:wrap}"
  let _ = w f " .about-photo {width:180px;height:180px;border-radius:50%;border:2px solid #27272a;object-fit:cover;flex-shrink:0}"
  let _ = w f " .about-text {flex:1;min-width:280px}"
  let _ = w f " .about-name {font-size:28px;font-weight:700;margin-bottom:4px}"
  let _ = w f " .about-role {font-family:'JetBrains Mono',monospace;font-size:13px;color:#00ff41;margin-bottom:16px}"
  let _ = w f " .about-bio {color:#a1a1aa;font-size:15px;line-height:1.8;margin-bottom:20px}"
  let _ = w f " .about-links {display:flex;gap:16px;font-family:'JetBrains Mono',monospace;font-size:12px}"
  let _ = w f " .about-links a {color:#71717a;text-decoration:none;transition:color 0.2s} .about-links a:hover {color:#00ff41}"
  let _ = w f " @media(max-width:640px){.about{flex-direction:column;text-align:center} .about-links{justify-content:center}}"

  let _ = w f "</style></head><body>"

  -- NAV
  let _ = w f "<nav><div class='logo'><span>&gt;</span> LEDATIC</div><div class='links'><a href='#about'>About</a><a href='#story'>Story</a><a href='#language'>Language</a><a href='#stdlib'>Stdlib</a><a href='#stack'>Stack</a><a href='https://github.com/zemo-g/rail'>GitHub</a></div></nav>"

  -- HERO
  let _ = w f "<section id='hero'><div class='wrap'>"
  let _ = w f (cat ["<p class='hero-tag'>v1.0.0 // ", date, "</p>"])
  let _ = w f "<h1>A language that<br><span class='g'>deleted</span> its own<br><span class='b'>compiler</span>.</h1>"
  let _ = w f "<p class='hero-sub'>I wrote a programming language in 21,086 lines of Rust. Then I rewrote the compiler in the language itself &mdash; 1,762 lines. It compiled itself. The output was byte-identical. I deleted the Rust.</p>"
  let _ = w f "<a href='https://github.com/zemo-g/rail' class='btn btn-g'>View on GitHub</a>"
  let _ = w f "<a href='#story' class='btn btn-o'>Read the story</a>"
  let _ = w f "<div class='stats'>"
  let _ = w f "<div class='stat'><span class='stat-v' style='color:#00ff41'>1,762</span><span class='stat-l'>lines of compiler</span></div>"
  let _ = w f "<div class='stat'><span class='stat-v' style='color:#3b82f6'>67</span><span class='stat-l'>tests passing</span></div>"
  let _ = w f "<div class='stat'><span class='stat-v' style='color:#f97316'>297K</span><span class='stat-l'>binary size</span></div>"
  let _ = w f "<div class='stat'><span class='stat-v' style='color:#c084fc'>22</span><span class='stat-l'>stdlib modules</span></div>"
  let _ = w f "<div class='stat'><span class='stat-v' style='color:#e4e4e7'>0</span><span class='stat-l'>dependencies</span></div>"
  let _ = w f "</div></div></section>"

  -- ABOUT
  let _ = w f "<section id='about'><div class='wrap'>"
  let _ = w f "<div class='about'>"
  let _ = w f "<img class='about-photo' src='https://pub-e9d7c87d3a1b43bea50d3bd0d8ba9ffb.r2.dev/og-image.png' alt='Reilly Gomez'>"
  let _ = w f "<div class='about-text'>"
  let _ = w f "<div class='about-name'>Reilly Gomez</div>"
  let _ = w f "<div class='about-role'>AI Infrastructure Engineer</div>"
  let _ = w f "<p class='about-bio'>I build AI systems that run on your hardware. No cloud dependency, no per-query costs, your data stays yours. I designed a programming language, made it compile itself, trained a model to write in it, and pointed the whole thing at a GPU &mdash; all on one Mac Mini.</p>"
  let _ = w f "<p class='about-bio'>Past work: competitive intelligence automation, document processing pipelines, autonomous trading systems, local LLM infrastructure.</p>"
  let _ = w f "<div class='about-links'>"
  let _ = w f "<a href='https://github.com/zemo-g'>github</a>"
  let _ = w f "<a href='mailto:reilly@ledatic.org'>email</a>"
  let _ = w f "</div></div></div>"
  let _ = w f "</div></section>"

  -- STORY
  let _ = w f "<section id='story'><div class='wrap'>"
  let _ = w f "<h2>The <span class='g'>story</span></h2>"
  let _ = w f "<p class='section-sub'>Rail started as a Rust project in January 2026. Two months later, it deleted its parent.</p>"
  let _ = w f "<div class='timeline'>"
  let _ = w f "<div class='tl-item'><div class='tl-date'>JAN 2026</div><div class='tl-title'>21,086 lines of Rust</div><div class='tl-desc'>Interpreter, parser, type checker, LSP, formatter, Cranelift JIT backend. A proper language toolchain. 141 tests.</div></div>"
  let _ = w f "<div class='tl-item'><div class='tl-date'>FEB 2026</div><div class='tl-title'>ARM64 native compiler</div><div class='tl-desc'>Wrote an ARM64 code generator in Rail itself. Tagged pointers, bump allocator, tail-call optimization. No LLVM.</div></div>"
  let _ = w f "<div class='tl-item'><div class='tl-date'>MAR 2026</div><div class='tl-title'>Self-hosting achieved</div><div class='tl-desc'>The Rail compiler compiled itself. Then the output compiled the compiler again. Byte-identical binary. Fixed point.</div></div>"
  let _ = w f "<div class='tl-item'><div class='tl-date'>MAR 14</div><div class='tl-title'>LoRA self-training</div><div class='tl-desc'>Built a loop: generate Rail &rarr; try to compile it &rarr; keep what works &rarr; retrain. 1,300+ verified examples. 100% pass rate.</div></div>"
  let _ = w f "<div class='tl-item'><div class='tl-date'>MAR 16</div><div class='tl-title'>The Rust was deleted</div><div class='tl-desc'>21,086 lines removed. Rail bootstraps from a 297K seed binary. No Rust. No Cargo. No dependencies beyond macOS as + ld.</div></div>"
  let _ = w f "<div class='tl-item active'><div class='tl-date'>MAR 17</div><div class='tl-title'>v1.0.0 shipped</div><div class='tl-desc'>67 tests. 22 stdlib libraries. Metal GPU backend. WASM backend. tree-sitter grammar. VS Code extension. Zero external dependencies.</div></div>"
  let _ = w f "</div></div></section>"

  -- LANGUAGE
  let _ = w f "<section id='language'><div class='wrap'>"
  let _ = w f "<h2>The <span class='b'>language</span></h2>"
  let _ = w f "<p class='section-sub'>Pure functional. ARM64 native. No runtime, no GC, no VM. The compiler is 1,762 lines of itself.</p>"
  let _ = w f "<div class='grid'>"
  let _ = w f "<div class='card'><span class='icon' style='color:#00ff41'>&lambda;</span><h3>Pure functional</h3><p>Immutable bindings. Pattern matching. Algebraic data types. Closures with captured variables. Tail-call optimization.</p></div>"
  let _ = w f "<div class='card'><span class='icon' style='color:#3b82f6'>&#9661;</span><h3>Native ARM64</h3><p>Compiles directly to ARM64 assembly. Tagged pointers. 256MB bump allocator. 2048-byte stack frames. No LLVM, no Cranelift.</p></div>"
  let _ = w f "<div class='card'><span class='icon' style='color:#f97316'>&#9881;</span><h3>Metal GPU</h3><p>Compile Rail expressions to Metal compute shaders. Element-wise GPU operations on M-series chips. Pure Rail codegen.</p></div>"
  let _ = w f "<div class='card'><span class='icon' style='color:#c084fc'>&#8644;</span><h3>FFI</h3><p>Call any C function directly. Foreign declarations for libc, SQLite, regex, sockets. No wrappers, no bindings generators.</p></div>"
  let _ = w f "<div class='card'><span class='icon' style='color:#e4e4e7'>&#8704;</span><h3>Concurrency</h3><p>Lightweight fibers with spawn/await. Channels for message passing. Built into the runtime, not bolted on.</p></div>"
  let _ = w f "<div class='card'><span class='icon' style='color:#00ff41'>&#8635;</span><h3>Self-hosting</h3><p>The compiler compiles itself to a byte-identical binary. Fixed-point bootstrapping. The seed binary is in the repo.</p></div>"
  let _ = w f "</div>"

  -- code sample
  let _ = w f "<div class='code'>"
  let _ = w f "<span class='cm'>-- Rail compiles this to a native ARM64 binary</span>\n"
  let _ = w f "<span class='fn'>factorial</span> n <span class='op'>=</span> <span class='kw'>if</span> n <span class='op'>&lt;=</span> <span class='num'>1</span> <span class='kw'>then</span> <span class='num'>1</span> <span class='kw'>else</span> n <span class='op'>*</span> factorial (n <span class='op'>-</span> <span class='num'>1</span>)\n\n"
  let _ = w f "<span class='kw'>type</span> <span class='fn'>Option</span> <span class='op'>=</span> <span class='op'>|</span> Some x <span class='op'>|</span> None\n"
  let _ = w f "<span class='fn'>unwrap</span> opt d <span class='op'>=</span> <span class='kw'>match</span> opt <span class='op'>|</span> Some x <span class='op'>-&gt;</span> x <span class='op'>|</span> None <span class='op'>-&gt;</span> d\n\n"
  let _ = w f "<span class='fn'>main</span> <span class='op'>=</span>\n"
  let _ = w f "  <span class='kw'>let</span> nums <span class='op'>=</span> range <span class='num'>1</span> <span class='num'>11</span>\n"
  let _ = w f "  <span class='kw'>let</span> total <span class='op'>=</span> fold <span class='num'>0</span> (\\a <span class='op'>-&gt;</span> \\b <span class='op'>-&gt;</span> a <span class='op'>+</span> b) nums\n"
  let _ = w f "  <span class='kw'>let</span> _ <span class='op'>=</span> print (unwrap (Some <span class='num'>42</span>) <span class='num'>0</span>)\n"
  let _ = w f "  print total"
  let _ = w f "</div></div></section>"

  -- STDLIB
  let _ = w f "<section id='stdlib'><div class='wrap'>"
  let _ = w f "<h2><span class='o'>22</span> standard libraries</h2>"
  let _ = w f "<p class='section-sub'>All written in Rail. JSON parser, HTTP, SQLite, regex, sockets, Base64 &mdash; no external dependencies.</p>"
  let _ = w f "<div class='lib-grid'>"
  let _ = w f "<div class='lib'>json<span>144 lines &middot; parser</span></div><div class='lib'>http<span>64 lines &middot; request/response</span></div>"
  let _ = w f "<div class='lib'>base64<span>106 lines &middot; encode/decode</span></div><div class='lib'>sqlite<span>23 lines &middot; database</span></div>"
  let _ = w f "<div class='lib'>regex<span>32 lines &middot; POSIX via FFI</span></div><div class='lib'>socket<span>27 lines &middot; TCP/UDP</span></div>"
  let _ = w f "<div class='lib'>args<span>82 lines &middot; CLI parsing</span></div><div class='lib'>fmt<span>84 lines &middot; formatting</span></div>"
  let _ = w f "<div class='lib'>url<span>78 lines &middot; parse/encode</span></div><div class='lib'>hash<span>81 lines &middot; hashing</span></div>"
  let _ = w f "<div class='lib'>list<span>69 lines &middot; utilities</span></div><div class='lib'>string<span>41 lines &middot; manipulation</span></div>"
  let _ = w f "<div class='lib'>math<span>28 lines &middot; sqrt/sin/cos</span></div><div class='lib'>file<span>28 lines &middot; stat/metadata</span></div>"
  let _ = w f "<div class='lib'>mmap<span>25 lines &middot; memory-mapped</span></div><div class='lib'>signal<span>27 lines &middot; signal handling</span></div>"
  let _ = w f "<div class='lib'>time<span>11 lines &middot; system clock</span></div><div class='lib'>env<span>11 lines &middot; environment</span></div>"
  let _ = w f "<div class='lib'>test<span>48 lines &middot; test framework</span></div><div class='lib'>stat<span>27 lines &middot; file info</span></div>"
  let _ = w f "<div class='lib'>dirent<span>15 lines &middot; directories</span></div><div class='lib'>dlopen<span>21 lines &middot; dynamic libs</span></div>"
  let _ = w f "</div></div></section>"

  -- STACK
  let _ = w f "<section id='stack'><div class='wrap'>"
  let _ = w f "<h2>The <span class='b'>stack</span></h2>"
  let _ = w f "<p class='section-sub'>Everything runs on one Mac Mini M4 Pro. No cloud. No team. No framework.</p>"
  let _ = w f "<div class='grid'>"
  let _ = w f "<div class='card'><span class='icon' style='color:#00ff41'>&gt;_</span><h3>ARM64 compiler</h3><p>1,762 lines. Lexer, parser, codegen, build. Emits assembly, calls as + ld. 5-second self-compilation.</p></div>"
  let _ = w f "<div class='card'><span class='icon' style='color:#f97316'>&#9708;</span><h3>Metal GPU</h3><p>Rail expressions compile to Metal compute shaders. The M4 Pro GPU runs them. Pure Rail codegen path.</p></div>"
  let _ = w f "<div class='card'><span class='icon' style='color:#3b82f6'>&#8962;</span><h3>WebAssembly</h3><p>320-line WASM backend. Compiles Rail to .wat, assembles to .wasm. Runs anywhere with wasmtime.</p></div>"
  let _ = w f "<div class='card'><span class='icon' style='color:#c084fc'>&#10697;</span><h3>tree-sitter</h3><p>Full grammar with syntax highlighting. VS Code extension. Bindings for Node, Python, Rust, Swift, Go.</p></div>"
  let _ = w f "<div class='card'><span class='icon' style='color:#00ff41'>&#8635;</span><h3>Self-training</h3><p>Compiler-as-oracle: generate Rail &rarr; compile &rarr; keep what works &rarr; retrain LoRA. 1,300+ examples at 100%.</p></div>"
  let _ = w f "<div class='card'><span class='icon' style='color:#e4e4e7'>&#9745;</span><h3>CI</h3><p>GitHub Actions: 67-test suite + fixed-point self-compilation on every push. Green badge.</p></div>"
  let _ = w f "</div>"

  -- terminal demo
  let _ = w f "<div class='pipe'>"
  let _ = w f "<div class='step'><span style='color:#00ff41'>$</span> <span style='color:#a1a1aa'>./rail_native test</span></div>"
  let _ = w f "<div class='step'><span style='color:#00ff41'>67/67 tests passed</span></div>"
  let _ = w f "<div class='step'>&nbsp;</div>"
  let _ = w f "<div class='step'><span style='color:#3b82f6'>$</span> <span style='color:#a1a1aa'>./rail_native self</span></div>"
  let _ = w f "<div class='step'><span style='color:#3b82f6'>Binary: /tmp/rail_self</span> <span style='color:#52525b'>(byte-identical)</span></div>"
  let _ = w f "<div class='step'>&nbsp;</div>"
  let _ = w f "<div class='step'><span style='color:#f97316'>$</span> <span style='color:#a1a1aa'>./rail_native run examples/hello.rail</span></div>"
  let _ = w f "<div class='step'><span style='color:#f97316'>hello, rail</span></div>"
  let _ = w f "</div></div></section>"

  -- NUMBERS
  let _ = w f "<section id='numbers'><div class='wrap'>"
  let _ = w f "<h2>The <span class='o'>numbers</span></h2>"
  let _ = w f "<p class='section-sub'>What changed when the language compiled itself.</p>"
  let _ = w f "<table class='tbl'><tr><th></th><th>Before (Rust)</th><th>After (Rail)</th></tr>"
  let _ = w f "<tr><td>Compiler</td><td class='old'>21,086 lines</td><td class='new'>1,762 lines</td></tr>"
  let _ = w f "<tr><td>Binary</td><td class='old'>~8 MB</td><td class='new'>297 KB</td></tr>"
  let _ = w f "<tr><td>Dependencies</td><td class='old'>Cargo, Cranelift, Rayon</td><td class='new'>as + ld</td></tr>"
  let _ = w f "<tr><td>Build time</td><td class='old'>~30 seconds</td><td class='new'>~5 seconds</td></tr>"
  let _ = w f "<tr><td>Tests</td><td class='old'>141</td><td class='new'>67 (self-testing)</td></tr>"
  let _ = w f "<tr><td>Stdlib</td><td class='old'>0 modules</td><td class='new'>22 modules</td></tr>"
  let _ = w f "<tr><td>GPU backend</td><td class='old'>none</td><td class='new'>Metal compute</td></tr>"
  let _ = w f "<tr><td>WASM backend</td><td class='old'>none</td><td class='new'>320 lines</td></tr>"
  let _ = w f "</table></div></section>"

  -- FOOTER
  let _ = w f "<footer><span style='color:#00ff41'>&gt;</span> LEDATIC // v1.0.0<br><br>"
  let _ = w f "This page was generated by Rail, compiled by Rail, deployed by Rail.<br>"
  let _ = w f "The language, the compiler, the site generator &mdash; all the same thing.<br><br>"
  let _ = w f "<a href='https://github.com/zemo-g/rail'>github.com/zemo-g/rail</a><br><br>"
  let _ = w f (cat ["<span style='color:#27272a'>", date, "</span></footer>"])
  let _ = w f "</body></html>"

  let size = trim (shell (cat ["wc -c < ", f]))
  let _ = print (cat ["Generated: ", f, " (", size, " bytes)"])
  let _ = print "Deploying to Cloudflare KV..."
  let deploy_result = shell "cd ~/projects/rail && ./rail_native run tools/deploy/cf_deploy.rail /tmp/ledatic.html 2>&1"
  let _ = print deploy_result
  let _ = shell "cp /tmp/ledatic.html ~/ledatic-site/index.html"
  let _ = print "Done."
  0
