-- gen_site.rail — Generate ledatic.org
-- v2: interactive charts + diagrams, technical detail on /system
-- Usage: ./rail_native run tools/deploy/gen_site.rail

cat parts = join "" parts
trim s = head (split "\n" s)

w path s =
  let _ = write_file "/tmp/_rc.txt" s
  shell (cat ["cat /tmp/_rc.txt >> ", path])

main =
  let date = trim (shell "date -u '+%Y-%m-%d'")
  let f = "/tmp/ledatic.html"
  let _ = shell (cat ["rm -f ", f])

  -- HEAD
  let _ = w f "<!DOCTYPE html><html lang='en'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1.0'>"
  let _ = w f "<title>Reilly Gomez — LEDATIC</title>"
  let _ = w f "<meta name='description' content='Self-hosting language. 4,200 lines compile to ARM64, x86, Linux, and WASM. Native floats match C. Zero dependencies.'>"
  let _ = w f "<meta property='og:title' content='Reilly Gomez — LEDATIC'>"
  let _ = w f "<meta property='og:description' content='A language that deleted its own compiler.'>"
  let _ = w f "<meta property='og:image' content='https://pub-e9d7c87d3a1b43bea50d3bd0d8ba9ffb.r2.dev/og-image.png'>"
  let _ = w f "<link rel='icon' href='data:image/svg+xml,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 100 100\"><text y=\".9em\" font-size=\"90\">%3E</text></svg>'>"
  let _ = w f "<link rel='preconnect' href='https://fonts.googleapis.com'>"
  let _ = w f "<link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap' rel='stylesheet'>"
  let _ = w f "<style>"

  -- CSS: reset + base
  let _ = w f "*{margin:0;padding:0;box-sizing:border-box}html{scroll-behavior:smooth}"
  let _ = w f "body{background:#09090b;color:#e4e4e7;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}"
  let _ = w f "::selection{background:#00ff4130;color:#fff}"
  let _ = w f "body::before{content:'';position:fixed;top:0;left:0;width:100%;height:100%;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,255,65,0.006) 3px,rgba(0,255,65,0.006) 6px);pointer-events:none;z-index:9999}"

  -- CSS: layout
  let _ = w f ".wrap{max-width:1080px;margin:0 auto;padding:0 28px}"
  let _ = w f "section{padding:80px 0;border-bottom:1px solid #18181b}section:last-of-type{border-bottom:none}"
  let _ = w f ".reveal{opacity:0;transform:translateY(20px);transition:all 0.7s ease-out}.reveal.visible{opacity:1;transform:translateY(0)}"

  -- CSS: nav
  let _ = w f "nav{position:fixed;top:0;left:0;right:0;z-index:10000;background:rgba(9,9,11,0.85);backdrop-filter:blur(16px);border-bottom:1px solid #18181b;padding:16px 28px;font-family:'JetBrains Mono',monospace;font-size:12px;display:flex;justify-content:space-between;align-items:center}"
  let _ = w f "nav a{color:#71717a;text-decoration:none;transition:color 0.2s}nav a:hover{color:#00ff41}"
  let _ = w f "nav .links{display:flex;gap:24px}.logo{color:#e4e4e7;font-weight:600;letter-spacing:2px;font-size:13px}.logo span{color:#00ff41}"
  let _ = w f ".burger{display:none;background:none;border:1px solid #27272a;color:#e4e4e7;font-size:20px;padding:4px 10px;border-radius:4px;cursor:pointer;font-family:'JetBrains Mono',monospace}"
  let _ = w f ".dropdown{display:none;position:absolute;top:100%;right:16px;background:#0a0a0a;border:1px solid #27272a;border-radius:8px;padding:8px 0;min-width:160px;z-index:101}"
  let _ = w f ".dropdown a{display:block;padding:10px 20px;color:#a1a1aa;font-size:13px}.dropdown a:hover{color:#00ff41;background:#111}"
  let _ = w f ".dropdown.open{display:block}"

  -- CSS: hero
  let _ = w f "#hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding-top:60px}"
  let _ = w f ".hero-tag{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:4px;color:#52525b;text-transform:uppercase;margin-bottom:20px}"
  let _ = w f "h1{font-size:clamp(40px,7vw,80px);font-weight:700;line-height:1.05;letter-spacing:-2px;margin-bottom:24px}"
  let _ = w f "h1 .g{color:#00ff41}h1 .b{color:#3b82f6}h1 .o{color:#f97316}"
  let _ = w f ".hero-sub{color:#a1a1aa;font-size:18px;line-height:1.7;max-width:640px;margin-bottom:40px}"
  let _ = w f ".btn{font-family:'JetBrains Mono',monospace;font-size:12px;padding:12px 24px;border-radius:4px;text-decoration:none;transition:all 0.2s;letter-spacing:0.5px;display:inline-block;margin-right:12px;margin-bottom:12px}"
  let _ = w f ".btn-g{background:#00ff41;color:#09090b;font-weight:600}.btn-g:hover{background:#00cc33;box-shadow:0 0 24px rgba(0,255,65,0.2)}"
  let _ = w f ".btn-o{border:1px solid #27272a;color:#a1a1aa}.btn-o:hover{border-color:#00ff41;color:#00ff41}"

  -- CSS: sections
  let _ = w f "h2{font-size:clamp(28px,4vw,44px);font-weight:700;letter-spacing:-1px;margin-bottom:16px}"
  let _ = w f ".section-sub{color:#71717a;font-size:15px;line-height:1.7;max-width:640px;margin-bottom:40px}"
  let _ = w f ".grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin:32px 0}"
  let _ = w f ".card{background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px;padding:28px;transition:all 0.3s ease}.card:hover{border-color:#27272a;box-shadow:0 0 20px rgba(0,255,65,0.06);transform:translateY(-2px)}"
  let _ = w f ".card h3{font-size:16px;font-weight:600;margin-bottom:8px}.card p{color:#71717a;font-size:13px;line-height:1.7}"

  -- CSS: reduction bar
  let _ = w f ".bar-wrap{margin:48px 0}.bar-row{display:flex;align-items:center;gap:16px;margin-bottom:16px}"
  let _ = w f ".bar-label{font-family:'JetBrains Mono',monospace;font-size:12px;color:#71717a;width:100px;text-align:right;flex-shrink:0}"
  let _ = w f ".bar-track{flex:1;height:36px;background:#111;border-radius:4px;overflow:hidden;position:relative}"
  let _ = w f ".bar-fill{height:100%;border-radius:4px;transition:width 1.5s cubic-bezier(0.25,1,0.5,1);width:0;display:flex;align-items:center;justify-content:flex-end;padding-right:12px;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600;color:#09090b}"
  let _ = w f ".bar-fill.rust{background:linear-gradient(90deg,#f9731640,#f97316)}.bar-fill.rail{background:linear-gradient(90deg,#00ff4140,#00ff41)}"
  let _ = w f "@media(max-width:640px){.bar-label{width:70px;font-size:11px}}"

  -- CSS: flywheel
  let _ = w f ".flywheel-wrap{display:flex;justify-content:center;margin:48px 0}"
  let _ = w f ".flywheel-svg{width:400px;height:400px;max-width:100%}"
  let _ = w f "@keyframes fw-spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}"
  let _ = w f "@keyframes fw-pulse{0%,100%{opacity:0.4}50%{opacity:1}}"
  let _ = w f ".fw-orbit{animation:fw-spin 20s linear infinite;transform-origin:200px 200px}"
  let _ = w f ".fw-node{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:600}"
  let _ = w f ".fw-arrow{animation:fw-pulse 2s ease-in-out infinite}"

  -- CSS: timeline compact
  let _ = w f ".tl-compact{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:2px;margin:48px 0}"
  let _ = w f ".tl-c{background:#0c0c0e;padding:20px;border-left:3px solid #1c1c1e;transition:all 0.3s}.tl-c:hover{border-left-color:#00ff41;background:#111}"
  let _ = w f ".tl-c.active{border-left-color:#00ff41;background:#0d1a0e}"
  let _ = w f ".tl-c-date{font-family:'JetBrains Mono',monospace;font-size:10px;color:#52525b;letter-spacing:1px;margin-bottom:4px}"
  let _ = w f ".tl-c-title{font-size:13px;font-weight:600;color:#e4e4e7;margin-bottom:4px}"
  let _ = w f ".tl-c-desc{font-size:11px;color:#52525b;line-height:1.4}"

  -- CSS: about
  let _ = w f ".about{display:flex;gap:48px;align-items:center;flex-wrap:wrap}"
  let _ = w f ".about-photo{width:140px;height:140px;border-radius:50%;border:2px solid #27272a;object-fit:cover;flex-shrink:0}"
  let _ = w f ".about-text{flex:1;min-width:280px}"
  let _ = w f ".about-name{font-size:28px;font-weight:700;margin-bottom:4px}"
  let _ = w f ".about-role{font-family:'JetBrains Mono',monospace;font-size:13px;color:#00ff41;margin-bottom:16px}"
  let _ = w f ".about-bio{color:#a1a1aa;font-size:15px;line-height:1.8;margin-bottom:20px}"
  let _ = w f ".about-links{display:flex;gap:16px;font-family:'JetBrains Mono',monospace;font-size:12px}"
  let _ = w f ".about-links a{color:#71717a;text-decoration:none;transition:color 0.2s}.about-links a:hover{color:#00ff41}"
  let _ = w f "@media(max-width:640px){.about{flex-direction:column;text-align:center}.about-links{justify-content:center}}"

  -- CSS: other work
  let _ = w f ".ow-card{background:#111;border:1px solid #222;border-radius:8px;padding:24px;transition:all 0.3s}"
  let _ = w f ".ow-card:hover{transform:translateY(-3px);border-color:#333}"
  let _ = w f ".ow-card.c-orange:hover{box-shadow:0 4px 24px rgba(249,115,22,0.1)}"
  let _ = w f ".ow-card.c-blue:hover{box-shadow:0 4px 24px rgba(59,130,246,0.1)}"
  let _ = w f ".ow-card.c-purple:hover{box-shadow:0 4px 24px rgba(192,132,252,0.1)}"
  let _ = w f ".ow-card.c-green:hover{box-shadow:0 4px 24px rgba(0,255,65,0.1)}"

  -- CSS: arch flow
  let _ = w f ".arch-flow{display:flex;align-items:center;justify-content:center;gap:0;margin:48px 0;flex-wrap:wrap}"
  let _ = w f ".arch-node{background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px;padding:16px 20px;text-align:center;font-family:'JetBrains Mono',monospace;font-size:12px;transition:all 0.3s;min-width:100px}"
  let _ = w f ".arch-node:hover{border-color:#00ff41;box-shadow:0 0 16px rgba(0,255,65,0.1)}"
  let _ = w f ".arch-node .label{color:#e4e4e7;font-weight:600;margin-bottom:4px}.arch-node .sub{color:#52525b;font-size:10px}"
  let _ = w f ".arch-arrow{color:#27272a;font-size:18px;padding:0 8px;flex-shrink:0}"

  -- CSS: footer + responsive
  let _ = w f "footer{text-align:center;padding:64px 28px;color:#3f3f46;font-family:'JetBrains Mono',monospace;font-size:11px;line-height:2}"
  let _ = w f "footer a{color:#52525b;text-decoration:none}footer a:hover{color:#00ff41}"
  let _ = w f "#particles{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:0.3}"
  let _ = w f "section,nav,footer,#boot{position:relative;z-index:1}"
  let _ = w f "@media(max-width:768px){nav .links{display:none}.burger{display:block}.arch-arrow{display:none}.arch-flow{gap:8px}}"

  -- Boot overlay
  let _ = w f "#boot{position:fixed;top:0;left:0;width:100%;height:100%;background:#09090b;z-index:50000;display:flex;align-items:center;justify-content:center;flex-direction:column;font-family:'JetBrains Mono',monospace;font-size:13px;transition:opacity 0.6s}"
  let _ = w f "#boot.done{opacity:0;pointer-events:none}"
  let _ = w f "#boot .line{opacity:0;margin:3px 0;color:#00ff41}"
  let _ = w f "@keyframes fadein{to{opacity:1}}"

  let _ = w f "</style></head><body>"
  let _ = w f "<canvas id='particles'></canvas>"

  -- NAV
  let _ = w f "<nav style='position:relative'><div class='logo'><span>&gt;</span> LEDATIC</div>"
  let _ = w f "<div class='links'><a href='#work'>Work</a><a href='#about'>About</a><a href='#playground'>Playground</a><a href='#story'>Story</a><a href='#technical'>Technical</a><a href='https://github.com/zemo-g/rail'>GitHub</a></div>"
  let _ = w f "<button class='burger' onclick='var d=document.getElementById(\"dd\");d.classList.toggle(\"open\")'>&#9776;</button>"
  let _ = w f "<div class='dropdown' id='dd'><a href='#work'>Work</a><a href='#about'>About</a><a href='#playground'>Playground</a><a href='#story'>Story</a><a href='#technical'>Technical</a><a href='https://github.com/zemo-g/rail'>GitHub</a></div></nav>"

  -- HERO — accessible first, technical second
  let _ = w f "<section id='hero'><div class='wrap'>"
  let _ = w f "<h1>I build software that<br><span class='g'>builds</span> itself.</h1>"
  let _ = w f "<p class='hero-sub'>Programming languages. Autonomous systems. AI that writes code verified by the compiler it runs on. I like making things that work with minimal resources.</p>"
  let _ = w f "<a href='#work' class='btn btn-g'>See what I build</a>"
  let _ = w f "<a href='#about' class='btn btn-o'>About me</a>"
  let _ = w f "</div></section>"

  -- WHAT I BUILD — outcomes, not implementation
  let _ = w f "<section id='work' class='reveal'><div class='wrap'>"
  let _ = w f "<h2>What I <span class='g'>build</span></h2>"
  let _ = w f "<div class='grid' style='grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px'>"
  let _ = w f "<div class='card' style='border-color:#00ff4120'><h3 style='color:#00ff41'>A Programming Language</h3><p>Built from scratch in 3 months. It compiles itself &mdash; the output is byte-identical. Runs on ARM, x86, Linux, and in your browser via WebAssembly. <a href='#playground' style='color:#00ff41'>Try it live below.</a></p></div>"
  let _ = w f "<div class='card' style='border-color:#3b82f620'><h3 style='color:#3b82f6'>Self-Training AI</h3><p>Gemma 4 fine-tuned on Rail. The compiler verifies the AI's output &mdash; if it compiles, the code is correct. 14/30 benchmark, 7,600+ verified programs, model improves by writing the language it's tested by.</p></div>"
  let _ = w f "<div class='card' style='border-color:#f9731620'><h3 style='color:#f97316'>Autonomous Robotics</h3><p>Real-time neural control running at microsecond speed. The language IS the inference engine. Competition entry in progress.</p></div>"
  let _ = w f "<div class='card' style='border-color:#c084fc20'><h3 style='color:#c084fc'>Distributed Compute</h3><p>Three machines, three architectures. Mac Mini compiles and serves. RTX 3070 trains models. Pi Zero runs at the edge. All coordinated by software written in the language.</p></div>"
  let _ = w f "</div></div></section>"

  -- TECHNICAL HERO (for engineers who scroll)
  let _ = w f "<section id='technical' class='reveal'><div class='wrap'>"
  let _ = w f (cat ["<p class='hero-tag'>v2.0.0 // ", date, "</p>"])
  let _ = w f "<h2>The <span class='b'>numbers</span></h2>"
  let _ = w f "<p class='section-sub'>4,200 lines of Rail compile to ARM64, x86_64, Linux, and WASM. Native IEEE 754 floats. Conservative GC in assembly. Try/catch with setjmp. Zero C dependencies.</p>"
  let _ = w f "<a href='https://github.com/zemo-g/rail' class='btn btn-g'>View on GitHub</a>"
  let _ = w f "<a href='#story' class='btn btn-o'>Read the story</a>"

  -- Animated reduction bars
  let _ = w f "<div class='bar-wrap' id='bars'>"
  let _ = w f "<div class='bar-row'><div class='bar-label'>Rust</div><div class='bar-track'><div class='bar-fill rust' data-w='100' data-t='21,086 lines'>21,086</div></div></div>"
  let _ = w f "<div class='bar-row'><div class='bar-label'>Rail</div><div class='bar-track'><div class='bar-fill rail' data-w='20' data-t='4,212 lines'>4,212</div></div></div>"
  let _ = w f "<div class='bar-row'><div class='bar-label'>Binary</div><div class='bar-track'><div class='bar-fill rust' data-w='100' data-t='~8 MB' style='font-size:11px'>~8 MB</div></div></div>"
  let _ = w f "<div class='bar-row'><div class='bar-label'>Binary</div><div class='bar-track'><div class='bar-fill rail' data-w='8.5' data-t='686 KB' style='font-size:11px'>686 KB</div></div></div>"
  let _ = w f "<div class='bar-row'><div class='bar-label'>Targets</div><div class='bar-track'><div class='bar-fill rust' data-w='30' data-t='1 (native)' style='font-size:11px'>1</div></div></div>"
  let _ = w f "<div class='bar-row'><div class='bar-label'>Targets</div><div class='bar-track'><div class='bar-fill rail' data-w='60' data-t='4 (ARM64, x86, Linux, WASM)' style='font-size:10px'>ARM64 + x86 + Linux + WASM</div></div></div>"
  let _ = w f "<div class='bar-row'><div class='bar-label'>Tests</div><div class='bar-track'><div class='bar-fill rail' data-w='45' data-t='92/92' style='font-size:11px'>92/92</div></div></div>"
  let _ = w f "<div class='bar-row'><div class='bar-label'>Deps</div><div class='bar-track'><div class='bar-fill rail' data-w='8' data-t='as + ld' style='font-size:11px'>as + ld (zero C deps)</div></div></div>"
  let _ = w f "</div>"
  let _ = w f "</div></section>"

  -- ABOUT
  let _ = w f "<section id='about' class='reveal'><div class='wrap'>"
  let _ = w f "<div class='about'>"
  let _ = w f "<img class='about-photo' src='https://pub-e9d7c87d3a1b43bea50d3bd0d8ba9ffb.r2.dev/og-image.png' alt='Reilly Gomez'>"
  let _ = w f "<div class='about-text'>"
  let _ = w f "<div class='about-name'>Reilly Gomez</div>"
  let _ = w f "<div class='about-role'>Systems Engineer</div>"
  let _ = w f "<p class='about-bio'>I like building things that work with minimal resources. Most of my time goes into Rail and the infrastructure around it. Before that I spent nine years running a food production business, which taught me that systems need to be reliable before they can be clever.</p>"
  let _ = w f "<div class='about-links'>"
  let _ = w f "<a href='https://github.com/zemo-g'>github</a>"
  let _ = w f "<a href='mailto:reillygomez13@icloud.com'>email</a>"
  let _ = w f "</div></div></div></div></section>"

  -- STORY (compact timeline)
  let _ = w f "<section id='story' class='reveal'><div class='wrap'>"
  let _ = w f "<h2>The <span class='g'>story</span></h2>"
  let _ = w f "<p class='section-sub'>Rail started as a Rust project in January 2026. Three months later, it has four backends and trains its own AI.</p>"
  let _ = w f "<div class='tl-compact'>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>JAN</div><div class='tl-c-title'>21K lines of Rust</div><div class='tl-c-desc'>Interpreter, parser, type checker, Cranelift JIT</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>FEB</div><div class='tl-c-title'>ARM64 codegen</div><div class='tl-c-desc'>Native compiler written in Rail itself</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>MAR 16</div><div class='tl-c-title'>Self-hosting</div><div class='tl-c-desc'>Fixed point. Rust deleted.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>MAR 20</div><div class='tl-c-title'>Flywheel</div><div class='tl-c-desc'>Self-training loop: compiler is the oracle</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>MAR 25</div><div class='tl-c-title'>Performance</div><div class='tl-c-desc'>Matches C -O2. 5 instructions/iteration.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>APR 2</div><div class='tl-c-title'>Native floats</div><div class='tl-c-desc'>Unboxed IEEE 754 in d-registers. Zero heap allocation.</div></div>"
  let _ = w f "<div class='tl-c'><div class='tl-c-date'>APR 3</div><div class='tl-c-title'>v2.0.0</div><div class='tl-c-desc'>WASM backend, try/catch, REPL, HTTP server. 92 tests.</div></div>"
  let _ = w f "<div class='tl-c active'><div class='tl-c-date'>APR 4</div><div class='tl-c-title'>Gemma 4 flywheel</div><div class='tl-c-desc'>14/30 benchmark (46%). Few-shot prompt engineering + failure diagnosis.</div></div>"
  let _ = w f "</div></div></section>"

  -- ARCHITECTURE (interactive flow diagram)
  let _ = w f "<section id='arch' class='reveal'><div class='wrap'>"
  let _ = w f "<h2>How it <span class='b'>works</span></h2>"
  let _ = w f "<p class='section-sub'>4,212 lines. Source in, native binary out. Four targets from one compiler.</p>"
  let _ = w f "<div class='arch-flow'>"
  let _ = w f "<div class='arch-node'><div class='label'>.rail</div><div class='sub'>source</div></div>"
  let _ = w f "<div class='arch-arrow'>&rarr;</div>"
  let _ = w f "<div class='arch-node'><div class='label' style='color:#c084fc'>Lexer</div><div class='sub'>tokens</div></div>"
  let _ = w f "<div class='arch-arrow'>&rarr;</div>"
  let _ = w f "<div class='arch-node'><div class='label' style='color:#3b82f6'>Parser</div><div class='sub'>AST</div></div>"
  let _ = w f "<div class='arch-arrow'>&rarr;</div>"
  let _ = w f "<div class='arch-node'><div class='label' style='color:#f97316'>Codegen</div><div class='sub'>ARM64 / x86 / WASM</div></div>"
  let _ = w f "<div class='arch-arrow'>&rarr;</div>"
  let _ = w f "<div class='arch-node'><div class='label' style='color:#00ff41'>as + ld</div><div class='sub'>686K binary</div></div>"
  let _ = w f "</div>"

  -- Runtime diagram
  let _ = w f "<div style='margin-top:48px'>"
  let _ = w f "<div class='grid' style='grid-template-columns:repeat(3,1fr)'>"
  let _ = w f "<div class='card' style='text-align:center;border-color:#00ff4120'><h3 style='color:#00ff41;font-size:14px'>Allocator</h3><p>1GB bump arena<br>+ free list</p></div>"
  let _ = w f "<div class='card' style='text-align:center;border-color:#3b82f620'><h3 style='color:#3b82f6;font-size:14px'>GC</h3><p>Conservative<br>mark-sweep</p></div>"
  let _ = w f "<div class='card' style='text-align:center;border-color:#c084fc20'><h3 style='color:#c084fc;font-size:14px'>Runtime</h3><p>Tagged pointers<br>TCO + closures</p></div>"
  let _ = w f "</div>"
  let _ = w f "<p style='text-align:center;margin-top:24px;font-family:JetBrains Mono,monospace;font-size:11px;color:#52525b'>Full technical details on <a href='/system' style='color:#00ff41;text-decoration:none'>/system</a></p>"
  let _ = w f "</div></div></section>"

  -- PLAYGROUND — WASM demos that run in-browser
  let _ = w f "<section id='playground' class='reveal'><div class='wrap'>"
  let _ = w f "<h2>Try it <span class='g'>live</span></h2>"
  let _ = w f "<p class='section-sub'>These Rail programs are compiled to WebAssembly and run in your browser. No server. No install.</p>"
  let _ = w f "<div class='pg-demos'>"

  -- Demo 1: Hello
  let _ = w f "<div class='pg-demo'>"
  let _ = w f "<div class='pg-src'><pre><code>main =\n  let _ = print \"Hello from Rail!\"\n  let _ = print \"Running as WebAssembly.\"\n  0</code></pre></div>"
  let _ = w f "<button class='pg-run' onclick='runWasm(0)'>Run</button>"
  let _ = w f "<pre class='pg-out' id='out0'></pre></div>"

  -- Demo 2: Fibonacci
  let _ = w f "<div class='pg-demo'>"
  let _ = w f "<div class='pg-src'><pre><code>fib n =\n  if n < 2 then n\n  else fib (n - 1) + fib (n - 2)\n\nmain =\n  let _ = print (fib 10)\n  let _ = print (fib 20)\n  let _ = print (fib 30)\n  0</code></pre></div>"
  let _ = w f "<button class='pg-run' onclick='runWasm(1)'>Run</button>"
  let _ = w f "<pre class='pg-out' id='out1'></pre></div>"

  -- Demo 3: Math
  let _ = w f "<div class='pg-demo'>"
  let _ = w f "<div class='pg-src'><pre><code>square x = x * x\ncube x = x * x * x\n\nmain =\n  let _ = print (square 7)\n  let _ = print (cube 5)\n  let _ = print (square 12 + cube 3)\n  0</code></pre></div>"
  let _ = w f "<button class='pg-run' onclick='runWasm(2)'>Run</button>"
  let _ = w f "<pre class='pg-out' id='out2'></pre></div>"

  -- Demo 4: FizzBuzz
  let _ = w f "<div class='pg-demo'>"
  let _ = w f "<div class='pg-src'><pre><code>fizzbuzz n =\n  if n > 30 then 0\n  else\n    let _ = if (n % 15) == 0 then print \"FizzBuzz\"\n      else if (n % 3) == 0 then print \"Fizz\"\n      else if (n % 5) == 0 then print \"Buzz\"\n      else print n\n    fizzbuzz (n + 1)\n\nmain = fizzbuzz 1</code></pre></div>"
  let _ = w f "<button class='pg-run' onclick='runWasm(3)'>Run</button>"
  let _ = w f "<pre class='pg-out' id='out3'></pre></div>"

  let _ = w f "</div>"

  -- Embed WASM binaries as base64
  let hello_b64 = trim (shell "base64 -i /tmp/demo_hello.wasm | tr -d '\\n'")
  let fib_b64 = trim (shell "base64 -i /tmp/demo_fib.wasm | tr -d '\\n'")
  let math_b64 = trim (shell "base64 -i /tmp/demo_math.wasm | tr -d '\\n'")
  let fizz_b64 = trim (shell "base64 -i /tmp/demo_fizz.wasm | tr -d '\\n'")

  let _ = w f "<script>"
  let _ = w f (cat ["var WASM_BINS=[\"", hello_b64, "\",\"", fib_b64, "\",\"", math_b64, "\",\"", fizz_b64, "\"];"])
  let _ = w f "function b64toBytes(b){var r=atob(b),a=new Uint8Array(r.length);for(var i=0;i<r.length;i++)a[i]=r.charCodeAt(i);return a}"
  let _ = w f "async function runWasm(idx){var el=document.getElementById('out'+idx);el.textContent='Running...\\n';try{"
  let _ = w f "var bytes=b64toBytes(WASM_BINS[idx]);var out='';var M={m:null};"
  let _ = w f "var imports={wasi_snapshot_preview1:{"
  let _ = w f "fd_write:function(fd,iovs,cnt,pw){var v=new DataView(M.m.buffer);var p=v.getUint32(iovs,true);var l=v.getUint32(iovs+4,true);out+=new TextDecoder().decode(new Uint8Array(M.m.buffer,p,l));v.setUint32(pw,l,true);return 0},"
  let _ = w f "proc_exit:function(code){}}};"
  let _ = w f "var{instance}=await WebAssembly.instantiate(bytes,imports);"
  let _ = w f "M.m=instance.exports.memory;"
  let _ = w f "out='';instance.exports._start();el.textContent=out||'(no output)';el.style.borderColor='#00ff41'"
  let _ = w f "}catch(e){el.textContent='Error: '+e.message;el.style.borderColor='#f97316'}}"
  let _ = w f "</script>"

  -- Playground CSS
  let _ = w f "<style>"
  let _ = w f ".pg-demos{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:20px;margin-top:24px}"
  let _ = w f ".pg-demo{background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px;overflow:hidden}"
  let _ = w f ".pg-src{padding:16px;border-bottom:1px solid #1c1c1e}.pg-src pre{margin:0;font-size:12px;line-height:1.5;color:#a1a1aa;overflow-x:auto}.pg-src code{font-family:'JetBrains Mono',monospace}"
  let _ = w f ".pg-run{display:block;width:100%;padding:10px;background:#111;border:none;color:#00ff41;font-family:'JetBrains Mono',monospace;font-size:13px;cursor:pointer;border-bottom:1px solid #1c1c1e;transition:background 0.2s}.pg-run:hover{background:#1a1a1a}"
  let _ = w f ".pg-out{margin:0;padding:16px;font-family:'JetBrains Mono',monospace;font-size:12px;color:#e4e4e7;min-height:40px;border-left:2px solid #27272a;transition:border-color 0.3s}"
  let _ = w f "</style>"
  let _ = w f "</div></section>"

  -- FLYWHEEL (SVG diagram)
  let _ = w f "<section id='flywheel' class='reveal'><div class='wrap'>"
  let _ = w f "<h2>The <span class='g'>flywheel</span></h2>"
  let _ = w f "<p class='section-sub'>The compiler is the oracle. If it compiles, the code is correct. The model gets better at writing the language it is verified by.</p>"

  let _ = w f "<div class='flywheel-wrap'>"
  let _ = w f "<svg class='flywheel-svg' viewBox='0 0 400 400'>"
  -- Center circle
  let _ = w f "<circle cx='200' cy='200' r='60' fill='none' stroke='#1c1c1e' stroke-width='1'/>"
  let _ = w f "<text x='200' y='195' text-anchor='middle' fill='#00ff41' font-family='JetBrains Mono' font-size='11' font-weight='600'>COMPILER</text>"
  let _ = w f "<text x='200' y='212' text-anchor='middle' fill='#52525b' font-family='JetBrains Mono' font-size='9'>oracle</text>"
  -- Orbit ring
  let _ = w f "<circle cx='200' cy='200' r='140' fill='none' stroke='#1c1c1e' stroke-width='1' stroke-dasharray='4,8'/>"
  -- Nodes
  let _ = w f "<g>"
  let _ = w f "<rect x='162' y='28' width='76' height='36' rx='6' fill='#0c0c0e' stroke='#00ff41' stroke-width='1'/>"
  let _ = w f "<text x='200' y='51' text-anchor='middle' fill='#00ff41' font-family='JetBrains Mono' font-size='11' font-weight='600'>Generate</text>"
  let _ = w f "<rect x='308' y='162' width='76' height='36' rx='6' fill='#0c0c0e' stroke='#3b82f6' stroke-width='1'/>"
  let _ = w f "<text x='346' y='185' text-anchor='middle' fill='#3b82f6' font-family='JetBrains Mono' font-size='11' font-weight='600'>Compile</text>"
  let _ = w f "<rect x='162' y='336' width='76' height='36' rx='6' fill='#0c0c0e' stroke='#f97316' stroke-width='1'/>"
  let _ = w f "<text x='200' y='359' text-anchor='middle' fill='#f97316' font-family='JetBrains Mono' font-size='11' font-weight='600'>Harvest</text>"
  let _ = w f "<rect x='16' y='162' width='76' height='36' rx='6' fill='#0c0c0e' stroke='#c084fc' stroke-width='1'/>"
  let _ = w f "<text x='54' y='185' text-anchor='middle' fill='#c084fc' font-family='JetBrains Mono' font-size='11' font-weight='600'>Train</text>"
  let _ = w f "</g>"
  -- Arrows (curved paths between nodes)
  let _ = w f "<path d='M238 58 Q310 80 316 168' fill='none' stroke='#27272a' stroke-width='1' marker-end='url(#arrowhead)' class='fw-arrow'/>"
  let _ = w f "<path d='M340 198 Q330 300 238 346' fill='none' stroke='#27272a' stroke-width='1' marker-end='url(#arrowhead)' class='fw-arrow' style='animation-delay:0.5s'/>"
  let _ = w f "<path d='M162 352 Q90 320 84 198' fill='none' stroke='#27272a' stroke-width='1' marker-end='url(#arrowhead)' class='fw-arrow' style='animation-delay:1s'/>"
  let _ = w f "<path d='M60 162 Q70 80 162 52' fill='none' stroke='#27272a' stroke-width='1' marker-end='url(#arrowhead)' class='fw-arrow' style='animation-delay:1.5s'/>"
  let _ = w f "<defs><marker id='arrowhead' markerWidth='8' markerHeight='6' refX='8' refY='3' orient='auto'><polygon points='0 0, 8 3, 0 6' fill='#52525b'/></marker></defs>"
  -- Animated dot orbiting
  let _ = w f "<circle r='4' fill='#00ff41' opacity='0.8'><animateMotion dur='6s' repeatCount='indefinite' path='M200 60 Q340 60 340 200 Q340 340 200 340 Q60 340 60 200 Q60 60 200 60 Z'/></circle>"
  let _ = w f "</svg></div>"

  -- Flywheel stats
  let _ = w f "<div class='grid' style='grid-template-columns:repeat(3,1fr);margin-top:32px'>"
  let _ = w f "<div class='card' style='text-align:center'><h3 style='color:#00ff41;font-size:28px;font-family:JetBrains Mono'>14/30</h3><p>benchmark (46%)</p></div>"
  let _ = w f "<div class='card' style='text-align:center'><h3 style='color:#3b82f6;font-size:28px;font-family:JetBrains Mono'>7,600+</h3><p>verified examples</p></div>"
  let _ = w f "<div class='card' style='text-align:center'><h3 style='color:#f97316;font-size:28px;font-family:JetBrains Mono'>3</h3><p>nodes (M4 + 3070 + Pi)</p></div>"
  let _ = w f "</div></div></section>"

  -- OTHER WORK
  let _ = w f "<section id='other' class='reveal'><div class='wrap'>"
  let _ = w f "<h2>Other <span class='o'>work</span></h2>"
  let _ = w f "<div class='grid' style='grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:16px'>"
  let _ = w f "<div class='ow-card c-orange'><h3 style='color:#f97316;font-size:16px;margin-bottom:8px'>Autonomous Robotics</h3><p style='color:#a1a1aa;font-size:14px;line-height:1.6'>Real-time neural control with native float MLP. Rail as the inference engine. Competition entry in progress.</p></div>"
  let _ = w f "<div class='ow-card c-blue'><h3 style='color:#3b82f6;font-size:16px;margin-bottom:8px'>Compute Fleet</h3><p style='color:#a1a1aa;font-size:14px;line-height:1.6'>Mac Mini M4 Pro + RTX 3070 + Pi Zero. Rail fleet agents, CUDA QLoRA training, cross-compilation. 3 architectures.</p></div>"
  let _ = w f "<div class='ow-card c-purple'><h3 style='color:#c084fc;font-size:16px;margin-bottom:8px'>WASM + HTTP</h3><p style='color:#a1a1aa;font-size:14px;line-height:1.6'>Rail compiles to WebAssembly. Built-in HTTP server and REPL. Programs run in browsers, on servers, and at the edge.</p></div>"
  let _ = w f "<div class='ow-card c-green'><h3 style='color:#00ff41;font-size:16px;margin-bottom:8px'>Nanoversight</h3><p style='color:#a1a1aa;font-size:14px;line-height:1.6'>Autonomous oversight. One file, one loop, one LLM. <a href='https://github.com/zemo-g/nanoversight' style='color:#00ff41'>Open source</a>.</p></div>"
  let _ = w f "</div>"
  let _ = w f "<div style='margin-top:48px;padding:32px;background:#111;border:1px solid #222;border-radius:8px;text-align:center'>"
  let _ = w f "<p style='color:#e4e4e7;font-size:16px;margin-bottom:12px'>Interested in working together?</p>"
  let _ = w f "<p style='color:#a1a1aa;font-size:14px;margin-bottom:20px'>Open to remote work and collaboration.</p>"
  let _ = w f "<a href='mailto:reillygomez13@icloud.com' class='btn btn-g'>Email</a>"
  let _ = w f "<a href='https://github.com/zemo-g' class='btn btn-o'>GitHub</a>"
  let _ = w f "</div></div></section>"

  -- FOOTER
  let _ = w f "<footer><span style='color:#00ff41'>&gt;</span> LEDATIC // v2.0.0<br><br>"
  let _ = w f "This page was generated by Rail, compiled by Rail, deployed by Rail.<br><br>"
  let _ = w f "<a href='https://github.com/zemo-g/rail'>github.com/zemo-g/rail</a><br><br>"
  let _ = w f (cat ["<span style='color:#27272a'>", date, "</span></footer>"])

  -- BOOT SEQUENCE
  let _ = w f "<div id='boot'>"
  let _ = w f "<div class='line' style='animation:fadein 0.1s 0.1s forwards'><span style='color:#52525b'>&gt;</span> LEDATIC v2.0.0</div>"
  let _ = w f "<div class='line' style='animation:fadein 0.1s 0.3s forwards;color:#52525b'>targets: arm64 x86_64 linux wasm</div>"
  let _ = w f "<div class='line' style='animation:fadein 0.1s 0.5s forwards;color:#52525b'>self-compile: <span style='color:#00ff41'>92/92</span></div>"
  let _ = w f "<div class='line' style='animation:fadein 0.1s 0.7s forwards;color:#52525b'>floats: native ieee754 d-registers</div>"
  let _ = w f "<div class='line' style='animation:fadein 0.1s 1.0s forwards;color:#00ff41'>READY</div>"
  let _ = w f "</div>"

  -- JS
  let _ = w f "<script>"
  let _ = w f "setTimeout(function(){document.getElementById('boot').classList.add('done')},1600);"
  let _ = w f "var obs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting)e.target.classList.add('visible')})},{threshold:0.15});"
  let _ = w f "document.querySelectorAll('.reveal').forEach(function(el){obs.observe(el)});"
  let _ = w f "document.querySelectorAll('.dropdown a').forEach(function(a){a.addEventListener('click',function(){document.getElementById('dd').classList.remove('open')})});"

  -- Animated bars
  let _ = w f "var barsDone=false;function animBars(){if(barsDone)return;barsDone=true;"
  let _ = w f "document.querySelectorAll('.bar-fill').forEach(function(el,i){"
  let _ = w f "setTimeout(function(){el.style.width=el.dataset.w+'%'},i*150)})};"
  let _ = w f "var bobs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting)animBars()})},{threshold:0.3});"
  let _ = w f "var bars=document.getElementById('bars');if(bars)bobs.observe(bars);"

  -- Particle system
  let _ = w f "var c=document.getElementById('particles'),ctx=c.getContext('2d');"
  let _ = w f "function resize(){c.width=window.innerWidth;c.height=window.innerHeight}resize();window.addEventListener('resize',resize);"
  let _ = w f "var pts=[];for(var i=0;i<50;i++)pts.push({x:Math.random()*c.width,y:Math.random()*c.height,vx:(Math.random()-0.5)*0.3,vy:(Math.random()-0.5)*0.3,r:Math.random()*1.5+0.5});"
  let _ = w f "var mx=-1,my=-1;document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY});"
  let _ = w f "function draw(){ctx.clearRect(0,0,c.width,c.height);"
  let _ = w f "for(var i=0;i<pts.length;i++){var p=pts[i];p.x+=p.vx;p.y+=p.vy;"
  let _ = w f "if(p.x<0)p.x=c.width;if(p.x>c.width)p.x=0;if(p.y<0)p.y=c.height;if(p.y>c.height)p.y=0;"
  let _ = w f "if(mx>0){var dx=p.x-mx,dy=p.y-my,d=Math.sqrt(dx*dx+dy*dy);if(d<120){p.x+=dx/d*0.5;p.y+=dy/d*0.5}}"
  let _ = w f "ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,6.28);ctx.fillStyle='rgba(0,255,65,0.12)';ctx.fill();"
  let _ = w f "for(var j=i+1;j<pts.length;j++){var q=pts[j];var dx2=p.x-q.x,dy2=p.y-q.y,d2=Math.sqrt(dx2*dx2+dy2*dy2);"
  let _ = w f "if(d2<100){ctx.beginPath();ctx.moveTo(p.x,p.y);ctx.lineTo(q.x,q.y);ctx.strokeStyle='rgba(0,255,65,'+(0.05*(1-d2/100))+')';ctx.stroke()}}}"
  let _ = w f "requestAnimationFrame(draw)}draw();"
  let _ = w f "</script></body></html>"

  let size = trim (shell (cat ["wc -c < ", f]))
  let _ = print (cat ["Generated: ", f, " (", size, " bytes)"])
  let _ = print "Deploying to Cloudflare KV..."
  let deploy_result = shell "cd ~/projects/rail && ./rail_native run tools/deploy/cf_deploy.rail /tmp/ledatic.html 2>&1"
  let _ = print deploy_result
  let _ = shell "cp /tmp/ledatic.html ~/ledatic-site/index.html"
  let _ = print "Done."
  0
