  let _ = w f "<div class='line' data-s='sc68261'>targets: arm64 x86_64 linux wasm metal</div>"
  let _ = w f "<div class='line' data-s='s4a317b'>self-compile: <span data-s='s3b1cff'>116/116</span></div>"
  let _ = w f "<div class='line' data-s='seb77ad'>floats: native ieee754 d-registers</div>"
  let _ = w f "<div class='line' data-s='s31b218'>READY</div>"
  let _ = w f "</div>"

  -- JS
  let _ = w js_file "setTimeout(function(){document.getElementById('boot').classList.add('done')},1600);"
  let _ = w js_file "var obs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting)e.target.classList.add('visible')})},{threshold:0.15});"
  let _ = w js_file "document.querySelectorAll('.reveal').forEach(function(el){obs.observe(el)});"
  let _ = w js_file "document.querySelectorAll('.dropdown a').forEach(function(a){a.addEventListener('click',function(){document.getElementById('dd').classList.remove('open')})});"

  -- Animated bars
  let _ = w js_file "var barsDone=false;function animBars(){if(barsDone)return;barsDone=true;"
  let _ = w js_file "document.querySelectorAll('.bar-fill').forEach(function(el,i){"
  let _ = w js_file "setTimeout(function(){el.style.width=el.dataset.w+'%'},i*150)})};"
  let _ = w js_file "var bobs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting)animBars()})},{threshold:0.3});"
  let _ = w js_file "var bars=document.getElementById('bars');if(bars)bobs.observe(bars);"

  -- Particle system
  let _ = w js_file "var c=document.getElementById('particles'),ctx=c.getContext('2d');"
  let _ = w js_file "function resize(){c.width=window.innerWidth;c.height=window.innerHeight}resize();window.addEventListener('resize',resize);"
  let _ = w js_file "var pts=[];for(var i=0;i<50;i++)pts.push({x:Math.random()*c.width,y:Math.random()*c.height,vx:(Math.random()-0.5)*0.3,vy:(Math.random()-0.5)*0.3,r:Math.random()*1.5+0.5});"
  let _ = w js_file "var mx=-1,my=-1;document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY});"
  let _ = w js_file "function draw(){ctx.clearRect(0,0,c.width,c.height);"
  let _ = w js_file "for(var i=0;i<pts.length;i++){var p=pts[i];p.x+=p.vx;p.y+=p.vy;"
  let _ = w js_file "if(p.x<0)p.x=c.width;if(p.x>c.width)p.x=0;if(p.y<0)p.y=c.height;if(p.y>c.height)p.y=0;"
  let _ = w js_file "if(mx>0){var dx=p.x-mx,dy=p.y-my,d=Math.sqrt(dx*dx+dy*dy);if(d<120){p.x+=dx/d*0.5;p.y+=dy/d*0.5}}"
  let _ = w js_file "ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,6.28);ctx.fillStyle='rgba(0,255,65,0.12)';ctx.fill();"
  let _ = w js_file "for(var j=i+1;j<pts.length;j++){var q=pts[j];var dx2=p.x-q.x,dy2=p.y-q.y,d2=Math.sqrt(dx2*dx2+dy2*dy2);"
  let _ = w js_file "if(d2<100){ctx.beginPath();ctx.moveTo(p.x,p.y);ctx.lineTo(q.x,q.y);ctx.strokeStyle='rgba(0,255,65,'+(0.05*(1-d2/100))+')';ctx.stroke()}}}"
  let _ = w js_file "requestAnimationFrame(draw)}draw();"
  -- Click delegator (replaces former inline onclick handlers)
  let _ = w js_file "document.addEventListener(\"click\",function(e){var t=e.target;if(t.classList&&t.classList.contains(\"burger\")){document.getElementById(\"dd\").classList.toggle(\"open\");return}if(t.id===\"run-all\"){for(var i=0;i<8;i++)runWasm(i);return}if(t.dataset&&t.dataset.run!==undefined){runWasm(parseInt(t.dataset.run,10));return}});"
  let _ = w f "<script src='/main.js' defer></script>"
  -- Analytics: server-side via CF Worker dashboard. No client beacon.
