-- daily_deploy.rail — Rebuild and deploy all ledatic.org pages
-- Called by com.ledatic.site-deploy at 06:00 daily
-- Usage: ./rail_native run tools/deploy/daily_deploy.rail
--
-- Each gen_*.rail is responsible for its own cf_deploy step now.

cat parts = join "" parts
trim s = head (split "\n" s)

main =
  let _ = print (cat ["=== ", trim (shell "date -u"), " ==="])

  let _ = print "[1/4] Main site (/, main.css, main.js, llms.txt, robots.txt, sitemap.xml)..."
  let _ = print (shell "cd ~/projects/rail && ./rail_native run tools/deploy/gen_site.rail 2>&1")

  let _ = print "[2/4] Mission control (/system)..."
  let _ = print (shell "cd ~/projects/rail && ./rail_native run tools/deploy/gen_mission_control.rail 2>&1")

  let _ = print "[3/4] Playground (/playground)..."
  let _ = print (shell "cd ~/projects/rail && ./rail_native run tools/deploy/gen_playground.rail 2>&1")

  let _ = print "[4/4] Plasma landing (/plasma)..."
  let _ = print (shell "cd ~/projects/rail && ./rail_native run tools/deploy/gen_plasma_landing.rail 2>&1")

  let _ = print "Daily deploy complete."
  0
