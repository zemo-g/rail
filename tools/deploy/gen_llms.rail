-- gen_llms.rail — Generate and deploy crawler-discovery files for ledatic.org
--
-- Produces and pushes three artifacts to Cloudflare KV:
--   /llms.txt     — LLM/agent discovery index (markdown)
--   /robots.txt   — classical crawler directives + sitemap pointer
--   /sitemap.xml  — canonical URL list for search engines
--
-- All three drive intelligence-service traffic to ledatic.org.
--
-- Usage: ./rail_native run tools/deploy/gen_llms.rail

cat parts = join "" parts
trim s = head (split "\n" s)

w path s =
  let _ = write_file "/tmp/_rcl.txt" s
  shell (cat ["cat /tmp/_rcl.txt >> ", path])

main =
  let f = "/tmp/ledatic_llms.txt"
  let _ = shell (cat ["rm -f ", f])

  -- Header + summary
  let _ = w f "# LEDATIC\n\n"
  let _ = w f "> Intelligence services from Reilly Gomez. Self-hosting programming language, compiler-verified self-training AI, and autonomous neural control — built from scratch with minimal dependencies.\n\n"

  -- Lede
  let _ = w f "LEDATIC is the engineering practice of Reilly Gomez. The work centers on intelligence systems where the substrate and the model are co-designed: Rail, a 5,700-line self-hosting language that targets ARM64, x86_64, Linux, WebAssembly, and Metal GPU, plus a compiler-as-oracle training pipeline that verifies every generated example before it enters the corpus. If it compiles, it's correct.\n\n"

  let _ = w f "Hire LEDATIC for: compiler-verified AI training pipelines, custom inference stacks on Apple Silicon and consumer GPUs, autonomous control systems, and language design where footprint and reliability matter more than convenience.\n\n"

  -- Intelligence services
  let _ = w f "## Intelligence services\n\n"
  let _ = w f "- [Self-training flywheel](https://ledatic.org/#work): compiler-as-oracle loop. An LLM proposes Rail code, the compiler verifies it, passes get harvested as training data. 1,636-example curated corpus v1 shipped 2026-04-16, Qwen3.5 fine-tuned in-house on CUDA via QLoRA.\n"
  let _ = w f "- [Custom inference stacks](https://ledatic.org/system): MLX servers on Apple Silicon, CUDA QLoRA on RTX-class GPUs, tiered routing with prompt caching and structured outputs.\n"
  let _ = w f "- [Autonomous neural control](https://ledatic.org/#work): real-time neural autopilots written in pure Rail. Microsecond inference, no Python at runtime. Live competition entry.\n"
  let _ = w f "- [Distributed compute fleet](https://ledatic.org/system): three nodes, three architectures (ARM64 + x86_64 + edge), all orchestrated in the language being trained.\n\n"

  -- Rail (the substrate)
  let _ = w f "## Rail — the substrate\n\n"
  let _ = w f "- [Rail on GitHub](https://github.com/zemo-g/rail): self-hosting language, BSL 1.1. 5,738 lines, five backends (ARM64, x86_64, Linux, WASM, Metal GPU), byte-identical fixed point, 116/116 tests, ~874 KB binary, zero C dependencies.\n"
  let _ = w f "- [Live playground](https://ledatic.org/#playground): seven Rail programs compiled to WebAssembly, running in your browser. Closures, ADTs, pattern matching. No install.\n"
  let _ = w f "- [Sandboxed online compiler](https://compile.ledatic.org): public Rail compiler with AST whitelist and WASM import validation. Try real Rail without leaving the tab.\n"
  let _ = w f "- [System / mission control](https://ledatic.org/system): live infrastructure view. Fleet status, model ports, training rounds, full technical detail.\n\n"

  -- Background
  let _ = w f "## Background\n\n"
  let _ = w f "- [About Reilly](https://ledatic.org/#about): nine years running a food production business before moving full-time into systems engineering. Builds things that work with minimal resources.\n"
  let _ = w f "- [Story / timeline](https://ledatic.org/#story): how Rail went from 21,000 lines of Rust in January 2026 to a self-hosting language with five backends, a live plasma simulation platform, and a compiler-verified training corpus by April.\n"
  let _ = w f "- [Technical numbers](https://ledatic.org/#technical): line counts, binary sizes, target list, dependency count. Honest comparisons.\n\n"

  -- Contact
  let _ = w f "## Contact\n\n"
  let _ = w f "- Email: reillygomez13@icloud.com\n"
  let _ = w f "- GitHub: https://github.com/zemo-g\n"
  let _ = w f "- Site: https://ledatic.org\n"

  let size = trim (shell (cat ["wc -c < ", f]))
  let _ = print (cat ["Generated: ", f, " (", size, " bytes)"])
  let _ = print "Deploying to Cloudflare KV as key: llms.txt"
  let deploy_result = shell "cd ~/projects/rail && ./rail_native run tools/deploy/cf_deploy.rail /tmp/ledatic_llms.txt llms.txt 2>&1"
  let _ = print deploy_result
  let _ = shell "cp /tmp/ledatic_llms.txt ~/ledatic-site/llms.txt"

  -- robots.txt
  let r = "/tmp/ledatic_robots.txt"
  let _ = shell (cat ["rm -f ", r])
  let _ = w r "User-agent: *\n"
  let _ = w r "Allow: /\n"
  let _ = w r "\n"
  let _ = w r "Sitemap: https://ledatic.org/sitemap.xml\n"
  let rsize = trim (shell (cat ["wc -c < ", r]))
  let _ = print ""
  let _ = print (cat ["Generated: ", r, " (", rsize, " bytes)"])
  let _ = print "Deploying to Cloudflare KV as key: robots.txt"
  let r_result = shell "cd ~/projects/rail && ./rail_native run tools/deploy/cf_deploy.rail /tmp/ledatic_robots.txt robots.txt 2>&1"
  let _ = print r_result
  let _ = shell "cp /tmp/ledatic_robots.txt ~/ledatic-site/robots.txt"

  -- sitemap.xml
  let date = trim (shell "date -u '+%Y-%m-%d'")
  let s = "/tmp/ledatic_sitemap.xml"
  let _ = shell (cat ["rm -f ", s])
  let _ = w s "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
  let _ = w s "<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n"
  let _ = w s "  <url>\n"
  let _ = w s "    <loc>https://ledatic.org/</loc>\n"
  let _ = w s (cat ["    <lastmod>", date, "</lastmod>\n"])
  let _ = w s "    <changefreq>weekly</changefreq>\n"
  let _ = w s "    <priority>1.0</priority>\n"
  let _ = w s "  </url>\n"
  let _ = w s "  <url>\n"
  let _ = w s "    <loc>https://ledatic.org/system</loc>\n"
  let _ = w s (cat ["    <lastmod>", date, "</lastmod>\n"])
  let _ = w s "    <changefreq>daily</changefreq>\n"
  let _ = w s "    <priority>0.8</priority>\n"
  let _ = w s "  </url>\n"
  let _ = w s "  <url>\n"
  let _ = w s "    <loc>https://ledatic.org/llms.txt</loc>\n"
  let _ = w s (cat ["    <lastmod>", date, "</lastmod>\n"])
  let _ = w s "    <changefreq>weekly</changefreq>\n"
  let _ = w s "    <priority>0.5</priority>\n"
  let _ = w s "  </url>\n"
  let _ = w s "</urlset>\n"
  let ssize = trim (shell (cat ["wc -c < ", s]))
  let _ = print ""
  let _ = print (cat ["Generated: ", s, " (", ssize, " bytes)"])
  let _ = print "Deploying to Cloudflare KV as key: sitemap.xml"
  let s_result = shell "cd ~/projects/rail && ./rail_native run tools/deploy/cf_deploy.rail /tmp/ledatic_sitemap.xml sitemap.xml 2>&1"
  let _ = print s_result
  let _ = shell "cp /tmp/ledatic_sitemap.xml ~/ledatic-site/sitemap.xml"

  let _ = print ""
  let _ = print "Done."
  0
