-- gen_tls_landing.rail — generate ledatic.org/tls, the v3.0.0 story page.
--
-- Aesthetic: steel + teal + amber. Not Matrix-green cosplay. The
-- homepage keeps its established green matrix feel; /tls is a cousin
-- dressed for the gallery.
--
-- Palette:
--   #0a0a0c  bg (near-black, slight blue cast)
--   #111116  surface
--   #1c1c22  border
--   #e8e8ec  text primary
--   #9a9aa4  text secondary
--   #555560  text dim
--   #d8d8dc  steel (primary accent)
--   #5eead4  teal (signal — "this is live")
--   #fb923c  amber (limits)
--   #ef4444  red (only in warning banner)
--
-- Output: /tmp/ledatic_tls.html + /tmp/ledatic_tls.css

cat parts = join "" parts

w path s =
  let _ = write_file "/tmp/_rc.txt" s
  shell (cat ["cat /tmp/_rc.txt >> ", path])

main =
  let f = "/tmp/ledatic_tls.html"
  let css = "/tmp/ledatic_tls.css"
  let _ = shell (cat ["rm -f ", f, " ", css])

  -- ── HEAD ─────────────────────────────────────────────────────────
  let _ = w f "<!DOCTYPE html><html lang='en'><head>"
  let _ = w f "<meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1.0'>"
  let _ = w f "<title>Rail speaks TLS — LEDATIC</title>"
  let _ = w f "<meta name='description' content='Rail v3.0.0 — a self-hosting language that talks HTTPS by itself. Pure-Rail TLS 1.3. Zero C dependencies.'>"
  let _ = w f "<meta property='og:title' content='Rail speaks TLS'>"
  let _ = w f "<meta property='og:description' content='A self-hosting language that talks to api.anthropic.com by itself. Zero C. Zero OpenSSL. Zero curl. Zero socat.'>"
  let _ = w f "<meta property='og:url' content='https://ledatic.org/tls'>"
  let _ = w f "<meta property='og:type' content='website'>"
  let _ = w f "<meta name='twitter:card' content='summary_large_image'>"
  let _ = w f "<meta name='twitter:title' content='Rail speaks TLS'>"
  let _ = w f "<meta name='twitter:description' content='v3.0.0 — a self-hosting language that talks HTTPS by itself.'>"
  let _ = w f "<link rel='icon' href='data:image/svg+xml,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 100 100\"><text y=\".9em\" font-size=\"90\">%3E</text></svg>'>"
  let _ = w f "<link rel='canonical' href='https://ledatic.org/tls'>"
  let _ = w f "<link rel='stylesheet' href='/tls/main.css'>"
  let _ = w f "</head>"

  -- ── CSS ──────────────────────────────────────────────────────────
  let _ = w css "*\{margin:0;padding:0;box-sizing:border-box\}"
  let _ = w css "html\{scroll-behavior:smooth\}"
  let _ = w css "body\{background:#0a0a0c;color:#e8e8ec;font-family:-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',system-ui,sans-serif;-webkit-font-smoothing:antialiased;line-height:1.55;min-height:100vh\}"
  let _ = w css "::selection\{background:#5eead432;color:#fff\}"

  -- very subtle scanline — 3px gap, 0.4% opacity teal (NOT green)
  let _ = w css "body::before\{content:'';position:fixed;top:0;left:0;width:100%;height:100%;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(94,234,212,0.004) 3px,rgba(94,234,212,0.004) 6px);pointer-events:none;z-index:9999\}"

  -- typography
  let _ = w css ".mono\{font-family:ui-monospace,'SF Mono',Menlo,Monaco,monospace\}"
  let _ = w css ".dim\{color:#9a9aa4\}"
  let _ = w css ".dimmer\{color:#555560\}"
  let _ = w css ".teal\{color:#5eead4\}"
  let _ = w css ".steel\{color:#d8d8dc\}"
  let _ = w css ".amber\{color:#fb923c\}"

  -- layout
  let _ = w css ".wrap\{max-width:960px;margin:0 auto;padding:0 28px\}"
  let _ = w css "section\{padding:64px 0;border-bottom:1px solid #1c1c22\}"
  let _ = w css "section:last-of-type\{border-bottom:none\}"

  -- top bar
  let _ = w css ".bar\{position:fixed;top:0;left:0;right:0;background:rgba(10,10,12,0.82);backdrop-filter:blur(12px);border-bottom:1px solid #1c1c22;padding:14px 28px;z-index:500;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:11px;letter-spacing:2px;text-transform:uppercase;display:flex;justify-content:space-between;align-items:center\}"
  let _ = w css ".bar a\{color:#9a9aa4;text-decoration:none;margin-right:18px;transition:color .2s\}"
  let _ = w css ".bar a:hover\{color:#5eead4\}"
  let _ = w css ".bar .logo\{color:#e8e8ec\}.bar .logo .dot\{color:#5eead4\}"
  let _ = w css ".bar .live\{color:#5eead4;font-variant-numeric:tabular-nums;letter-spacing:3px\}"

  -- hero
  let _ = w css "#hero\{padding-top:120px;padding-bottom:72px;border-bottom:1px solid #1c1c22\}"
  let _ = w css ".tag\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:11px;letter-spacing:4px;color:#555560;text-transform:uppercase;margin-bottom:32px\}"
  let _ = w css ".tag .pip\{color:#5eead4;margin-right:8px\}"
  let _ = w css "h1\{font-size:clamp(48px,8vw,96px);font-weight:700;line-height:1;letter-spacing:-.03em;margin-bottom:28px;color:#e8e8ec\}"
  let _ = w css "h1 .period\{color:#5eead4\}"
  let _ = w css ".lede\{color:#9a9aa4;font-size:19px;line-height:1.65;max-width:620px;margin-bottom:40px\}"
  let _ = w css ".lede b\{color:#e8e8ec;font-weight:500\}"
  let _ = w css ".cta-row\{display:flex;gap:12px;flex-wrap:wrap\}"
  let _ = w css ".cta\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:12px;letter-spacing:1px;text-transform:uppercase;padding:14px 22px;border-radius:3px;text-decoration:none;transition:all .2s\}"
  let _ = w css ".cta-p\{background:#e8e8ec;color:#0a0a0c;font-weight:600\}"
  let _ = w css ".cta-p:hover\{background:#5eead4\}"
  let _ = w css ".cta-s\{border:1px solid #1c1c22;color:#9a9aa4\}"
  let _ = w css ".cta-s:hover\{border-color:#5eead4;color:#e8e8ec\}"

  -- section headers
  let _ = w css ".sh\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:10px;letter-spacing:4px;text-transform:uppercase;color:#555560;margin-bottom:24px;display:flex;align-items:center;gap:14px\}"
  let _ = w css ".sh .rule\{flex:1;height:1px;background:#1c1c22\}"
  let _ = w css ".sh .stamp\{color:#5eead4\}"

  -- terminal
  let _ = w css ".term\{background:#0e0e12;border:1px solid #1c1c22;border-radius:4px;padding:24px 26px;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:13px;line-height:1.75;color:#e8e8ec;overflow-x:auto\}"
  let _ = w css ".term .row\{display:flex;gap:18px;white-space:pre;opacity:0;animation:type .01s forwards\}"
  let _ = w css ".term .t\{color:#555560;font-variant-numeric:tabular-nums\}"
  let _ = w css ".term .g\{color:#5eead4;width:18px;display:inline-block;flex-shrink:0;text-align:center\}"
  let _ = w css ".term .k\{color:#9a9aa4\}"
  let _ = w css ".term .v\{color:#e8e8ec\}"
  let _ = w css ".term .hex\{color:#fb923c;font-variant-numeric:tabular-nums\}"
  let _ = w css ".term .em\{color:#5eead4;font-weight:500\}"
  let _ = w css ".term .ok\{color:#5eead4\}"
  let _ = w css ".term .dash\{color:#555560\}"
  let _ = w css ".term .x\{color:#5eead4\}"
  let _ = w css "@keyframes type\{from\{opacity:0\}to\{opacity:1\}\}"

  -- gates
  let _ = w css ".gates\{display:grid;grid-template-columns:repeat(2,1fr);gap:16px\}"
  let _ = w css "@media(min-width:720px)\{.gates\{grid-template-columns:repeat(4,1fr)\}\}"
  let _ = w css ".gate\{background:#0e0e12;border:1px solid #1c1c22;border-radius:3px;padding:20px 18px;transition:border-color .2s\}"
  let _ = w css ".gate:hover\{border-color:#5eead4\}"
  let _ = w css ".gate .led\{width:8px;height:8px;border-radius:50%;background:#5eead4;box-shadow:0 0 10px #5eead4;display:inline-block;margin-right:10px;vertical-align:middle\}"
  let _ = w css ".gate h4\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#e8e8ec;font-weight:600;display:flex;align-items:center;margin-bottom:10px\}"
  let _ = w css ".gate p\{color:#9a9aa4;font-size:12px;font-family:ui-monospace,'SF Mono',Menlo,monospace;line-height:1.6\}"

  -- stack ledger — ls -la style
  let _ = w css ".ledger\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:12px;line-height:1.9;color:#e8e8ec;background:#0e0e12;border:1px solid #1c1c22;border-radius:4px;padding:22px 24px;overflow-x:auto\}"
  let _ = w css ".ledger .lh\{color:#555560;margin-bottom:10px;letter-spacing:1px\}"
  let _ = w css ".ledger .row\{display:grid;grid-template-columns:130px 60px 1fr 1.2fr;gap:12px;padding:2px 0\}"
  let _ = w css ".ledger .path\{color:#e8e8ec\}"
  let _ = w css ".ledger .size\{color:#9a9aa4;text-align:right;font-variant-numeric:tabular-nums\}"
  let _ = w css ".ledger .note\{color:#555560\}"
  let _ = w css ".ledger .sum\{border-top:1px solid #1c1c22;margin-top:12px;padding-top:12px;color:#d8d8dc\}"
  let _ = w css "@media(max-width:720px)\{.ledger .row\{grid-template-columns:1fr 60px;gap:8px\}.ledger .row .note\{display:none\}.ledger .row .path\{grid-column:1\}.ledger .row .size\{grid-column:2\}\}"

  -- count block
  let _ = w css ".count\{display:grid;grid-template-columns:repeat(2,1fr);gap:0;border-left:1px solid #1c1c22\}"
  let _ = w css "@media(min-width:720px)\{.count\{grid-template-columns:repeat(4,1fr)\}\}"
  let _ = w css ".cell\{border:1px solid #1c1c22;border-left:none;padding:32px 24px;text-align:center\}"
  let _ = w css ".cell .big\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:44px;font-weight:300;color:#d8d8dc;letter-spacing:-2px;font-variant-numeric:tabular-nums;line-height:1}"
  let _ = w css ".cell .lab\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#555560;margin-top:12px;line-height:1.5\}"

  -- limits warning
  let _ = w css ".limits\{background:#1a0d0d;border:1px solid #3a1818;border-radius:4px;padding:28px 30px;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:13px;line-height:1.75;color:#e8e8ec\}"
  let _ = w css ".limits .warn\{color:#ef4444;font-size:14px;letter-spacing:3px;text-transform:uppercase;margin-bottom:16px;font-weight:600\}"
  let _ = w css ".limits p\{margin-bottom:12px\}"
  let _ = w css ".limits b\{color:#fb923c;font-weight:500\}"
  let _ = w css ".limits .last\{color:#9a9aa4;margin-top:18px;padding-top:18px;border-top:1px solid #3a1818;font-style:italic\}"

  -- arc
  let _ = w css ".arc\{font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:13px\}"
  let _ = w css ".arc .line\{display:grid;grid-template-columns:50px 90px 1fr;gap:14px;padding:10px 0;border-bottom:1px dashed #1c1c22\}"
  let _ = w css ".arc .line:last-child\{border-bottom:none;color:#e8e8ec\}"
  let _ = w css ".arc .ver\{color:#5eead4;font-weight:500\}"
  let _ = w css ".arc .date\{color:#555560\}"
  let _ = w css ".arc .desc\{color:#9a9aa4\}"
  let _ = w css ".arc .line:last-child .desc\{color:#e8e8ec\}"

  -- footer
  let _ = w css "footer\{padding:56px 28px;text-align:center;color:#555560;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:11px;letter-spacing:2px;text-transform:uppercase\}"
  let _ = w css "footer a\{color:#9a9aa4;text-decoration:none;margin:0 10px\}"
  let _ = w css "footer a:hover\{color:#5eead4\}"
  let _ = w css "footer .mantra\{margin-top:20px;color:#555560;letter-spacing:4px\}"
  let _ = w css "footer .mantra .bright\{color:#5eead4\}"

  -- ── BODY ─────────────────────────────────────────────────────────
  let _ = w f "<body>"

  -- top bar
  let _ = w f "<div class='bar'>"
  let _ = w f "<div><span class='logo'>ledatic<span class='dot'>.</span>org</span></div>"
  let _ = w f "<div><a href='/'>home</a> <a href='/system'>system</a> <a href='/plasma/'>plasma</a> <span style='color:#5eead4'>· tls</span></div>"
  let _ = w f "</div>"

  -- HERO
  let _ = w f "<section id='hero'><div class='wrap'>"
  let _ = w f "<div class='tag'><span class='pip'>●</span>v3.0.0 &nbsp;·&nbsp; 2026-04-18</div>"
  let _ = w f "<h1>Rail speaks TLS<span class='period'>.</span></h1>"
  let _ = w f "<p class='lede'>A self-hosting language that talks to <b>api.anthropic.com</b> by itself. Pure-Rail TLS 1.3, X.509 chain validation to the system trust store, live HTTPS clients. Zero C. Zero OpenSSL. Zero curl. Zero socat.</p>"
  let _ = w f "<div class='cta-row'>"
  let _ = w f "<a class='cta cta-p' href='https://github.com/zemo-g/rail/releases/tag/v3.0.0'>Release</a>"
  let _ = w f "<a class='cta cta-s' href='https://github.com/zemo-g/rail'>Source</a>"
  let _ = w f "<a class='cta cta-s' href='https://github.com/zemo-g/rail/blob/master/CHANGELOG.md'>Changelog</a>"
  let _ = w f "</div>"
  let _ = w f "</div></section>"

  -- LIVE TRACE — real handshake log from today
  let _ = w f "<section><div class='wrap'>"
  let _ = w f "<div class='sh'><span class='stamp'>LIVE</span><div class='rule'></div><span>handshake · api.anthropic.com · 2026-04-18 15:44:07 UTC</span></div>"
  let _ = w f "<div class='term' id='term'>"
  let _ = w f "<div class='row'><span class='t'>15:44:07.102</span><span class='g'>+</span><span class='k'>dns      </span><span class='v'>api.anthropic.com</span><span class='dash'>→</span><span class='em'>160.79.104.10</span></div>"
  let _ = w f "<div class='row'><span class='t'>15:44:07.289</span><span class='g'>+</span><span class='k'>tcp      </span><span class='v'>connect 160.79.104.10:443</span><span class='ok'>ok</span></div>"
  let _ = w f "<div class='row'><span class='t'>15:44:07.294</span><span class='g'>+</span><span class='k'>tls      </span><span class='v'>ClientHello &nbsp;cipher=TLS_CHACHA20_POLY1305_SHA256 &nbsp;group=x25519</span></div>"
  let _ = w f "<div class='row'><span class='t'>15:44:07.318</span><span class='g'>+</span><span class='k'>tls      </span><span class='v'>ServerHello &nbsp;random=</span><span class='hex'>a6af06a4...</span></div>"
  let _ = w f "<div class='row'><span class='t'>15:44:07.319</span><span class='g'>+</span><span class='k'>ecdhe    </span><span class='v'>x25519 shared =</span> <span class='hex'>8bd4054fb55b9d63...</span></div>"
  let _ = w f "<div class='row'><span class='t'>15:44:07.401</span><span class='g'>+</span><span class='k'>cert     </span><span class='v'>sig=ECDSA-P256-SHA256 &nbsp;</span><span class='ok'>verified</span></div>"
  let _ = w f "<div class='row'><span class='t'>15:44:07.402</span><span class='g'>+</span><span class='k'>san      </span><span class='v'>api.anthropic.com &nbsp;</span><span class='ok'>match</span></div>"
  let _ = w f "<div class='row'><span class='t'>15:44:07.402</span><span class='g'>+</span><span class='k'>valid    </span><span class='v'>[2026-03-28, 2026-06-26] &nbsp;</span><span class='ok'>in window</span></div>"
  let _ = w f "<div class='row'><span class='t'>15:44:07.419</span><span class='g'>+</span><span class='k'>finished </span><span class='v'>HMAC-SHA-256 over transcript &nbsp;</span><span class='ok'>ok</span></div>"
  let _ = w f "<div class='row'><span class='t'>15:44:13.980</span><span class='g'>+</span><span class='k'>http     </span><span class='v'>POST /v1/messages &nbsp;</span><span class='em'>200</span></div>"
  let _ = w f "<div class='row'><span class='t'>15:44:13.982</span><span class='g'>+</span><span class='k'>reply    </span><span class='v'>&quot;hello from pure rail&quot;</span></div>"
  let _ = w f "<div class='row'><span class='t'>15:44:13.983</span><span class='g'>—</span><span class='k'>         </span><span class='dim'>6.88 s end-to-end · zero C on the wire</span></div>"
  let _ = w f "</div></div></section>"

  -- TRUST GATES
  let _ = w f "<section><div class='wrap'>"
  let _ = w f "<div class='sh'><span class='stamp'>GATES</span><div class='rule'></div><span>all four pass or the connection fails closed</span></div>"
  let _ = w f "<div class='gates'>"
  let _ = w f "<div class='gate'><h4><span class='led'></span>cert sig</h4><p>ECDSA-P256-SHA256 &nbsp;or&nbsp; RSA-PSS-SHA256 verified against the leaf&rsquo;s SubjectPublicKey.</p></div>"
  let _ = w f "<div class='gate'><h4><span class='led'></span>san match</h4><p>dNSName entries matched against the SNI you asked for. Wildcard per RFC 6125 &sect;6.4.3.</p></div>"
  let _ = w f "<div class='gate'><h4><span class='led'></span>validity</h4><p>date -u within the leaf&rsquo;s notBefore / notAfter window.</p></div>"
  let _ = w f "<div class='gate'><h4><span class='led'></span>finished mac</h4><p>HMAC-SHA-256 over the handshake transcript. Server proves it computed the same thing.</p></div>"
  let _ = w f "</div></div></section>"

  -- THE STACK — ledger
  let _ = w f "<section><div class='wrap'>"
  let _ = w f "<div class='sh'><span class='stamp'>STACK</span><div class='rule'></div><span>what v3.0.0 added · 22 modules · 6,223 lines of pure Rail</span></div>"
  let _ = w f "<div class='ledger'>"
  let _ = w f "<div class='lh'>path                               lines    rfc / spec</div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/sha256.rail</span><span class='size'>223</span><span class='note'>FIPS 180-4 · SHA-256</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/sha512.rail</span><span class='size'>359</span><span class='note'>FIPS 180-4 · SHA-384 / 512</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/hmac.rail</span><span class='size'>82</span><span class='note'>RFC 4231</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/hkdf.rail</span><span class='size'>50</span><span class='note'>RFC 5869</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/chacha20.rail</span><span class='size'>158</span><span class='note'>RFC 8439 &sect;2.3</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/poly1305.rail</span><span class='size'>260</span><span class='note'>RFC 8439 &sect;2.5</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/aead.rail</span><span class='size'>126</span><span class='note'>RFC 8439 &sect;2.8 · AEAD</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/x25519.rail</span><span class='size'>324</span><span class='note'>RFC 7748 · ECDHE</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/bignum_n.rail</span><span class='size'>258</span><span class='note'>n-limb arithmetic</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/ecdsa_p256.rail</span><span class='size'>610</span><span class='note'>RFC 6979 &sect;A.2.5</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/ecdsa_p384.rail</span><span class='size'>324</span><span class='note'>RFC 6979 &sect;A.2.6</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/rsa_pss.rail</span><span class='size'>191</span><span class='note'>RFC 8017 · PSS + PKCS1</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/asn1.rail</span><span class='size'>534</span><span class='note'>X.509 DER walker</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/b64.rail</span><span class='size'>84</span><span class='note'>base64 decode</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/pem.rail</span><span class='size'>89</span><span class='note'>/etc/ssl/cert.pem · 128 roots</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/tls13.rail</span><span class='size'>165</span><span class='note'>RFC 8446 · key schedule</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/tls13_hs.rail</span><span class='size'>471</span><span class='note'>handshake messages</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/tls13_record.rail</span><span class='size'>141</span><span class='note'>record wrap / unwrap</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/tls13_cert_verify.rail</span><span class='size'>468</span><span class='note'>CertificateVerify dispatch</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/tls13_client.rail</span><span class='size'>168</span><span class='note'>client FSM</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/cert_chain.rail</span><span class='size'>66</span><span class='note'>chain walk · shortest-path</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/cert_p384.rail</span><span class='size'>84</span><span class='note'>P-384 chain edge</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/https_client.rail</span><span class='size'>562</span><span class='note'>HTTPS + URL parse</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/dns.rail</span><span class='size'>219</span><span class='note'>UDP DNS A-record</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/anthropic_client.rail</span><span class='size'>69</span><span class='note'>api.anthropic.com · live</span></div>"
  let _ = w f "<div class='row'><span class='path'>stdlib/slack_client.rail</span><span class='size'>43</span><span class='note'>slack.com · live</span></div>"
  let _ = w f "<div class='row sum'><span class='path'>total</span><span class='size'>6,223</span><span class='note'>lines of pure Rail, no C</span></div>"
  let _ = w f "</div></div></section>"

  -- COUNT block
  let _ = w f "<section><div class='wrap'>"
  let _ = w f "<div class='sh'><span class='stamp'>COUNT</span><div class='rule'></div><span>what you&rsquo;re looking at</span></div>"
  let _ = w f "<div class='count'>"
  let _ = w f "<div class='cell'><div class='big'>6,223</div><div class='lab'>lines of<br>pure Rail</div></div>"
  let _ = w f "<div class='cell'><div class='big'>22</div><div class='lab'>TLS tests<br>all green</div></div>"
  let _ = w f "<div class='cell'><div class='big'>116</div><div class='lab'>core tests<br>fixed point</div></div>"
  let _ = w f "<div class='cell'><div class='big'>0</div><div class='lab'>C deps<br>linked</div></div>"
  let _ = w f "</div></div></section>"

  -- LIMITS — red-tinted, honest
  let _ = w f "<section><div class='wrap'>"
  let _ = w f "<div class='sh'><span class='stamp' style='color:#ef4444'>LIMITS</span><div class='rule'></div><span>what this is not · read before you deploy</span></div>"
  let _ = w f "<div class='limits'>"
  let _ = w f "<div class='warn'>&#9888; not a drop-in openssl</div>"
  let _ = w f "<p>Rail v3.0.0 is <b>not constant-time</b>. <b>Not side-channel hardened</b>. <b>Not formally verified</b>. <b>Not audited</b>. One cipher suite (TLS_CHACHA20_POLY1305_SHA256), one ECDHE group (x25519), three sig-algs. No session resumption. No 0-RTT. No client certificates.</p>"
  let _ = w f "<p>A connection is <b>5 to 8 seconds wall time</b>, dominated by public-key verify. Fine for a one-shot API call. Bad for an HTTP proxy.</p>"
  let _ = w f "<p class='last'>If it matters, use rustls or BoringSSL. This is for Rail to talk to the world — not for the world to talk through Rail.</p>"
  let _ = w f "</div></div></section>"

  -- ARC
  let _ = w f "<section><div class='wrap'>"
  let _ = w f "<div class='sh'><span class='stamp'>ARC</span><div class='rule'></div><span>three years, three verbs</span></div>"
  let _ = w f "<div class='arc'>"
  let _ = w f "<div class='line'><span class='ver'>v1.x</span><span class='date'>2026-03</span><span class='desc'>Rail compiled itself.</span></div>"
  let _ = w f "<div class='line'><span class='ver'>v2.x</span><span class='date'>2026-04</span><span class='desc'>Rail gained networks, trained transformers, shipped to Cloudflare.</span></div>"
  let _ = w f "<div class='line'><span class='ver'>v3.0</span><span class='date'>2026-04-18</span><span class='desc'>Rail calls api.anthropic.com by itself.</span></div>"
  let _ = w f "</div></div></section>"

  -- FOOTER
  let _ = w f "<footer>"
  let _ = w f "<div><a href='https://github.com/zemo-g/rail'>github</a><a href='https://github.com/zemo-g/rail/blob/master/CHANGELOG.md'>changelog</a><a href='https://github.com/zemo-g/rail/releases/tag/v3.0.0'>v3.0.0</a><a href='https://github.com/zemo-g/rail/blob/master/SECURITY.md'>security</a><a href='/'>ledatic.org</a></div>"
  let _ = w f "<div class='mantra'>rail runs on rail <span class='bright'>·</span> the rest runs on physics</div>"
  let _ = w f "</footer>"

  let _ = w f "</body></html>"

  let _ = print "wrote /tmp/ledatic_tls.html + /tmp/ledatic_tls.css"
  let size_html = shell "wc -c < /tmp/ledatic_tls.html | tr -d ' '"
  let size_css = shell "wc -c < /tmp/ledatic_tls.css | tr -d ' '"
  let _ = print (cat ["html: ", head (split "\n" size_html), " bytes"])
  let _ = print (cat ["css : ", head (split "\n" size_css), " bytes"])
  0
