-- gen_flywheel_page.rail — Generate ledatic.org/flywheel metrics page
-- Usage: ./rail_native run tools/deploy/gen_flywheel_page.rail
-- Deploy: ./rail_native run tools/deploy/cf_deploy.rail /tmp/flywheel.html flywheel

cat parts = join "" parts
trim s = head (split "\n" s)

w path s =
  let _ = write_file "/tmp/_rc.txt" s
  shell (cat ["cat /tmp/_rc.txt >> ", path])

main =
  let f = "/tmp/flywheel.html"
  let _ = shell (cat ["rm -f ", f])

  -- Use shell to extract bench data into simple values
  let nruns = trim (shell "grep -c 'total=' flywheel/bench_log.txt 2>/dev/null || echo 0")
  let latest_pct = trim (shell "tail -1 flywheel/bench_log.txt | grep -o '([0-9]*%)' | tr -d '(%)'")
  let latest_total = trim (shell "tail -1 flywheel/bench_log.txt | grep -o 'total=[0-9]*/[0-9]*' | cut -d= -f2")
  let latest_date = trim (shell "tail -1 flywheel/bench_log.txt | cut -dT -f1")
  let best_pct = trim (shell "grep -o '([0-9]*%)' flywheel/bench_log.txt | tr -d '(%)' | sort -n | tail -1")

  -- Extract latest band scores
  let fund = trim (shell "tail -1 flywheel/bench_log.txt | grep -o 'fund=[0-9]*/[0-9]*' | cut -d= -f2")
  let io = trim (shell "tail -1 flywheel/bench_log.txt | grep -o 'io=[0-9]*/[0-9]*' | cut -d= -f2")
  let tools_s = trim (shell "tail -1 flywheel/bench_log.txt | grep -o 'tools=[0-9]*/[0-9]*' | cut -d= -f2")
  let comp = trim (shell "tail -1 flywheel/bench_log.txt | grep -o 'comp=[0-9]*/[0-9]*' | cut -d= -f2")
  let adv = trim (shell "tail -1 flywheel/bench_log.txt | grep -o 'adv=[0-9]*/[0-9]*' | cut -d= -f2")
  let comprehend = trim (shell "tail -1 flywheel/bench_log.txt | grep -o 'comprehend=[0-9]*/[0-9]*' | cut -d= -f2")

  -- Get individual band numerators for bar widths
  let fund_n = trim (shell "tail -1 flywheel/bench_log.txt | grep -o 'fund=[0-9]*' | cut -d= -f2")
  let io_n = trim (shell "tail -1 flywheel/bench_log.txt | grep -o 'io=[0-9]*' | cut -d= -f2")
  let tools_n = trim (shell "tail -1 flywheel/bench_log.txt | grep -o 'tools=[0-9]*' | cut -d= -f2")
  let comp_n = trim (shell "tail -1 flywheel/bench_log.txt | grep -o 'comp=[0-9]*' | cut -d= -f2")
  let adv_n = trim (shell "tail -1 flywheel/bench_log.txt | grep -o 'adv=[0-9]*' | cut -d= -f2")
  let comprehend_n = trim (shell "tail -1 flywheel/bench_log.txt | grep -o 'comprehend=[0-9]*' | cut -d= -f2")

  -- Generate SVG bars data via shell (one bar per line: pct,date)
  let _ = shell "grep 'total=' flywheel/bench_log.txt | while IFS= read -r line; do pct=$(echo \"$line\" | grep -o '([0-9]*%)' | tr -d '(%)'); dt=$(echo \"$line\" | cut -dT -f1 | cut -d- -f2,3); echo \"$pct $dt\"; done > /tmp/_fw_bars.txt"
  let bars_data = read_file "/tmp/_fw_bars.txt"

  -- Build SVG bars via shell script (avoids Rail int parsing)
  let _ = shell "awk 'BEGIN{i=0} {pct=$1; dt=$2; x=60+i*56; barh=pct*2; y=220-barh; if(pct>=80) c=\"#00ff41\"; else if(pct>=40) c=\"#3b82f6\"; else if(pct>0) c=\"#f97316\"; else c=\"#27272a\"; printf \"<rect x=\\x27%d\\x27 y=\\x27%d\\x27 width=\\x2740\\x27 height=\\x27%d\\x27 rx=\\x273\\x27 fill=\\x27%s\\x27 opacity=\\x270.85\\x27/>\", x, y, barh, c; printf \"<text x=\\x27%d\\x27 y=\\x27%d\\x27 text-anchor=\\x27middle\\x27 fill=\\x27#e4e4e7\\x27 font-family=\\x27JetBrains Mono\\x27 font-size=\\x2711\\x27 font-weight=\\x27600\\x27>%d%%</text>\", x+20, y-8, pct; printf \"<text x=\\x27%d\\x27 y=\\x27240\\x27 text-anchor=\\x27middle\\x27 fill=\\x27#52525b\\x27 font-family=\\x27JetBrains Mono\\x27 font-size=\\x279\\x27 transform=\\x27rotate(-45 %d 240)\\x27>%s</text>\\n\", x+20, x+20, dt; i++} END{printf \"%d\\n\", 60+i*56+40 > \"/tmp/_fw_chartw.txt\"}' /tmp/_fw_bars.txt > /tmp/_fw_svg_bars.txt"
  let svg_bars = read_file "/tmp/_fw_svg_bars.txt"
  let chartw = trim (read_file "/tmp/_fw_chartw.txt")

  -- HEAD
  let _ = w f "<!DOCTYPE html><html lang='en'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1.0'>"
  let _ = w f "<title>Flywheel Metrics — LEDATIC</title>"
  let _ = w f "<meta name='description' content='Rail self-training flywheel benchmark metrics and training progress.'>"
  let _ = w f "<link rel='icon' href='data:image/svg+xml,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 100 100\"><text y=\".9em\" font-size=\"90\">%3E</text></svg>'>"
  let _ = w f "<link rel='preconnect' href='https://fonts.googleapis.com'>"
  let _ = w f "<link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap' rel='stylesheet'>"
  let _ = w f "<style>"

  -- CSS reset + base (matching main site)
  let _ = w f "*{margin:0;padding:0;box-sizing:border-box}html{scroll-behavior:smooth}"
  let _ = w f "body{background:#09090b;color:#e4e4e7;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}"
  let _ = w f "::selection{background:#00ff4130;color:#fff}"
  let _ = w f "body::before{content:'';position:fixed;top:0;left:0;width:100%;height:100%;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,255,65,0.006) 3px,rgba(0,255,65,0.006) 6px);pointer-events:none;z-index:9999}"

  -- CSS layout
  let _ = w f ".wrap{max-width:1080px;margin:0 auto;padding:0 28px}"
  let _ = w f "section{padding:80px 0;border-bottom:1px solid #18181b}section:last-of-type{border-bottom:none}"

  -- CSS nav
  let _ = w f "nav{position:fixed;top:0;left:0;right:0;z-index:10000;background:rgba(9,9,11,0.85);backdrop-filter:blur(16px);border-bottom:1px solid #18181b;padding:16px 28px;font-family:'JetBrains Mono',monospace;font-size:12px;display:flex;justify-content:space-between;align-items:center}"
  let _ = w f "nav a{color:#71717a;text-decoration:none;transition:color 0.2s}nav a:hover{color:#00ff41}"
  let _ = w f "nav .links{display:flex;gap:24px}.logo{color:#e4e4e7;font-weight:600;letter-spacing:2px;font-size:13px}.logo span{color:#00ff41}"
  let _ = w f ".burger{display:none;background:none;border:1px solid #27272a;color:#e4e4e7;font-size:20px;padding:4px 10px;border-radius:4px;cursor:pointer;font-family:'JetBrains Mono',monospace}"
  let _ = w f ".dropdown{display:none;position:absolute;top:100%;right:16px;background:#0a0a0a;border:1px solid #27272a;border-radius:8px;padding:8px 0;min-width:160px;z-index:101}"
  let _ = w f ".dropdown a{display:block;padding:10px 20px;color:#a1a1aa;font-size:13px}.dropdown a:hover{color:#00ff41;background:#111}"
  let _ = w f ".dropdown.open{display:block}"
  let _ = w f "@media(max-width:768px){nav .links{display:none}.burger{display:block}}"

  -- CSS headings + cards
  let _ = w f "h1{font-size:clamp(32px,5vw,56px);font-weight:700;line-height:1.1;letter-spacing:-1.5px;margin-bottom:16px}"
  let _ = w f "h1 .g{color:#00ff41}h1 .b{color:#3b82f6}"
  let _ = w f "h2{font-size:clamp(24px,3vw,36px);font-weight:700;letter-spacing:-0.5px;margin-bottom:12px}"
  let _ = w f ".section-sub{color:#71717a;font-size:15px;line-height:1.7;max-width:640px;margin-bottom:40px}"
  let _ = w f ".grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin:32px 0}"
  let _ = w f ".card{background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px;padding:28px;transition:all 0.3s ease}.card:hover{border-color:#27272a;box-shadow:0 0 20px rgba(0,255,65,0.06);transform:translateY(-2px)}"
  let _ = w f ".card h3{font-size:16px;font-weight:600;margin-bottom:8px}.card p{color:#71717a;font-size:13px;line-height:1.7}"
  let _ = w f ".stat{font-family:'JetBrains Mono',monospace;font-size:32px;font-weight:700;margin-bottom:4px}"

  -- CSS chart
  let _ = w f ".chart-wrap{background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px;padding:32px;margin:32px 0;overflow-x:auto}"
  let _ = w f ".chart-title{font-family:'JetBrains Mono',monospace;font-size:13px;color:#71717a;margin-bottom:16px;letter-spacing:1px;text-transform:uppercase}"

  -- CSS band meter
  let _ = w f ".meter{width:100%;height:32px;background:#111;border-radius:16px;overflow:hidden;position:relative;margin:16px 0}"
  let _ = w f ".meter-fill{height:100%;border-radius:16px;transition:width 1.5s cubic-bezier(0.25,1,0.5,1);display:flex;align-items:center;justify-content:flex-end;padding-right:16px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;color:#09090b}"
  let _ = w f ".meter-labels{display:flex;justify-content:space-between;font-family:'JetBrains Mono',monospace;font-size:10px;color:#52525b;margin-top:4px}"

  -- CSS band breakdown
  let _ = w f ".bands{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin:24px 0}"
  let _ = w f ".band{background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px;padding:16px;text-align:center}"
  let _ = w f ".band-name{font-family:'JetBrains Mono',monospace;font-size:11px;color:#71717a;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}"
  let _ = w f ".band-score{font-family:'JetBrains Mono',monospace;font-size:24px;font-weight:700}"
  let _ = w f ".band-bar{height:4px;background:#1c1c1e;border-radius:2px;margin-top:8px;overflow:hidden}"
  let _ = w f ".band-bar-fill{height:100%;border-radius:2px}"

  -- CSS footer
  let _ = w f "footer{text-align:center;padding:64px 28px;color:#3f3f46;font-family:'JetBrains Mono',monospace;font-size:11px;line-height:2}"
  let _ = w f "footer a{color:#52525b;text-decoration:none}footer a:hover{color:#00ff41}"

  let _ = w f "</style></head><body>"

  -- NAV
  let _ = w f "<nav style='position:relative'><div class='logo'><span>&gt;</span> LEDATIC</div>"
  let _ = w f "<div class='links'><a href='/'>Home</a><a href='/system'>System</a><a href='/flywheel'>Flywheel</a><a href='https://github.com/zemo-g/rail'>GitHub</a></div>"
  let _ = w f "<button class='burger' onclick='var d=document.getElementById(\"dd\");d.classList.toggle(\"open\")'>&#9776;</button>"
  let _ = w f "<div class='dropdown' id='dd'><a href='/'>Home</a><a href='/system'>System</a><a href='/flywheel'>Flywheel</a><a href='https://github.com/zemo-g/rail'>GitHub</a></div></nav>"

  -- HERO
  let _ = w f "<section style='padding-top:120px'><div class='wrap'>"
  let _ = w f "<h1>The <span class='g'>flywheel</span></h1>"
  let _ = w f "<p class='section-sub'>Compiler-verified self-training. The compiler is the oracle. If it compiles, the code is correct. The model gets better at writing the language it is verified by.</p>"

  -- Key stats
  let _ = w f "<div class='grid' style='grid-template-columns:repeat(auto-fit,minmax(180px,1fr))'>"
  let _ = w f (cat ["<div class='card' style='text-align:center'><div class='stat' style='color:#00ff41'>", latest_pct, "%</div><p>latest bench score</p></div>"])
  let _ = w f (cat ["<div class='card' style='text-align:center'><div class='stat' style='color:#3b82f6'>", best_pct, "%</div><p>best score (peak)</p></div>"])
  let _ = w f "<div class='card' style='text-align:center'><div class='stat' style='color:#f97316'>4,059</div><p>verified examples</p></div>"
  let _ = w f (cat ["<div class='card' style='text-align:center'><div class='stat' style='color:#c084fc'>", nruns, "</div><p>benchmark runs</p></div>"])
  let _ = w f "</div></div></section>"

  -- BENCHMARK CHART
  let _ = w f "<section><div class='wrap'>"
  let _ = w f "<h2>Benchmark <span class='b'>scores</span></h2>"
  let _ = w f "<p class='section-sub'>30 tasks across 6 bands: fundamentals, I/O, tools, composition, advanced, comprehension. Output-verified where possible.</p>"

  let _ = w f "<div class='chart-wrap'>"
  let _ = w f "<div class='chart-title'>Score over time (%)</div>"

  -- SVG chart with bars generated by shell
  let _ = w f (cat ["<svg width='100%' viewBox='0 0 ", chartw, " 280' preserveAspectRatio='xMinYMid meet'>"])

  -- Grid lines + axis labels
  let _ = w f "<line x1='50' y1='20' x2='50' y2='220' stroke='#1c1c1e' stroke-width='1'/>"
  let _ = w f "<line x1='50' y1='220' x2='100%' y2='220' stroke='#1c1c1e' stroke-width='1'/>"
  let _ = w f "<line x1='50' y1='170' x2='100%' y2='170' stroke='#1c1c1e' stroke-width='0.5' stroke-dasharray='4,4'/>"
  let _ = w f "<text x='45' y='174' text-anchor='end' fill='#3f3f46' font-family='JetBrains Mono' font-size='9'>25%</text>"
  let _ = w f "<line x1='50' y1='120' x2='100%' y2='120' stroke='#1c1c1e' stroke-width='0.5' stroke-dasharray='4,4'/>"
  let _ = w f "<text x='45' y='124' text-anchor='end' fill='#3f3f46' font-family='JetBrains Mono' font-size='9'>50%</text>"
  let _ = w f "<line x1='50' y1='70' x2='100%' y2='70' stroke='#1c1c1e' stroke-width='0.5' stroke-dasharray='4,4'/>"
  let _ = w f "<text x='45' y='74' text-anchor='end' fill='#3f3f46' font-family='JetBrains Mono' font-size='9'>75%</text>"
  let _ = w f "<line x1='50' y1='20' x2='100%' y2='20' stroke='#1c1c1e' stroke-width='0.5' stroke-dasharray='4,4'/>"
  let _ = w f "<text x='45' y='24' text-anchor='end' fill='#3f3f46' font-family='JetBrains Mono' font-size='9'>100%</text>"
  let _ = w f "<text x='45' y='224' text-anchor='end' fill='#3f3f46' font-family='JetBrains Mono' font-size='9'>0%</text>"

  -- Bars (pre-generated by awk)
  let _ = w f svg_bars

  let _ = w f "</svg></div></div></section>"

  -- PERFORMANCE BAND
  let _ = w f "<section><div class='wrap'>"
  let _ = w f "<h2>Current <span class='g'>performance</span></h2>"

  -- Overall meter
  let _ = w f (cat ["<p style='font-family:JetBrains Mono,monospace;font-size:14px;color:#e4e4e7;margin-bottom:8px'>Latest: <span style='color:#00ff41'>", latest_total, "</span> (", latest_pct, "%) &mdash; ", latest_date, "</p>"])
  let _ = w f "<div class='meter'>"
  let _ = w f (cat ["<div class='meter-fill' style='width:", latest_pct, "%;background:linear-gradient(90deg,#00ff4140,#00ff41)'>", latest_pct, "%</div>"])
  let _ = w f "</div>"
  let _ = w f "<div class='meter-labels'><span>0%</span><span>25%</span><span>50%</span><span>75%</span><span>100%</span></div>"

  -- Band breakdown from latest run
  let _ = w f "<h3 style='margin-top:40px;font-size:16px;color:#a1a1aa;margin-bottom:8px'>Band breakdown (latest run)</h3>"
  let _ = w f "<div class='bands'>"

  -- Use shell to compute bar width percentages (score/5 * 100)
  let fund_w = trim (shell (cat ["echo $((", fund_n, " * 20))"]))
  let io_w = trim (shell (cat ["echo $((", io_n, " * 20))"]))
  let tools_w = trim (shell (cat ["echo $((", tools_n, " * 20))"]))
  let comp_w = trim (shell (cat ["echo $((", comp_n, " * 20))"]))
  let adv_w = trim (shell (cat ["echo $((", adv_n, " * 20))"]))
  let comprehend_w = if length comprehend > 0 then trim (shell (cat ["echo $((", comprehend_n, " * 20))"])) else "0"

  let _ = w f (cat ["<div class='band'><div class='band-name'>Fundamentals</div><div class='band-score' style='color:#00ff41'>", fund, "</div><div class='band-bar'><div class='band-bar-fill' style='width:", fund_w, "%;background:#00ff41'></div></div></div>"])
  let _ = w f (cat ["<div class='band'><div class='band-name'>I/O</div><div class='band-score' style='color:#3b82f6'>", io, "</div><div class='band-bar'><div class='band-bar-fill' style='width:", io_w, "%;background:#3b82f6'></div></div></div>"])
  let _ = w f (cat ["<div class='band'><div class='band-name'>Tools</div><div class='band-score' style='color:#f97316'>", tools_s, "</div><div class='band-bar'><div class='band-bar-fill' style='width:", tools_w, "%;background:#f97316'></div></div></div>"])
  let _ = w f (cat ["<div class='band'><div class='band-name'>Composition</div><div class='band-score' style='color:#c084fc'>", comp, "</div><div class='band-bar'><div class='band-bar-fill' style='width:", comp_w, "%;background:#c084fc'></div></div></div>"])
  let _ = w f (cat ["<div class='band'><div class='band-name'>Advanced</div><div class='band-score' style='color:#facc15'>", adv, "</div><div class='band-bar'><div class='band-bar-fill' style='width:", adv_w, "%;background:#facc15'></div></div></div>"])
  let _ = if length comprehend > 0 then w f (cat ["<div class='band'><div class='band-name'>Comprehension</div><div class='band-score' style='color:#ec4899'>", comprehend, "</div><div class='band-bar'><div class='band-bar-fill' style='width:", comprehend_w, "%;background:#ec4899'></div></div></div>"]) else ""

  let _ = w f "</div></div></section>"

  -- HOW IT WORKS
  let _ = w f "<section><div class='wrap'>"
  let _ = w f "<h2>How it <span class='b'>works</span></h2>"
  let _ = w f "<p class='section-sub'>A four-stage loop. The compiler is the only judge.</p>"
  let _ = w f "<div class='grid' style='grid-template-columns:repeat(auto-fit,minmax(220px,1fr))'>"
  let _ = w f "<div class='card'><h3 style='color:#00ff41'>1. Generate</h3><p>LLM writes Rail code from a curriculum prompt (25 levels, 10 seeds each)</p></div>"
  let _ = w f "<div class='card'><h3 style='color:#3b82f6'>2. Compile</h3><p>rail_native compiles it. Exit code 0 = pass. The compiler is the oracle.</p></div>"
  let _ = w f "<div class='card'><h3 style='color:#f97316'>3. Harvest</h3><p>Passing examples become training data. SHA-256 dedup. ~4,059 verified examples.</p></div>"
  let _ = w f "<div class='card'><h3 style='color:#c084fc'>4. Train</h3><p>QLoRA on Qwen3.5-4B (Razer 3070). New adapter deployed to Mac Mini for inference.</p></div>"
  let _ = w f "</div>"

  -- Architecture detail
  let _ = w f "<div style='margin-top:32px;background:#0c0c0e;border:1px solid #1c1c1e;border-radius:8px;padding:28px'>"
  let _ = w f "<div style='font-family:JetBrains Mono,monospace;font-size:12px;color:#71717a;line-height:2'>"
  let _ = w f "<span style='color:#52525b'>Nodes:</span> Mac Mini M4 Pro (inference) + Razer 3070 (training)<br>"
  let _ = w f "<span style='color:#52525b'>Model:</span> Qwen3.5-4B &mdash; 32 layers (8 self-attention + 24 DeltaNet)<br>"
  let _ = w f "<span style='color:#52525b'>LoRA:</span> All 32 layers targeted (self_attn + DeltaNet projections)<br>"
  let _ = w f "<span style='color:#52525b'>Data:</span> 10 JSONL sources merged, SHA-256 dedup, 90/5/5 split<br>"
  let _ = w f "<span style='color:#52525b'>Bench:</span> 30 tasks, 6 bands, output-verified (bands 1-4)<br>"
  let _ = w f "<span style='color:#52525b'>Curriculum:</span> 25 levels, auto-advance at 80%+ for 3 consecutive rounds"
  let _ = w f "</div></div>"

  let _ = w f "</div></section>"

  -- FOOTER
  let _ = w f "<footer><span style='color:#00ff41'>&gt;</span> LEDATIC // flywheel<br><br>"
  let _ = w f "This page was generated by Rail, compiled by Rail.<br>"
  let _ = w f "<a href='/'>Home</a> &middot; <a href='/system'>System</a> &middot; <a href='https://github.com/zemo-g/rail'>GitHub</a>"
  let _ = w f "</footer></body></html>"

  let size = trim (shell (cat ["wc -c < ", f]))
  let _ = print (cat ["Generated: ", f, " (", size, " bytes)"])
  let _ = print "Deploy with: ./rail_native run tools/deploy/cf_deploy.rail /tmp/flywheel.html flywheel"
  0
