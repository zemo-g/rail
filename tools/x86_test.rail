-- Test program for x86_64 backend
-- Expected output on Linux x86_64:
--   42
--   30
--   3628800
--   300
--   99
--   hello world
--   1

add a b = a + b

fact n = if n <= 1 then 1 else n * fact (n - 1)

main =
  let _ = print 42
  let _ = print (add 10 20)
  let _ = print (fact 10)
  let x = 100 + 200
  let _ = print x
  let _ = print (show 99)
  let _ = print "hello world"
  let y = if 5 > 3 then 1 else 0
  let _ = print y
  0
