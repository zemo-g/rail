-- ckpt_test.rail — round-trip verification of stdlib/checkpoint.rail.
-- Train Adam XOR for 50 steps → save → reload into fresh model → forward pass
-- must match original forward pass bit-for-bit (well, within f32 tolerance).
import "stdlib/autograd.rail"
import "stdlib/optim.rail"
import "stdlib/checkpoint.rail"

make_xor_inputs _ =
  let x = tensor_new (cons 4 (cons 2 [])) 0.0
  let _ = tensor_set_flat x 0 0.0
  let _ = tensor_set_flat x 1 0.0
  let _ = tensor_set_flat x 2 1.0
  let _ = tensor_set_flat x 3 0.0
  let _ = tensor_set_flat x 4 0.0
  let _ = tensor_set_flat x 5 1.0
  let _ = tensor_set_flat x 6 1.0
  let _ = tensor_set_flat x 7 1.0
  x

init_w seed n m v0 =
  let t = tensor_new (cons n (cons m [])) 0.0
  let _ = tensor_set_flat t 0 v0
  let _ = tensor_set_flat t 1 (v0 * 2.0)
  t

predict w1 w2 x =
  let h = tensor_relu (matmul x w1)
  matmul h w2

main =
  let _ = print "=== checkpoint round-trip ==="
  let w1 = init_w 0 2 4 0.5
  let w2 = init_w 0 4 1 0.25

  let x = make_xor_inputs 0

  -- Mutate the weights with a few arbitrary writes to simulate "training".
  let _ = tensor_set_flat w1 0 0.75
  let _ = tensor_set_flat w1 3 (0.0 - 0.4)
  let _ = tensor_set_flat w2 0 0.6
  let _ = tensor_set_flat w2 2 (0.0 - 0.15)

  -- Forward pass before save.
  let y1 = predict w1 w2 x
  let y1_0 = tensor_get_flat y1 0
  let y1_3 = tensor_get_flat y1 3
  let _ = print "before save:"
  let _ = print (show_float y1_0)
  let _ = print (show_float y1_3)

  -- Save.
  let params = cons w1 (cons w2 [])
  let _ = save_model "/tmp/rail_ckpt_test" params
  let _ = print "saved to /tmp/rail_ckpt_test.manifest + .0.f32 / .1.f32"

  -- Load into fresh list and forward pass.
  let loaded = load_model "/tmp/rail_ckpt_test"
  let w1b = head loaded
  let w2b = head (tail loaded)
  let y2 = predict w1b w2b x
  let y2_0 = tensor_get_flat y2 0
  let y2_3 = tensor_get_flat y2 3
  let _ = print "after load:"
  let _ = print (show_float y2_0)
  let _ = print (show_float y2_3)

  -- Validation: y1 and y2 should match to f32 tolerance (~1e-6).
  let _ = print "\ndelta 0 and 3 (expect ~0):"
  let d0 = y1_0 - y2_0
  let d3 = y1_3 - y2_3
  let _ = print (show_float d0)
  let _ = print (show_float d3)

  let _ = print "\n=== done ==="
  0
