-- tokenizer_test.rail — round-trip verification of stdlib/tokenizer.rail.
-- Success criteria: encode(decode(x)) == x for a corpus >10k characters.
import "stdlib/tokenizer.rail"

-- Repeat a string k times, building a corpus large enough to exercise
-- the encoder/decoder on >10k characters without requiring any external
-- dataset.
repeat_cat s k acc =
  if k == 0 then acc
  else repeat_cat s (k - 1) (cat [acc, s])

-- Confirm two strings are byte-identical by comparing their chars list.
eq_chars_loop xs ys =
  if length xs == 0 then length ys == 0
  else if length ys == 0 then false
  else if head xs == head ys then eq_chars_loop (tail xs) (tail ys)
  else false

eq_str a b = eq_chars_loop (chars a) (chars b)

main =
  let seed = "The quick brown fox jumps over the lazy dog.\nShakespeare said: 'To be, or not to be.'\n"
  -- 88 chars × 120 = 10,560 characters — comfortably past the 10k bar.
  let corpus = repeat_cat seed 120 ""
  let n = length (chars corpus)
  let _ = print (cat ["corpus length (chars): ", show n])

  let vocab = build_vocab corpus
  let _ = print (cat ["vocab size: ", show (vocab_size vocab)])

  let ids = encode vocab corpus
  let _ = print (cat ["encoded ids: ", show (length ids)])

  let back = decode vocab ids
  let _ = print (cat ["decoded length: ", show (length (chars back))])

  let match_ok = eq_str corpus back
  let verdict = if match_ok then "PASS: round-trip exact" else "FAIL: round-trip diverged"
  let _ = print verdict

  -- Spot-check a few ids map to the right characters.
  let _ = print (cat ["id of 'T': ", show (char_id vocab "T")])
  let _ = print (cat ["id of ' ': ", show (char_id vocab " ")])
  let _ = print (cat ["char at id 0: ", id_char vocab 0])
  0
