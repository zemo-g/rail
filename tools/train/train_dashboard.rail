-- train_dashboard.rail — Steezy self-training dashboard
-- Generates interactive HTML with tunables, controls, live stats
-- Paired with dashboard.sh for HTTP serving
-- Usage: ./rail_native run tools/train/train_dashboard.rail

cat parts = join "" parts
trim s = head (split "\n" s)
html_esc s = join "&amp;" (split "&" (join "&lt;" (split "<" (join "&gt;" (split ">" s)))))

read_kv content key =
  let lines = split "\n" content
  rkv lines key
rkv lines key =
  if length lines == 0 then "0"
  else
    let parts = split "=" (head lines)
    if length parts >= 2 then
      if head parts == key then head (tail parts) else rkv (tail lines) key
    else rkv (tail lines) key

pi s = pia (chars s) 0
pia cs a =
  if length cs == 0 then a
  else
    let c = head cs
    let d = if c == "1" then 1 else if c == "2" then 2 else if c == "3" then 3 else if c == "4" then 4 else if c == "5" then 5 else if c == "6" then 6 else if c == "7" then 7 else if c == "8" then 8 else if c == "9" then 9 else 0
    if c == "0" then pia (tail cs) (a * 10) else if d > 0 then pia (tail cs) (a * 10 + d) else a

take_last xs n = if length xs <= n then xs else take_last (tail xs) n

log_row line =
  let hr = length (split "rate=" line) > 1
  let rp = if hr then head (tail (split "rate=" line)) else "0%"
  let r = head (split "%" rp)
  let c = if r == "0" then "rd" else if r == "100" then "gn" else if length r == 2 then (if head (chars r) == "8" then "gn" else if head (chars r) == "9" then "gn" else "yl") else "yl"
  cat ["<div class=lr><span class=\"dot ", c, "\"></span><span class=lt>", rp, "</span><span class=ll>", line, "</span></div>"]

dots lv =
  cat [if lv >= 1 then "<div class=\"ld a1\"><span>1</span><div class=ln>Basic</div></div>" else "<div class=ld><span>1</span><div class=ln>Basic</div></div>",
       if lv >= 2 then "<div class=\"ld a2\"><span>2</span><div class=ln>Lists</div></div>" else "<div class=ld><span>2</span><div class=ln>Lists</div></div>",
       if lv >= 3 then "<div class=\"ld a3\"><span>3</span><div class=ln>ADTs</div></div>" else "<div class=ld><span>3</span><div class=ln>ADTs</div></div>",
       if lv >= 4 then "<div class=\"ld a4\"><span>4</span><div class=ln>Compose</div></div>" else "<div class=ld><span>4</span><div class=ln>Compose</div></div>",
       if lv >= 5 then "<div class=\"ld a5\"><span>5</span><div class=ln>Algo</div></div>" else "<div class=ld><span>5</span><div class=ln>Algo</div></div>"]

sel name val opt lbl = cat ["<option ", if val == opt then "selected " else "", "value=", opt, ">", lbl, "</option>"]

main =
  let _ = shell "touch training/self_train/progress.txt training/self_train/log.txt training/self_train/harvest.jsonl training/self_train/goals.txt training/self_train/config.txt"
  let p = read_file "training/self_train/progress.txt"
  let rd = read_kv p "round"
  let ls = read_kv p "level"
  let hv = read_kv p "harvested"
  let sr = read_kv p "since_retrain"
  let goals = read_file "training/self_train/goals.txt"
  let cfg = read_file "training/self_train/config.txt"
  let cfg_lr = if length cfg > 0 then read_kv cfg "lr" else "1e-5"
  let cfg_iters = if length cfg > 0 then read_kv cfg "iters" else "2000"
  let cfg_retrain = if length cfg > 0 then read_kv cfg "retrain_at" else "200"
  let cfg_layers = if length cfg > 0 then read_kv cfg "layers" else "16"
  let cfg_attempts = if length cfg > 0 then read_kv cfg "attempts" else "5"
  let cfg_retries = if length cfg > 0 then read_kv cfg "retries" else "3"
  let lc = read_file "training/self_train/log.txt"
  let ll = if length lc == 0 then [] else filter (\l -> length l > 3) (take_last (split "\n" lc) 20)
  let hc = trim (shell "wc -l < training/self_train/harvest.jsonl 2>/dev/null || echo 0")
  let run = trim (shell "pgrep -f self_train > /dev/null 2>&1 && echo yes || echo no")
  let lv = pi ls
  let s = pi sr
  let rt = pi cfg_retrain
  let pct = if rt == 0 then 0 else if s > rt then 100 else s * 100 / rt
  let last_code = read_file "/tmp/rail_st_test.rail"
  let loc = trim (shell "wc -l < tools/compile.rail 2>/dev/null || echo ?")
  -- Smart stats from log
  let total_rounds = pi rd
  let total_harvested = pi hv
  let avg_per_round = if total_rounds > 0 then total_harvested / total_rounds else 0
  let rounds_to_retrain = if avg_per_round > 0 then (rt - s) / avg_per_round else 0
  -- Last round's pass rate
  let last_log = if length ll > 0 then head (reverse ll) else ""
  let last_rate = if length (split "rate=" last_log) > 1 then head (split "%" (head (tail (split "rate=" last_log)))) else "0"
  -- Level progress: need 2 consecutive rounds at 80%+ to advance
  let streak_count = count_streak ll 0
  -- Overall progress: level/5
  let overall_pct = lv * 100 / 5

  let html = cat ["<!DOCTYPE html><html><head><meta charset=utf-8><title>Rail Training</title><meta http-equiv=refresh content=5>",
    "<style>",
    ":root{--bg:#08090a;--card:#111214;--border:#1e2024;--text:#e2e4e8;--dim:#555a63;--blue:#4a9eff;--green:#34d399;--purple:#a78bfa;--orange:#fb923c;--red:#f87171;--cyan:#22d3ee;--glow:0 0 20px rgba(74,158,255,0.15)}",
    "*{margin:0;padding:0;box-sizing:border-box}",
    "body{font-family:-apple-system,SF Pro Display,system-ui,sans-serif;background:var(--bg);color:var(--text);padding:20px 24px;max-width:620px;margin:0 auto;line-height:1.4}",
    "h1{font-size:22px;font-weight:700;background:linear-gradient(135deg,var(--blue),var(--purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent}",
    ".hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}",
    ".badge{display:flex;align-items:center;gap:6px;font-size:12px;padding:4px 10px;border-radius:20px;border:1px solid var(--border)}",
    ".badge .pip{width:8px;height:8px;border-radius:50%;animation:pulse 2s infinite}",
    ".badge.on{border-color:var(--green)}.badge.on .pip{background:var(--green)}",
    ".badge.off{border-color:var(--red)}.badge.off .pip{background:var(--red)}",
    "@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}",
    ".cards{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}",
    ".card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px 10px;text-align:center;transition:all 0.3s}",
    ".card:hover{border-color:var(--blue);box-shadow:var(--glow)}",
    ".card .v{font-size:30px;font-weight:800;font-family:SF Mono,ui-monospace,monospace;letter-spacing:-1px}",
    ".card .l{font-size:10px;color:var(--dim);margin-top:4px;text-transform:uppercase;letter-spacing:1px}",
    ".sec{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px;margin-bottom:12px;transition:all 0.3s}",
    ".sec:hover{border-color:var(--blue);box-shadow:var(--glow)}",
    ".sec h2{font-size:11px;font-weight:600;color:var(--dim);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px;display:flex;align-items:center;gap:6px}",
    ".sec h2::before{content:'';width:3px;height:12px;border-radius:2px;background:var(--blue)}",
    ".bar-o{height:8px;background:#1a1c20;border-radius:4px;overflow:hidden}",
    ".bar-f{height:100%;border-radius:4px;transition:width 0.8s;background:linear-gradient(90deg,var(--purple),var(--blue));position:relative}",
    ".bar-f::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent 60%,rgba(255,255,255,0.15));animation:shm 2s infinite linear}",
    "@keyframes shm{from{transform:translateX(-100%)}to{transform:translateX(100%)}}",
    ".level{display:flex;gap:12px;justify-content:center;margin:16px 0 8px}",
    ".ld{width:48px;text-align:center;opacity:0.3;transition:all 0.3s}",
    ".ld span{display:flex;width:32px;height:32px;border-radius:50%;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:var(--dim);background:#1a1c20;border:2px solid var(--border);margin:0 auto 4px;transition:all 0.3s}",
    ".ld .ln{font-size:9px;color:var(--dim);text-transform:uppercase;letter-spacing:0.5px}",
    ".ld.a1,.ld.a2,.ld.a3,.ld.a4,.ld.a5{opacity:1}",
    ".ld.a1 span{background:var(--green);color:#000;border-color:var(--green);box-shadow:0 0 12px rgba(52,211,153,0.4)}",
    ".ld.a2 span{background:var(--blue);color:#fff;border-color:var(--blue);box-shadow:0 0 12px rgba(74,158,255,0.4)}",
    ".ld.a3 span{background:var(--purple);color:#fff;border-color:var(--purple);box-shadow:0 0 12px rgba(167,139,250,0.4)}",
    ".ld.a4 span{background:var(--orange);color:#000;border-color:var(--orange);box-shadow:0 0 12px rgba(251,146,60,0.4)}",
    ".ld.a5 span{background:var(--red);color:#fff;border-color:var(--red);box-shadow:0 0 12px rgba(248,113,113,0.4)}",
    "textarea{width:100%;background:#0c0d0f;color:#ccc;border:1px solid var(--border);border-radius:8px;padding:12px;font-size:12px;font-family:SF Mono,ui-monospace,monospace;resize:vertical;min-height:80px;line-height:1.6;transition:border-color 0.3s}",
    "textarea:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 3px rgba(74,158,255,0.1)}",
    "button{padding:8px 16px;border-radius:8px;border:1px solid var(--border);font-size:12px;font-weight:600;cursor:pointer;transition:all 0.2s;background:var(--card);color:var(--text)}",
    "button:hover{border-color:var(--blue);box-shadow:var(--glow)}",
    ".bg{background:var(--green);color:#000;border-color:var(--green)}.bs{background:var(--red);color:#fff;border-color:var(--red)}",
    ".bv{background:var(--blue);color:#fff;border-color:var(--blue)}.bp{background:var(--purple);color:#fff;border-color:var(--purple)}",
    ".lr{display:flex;align-items:center;gap:8px;padding:3px 0;font-size:11px;font-family:SF Mono,ui-monospace,monospace}",
    ".lr .dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}",
    ".lr .lt{min-width:36px;font-weight:600}.lr .ll{color:var(--dim);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}",
    ".gn{background:var(--green)}.yl{background:#eab308}.rd{background:var(--red)}",
    ".tunable{display:grid;grid-template-columns:1fr 1fr;gap:8px}",
    ".tf{display:flex;flex-direction:column;gap:3px}",
    ".tf label{font-size:10px;color:var(--dim);text-transform:uppercase;letter-spacing:0.5px}",
    ".tf select{background:#0c0d0f;color:var(--text);border:1px solid var(--border);border-radius:6px;padding:6px 8px;font-size:12px;font-family:SF Mono,ui-monospace,monospace}",
    ".tf select:focus{outline:none;border-color:var(--blue)}",
    ".preview{background:#0c0d0f;border:1px solid var(--border);border-radius:8px;padding:10px;font-size:11px;font-family:SF Mono,ui-monospace,monospace;color:#888;max-height:120px;overflow:auto;white-space:pre-wrap;line-height:1.5}",
    ".tag{display:inline-block;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:600;border:1px solid var(--border);margin:2px}",
    "</style></head><body>",

    -- Header
    "<div class=hdr><div><h1>Rail Self-Training</h1><div style=\"font-size:11px;color:var(--dim);margin-top:2px\">Compiler is the oracle</div></div>",
    "<div style=\"display:flex;gap:8px;align-items:center\">",
    "<div class=\"badge ", if run == "yes" then "on" else "off", "\"><div class=pip></div>", if run == "yes" then "Live" else "Idle", "</div>",
    "<button class=bg onclick=\"fetch('/?start').catch(()=>{})\">Start</button>",
    "<button class=bs onclick=\"fetch('/?stop').catch(()=>{})\">Stop</button>",
    "</div></div>",

    -- Cards
    "<div class=cards>",
    "<div class=card><div class=v id=v-round style=\"color:var(--blue)\">", rd, "</div><div class=l>Round</div></div>",
    "<div class=card><div class=v id=v-harvested style=\"color:var(--green)\">", hv, "</div><div class=l>Harvested</div></div>",
    "<div class=card><div class=v id=v-retrain style=\"color:var(--purple)\">", sr, "</div><div class=l>To Retrain</div></div>",
    "<div class=card><div class=v id=v-jsonl style=\"color:var(--cyan)\">", hc, "</div><div class=l>JSONL</div></div></div>",

    -- Smart progress section
    "<div class=sec><h2>Progress</h2>",
    -- Overall mastery
    "<div style=\"display:flex;justify-content:space-between;align-items:center;margin-bottom:8px\">",
    "<span style=\"font-size:10px;color:var(--dim)\">MASTERY</span>",
    "<span style=\"font-size:12px;font-weight:700;color:var(--blue)\">Level ", show lv, "/5</span></div>",
    "<div class=bar-o><div class=bar-f style=\"width:", show overall_pct, "%;background:linear-gradient(90deg,var(--green),var(--blue),var(--purple))\"></div></div>",

    -- Level advancement streak
    "<div style=\"display:flex;justify-content:space-between;align-items:center;margin-top:12px;margin-bottom:6px\">",
    "<span style=\"font-size:10px;color:var(--dim)\">ADVANCE STREAK</span>",
    "<span style=\"font-size:11px;color:", if streak_count >= 2 then "var(--green)" else "var(--dim)", "\">", show streak_count, "/2 rounds at 80%+",
    if streak_count >= 2 then " — READY" else "", "</span></div>",
    "<div class=bar-o style=height:6px><div class=bar-f style=\"width:", show (streak_count * 50), "%;background:", if streak_count >= 2 then "var(--green)" else "var(--orange)", "\"></div></div>",

    -- Retrain countdown
    "<div style=\"display:flex;justify-content:space-between;align-items:center;margin-top:12px;margin-bottom:6px\">",
    "<span style=\"font-size:10px;color:var(--dim)\">RETRAIN</span>",
    "<span style=\"font-size:11px;color:", if pct >= 90 then "var(--orange)" else "var(--dim)", "\">", sr, "/", cfg_retrain,
    if avg_per_round > 0 then cat [" — ~", show rounds_to_retrain, " rounds"] else "",
    "</span></div>",
    "<div class=bar-o style=height:6px><div class=bar-f style=\"width:", show pct, "%;background:", if pct >= 90 then "var(--orange)" else "var(--purple)", "\"></div></div>",

    -- Last round rate
    "<div style=\"display:flex;justify-content:space-between;align-items:center;margin-top:12px\">",
    "<span style=\"font-size:10px;color:var(--dim)\">LAST ROUND</span>",
    "<span style=\"font-size:12px;font-weight:700;color:", if pi last_rate >= 80 then "var(--green)" else if pi last_rate >= 50 then "var(--orange)" else "var(--red)", "\">", last_rate, "%</span></div>",
    "<div class=bar-o style=height:6px><div class=bar-f style=\"width:", last_rate, "%;background:", if pi last_rate >= 80 then "var(--green)" else if pi last_rate >= 50 then "var(--orange)" else "var(--red)", "\"></div></div>",

    -- Harvest rate
    "<div style=\"display:flex;justify-content:space-between;margin-top:10px;font-size:10px;color:var(--dim)\">",
    "<span>~", show avg_per_round, " examples/round</span>",
    "<span>", hv, " total harvested</span></div>",
    "</div>",

    -- Curriculum dots
    "<div class=sec style=text-align:center><h2 style=justify-content:center>Curriculum</h2>",
    "<div class=level>", dots lv, "</div></div>",

    -- Goals
    "<div class=sec><h2>Goals</h2>",
    "<textarea id=goals rows=4 placeholder=\"One goal per line...\">", html_esc goals, "</textarea>",
    "<div style=\"display:flex;justify-content:space-between;align-items:center;margin-top:8px\">",
    "<span style=\"font-size:10px;color:var(--dim)\">Hot-reloads each round</span>",
    "<button class=bv onclick=\"fetch('/?savegoals='+encodeURIComponent(document.getElementById('goals').value)).catch(()=>{});this.textContent='Saved!';setTimeout(()=>this.textContent='Save Goals',1500)\">Save Goals</button></div></div>",

    -- Activity log
    "<div class=sec><h2>Activity</h2><div id=activity>",
    if length ll == 0 then "<div style=\"color:var(--dim);text-align:center;padding:16px\">No activity yet. Hit Start.</div>"
    else join "" (map log_row (reverse ll)),
    "</div></div>",

    -- Code preview
    if length last_code > 5 then
      cat ["<div class=sec><h2>Last Generated</h2><div class=preview>", html_esc (if length last_code > 500 then join "" (take_n (chars last_code) 500) else last_code), "</div></div>"]
    else "",

    -- Footer tags
    "<div style=\"text-align:center;padding:16px 0;font-size:10px;color:var(--dim)\">",
    "<span class=tag>Rail ", loc, " LOC</span>",
    "<span class=tag>", hc, " examples</span>",
    "<span class=tag>Qwen 9B + LoRA</span>",
    "<span class=tag>M4 Pro 24GB</span></div>",

    -- JS: poll /data every 5s, update stats in-place (no full reload)
    "<script>",
    "async function poll(){try{const r=await fetch('/data');const d=await r.json();",
    "document.getElementById('v-round').textContent=d.round;",
    "document.getElementById('v-harvested').textContent=d.harvested;",
    "document.getElementById('v-retrain').textContent=d.since_retrain;",
    "document.getElementById('v-jsonl').textContent=d.jsonl;",
    "document.getElementById('bar-retrain').style.width=d.pct+'%';",
    "document.getElementById('bar-label').textContent=d.since_retrain+' examples';",
    "if(d.activity){document.getElementById('activity').innerHTML=d.activity;}",
    "const b=document.querySelector('.badge');b.className='badge '+(d.running?'on':'off');",
    "b.querySelector('.pip').nextSibling.textContent=d.running?'Live':'Idle';",
    "}catch(e){}}",
    "setInterval(poll,5000);",
    "</script>",

    "</body></html>"]

  let _ = write_file "training/self_train/dashboard.html" html
  0

take_n lst n = if n <= 0 then [] else if length lst == 0 then [] else cons (head lst) (take_n (tail lst) (n - 1))

-- Count consecutive rounds with 80%+ pass rate (from end of log)
count_streak lines acc =
  if length lines == 0 then acc
  else
    let line = head (reverse lines)
    let has_rate = length (split "rate=" line) > 1
    let rp = if has_rate then head (tail (split "rate=" line)) else "0%"
    let r = pi (head (split "%" rp))
    if r >= 80 then count_streak (init_list lines) (acc + 1)
    else acc

init_list xs = if length xs <= 1 then [] else cons (head xs) (init_list (tail xs))
