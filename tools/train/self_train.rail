-- ══════════════════════════════════════════════════════════════════════════════
-- PROGRESS tracking
-- ══════════════════════════════════════════════════════════════════════════════

progress_file = "training/self_train/progress.txt"
harvest_file = "training/self_train/harvest.jsonl"
log_file = "training/self_train/log.txt"

read_progress dummy =
  let content = read_file progress_file
  if length content == 0 then (1, 1, 0, 0, 0, 0)
  else
    let lines = split "\n" content
    let round = parse_kv lines "round"
    let level = parse_kv lines "level"
    let harvested = parse_kv lines "harvested"
    let since_retrain = parse_kv lines "since_retrain"
    let consecutive_pass = parse_kv lines "consecutive_pass"
    let consecutive_zero = parse_kv lines "consecutive_zero"
    (round, level, harvested, since_retrain, consecutive_pass, consecutive_zero)

parse_kv lines key =
  if length lines == 0 then 0
  else
    let parts = split "=" (head lines)
    if length parts >= 2 then
      if head parts == key then to_int_safe (head (tail parts))
      else parse_kv (tail lines) key
    else parse_kv (tail lines) key

to_int_safe s =
  let trimmed = trim s
  parse_digits (chars trimmed) 0

parse_digits cs acc =
  if length cs == 0 then acc
  else
    let c = head cs
    let d = if c == "0" then 0 else if c == "1" then 1 else if c == "2" then 2 else if c == "3" then 3 else if c == "4" then 4 else if c == "5" then 5 else if c == "6" then 6 else if c == "7" then 7 else if c == "8" then 8 else if c == "9" then 9 else 0
    parse_digits (tail cs) (acc * 10 + d)

write_progress round level harvested since_retrain consecutive_pass consecutive_zero =
  write_file progress_file (cat [
    "round=", show round, "\n",
    "level=", show level, "\n",
    "harvested=", show harvested, "\n",
    "since_retrain=", show since_retrain, "\n",
    "consecutive_pass=", show consecutive_pass, "\n",
    "consecutive_zero=", show consecutive_zero, "\n"])

-- ══════════════════════════════════════════════════════════════════════════════
-- TASK SELECTION
-- ══════════════════════════════════════════════════════════════════════════════

-- Select tasks at given level from seed bank
select_tasks level all_tasks =
  filter (\t -> head (split "\t" t) == show level) all_tasks

-- Get task description from "level\ttask" format
task_desc t = head (tail (split "\t" t))

-- ══════════════════════════════════════════════════════════════════════════════
-- HARVEST — save successful (task, code) pairs
-- ══════════════════════════════════════════════════════════════════════════════

harvest task code =
  -- Deduplicate: check if this exact task already harvested (first 80 chars of code as fingerprint)
  let fingerprint = take_str code 80
  let already = trim (shell (cat ["grep -cF ", q, json_esc fingerprint, q, " ", harvest_file, " 2>/dev/null || echo 0"]))
  if already != "0" then
    let _ = print "    (duplicate — skipped)"
    0
  else
    -- Write 3 variants (different phrasings, same code)
    let _ = write_line harvest_file (entry task code)
    let _ = write_line harvest_file (entry (cat ["Implement in Rail: ", task]) code)
    let _ = write_line harvest_file (entry (cat ["Rail code for: ", task]) code)
    3

take_str s n =
  let cs = chars s
  join "" (take_n cs n)

-- ══════════════════════════════════════════════════════════════════════════════
-- RETRAIN — merge data + LoRA train + reload
-- ══════════════════════════════════════════════════════════════════════════════

retrain dummy =
  let _ = print "\n══ RETRAINING ══"
  -- Stop ALL MLX processes (pkill, not kill — prevents zombie servers)
  let _ = shell "pkill -9 -f 'mlx_lm' 2>/dev/null; sleep 2"
  -- Also stop launchd MLX services so they don't auto-restart
  let _ = shell "launchctl bootout gui/$(id -u)/com.ledatic.mlx 2>/dev/null; launchctl bootout gui/$(id -u)/com.ledatic.mlx_fast 2>/dev/null"
  -- Verify all MLX processes are dead
  let _ = shell "sleep 2"
  let alive = trim (shell "pgrep -f 'mlx_lm' 2>/dev/null | wc -l")
  let _ = if alive != "0" then
    let _ = print (cat ["  WARNING: ", alive, " MLX processes still alive, force killing..."])
    shell "pkill -9 -f 'mlx_lm' 2>/dev/null; sleep 3"
  else print "  MLX server stopped."
  -- Re-harvest git metadata (picks up any new commits since last retrain)
  let _ = print "  Harvesting git history..."
  let _ = shell "/opt/homebrew/bin/python3.11 ~/projects/rail/tools/train/harvest_git.py > /tmp/rail_harvest_git.log 2>&1"
  -- Merge all training data: original + self-harvest + git harvest
  let _ = shell "mkdir -p /tmp/rail_st_data"
  let _ = shell "cat ~/projects/rail/training/train.jsonl ~/projects/rail/training/self_train/harvest.jsonl ~/projects/rail/training/git_harvest.jsonl > /tmp/rail_st_merged.jsonl"
  let total = trim (shell "wc -l < /tmp/rail_st_merged.jsonl")
  let _ = print (cat ["  Merged training data: ", total, " examples"])
  -- 90/5/5 split
  let n = parse_digits (chars (trim total)) 0
  let train_n = n * 9 / 10
  let valid_n = n / 20
  let _ = shell (cat ["head -n ", show train_n, " /tmp/rail_st_merged.jsonl > /tmp/rail_st_data/train.jsonl"])
  let _ = shell (cat ["tail -n +", show (train_n + 1), " /tmp/rail_st_merged.jsonl | head -n ", show valid_n, " > /tmp/rail_st_data/valid.jsonl"])
  let _ = shell (cat ["tail -n +", show (train_n + valid_n + 1), " /tmp/rail_st_merged.jsonl > /tmp/rail_st_data/test.jsonl"])
  let _ = print (cat ["  Split: ", show train_n, " train / ", show valid_n, " valid / ", show (n - train_n - valid_n), " test"])
  -- LoRA train
  let _ = print "  Starting LoRA training (this takes ~30 min)..."
  let train_out = shell "/Users/ledaticempire/homebrew/bin/python3.11 -m mlx_lm lora --model /Users/ledaticempire/models/Qwen3.5-9B-6bit --train --data /tmp/rail_st_data/ --iters 2000 --batch-size 1 --learning-rate 1e-5 --num-layers 16 --steps-per-report 200 --steps-per-eval 500 --save-every 1000 --max-seq-length 1024 --mask-prompt --adapter-path /Users/ledaticempire/projects/rail/training/adapters_st 2>&1"
  -- Verify training produced an adapter file
  let adapter_ok = trim (shell "test -f /Users/ledaticempire/projects/rail/training/adapters_st/adapters.safetensors && echo ok || echo fail")
  let _ = if adapter_ok == "fail" then
    let _ = print "  ERROR: LoRA training failed. Restarting server without adapter."
    let port = trim (shell "cat /tmp/rail_st_port.txt 2>/dev/null || echo 8080")
    shell (cat ["/Users/ledaticempire/homebrew/bin/python3.11 -m mlx_lm.server --model /Users/ledaticempire/models/Qwen3.5-9B-6bit --host 0.0.0.0 --port ", port, " --trust-remote-code --max-tokens 4096 > /tmp/mlx_st_server.log 2>&1 &"])
  else
    let _ = print "  Training complete. Starting server with new adapter..."
    let port = trim (shell "cat /tmp/rail_st_port.txt 2>/dev/null || echo 8080")
    shell (cat ["/Users/ledaticempire/homebrew/bin/python3.11 -m mlx_lm.server --model /Users/ledaticempire/models/Qwen3.5-9B-6bit --adapter-path /Users/ledaticempire/projects/rail/training/adapters_st --host 0.0.0.0 --port ", port, " --trust-remote-code --max-tokens 4096 > /tmp/mlx_st_server.log 2>&1 &"])
  -- Wait for server warmup and verify
  let _ = shell "sleep 15"
  let _ = wait_for_server 0
  0

-- Check if MLX server is alive (returns true/false)
check_server dummy =
  let port = trim (shell "cat /tmp/rail_st_port.txt 2>/dev/null || echo 8080")
  let check = trim (shell (cat ["curl -s -m 5 http://localhost:", port, "/v1/models 2>/dev/null | head -1"]))
  length check > 5

-- Wait for MLX server with retries
wait_for_server attempt =
  if attempt >= 6 then print "  WARNING: Server not responding after 60s — continuing anyway"
  else
    let port = trim (shell "cat /tmp/rail_st_port.txt 2>/dev/null || echo 8080")
    let check = trim (shell (cat ["curl -s -m 5 http://localhost:", port, "/v1/models 2>/dev/null | head -1"]))
    if length check > 5 then print (cat ["  Server ready: ", check])
    else
      let _ = print (cat ["  Waiting for server... (attempt ", show (attempt + 1), "/6)"])
      let _ = shell "sleep 10"
      wait_for_server (attempt + 1)

-- ══════════════════════════════════════════════════════════════════════════════
-- GOALS — read from training/self_train/goals.txt, steer task generation
-- ══════════════════════════════════════════════════════════════════════════════

goals_file = "training/self_train/goals.txt"

load_goals dummy =
  let content = read_file goals_file
  if length content == 0 then []
  else
    let lines = split "\n" content
    filter (\l -> if length l < 3 then false else head (chars l) != "#") lines

-- Pick a goal for this round (rotate based on round number)
pick_goal goals round =
  if length goals == 0 then ""
  else
    let idx = round % length goals
    nth_elem goals idx

nth_elem xs n = if n <= 0 then head xs else nth_elem (tail xs) (n - 1)

-- ══════════════════════════════════════════════════════════════════════════════
-- GENERATE NEW TASKS via LLM — steered by goals
-- ══════════════════════════════════════════════════════════════════════════════

generate_tasks level sys n =
  generate_tasks_with_goal level sys n ""

-- Generate ultimate tasks for goal grind mode (post level 10)
generate_hard_tasks sys n goal =
  let _ = print (cat ["  Generating ", show n, " ULTIMATE goal-grind tasks (level 10)..."])
  let prompt = cat ["Generate ", show n, " ULTIMATE programming task descriptions for Rail (a pure functional language). These are EXPERT-level tasks that build real, practical programs. Each task should be on its own line. Output ONLY task descriptions, one per line, no numbering.\n\nFOCUS GOAL: ", goal, "\n\nGenerate tasks that DIRECTLY implement aspects of this goal. Programs should use Rail's full capabilities: shell calls, file I/O, HTTP serving, JSON building, ADTs, closures, arena memory management.\n\nExamples of this difficulty:\n- Write a Rail program that implements a complete HTTP API server with routing, auth, and JSON responses\n- Write a Rail program that generates a multi-page website with navigation, CSS, and data from shell commands\n- Write a Rail program that implements a deploy pipeline reading config, building artifacts, uploading via curl\n- Write a Rail program that implements a bytecode compiler and VM for a small expression language\n- Write a Rail program that implements an LLM-powered agent with retry logic and file-based memory"]
  let response = llm_call sys prompt 3
  let lines = split "\n" response
  let tasks = filter (\l -> length l > 10) lines
  let _ = print (cat ["  Generated ", show (length tasks), " ultimate tasks for: ", goal])
  map (\t -> cat ["10\t", t]) tasks

generate_tasks_with_goal level sys n goal =
  let _ = print (cat ["  Generating ", show n, " new tasks at level ", show level, "..."])
  let goal_context = if goal == "" then "" else cat ["\n\nFOCUS GOAL: ", goal, "\nGenerate tasks that progress toward this goal. Each task should build skills needed for the goal."]
  let prompt = cat ["Generate ", show n, " programming task descriptions for Rail (a pure functional language). Level ", show level, "/25. Each task should be on its own line. Output ONLY task descriptions, one per line, no numbering.", goal_context, "\n\nLevel guide:\n1=basic arithmetic/print\n2=lists/recursion\n3=ADTs/closures\n4=multi-concept composition\n5=practical I/O (shell calls, read_file/write_file, JSON building, arg parsing)\n6=HTTP/networking (request/response parsing, JSON, routing, auth)\n7=real tools (site generators, dashboards, config parsers, deploy scripts)\n8=systems (arena memory, Result ADT errors, process management, retries)\n9=compiler patterns (bytecode VM, type inference, AST transforms, codegen)\n10=full programs (HTTP servers, deploy pipelines, LLM callers, monitors)\n11=API integration (GitHub/Cloudflare/Telegram APIs via curl, pagination, rate limiting)\n12=database (SQLite via shell, CRUD, migrations, aggregation, joins)\n13=data pipelines (ETL, JSONL transform, dedup, validation, batch processing)\n14=testing (test frameworks, property testing, regression, snapshot, fuzzing)\n15=concurrency (parallel shell, worker pools, timeouts, job schedulers)\n16=protocols (wire formats, serialization, message framing, event sourcing)\n17=code generation (generate Rail/.sh/.sql/.html from templates and schemas)\n18=self-modifying (feedback loops, adaptive config, A/B testing, curriculum)\n19=infrastructure (deploy pipelines, monitoring, alerting, auto-recovery, cron)\n20=language tooling (Rail formatter, linter, REPL, doc generator, test runner)\n21=distributed (heartbeat, sync, leader election, gossip, fleet aggregation)\n22=AI/ML integration (LLM calls, prompt chaining, agent loops, RAG, evaluation)\n23=compiler extensions (Rail lexer/parser, type checker, optimizer, codegen)\n24=meta-compilation (fuzzer, benchmarks, error improvement, compile cache)\n25=self-improvement (training analysis, curriculum optimization, active learning)"]
  let response = llm_call sys prompt 2
  let lines = split "\n" response
  let tasks = filter (\l -> length l > 10) lines
  let _ = print (cat ["  Generated ", show (length tasks), " tasks"])
  let _ = if goal != "" then print (cat ["  Goal: ", goal]) else 0
  map (\t -> cat [show level, "\t", t]) tasks

-- ══════════════════════════════════════════════════════════════════════════════
-- MAIN LOOP
-- ══════════════════════════════════════════════════════════════════════════════

get_flag argv flag def =
  if length argv == 0 then def
  else if head argv == flag then
    if length (tail argv) > 0 then head (tail argv)
    else def
  else get_flag (tail argv) flag def

main =
  -- Parse CLI: --port PORT (default 8080), --no-retrain
  let port = get_flag args "--port" "8080"
  let no_retrain = get_flag args "--no-retrain" "no"
  let _ = write_file "/tmp/rail_st_port.txt" port
  let _ = write_file "/tmp/rail_st_no_retrain.txt" (if no_retrain != "no" then "yes" else "no")
  let _ = print "=== RAIL SELF-TRAINING LOOP ==="
  let _ = print (cat ["  Port: ", port, if no_retrain != "no" then " (no-retrain)" else ""])

  let sys = mk_sys 0

  -- Load progress first so we know which level to load
  let (round, level, harvested, since_retrain, saved_cp, saved_cz) = read_progress 0
  let _ = print (cat ["  Resuming: round=", show round, " level=", show level, " harvested=", show harvested, " since_retrain=", show since_retrain, " cp=", show saved_cp, " cz=", show saved_cz])

  -- Only load seed tasks for current level (saves arena memory)
  let tasks = seeds_for level
  let _ = print (cat ["  Seed tasks at level ", show level, ": ", show (length tasks)])

  -- Load goals
  let goals = load_goals 0
  let _ = print (cat ["  Goals: ", show (length goals)])
  let _ = if length goals > 0 then
    let _ = map (\g -> print (cat ["    • ", g])) goals
    0
  else print "    (none — add goals to training/self_train/goals.txt)"

  -- Run the loop (restore persisted curriculum counters)
  run_loop sys tasks goals round level harvested since_retrain saved_cp saved_cz

run_loop sys all_tasks goals round level harvested since_retrain consecutive_pass consecutive_zero =
  let _ = print (cat ["\n════ ROUND ", show round, " (level ", show level, " cp=", show consecutive_pass, " cz=", show consecutive_zero, ") ════"])

  -- Health-check MLX server before wasting a round
  let server_ok = check_server 0
  if server_ok == false then
    let _ = print "  ⚠ MLX server not responding — waiting 30s then retrying..."
    let _ = shell "sleep 30"
    let _ = write_progress round level harvested since_retrain consecutive_pass consecutive_zero
    run_loop sys all_tasks goals round level harvested since_retrain consecutive_pass consecutive_zero
  else

  -- Pick this round's goal (rotates through goals list)
  let goal = pick_goal goals round
  let _ = if goal != "" then print (cat ["  Focus: ", goal]) else 0

  -- Select tasks at current level
  let level_tasks = select_tasks level all_tasks
  let _ = print (cat ["  Tasks at level ", show level, ": ", show (length level_tasks)])

  -- Always generate fresh tasks (seeds are a starting point, not the whole diet)
  let fresh_tasks = generate_tasks_with_goal level sys 10 goal
  let level_tasks = if length level_tasks == 0 then fresh_tasks
    else append level_tasks fresh_tasks

  -- Run up to 10 tasks this round (use arena mark/reset if available)
  let batch = take_n level_tasks 10
  let (pass, fail, new_harvested) = run_batch sys batch 0 0 0

  let pass_rate = if (pass + fail) > 0 then pass * 100 / (pass + fail) else 0

  let _ = print (cat ["\n  Round ", show round, " results: ", show pass, "/", show (pass + fail), " (", show pass_rate, "%)"])
  let _ = print (cat ["  New examples harvested: ", show new_harvested])

  -- Update totals
  let harvested = harvested + new_harvested
  let since_retrain = since_retrain + new_harvested

  -- Log
  let _ = write_line log_file (cat ["round=", show round, " level=", show level, " pass=", show pass, "/", show (pass + fail), " rate=", show pass_rate, "% harvested=", show harvested])

  -- Check curriculum advancement (up) or fallback (down)
  let consecutive_pass = if pass_rate >= 80 then consecutive_pass + 1 else 0
  let consecutive_zero = if pass_rate == 0 then consecutive_zero + 1 else 0

  -- Save progress with counters BEFORE retrain (so we don't lose state if retrain crashes)
  let _ = write_progress round level harvested since_retrain consecutive_pass consecutive_zero

  -- Check retrain trigger (skip if --no-retrain flag set)
  let no_retrain = trim (shell "cat /tmp/rail_st_no_retrain.txt 2>/dev/null || echo no")
  let since_retrain = if no_retrain == "yes" then since_retrain
    else if since_retrain >= 200 then
      let _ = retrain 0
      let _ = print "  Adapter reloaded. Continuing with improved model."
      0
    else since_retrain

  let (level, consecutive_pass, consecutive_zero, all_tasks) = if consecutive_pass >= 2 then
    let new_level = level + 1
    let _ = print (cat ["\n  ★ ADVANCING to level ", show new_level, "!"])
    if new_level > 25 then
      let _ = print "\n  ★★★ ALL 25 LEVELS MASTERED — entering goal grind mode ★★★"
      let goal = pick_goal goals round
      let _ = print (cat ["  Grinding goal: ", goal])
      let new_tasks = generate_hard_tasks sys 10 goal
      (25, 0, 0, new_tasks)
    else
      let goal = pick_goal goals round
      -- Load seed tasks for new level + generate extras
      let seeds = seeds_for new_level
      let new_tasks = generate_tasks_with_goal new_level sys 10 goal
      (new_level, 0, 0, append seeds new_tasks)
  else if consecutive_zero >= 3 then
    -- FALLBACK: 3 consecutive 0% rounds — drop back one level
    let fallback_level = if level > 1 then level - 1 else 1
    let _ = print (cat ["\n  ⚠ PLATEAU DETECTED — 3 rounds at 0%. Falling back to level ", show fallback_level])
    let goal = pick_goal goals round
    let seeds = seeds_for fallback_level
    let new_tasks = generate_tasks_with_goal fallback_level sys 10 goal
    (fallback_level, 0, 0, append seeds new_tasks)
  else (level, consecutive_pass, consecutive_zero, all_tasks)

  -- Reload goals each round (user can edit mid-run)
  let goals = load_goals 0

  -- Save progress with updated counters
  let _ = write_progress round level harvested since_retrain consecutive_pass consecutive_zero

  -- Continue forever
  run_loop sys all_tasks goals (round + 1) level harvested since_retrain consecutive_pass consecutive_zero

-- Process a batch of tasks
run_batch sys tasks pass fail new_harvested =
  if length tasks == 0 then (pass, fail, new_harvested)
  else
    let task_line = head tasks
    let desc = task_desc task_line
    let _ = print (cat ["\n  → ", desc])

    -- Reset arena to prevent accumulation
    let m = arena_mark 0

    let (code, result) = try_task sys desc
    let _ = arena_reset m

    if result == "success" then
      let _ = print "    ✓ PASS"
      let n = harvest desc code
      run_batch sys (tail tasks) (pass + 1) fail (new_harvested + n)
    else
      let _ = print (cat ["    ✗ FAIL (", result, ")"])
      run_batch sys (tail tasks) pass (fail + 1) new_harvested

take_n lst n = if n <= 0 then [] else if length lst == 0 then [] else cons (head lst) (take_n (tail lst) (n - 1))
