-- self_train.rail — Rail trains itself to write better Rail
-- The compiler is the oracle. Generate → Compile → Harvest → Retrain → Repeat.
-- Usage: cd ~/projects/rail && ./rail_native run tools/train/self_train.rail
--
-- Requires: MLX server on :8080 with LoRA adapter loaded
--   /Users/ledaticempire/homebrew/bin/python3.11 -m mlx_lm.server \
--     --model /Users/ledaticempire/models/Qwen3.5-9B-6bit \
--     --adapter-path training/adapters_st \
--     --host 0.0.0.0 --port 8080 --trust-remote-code --max-tokens 4096

cat parts = join "" parts
trim s = head (split "\n" s)

-- ══════════════════════════════════════════════════════════════════════════════
-- JSON / JSONL helpers (from build_training_data.rail)
-- ══════════════════════════════════════════════════════════════════════════════

q = "\""
json_esc_bs s = join "\\\\" (split "\\" s)
json_esc_q s = join "\\\"" (split "\"" s)
json_esc_nl s = join "\\n" (split "\n" s)
json_esc_tab s = join "\\t" (split "\t" s)
json_esc s = json_esc_tab (json_esc_nl (json_esc_q (json_esc_bs s)))

sys_prompt = "You are a Rail language expert. Rail is a pure functional language that compiles to native ARM64 and Metal GPU shaders. Write correct Rail code."

entry usr asst =
  cat ["{", q, "messages", q, ":[",
    "{", q, "role", q, ":", q, "system", q, ",", q, "content", q, ":", q, json_esc sys_prompt, q, "},",
    "{", q, "role", q, ":", q, "user", q, ",", q, "content", q, ":", q, json_esc usr, q, "},",
    "{", q, "role", q, ":", q, "assistant", q, ",", q, "content", q, ":", q, json_esc asst, q, "}]}"]

write_line file text =
  let _ = write_file "/tmp/rail_st_line.txt" (cat [text, "\n"])
  shell (cat ["cat /tmp/rail_st_line.txt >> ", file])

-- ══════════════════════════════════════════════════════════════════════════════
-- LLM interface
-- ══════════════════════════════════════════════════════════════════════════════

mk_sys dummy =
  let grammar = read_file "grammar/rail.ebnf"
  cat ["You are a Rail language expert. Rail compiles to native ARM64.\n\nGRAMMAR:\n", grammar, "\n\nCRITICAL RULES:\n- Functions: name params = body (top-level only, no 'let rec')\n- Let uses NEWLINES not 'in': let x = 5\\n  x + 1\n- If: if cond then a else b (always both branches)\n- Match: match expr | Pat args -> expr (NO 'with', NO '::')\n- Lambda: \\x -> expr (single arg only)\n- Lists: [1,2,3], head, tail, cons, map, filter, fold, length, reverse, range\n- Tuples: (a,b), let (x,y) = expr\n- ADTs: type T = | A x | B\\nmatch val | A x -> ... | B -> ...\n- Strings: \"hello\", NO char literals (no 'a'), NO string indexing\n- print outputs value, show converts int to string\n- join sep list, split sep str, chars str, append str1 str2\n- main must exist and return an int\n- Use let _ = print expr for side effects\n- NO: let rec, match...with, x::xs, [x], arr[i], where, in (at end of let)"]

-- Native LLM call via builtin
-- Port read from /tmp/rail_st_port.txt (written by main from --port arg)
llm_call sys_msg user_msg temp =
  let port = trim (shell "cat /tmp/rail_st_port.txt 2>/dev/null || echo 8080")
  llm port sys_msg user_msg

-- ══════════════════════════════════════════════════════════════════════════════
-- Compile + Run verification
-- ══════════════════════════════════════════════════════════════════════════════

-- Returns: "success", "compile_fail", "runtime_fail", "timeout"
verify code =
  let _ = write_file "/tmp/rail_st_test.rail" code
  let _ = shell "rm -f /tmp/rail_st_bin"
  let compile_out = shell "cd ~/projects/rail && ./rail_native /tmp/rail_st_test.rail 2>&1 && cp /tmp/rail_out /tmp/rail_st_bin 2>&1"
  let check = trim (shell "test -f /tmp/rail_st_bin && echo ok || echo fail")
  if check == "fail" then "compile_fail"
  else
    let run_out = shell "perl -e 'alarm 5; exec @ARGV' /tmp/rail_st_bin 2>&1; echo $?"
    let lines = split "\n" run_out
    let exit_code = last_nonempty lines
    if exit_code == "0" then "success"
    else if exit_code == "142" then "timeout"
    else "runtime_fail"

last_nonempty xs =
  if length xs == 0 then ""
  else if length xs == 1 then head xs
  else
    let last = last_nonempty (tail xs)
    if last == "" then head xs else last

-- Generate with retry loop (up to 3 attempts with compiler feedback)
gen_with_retry sys task prev_err attempt temp =
  if attempt > 3 then ("", "compile_fail")
  else
    let user = if prev_err == "" then
      cat [task, "\n\nOutput ONLY Rail code. No markdown, no explanation. Functions before main."]
    else
      cat [task, "\n\nYour previous attempt failed:\n", prev_err, "\n\nFix the errors. Output ONLY Rail code."]
    let code = llm_call sys user temp
    let result = verify code
    if result == "success" then (code, "success")
    else if result == "compile_fail" then
      let err_out = trim (shell "cat /tmp/rail_st_test.rail 2>/dev/null | head -5")
      gen_with_retry sys task (cat ["Compile error for:\n", err_out]) (attempt + 1) temp
    else (code, result)

-- Try N attempts with varying temperature
try_task sys task =
  try_task_n sys task 1

try_task_n sys task temp =
  if temp > 5 then ("", "all_failed")
  else
    let (code, result) = gen_with_retry sys task "" 1 temp
    if result == "success" then (code, "success")
    else try_task_n sys task (temp + 1)

-- Per-level seed functions — only allocate strings for the requested level
seeds_for level =
  if level == 1 then seeds_1 0
  else if level == 2 then seeds_2 0
  else if level == 3 then seeds_3 0
  else if level == 4 then seeds_4 0
  else if level == 5 then seeds_5 0
  else if level == 6 then seeds_6 0
  else if level == 7 then seeds_7 0
  else if level == 8 then seeds_8 0
  else if level == 9 then seeds_9 0
  else if level == 10 then seeds_10 0
  else if level == 11 then seeds_11 0
  else if level == 12 then seeds_12 0
  else if level == 13 then seeds_13 0
  else if level == 14 then seeds_14 0
  else if level == 15 then seeds_15 0
  else if level == 16 then seeds_16 0
  else if level == 17 then seeds_17 0
  else if level == 18 then seeds_18 0
  else if level == 19 then seeds_19 0
  else if level == 20 then seeds_20 0
  else if level == 21 then seeds_21 0
  else if level == 22 then seeds_22 0
  else if level == 23 then seeds_23 0
  else if level == 24 then seeds_24 0
  else if level == 25 then seeds_25 0
  else []

