-- harvest_git.rail — Extract training data from Rail's git history
-- For each commit that added/modified .rail files, creates training pairs.
-- Also harvests stdlib and test files as training data.
--
-- Usage: cd ~/projects/rail && ./rail_native run tools/train/harvest_git.rail
-- Output: training/git_harvest.jsonl

cat parts = join "" parts
trim s = head (split "\n" s)
q = "\""

-- ══════════════════════════════════════════════════════════════════════════════
-- JSON helpers
-- ══════════════════════════════════════════════════════════════════════════════

json_esc_bs s = join "\\\\" (split "\\" s)
json_esc_q s = join "\\\"" (split "\"" s)
json_esc_nl s = join "\\n" (split "\n" s)
json_esc_tab s = join "\\t" (split "\t" s)
json_esc s = json_esc_tab (json_esc_nl (json_esc_q (json_esc_bs s)))

make_entry sys_msg user_msg asst_msg =
  cat ["{", q, "messages", q, ":[{",
    q, "role", q, ":", q, "system", q, ",",
    q, "content", q, ":", q, json_esc sys_msg, q, "},{",
    q, "role", q, ":", q, "user", q, ",",
    q, "content", q, ":", q, json_esc user_msg, q, "},{",
    q, "role", q, ":", q, "assistant", q, ",",
    q, "content", q, ":", q, json_esc asst_msg, q, "}]}"]

-- ══════════════════════════════════════════════════════════════════════════════
-- System prompts
-- ══════════════════════════════════════════════════════════════════════════════

sys_prompt = "You are a Rail language expert. Rail is a pure functional language that compiles to native ARM64 and Metal GPU shaders. Write correct Rail code."
sys_compiler = "You are a Rail compiler engineer. Rail is a pure functional language that self-hosts its compiler (compile.rail). Write correct Rail compiler code."

output_file = "training/git_harvest.jsonl"

-- ══════════════════════════════════════════════════════════════════════════════
-- Harvest git commits
-- Uses a Python helper to do the heavy lifting of git log parsing + dedup
-- ══════════════════════════════════════════════════════════════════════════════

harvest_git_commits _ =
  let _ = print "--- Git commits ---"
  -- Write a Python helper that does git log parsing and outputs JSONL entries
  let _ = write_file "/tmp/rail_harvest_git.py" "import json, subprocess, os\nos.chdir(os.path.expanduser('~/projects/rail'))\n\nSYS_PROMPT = 'You are a Rail language expert. Rail is a pure functional language that compiles to native ARM64 and Metal GPU shaders. Write correct Rail code.'\nSYS_COMPILER = 'You are a Rail compiler engineer. Rail is a pure functional language that self-hosts its compiler (compile.rail). Write correct Rail compiler code.'\n\ndef run(cmd):\n    return subprocess.run(cmd, shell=True, capture_output=True, text=True).stdout.strip()\n\ndef entry(sys_msg, user_msg, asst_msg):\n    return json.dumps({'messages': [{'role': 'system', 'content': sys_msg}, {'role': 'user', 'content': user_msg}, {'role': 'assistant', 'content': asst_msg}]}, ensure_ascii=False)\n\nSKIP_FILES = {'tools/train/build_training_data.rail', 'tools/train/overfitting_test.rail'}\nTOOL_FILES = {\n    'tools/train/self_train.rail': 'a self-training loop where Rail trains itself using the compiler as an oracle',\n    'tools/apps/brain.rail': 'a brain/reasoning module',\n    'tools/gpu.rail': 'GPU dispatch for Metal compute shaders',\n    'tools/apps/llm_call.rail': 'an LLM API caller',\n    'tools/apps/speak.rail': 'a text-to-speech interface',\n    'tools/deploy/gen_site.rail': 'a static site generator',\n    'tools/deploy/cf_deploy.rail': 'a Cloudflare Workers deployment tool',\n    'tools/apps/dash_serve.rail': 'an HTTP dashboard server',\n    'tools/apps/http_serve.rail': 'an HTTP server',\n    'tools/deploy/flash_pi.rail': 'a Raspberry Pi flash and deploy tool',\n    'tools/apps/config_check.rail': 'a service configuration checker',\n    'tools/apps/services.rail': 'a service status checker',\n    'tools/deploy/update_site.rail': 'a site data updater',\n    'tools/train/train_dashboard.rail': 'a training dashboard with live metrics',\n}\n\nlog = run('git log --format=\"%H|%s\" --diff-filter=AM -- \"*.rail\"')\nentries = []\nseen_files = set()\ncount = 0\n\nfor line in log.split('\\n'):\n    if not line.strip(): continue\n    parts = line.split('|', 1)\n    if len(parts) < 2: continue\n    commit_hash, subject = parts[0], parts[1]\n    files_out = run(f'git diff-tree --no-commit-id -r --diff-filter=AM --name-only {commit_hash} -- \"*.rail\"')\n    for filepath in files_out.split('\\n'):\n        filepath = filepath.strip()\n        if not filepath.endswith('.rail'): continue\n        if filepath in SKIP_FILES: continue\n        if filepath in TOOL_FILES and filepath not in seen_files:\n            seen_files.add(filepath)\n            code = run(f'git show {commit_hash}:{filepath} 2>/dev/null')\n            if not code or len(code) < 50: continue\n            desc = TOOL_FILES[filepath]\n            sys_msg = SYS_COMPILER if 'compile' in filepath else SYS_PROMPT\n            entries.append(entry(sys_msg, f'Write a Rail program that implements {desc}', code))\n            count += 1\n            print(f'  + {filepath} ({len(code)} chars) -- tool')\n            continue\n        if filepath == 'tools/compile.rail':\n            diff = run(f'git show {commit_hash} -- {filepath} | head -200')\n            if len(diff) > 200:\n                entries.append(entry(SYS_COMPILER, f'Modify the Rail compiler: {subject}', diff))\n                count += 1\n                print(f'  + compile.rail diff -- {subject}')\n            continue\n        if filepath not in seen_files:\n            seen_files.add(filepath)\n            code = run(f'git show {commit_hash}:{filepath} 2>/dev/null')\n            if not code or len(code) < 30: continue\n            task = subject.replace('T2: ', '').replace('T1: ', '')\n            entries.append(entry(SYS_PROMPT, f'Write a Rail program: {task}', code))\n            count += 1\n            print(f'  + {filepath} ({len(code)} chars) -- {task}')\n\nwith open('/tmp/rail_git_entries.jsonl', 'w') as f:\n    for e in entries: f.write(e + '\\n')\nprint(f'  Git commits: {count} entries')\n"
  let result = trim (shell "cd ~/projects/rail && python3 /tmp/rail_harvest_git.py 2>&1")
  let _ = print result
  0

-- ══════════════════════════════════════════════════════════════════════════════
-- Harvest stdlib modules
-- ══════════════════════════════════════════════════════════════════════════════

harvest_stdlib _ =
  let _ = print ""
  let _ = print "--- Stdlib modules ---"
  let files = trim (shell "ls stdlib/*.rail 2>/dev/null | sort")
  if files == "" then
    let _ = print "  No stdlib files found"
    0
  else
    let _ = write_file "/tmp/rail_harvest_stdlib.py" "import json, os, glob\nos.chdir(os.path.expanduser('~/projects/rail'))\nSYS = 'You are a Rail language expert. Rail is a pure functional language that compiles to native ARM64 and Metal GPU shaders. Write correct Rail code.'\nentries = []\nfor path in sorted(glob.glob('stdlib/*.rail')):\n    code = open(path).read().strip()\n    if len(code) < 20: continue\n    module = os.path.basename(path).replace('.rail', '')\n    entry = json.dumps({'messages': [{'role': 'system', 'content': SYS}, {'role': 'user', 'content': f'Write a Rail stdlib module for {module} operations'}, {'role': 'assistant', 'content': code}]}, ensure_ascii=False)\n    entries.append(entry)\n    print(f'  + {path} ({len(code)} chars)')\nwith open('/tmp/rail_stdlib_entries.jsonl', 'w') as f:\n    for e in entries: f.write(e + '\\n')\nprint(f'  Stdlib: {len(entries)} entries')\n"
    let result = trim (shell "cd ~/projects/rail && python3 /tmp/rail_harvest_stdlib.py 2>&1")
    let _ = print result
    0

-- ══════════════════════════════════════════════════════════════════════════════
-- Harvest test files
-- ══════════════════════════════════════════════════════════════════════════════

harvest_tests _ =
  let _ = print ""
  let _ = print "--- Test files ---"
  let _ = write_file "/tmp/rail_harvest_tests.py" "import json, os, glob\nos.chdir(os.path.expanduser('~/projects/rail'))\nSYS = 'You are a Rail language expert. Rail is a pure functional language that compiles to native ARM64 and Metal GPU shaders. Write correct Rail code.'\nentries = []\nfor path in sorted(glob.glob('tests/*.rail')):\n    code = open(path).read().strip()\n    if len(code) < 10: continue\n    name = os.path.basename(path).replace('.rail', '').replace('_', ' ')\n    entry = json.dumps({'messages': [{'role': 'system', 'content': SYS}, {'role': 'user', 'content': f'Write a Rail test program for: {name}'}, {'role': 'assistant', 'content': code}]}, ensure_ascii=False)\n    entries.append(entry)\nwith open('/tmp/rail_test_entries.jsonl', 'w') as f:\n    for e in entries: f.write(e + '\\n')\nprint(f'  + {len(entries)} test files')\n"
  let result = trim (shell "cd ~/projects/rail && python3 /tmp/rail_harvest_tests.py 2>&1")
  let _ = print result
  0

-- ══════════════════════════════════════════════════════════════════════════════
-- Merge all entries and write output
-- ══════════════════════════════════════════════════════════════════════════════

merge_and_write _ =
  let _ = shell "cat /tmp/rail_git_entries.jsonl /tmp/rail_stdlib_entries.jsonl /tmp/rail_test_entries.jsonl > /tmp/rail_all_harvest.jsonl 2>/dev/null"
  let _ = shell (cat ["cp /tmp/rail_all_harvest.jsonl ~/projects/rail/", output_file])
  let count = trim (shell (cat ["wc -l < ~/projects/rail/", output_file, " 2>/dev/null || echo 0"]))
  count

-- ══════════════════════════════════════════════════════════════════════════════
-- Show inventory
-- ══════════════════════════════════════════════════════════════════════════════

show_inventory total =
  let _ = print ""
  let train_count = trim (shell "wc -l < training/train.jsonl 2>/dev/null || echo 0")
  let harvest_count = trim (shell "wc -l < training/self_train/harvest.jsonl 2>/dev/null || echo 0")
  let _ = print "Training data inventory:"
  let _ = print (cat ["  Original (build_training_data.rail): ", train_count])
  let _ = print (cat ["  Self-training harvest:               ", harvest_count])
  let _ = print (cat ["  Git history harvest (NEW):           ", total])
  0

-- ══════════════════════════════════════════════════════════════════════════════
-- Main
-- ══════════════════════════════════════════════════════════════════════════════

main =
  let _ = print "=== Rail Git History Harvester ==="
  let _ = print ""
  -- Clean temp files
  let _ = shell "rm -f /tmp/rail_git_entries.jsonl /tmp/rail_stdlib_entries.jsonl /tmp/rail_test_entries.jsonl"
  let _ = shell "touch /tmp/rail_git_entries.jsonl /tmp/rail_stdlib_entries.jsonl /tmp/rail_test_entries.jsonl"
  let _ = harvest_git_commits 0
  let _ = harvest_stdlib 0
  let _ = harvest_tests 0
  let total = merge_and_write 0
  let _ = print ""
  let _ = print (cat ["=== Done: ", total, " entries written to ", output_file, " ==="])
  let _ = show_inventory total
  0
