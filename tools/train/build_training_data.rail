-- build_training_data.rail — Generate 1000+ LoRA training examples for Rail mastery
-- Pure Rail. Writes entries incrementally to avoid arena exhaustion.
-- Usage: ./rail_native run tools/build_training_data.rail

cat parts = join "" parts
q = "\""

-- JSON escaping: backslashes first, then quotes, then newlines, then tabs
json_esc_bs s = join "\\\\" (split "\\" s)
json_esc_q s = join "\\\"" (split "\"" s)
json_esc_nl s = join "\\n" (split "\n" s)
json_esc_tab s = join "\\t" (split "\t" s)
json_esc s = json_esc_tab (json_esc_nl (json_esc_q (json_esc_bs s)))

entry sys usr asst =
  cat ["{", q, "messages", q, ":[",
    "{", q, "role", q, ":", q, "system", q, ",", q, "content", q, ":", q, json_esc sys, q, "},",
    "{", q, "role", q, ":", q, "user", q, ",", q, "content", q, ":", q, json_esc usr, q, "},",
    "{", q, "role", q, ":", q, "assistant", q, ",", q, "content", q, ":", q, json_esc asst, q, "}]}"]

sys = "You are a Rail language expert. Rail is a pure functional language that compiles to native ARM64 and Metal GPU shaders. Write correct Rail code."
ref = "You are a Rail language reference."

-- Write a single entry as a line to file (shell append)
shell_esc s = join "'" (split "'" s)

write_entry file e =
  let _ = write_file "/tmp/rail_td_line.txt" (cat [e, "\n"])
  shell (cat ["cat /tmp/rail_td_line.txt >> ", file])

-- Write 15 variants for a test case, returns count
write_variants file name src exp =
  let _ = write_entry file (entry sys (cat ["Write a Rail program that outputs ", exp]) src)
  let _ = write_entry file (entry sys (cat ["Write ", name, " in Rail"]) src)
  let _ = write_entry file (entry sys (cat ["Implement ", name, " in Rail"]) src)
  let _ = write_entry file (entry sys (cat ["How would you write ", name, " in Rail?"]) src)
  let _ = write_entry file (entry sys (cat ["Show me Rail code for: ", name]) src)
  let _ = write_entry file (entry sys (cat ["Rail program: ", name, " (expected: ", exp, ")"]) src)
  let _ = write_entry file (entry sys (cat ["Create a Rail program where the result is ", exp]) src)
  let _ = write_entry file (entry sys (cat ["Write this in Rail: ", name]) src)
  let _ = write_entry file (entry sys (cat ["I need a Rail program that evaluates to ", exp]) src)
  let _ = write_entry file (entry sys (cat ["Give me a Rail example of ", name]) src)
  let _ = write_entry file (entry sys (cat ["Translate to Rail: ", name]) src)
  let _ = write_entry file (entry sys (cat ["Write Rail code for ", name]) src)
  let _ = write_entry file (entry sys (cat ["Show how to do ", name, " in Rail"]) src)
  let _ = write_entry file (entry sys (cat ["Rail example: ", name]) src)
  let _ = write_entry file (entry sys (cat ["Can you write ", name, " in Rail?"]) src)
  15

f = "/tmp/rail_training_all.jsonl"

main =
  let _ = print "Building Rail training data..."
  -- Clear output file
  let _ = write_file f ""
  let count = 0

  -- ═══ TEST CASE VARIANTS (63 × 15 = 945) ═══
  let count = count + write_variants f "constant integer" "main = 42" "42"
  let count = count + write_variants f "addition" "main = 3 + 4" "7"
  let count = count + write_variants f "if expression" "main = if 1 == 1 then 42 else 0" "42"
  let count = count + write_variants f "function call" "double x = x * 2\nmain = double 21" "42"
  let count = count + write_variants f "factorial" "fact n =\n  if n <= 1 then 1\n  else n * fact (n - 1)\nmain = fact 5" "120"
  let count = count + write_variants f "print side effect" "main =\n  let _ = print 42\n  0" "42"
  let count = count + write_variants f "two-arg function" "add x y = x + y\nmain = add 17 25" "42"
  let count = count + write_variants f "chained let bindings" "main =\n  let a = 7\n  let b = a * a\n  b - 1" "48"
  let count = count + write_variants f "string printing" "main =\n  let _ = print \"hello\"\n  0" "hello"
  let count = count + write_variants f "string equality" "main = if \"ab\" == \"ab\" then 1 else 0" "1"
  let count = count + write_variants f "string inequality" "main = if \"ab\" == \"cd\" then 1 else 0" "0"
  let count = count + write_variants f "show integer" "main =\n  let _ = print (show 42)\n  0" "42"
  let count = count + write_variants f "string append" "main =\n  let _ = print (append \"hel\" \"lo\")\n  0" "hello"
  let count = count + write_variants f "string plus" "main =\n  let _ = print (\"foo\" + \"bar\")\n  0" "foobar"
  let count = count + write_variants f "list length" "main = length [10, 20, 30]" "3"
  let count = count + write_variants f "head and tail" "main = head (tail [10, 20, 30])" "20"
  let count = count + write_variants f "cons" "main = head (cons 42 [1, 2])" "42"
  let count = count + write_variants f "list append" "main = length (append [1, 2] [3, 4, 5])" "5"
  let count = count + write_variants f "empty list" "main = length []" "0"
  let count = count + write_variants f "string length" "main = length \"hello\"" "5"
  let count = count + write_variants f "map named function" "double x = x * 2\nmain = head (map double [3, 5, 7])" "6"
  let count = count + write_variants f "map lambda" "main = head (map (\\x -> x + 10) [5, 6, 7])" "15"
  let count = count + write_variants f "closure capture" "main =\n  let n = 100\n  head (map (\\x -> x + n) [1, 2, 3])" "101"
  let count = count + write_variants f "join strings" "main =\n  let _ = print (join \"-\" [\"a\", \"b\", \"c\"])\n  0" "a-b-c"
  let count = count + write_variants f "tuple destructure" "main =\n  let (a, b) = (10, 32)\n  a + b" "42"
  let count = count + write_variants f "tuple return" "swap a b = (b, a)\nmain =\n  let (x, y) = swap 1 2\n  x * 10 + y" "21"
  let count = count + write_variants f "3-tuple" "main =\n  let (a, b, c) = (100, 20, 3)\n  a + b + c" "123"
  let count = count + write_variants f "chars function" "main =\n  let cs = chars \"abc\"\n  let _ = print (head cs)\n  length cs" "a"
  let count = count + write_variants f "split string" "main =\n  let _ = print (head (tail (split \",\" \"a,b,c\")))\n  0" "b"
  let count = count + write_variants f "file I/O" "main =\n  let _ = write_file \"/tmp/rail_test.txt\" \"hello42\"\n  let s = read_file \"/tmp/rail_test.txt\"\n  let _ = print s\n  0" "hello42"
  let count = count + write_variants f "shell command" "main =\n  let _ = print (head (split \"\\n\" (shell \"echo hi\")))\n  0" "hi"
  let count = count + write_variants f "integration test" "cat parts = join \"\" parts\ndbl x = x * 2\nmain =\n  let xs = map dbl [3, 5, 7]\n  let (a, b) = (head xs, length xs)\n  let _ = print (cat [\"sum=\", show (a + b)])\n  0" "sum=9"
  let count = count + write_variants f "tail call optimization" "loop n = if n == 0 then 42 else loop (n - 1)\nmain =\n  let _ = print (show (loop 50000))\n  0" "42"
  let count = count + write_variants f "big integer" "main =\n  let x = 100000\n  x - 99958" "42"
  let count = count + write_variants f "ADT None" "type Option = | Some x | None\nmain = match None | Some x -> x | None -> 42" "42"
  let count = count + write_variants f "ADT Some" "type Option = | Some x | None\nmain = match (Some 42) | Some x -> x | None -> 0" "42"
  let count = count + write_variants f "ADT pair" "type Pair = | MkPair a b\nfst p = match p | MkPair a b -> a\nmain = fst (MkPair 10 32)" "10"
  let count = count + write_variants f "negative literal" "main =\n  let _ = print (show (-42))\n  0" "-42"
  let count = count + write_variants f "escaped braces" "main =\n  let _ = print \"\\{hello\\}\"\n  0" "{hello}"
  let count = count + write_variants f "float addition" "main =\n  let _ = print (show (1.5 + 2.25))\n  0" "3.75"
  let count = count + write_variants f "float multiply" "main =\n  let _ = print (show (3.0 * 2.5))\n  0" "7.5"
  let count = count + write_variants f "float compare" "main = if 3.14 > 2.71 then 1 else 0" "1"
  let count = count + write_variants f "FFI abs" "foreign abs n\nmain =\n  let _ = print (show (abs (-5)))\n  0" "5"
  let count = count + write_variants f "FFI strlen" "foreign strlen s\nmain =\n  let _ = print (show (strlen \"hello\"))\n  0" "5"
  let count = count + write_variants f "FFI getenv" "foreign getenv s -> str\nmain =\n  let _ = print (getenv \"HOME\")\n  0" "/Users/ledaticempire"
  let count = count + write_variants f "wildcard pattern" "type T = | A x | B x | C\nmain = match (B 99)\n  | A x -> 0\n  | _ -> 42" "42"
  let count = count + write_variants f "arena mark reset" "main =\n  let m = arena_mark 0\n  let _ = cons 1 [2, 3]\n  let _ = arena_reset m\n  42" "42"
  let count = count + write_variants f "filter" "gt2 x = if x > 2 then true else false\nmain = length (filter gt2 [1, 2, 3, 4, 5])" "3"
  let count = count + write_variants f "fold" "add a b = a + b\nmain = fold add 0 [1, 2, 3, 4, 5]" "15"
  let count = count + write_variants f "reverse" "main =\n  let xs = reverse [1, 2, 3]\n  head xs" "3"
  let count = count + write_variants f "to_float" "main =\n  let _ = print (show (to_float 42))\n  0" "42"
  let count = count + write_variants f "boolean not" "main = if not false then 1 else 0" "1"
  let count = count + write_variants f "range" "main = length (range 10)" "10"
  let count = count + write_variants f "fold sum range" "add a b = a + b\nmain =\n  let _ = print (show (fold add 0 (range 101)))\n  0" "5050"
  let count = count + write_variants f "negative arithmetic" "main = 10 + (-3)" "7"
  let count = count + write_variants f "spawn fiber" "work x = x * 2\nmain =\n  let f = spawn (\\x -> work 21)\n  fiber_await f" "42"
  let count = count + write_variants f "match integer literal" "classify n = match n\n  | 0 -> \"zero\"\n  | 1 -> \"one\"\n  | _ -> \"other\"\nmain =\n  let _ = print (classify 1)\n  0" "one"
  let count = count + write_variants f "ADT guard pattern" "type Option = | Some x | None\nsafe_div a b = match b\n  | 0 -> None\n  | _ -> Some (a / b)\nmain = match (safe_div 10 2)\n  | Some x -> x\n  | None -> 0" "5"
  let count = count + write_variants f "ref counting" "foreign free p\nmain =\n  let p = rc_alloc 16\n  let _ = rc_retain p\n  let _ = rc_release p\n  let _ = rc_release p\n  42" "42"
  let count = count + write_variants f "channels" "main =\n  let ch = channel 0\n  let _ = send ch 10\n  let _ = send ch 20\n  let _ = send ch 30\n  let a = recv ch\n  let b = recv ch\n  a + b" "30"
  let count = count + write_variants f "FFI float sqrt" "foreign sqrt x -> float\nmain =\n  let _ = print (show (to_int (sqrt (to_float 144))))\n  0" "12"
  let _ = print (cat ["  Test variants: ", show count])

  -- ═══ GRAMMAR / REFERENCE ═══
  let _ = write_entry f (entry ref "What is Rail's syntax for functions?" "Rail functions are defined at the top level: name param1 param2 = body. Functions are curried. Example: add x y = x + y. The main function is the entry point: main = expr. Let bindings use: let name = expr (on the next indented line, the body continues). If expressions: if cond then expr1 else expr2. Lambdas: \\x -> expr.")
  let _ = write_entry f (entry ref "What types does Rail support?" "Rail supports: integers (tagged, 63-bit), strings (C string pointers), booleans (true/false), floats (boxed f64), lists ([1, 2, 3] with head/tail/cons/append/length), tuples ((a, b) with let (x, y) = expr destructuring), closures (\\x -> expr with variable capture), and algebraic data types (type Option = | Some x | None with match).")
  let _ = write_entry f (entry ref "What builtins does Rail have?" "I/O: print, show, read_file, write_file, shell. Lists: head, tail, cons, append, length, map, filter, fold, reverse, range. Strings: chars, split, join. Math: to_float, to_int. Boolean: not. System: args. Concurrency: spawn, fiber_await, channel, send, recv. Memory: arena_mark, arena_reset, rc_alloc, rc_retain, rc_release.")
  let _ = write_entry f (entry ref "Can Rail compile to GPU?" "Yes. Rail compiles expressions to Metal compute shaders for Apple Silicon GPUs. The gpu.rail tool handles the compilation pipeline.")
  let _ = write_entry f (entry ref "How does Rail's self-hosting work?" "Rail's compiler (tools/compile.rail, ~1500 lines) compiles itself to a native ARM64 binary. The compiler: lexes, parses into AST, generates ARM64 assembly, calls as+ld. Fixed point: compiled binary produces identical assembly.")
  let _ = write_entry f (entry ref "What are common mistakes in Rail?" "1. && and || do NOT short-circuit — use nested if/else. 2. Use (-n) for negatives. 3. Tuples are not lists. 4. Every program needs main. 5. Use let _ = print expr for side effects. 6. No string interpolation — use join.")
  let _ = write_entry f (entry ref "How do ADTs work in Rail?" "type Option = | Some x | None. Match with: match expr | Some x -> x | None -> 0. Wildcard _ matches anything. Multi-field: type Pair = | MkPair a b.")
  let _ = write_entry f (entry ref "How does FFI work in Rail?" "foreign name params [-> return_type]. Omit for int, -> str for string, -> float for f64. Example: foreign sqrt x -> float.")
  let _ = write_entry f (entry ref "How do imports work in Rail?" "import \"path.rail\". Qualified: import \"lib.rail\" as M — functions prefixed M_func.")
  let _ = write_entry f (entry ref "How does concurrency work in Rail?" "spawn (\\x -> expr) creates a fiber. fiber_await f runs it. channel 0 creates a channel, send/recv for communication.")
  let _ = write_entry f (entry ref "What are Rail's operator precedences?" "|> < || < && < comparisons < +- < */% < application. Parentheses override.")
  let _ = write_entry f (entry ref "How does memory management work in Rail?" "Bump allocator (arena) for most data. arena_mark/arena_reset for scoped allocation. rc_alloc/rc_retain/rc_release for long-lived data.")
  let count = count + 12
  let _ = print (cat ["  Grammar/ref: 12"])

  -- ═══ ERROR / FIX ENTRIES ═══
  let _ = write_entry f (entry sys "Fix this Rail code:\nmain = let x = 5 in x + 1" "-- Error: Rail uses newlines, not 'in'\nmain =\n  let x = 5\n  x + 1")
  let _ = write_entry f (entry sys "Fix this Rail code:\nMain = 42" "-- Error: lowercase function names\nmain = 42")
  let _ = write_entry f (entry sys "Fix this Rail code:\nmain = print(42)" "-- Error: space for application\nmain =\n  let _ = print 42\n  0")
  let _ = write_entry f (entry sys "Fix this Rail code:\nmain = [1, 2, 3].length" "-- Error: no method syntax\nmain = length [1, 2, 3]")
  let _ = write_entry f (entry sys "Fix this Rail code:\nmain =\n  x = 5\n  x + 1" "-- Error: need 'let'\nmain =\n  let x = 5\n  x + 1")
  let _ = write_entry f (entry sys "Fix this Rail code:\ndef factorial(n):\n  if n <= 1: return 1\n  return n * factorial(n-1)" "-- Python, not Rail:\nfactorial n = if n <= 1 then 1 else n * factorial (n - 1)\nmain =\n  let _ = print (show (factorial 10))\n  0")
  let _ = write_entry f (entry sys "Fix this Rail code:\nmain = x && y || z" "-- && and || don't short-circuit. Use if/else:\nmain =\n  let x = true\n  let y = false\n  let z = true\n  if x then (if y then true else z) else z")
  let _ = write_entry f (entry sys "Fix this Rail code:\nmain = \"answer: \" + 42" "-- Can't add string+int. Use show:\nmain =\n  let _ = print (\"answer: \" + show 42)\n  0")
  let _ = write_entry f (entry sys "Fix this Rail code:\ntype Maybe = Some(x) | None" "-- ADT syntax: | prefix, no parens\ntype Maybe = | Some x | None\nmain = match (Some 42) | Some x -> x | None -> 0")
  let _ = write_entry f (entry sys "Fix this Rail code:\nmain = head []" "-- head on empty list crashes:\nmain =\n  let xs = []\n  if length xs == 0 then 0 else head xs")
  let _ = write_entry f (entry sys "Fix this Rail code:\nmain = let (a, b) = [1, 2]" "-- Tuple destructure only on tuples:\nmain =\n  let (a, b) = (1, 2)\n  a + b")
  let _ = write_entry f (entry sys "Fix this Rail code:\nmain = \\x y -> x + y" "-- Lambdas take one arg:\nadd x y = x + y\nmain = add 3 4")
  let _ = write_entry f (entry sys "Fix this Rail code:\nimport math\nmain = math.sqrt(16)" "-- Use FFI:\nforeign sqrt x -> float\nmain =\n  let _ = print (show (to_int (sqrt (to_float 16))))\n  0")
  let _ = write_entry f (entry sys "Fix this Rail code:\nmain = for i in range(10): print(i)" "-- No for loops. Use recursion:\ngo n = if n >= 10 then 0 else let _ = print (show n)\n  go (n + 1)\nmain = go 0")
  let _ = write_entry f (entry sys "Fix this Rail code:\nfib n =\n  if n == 0 then 0\n  elif n == 1 then 1\n  else fib(n-1) + fib(n-2)" "-- Use 'else if' not 'elif':\nfib n = if n == 0 then 0 else if n == 1 then 1 else fib (n - 1) + fib (n - 2)\nmain =\n  let _ = print (show (fib 10))\n  0")
  let _ = write_entry f (entry sys "Fix this Rail code:\nmain = map (+ 1) [1, 2, 3]" "-- No operator sections. Use lambda:\nmain = head (map (\\x -> x + 1) [1, 2, 3])")
  let _ = write_entry f (entry sys "Fix this Rail code:\nmain = [1..10]" "-- No range literals. Use range:\nmain = length (range 10)")
  let _ = write_entry f (entry sys "Fix this Rail code:\ntype List a = | Cons a (List a) | Nil" "-- No type parameters:\ntype List = | Cons x xs | Nil\nmain = match (Cons 1 (Cons 2 Nil)) | Cons x xs -> x | Nil -> 0")
  let _ = write_entry f (entry sys "Fix this Rail code:\nfunction double(x) { return x * 2; }" "-- JavaScript to Rail:\ndouble x = x * 2\nmain = double 21")
  let _ = write_entry f (entry sys "Fix: main = 1 / 0" "-- Guard division:\nsafe_div a b = if b == 0 then 0 else a / b\nmain = safe_div 1 0")
  let count = count + 20
  let _ = print (cat ["  Error/fix: 20"])

  -- ═══ PATTERN ENTRIES ═══
  let _ = write_entry f (entry sys "Sum even numbers 1-100 in Rail" "is_even x = x % 2 == 0\nadd a b = a + b\nmain =\n  let _ = print (show (fold add 0 (filter is_even (range 101))))\n  0")
  let _ = write_entry f (entry sys "Reverse a string in Rail" "main =\n  let _ = print (join \"\" (reverse (chars \"hello\")))\n  0")
  let _ = write_entry f (entry sys "Find maximum in a list" "max_of a b = if a > b then a else b\nmain =\n  let _ = print (show (fold max_of 0 [3, 7, 2, 9, 1, 5]))\n  0")
  let _ = write_entry f (entry sys "Check palindrome in Rail" "main =\n  let s = \"racecar\"\n  let rev = join \"\" (reverse (chars s))\n  let _ = print (if s == rev then \"yes\" else \"no\")\n  0")
  let _ = write_entry f (entry sys "GCD in Rail" "gcd a b = if b == 0 then a else gcd b (a % b)\nmain =\n  let _ = print (show (gcd 48 18))\n  0")
  let _ = write_entry f (entry sys "Power function in Rail" "power x n = if n == 0 then 1 else x * power x (n - 1)\nmain =\n  let _ = print (show (power 2 10))\n  0")
  let _ = write_entry f (entry sys "Return multiple values with tuples" "divmod a b = (a / b, a % b)\nmain =\n  let (q, r) = divmod 17 5\n  let _ = print (join \" \" [\"q:\", show q, \"r:\", show r])\n  0")
  let _ = write_entry f (entry sys "Map then fold a list" "square x = x * x\nadd a b = a + b\nmain =\n  let _ = print (show (fold add 0 (map square [1, 2, 3, 4, 5])))\n  0")
  let _ = write_entry f (entry sys "Binary tree with ADT" "type Tree = | Leaf x | Node left right\nsum_tree t = match t\n  | Leaf x -> x\n  | Node left right -> sum_tree left + sum_tree right\nmain =\n  let _ = print (show (sum_tree (Node (Leaf 1) (Node (Leaf 2) (Leaf 3)))))\n  0")
  let _ = write_entry f (entry sys "Closures as adder factory" "make_adder n = \\x -> x + n\nmain =\n  let add5 = make_adder 5\n  let _ = print (show (head (map add5 [10, 20, 30])))\n  0")
  let _ = write_entry f (entry sys "Build CSV from int list" "main =\n  let _ = print (join \", \" (map show [1, 2, 3, 4, 5]))\n  0")
  let _ = write_entry f (entry sys "Count lines in a file" "main =\n  let _ = write_file \"/tmp/rail_count.txt\" \"a\\nb\\nc\"\n  let c = read_file \"/tmp/rail_count.txt\"\n  let _ = print (show (length (split \"\\n\" c)))\n  0")
  let _ = write_entry f (entry sys "Pipe operator example" "double x = x * 2\nadd1 x = x + 1\nmain =\n  let _ = print (show (5 |> double |> add1))\n  0")
  let _ = write_entry f (entry sys "Stack with lists" "push s v = cons v s\npop s = tail s\npeek s = head s\nmain =\n  let s = push (push (push [] 10) 20) 30\n  let _ = print (show (peek s))\n  0")
  let _ = write_entry f (entry sys "Fibonacci sequence" "fibs n a b = if n <= 0 then [] else cons a (fibs (n - 1) b (a + b))\nmain =\n  let _ = print (join \", \" (map show (fibs 10 0 1)))\n  0")
  let _ = write_entry f (entry sys "Function composition" "compose f g x = f (g x)\ndouble x = x * 2\nadd1 x = x + 1\nmain =\n  let _ = print (show (compose add1 double 5))\n  0")
  let _ = write_entry f (entry sys "Filter then map" "pos x = x > 0\nsq x = x * x\nmain =\n  let _ = print (join \" \" (map show (map sq (filter pos [3, 0, 5, 0, 7]))))\n  0")
  let _ = write_entry f (entry sys "Custom linked list ADT" "type MyList = | Cons x xs | Empty\nmy_len lst = match lst | Cons x xs -> 1 + my_len xs | Empty -> 0\nmain =\n  let _ = print (show (my_len (Cons 1 (Cons 2 (Cons 3 Empty)))))\n  0")
  let _ = write_entry f (entry sys "Result type for errors" "type Result = | Ok x | Err msg\nmain = match (Ok 42) | Ok x -> x | Err msg -> 0")
  let _ = write_entry f (entry sys "Repeat a string n times" "repeat s n = if n <= 0 then \"\" else s + repeat s (n - 1)\nmain =\n  let _ = print (repeat \"ha\" 3)\n  0")
  let _ = write_entry f (entry sys "Check if list is sorted" "sorted xs = if length xs <= 1 then true else if head xs > head (tail xs) then false else sorted (tail xs)\nmain =\n  let _ = print (if sorted [1, 2, 3] then \"yes\" else \"no\")\n  0")
  let _ = write_entry f (entry sys "Sum of digits" "sum_digits n = if n == 0 then 0 else n % 10 + sum_digits (n / 10)\nmain =\n  let _ = print (show (sum_digits 12345))\n  0")
  let _ = write_entry f (entry sys "Primality test" "prime_h n d = if d * d > n then true else if n % d == 0 then false else prime_h n (d + 1)\nis_prime n = if n < 2 then false else prime_h n 2\nmain =\n  let _ = print (if is_prime 17 then \"prime\" else \"not\")\n  0")
  let _ = write_entry f (entry sys "Absolute value" "abs n = if n < 0 then (0 - n) else n\nmain =\n  let _ = print (show (abs (-42)))\n  0")
  let _ = write_entry f (entry sys "Find minimum" "min_of a b = if a < b then a else b\nmain =\n  let _ = print (show (fold min_of 999 [5, 3, 8, 1, 9]))\n  0")
  let _ = write_entry f (entry sys "Insertion sort" "insert x xs = if length xs == 0 then [x] else if x <= head xs then cons x xs else cons (head xs) (insert x (tail xs))\nsort xs = if length xs == 0 then [] else insert (head xs) (sort (tail xs))\nmain =\n  let _ = print (join \" \" (map show (sort [5, 3, 8, 1])))\n  0")
  let _ = write_entry f (entry sys "Circle area with floats" "main =\n  let area = 3.14159 * 5.0 * 5.0\n  let _ = print (show area)\n  0")
  let _ = write_entry f (entry sys "Celsius to Fahrenheit" "c_to_f c = c * 1.8 + 32.0\nmain =\n  let _ = print (show (c_to_f 100.0))\n  0")
  let _ = write_entry f (entry sys "String calculator" "calc op a b = if op == \"+\" then a + b else if op == \"*\" then a * b else 0\nmain =\n  let _ = print (show (calc \"+\" 10 20))\n  0")
  let _ = write_entry f (entry sys "State machine ADT" "type State = | Start | Running | Done\nstep s = match s | Start -> Running | Running -> Done | Done -> Done\nlabel s = match s | Start -> \"start\" | Running -> \"running\" | Done -> \"done\"\nmain =\n  let _ = print (label (step Start))\n  let _ = print (label (step (step Start)))\n  0")
  let _ = write_entry f (entry sys "Zip two lists" "zip xs ys = if length xs == 0 then [] else if length ys == 0 then [] else cons (head xs, head ys) (zip (tail xs) (tail ys))\nmain =\n  let _ = print (show (length (zip [1, 2, 3] [10, 20, 30])))\n  0")
  let _ = write_entry f (entry sys "Take and drop" "take n xs = if n <= 0 then [] else if length xs == 0 then [] else cons (head xs) (take (n - 1) (tail xs))\ndrop n xs = if n <= 0 then xs else if length xs == 0 then [] else drop (n - 1) (tail xs)\nmain =\n  let _ = print (join \" \" (map show (take 3 [1, 2, 3, 4, 5])))\n  0")
  let _ = write_entry f (entry sys "Count occurrences" "count t xs = if length xs == 0 then 0 else (if head xs == t then 1 else 0) + count t (tail xs)\nmain =\n  let _ = print (show (count 3 [1, 3, 2, 3, 4, 3]))\n  0")
  let _ = write_entry f (entry sys "Deduplicate sorted list" "dedup xs = if length xs <= 1 then xs else if head xs == head (tail xs) then dedup (tail xs) else cons (head xs) (dedup (tail xs))\nmain =\n  let _ = print (join \" \" (map show (dedup [1, 1, 2, 2, 3])))\n  0")
  let _ = write_entry f (entry sys "Multi-arity ADT" "type Shape = | Circle r | Rect w h | Point\narea s = match s | Circle r -> r * r * 3 | Rect w h -> w * h | Point -> 0\nmain =\n  let _ = print (show (area (Rect 3 4)))\n  0")
  let _ = write_entry f (entry sys "Accumulator pattern" "sum_acc xs acc = if length xs == 0 then acc else sum_acc (tail xs) (acc + head xs)\nmain =\n  let _ = print (show (sum_acc [10, 20, 30] 0))\n  0")
  let _ = write_entry f (entry sys "Interleave lists" "inter xs ys = if length xs == 0 then ys else if length ys == 0 then xs else cons (head xs) (cons (head ys) (inter (tail xs) (tail ys)))\nmain =\n  let _ = print (join \" \" (map show (inter [1, 3, 5] [2, 4, 6])))\n  0")
  let _ = write_entry f (entry sys "Nth element" "nth xs n = if n == 0 then head xs else nth (tail xs) (n - 1)\nmain =\n  let _ = print (show (nth [10, 20, 30, 40] 2))\n  0")
  let _ = write_entry f (entry sys "Countdown list" "countdown n = if n <= 0 then [0] else cons n (countdown (n - 1))\nmain =\n  let _ = print (join \" \" (map show (countdown 5)))\n  0")
  let _ = write_entry f (entry sys "All predicate" "all pred xs = if length xs == 0 then true else if not (pred (head xs)) then false else all pred (tail xs)\npos x = x > 0\nmain =\n  let _ = print (if all pos [1, 2, 3] then \"yes\" else \"no\")\n  0")
  let _ = write_entry f (entry sys "Any predicate" "any pred xs = if length xs == 0 then false else if pred (head xs) then true else any pred (tail xs)\nis_z x = x == 0\nmain =\n  let _ = print (if any is_z [1, 0, 3] then \"yes\" else \"no\")\n  0")
  let _ = write_entry f (entry sys "Binary search" "nth xs n = if n == 0 then head xs else nth (tail xs) (n - 1)\nbsearch xs t lo hi = if lo > hi then (-1) else let mid = (lo + hi) / 2\n  if nth xs mid == t then mid else if nth xs mid < t then bsearch xs t (mid + 1) hi else bsearch xs t lo (mid - 1)\nmain =\n  let _ = print (show (bsearch [1, 3, 5, 7, 9] 7 0 4))\n  0")
  let _ = write_entry f (entry sys "Mutual recursion" "is_even n = if n == 0 then true else is_odd (n - 1)\nis_odd n = if n == 0 then false else is_even (n - 1)\nmain =\n  let _ = print (if is_even 10 then \"even\" else \"odd\")\n  0")
  let _ = write_entry f (entry sys "Int to word" "to_word n = if n == 0 then \"zero\" else if n == 1 then \"one\" else if n == 2 then \"two\" else \"many\"\nmain =\n  let _ = print (join \", \" (map to_word [0, 1, 2, 3]))\n  0")
  let _ = write_entry f (entry sys "Queue with ADT" "type Queue = | Q front back\nenqueue q x = match q | Q f b -> Q f (cons x b)\nmain =\n  let q = Q [] []\n  let q = enqueue q 10\n  let q = enqueue q 20\n  42")
  let _ = write_entry f (entry sys "Char frequency" "count_c c cs = if length cs == 0 then 0 else (if head cs == c then 1 else 0) + count_c c (tail cs)\nmain =\n  let s = chars \"hello\"\n  let _ = print (cat [\"l: \", show (count_c \"l\" s)])\n  0")
  let _ = write_entry f (entry sys "Channels for data" "main =\n  let ch = channel 0\n  let _ = send ch 10\n  let _ = send ch 20\n  let a = recv ch\n  let b = recv ch\n  let _ = print (show (a + b))\n  0")
  let _ = write_entry f (entry sys "Fiber for async work" "work x = x * x\nmain =\n  let f = spawn (\\x -> work 7)\n  let _ = print (show (fiber_await f))\n  0")
  let count = count + 50
  let _ = print (cat ["  Patterns: 50"])

  -- ═══ TOOL FILE ENTRIES ═══
  -- Strip CRs from CRLF files (Rail has no \r escape)
  let _ = shell "for f in tools/deploy/gen_site.rail tools/apps/brain.rail tools/gpu.rail tools/apps/speak.rail tools/apps/llm_call.rail tools/apps/services.rail tools/apps/config_check.rail tools/deploy/update_site.rail tools/deploy/cf_deploy.rail; do tr -d '\\r' < $f > /tmp/rail_td_$(basename $f); done"
  let gen_src = read_file "/tmp/rail_td_gen_site.rail"
  let _ = write_entry f (entry sys "Write a website generator in Rail" gen_src)
  let brain_src = read_file "/tmp/rail_td_brain.rail"
  let _ = write_entry f (entry sys "Write a system monitor in Rail" brain_src)
  let gpu_src = read_file "/tmp/rail_td_gpu.rail"
  let _ = write_entry f (entry sys "Write a GPU compiler in Rail" gpu_src)
  let speak_src = read_file "/tmp/rail_td_speak.rail"
  let _ = write_entry f (entry sys "NL to GPU pipeline in Rail" speak_src)
  let llm_src = read_file "/tmp/rail_td_llm_call.rail"
  let _ = write_entry f (entry sys "LLM API client in Rail" llm_src)
  let svc_src = read_file "/tmp/rail_td_services.rail"
  let _ = write_entry f (entry sys "Service manager in Rail" svc_src)
  let cfg_src = read_file "/tmp/rail_td_config_check.rail"
  let _ = write_entry f (entry sys "Config validator in Rail" cfg_src)
  let upd_src = read_file "/tmp/rail_td_update_site.rail"
  let _ = write_entry f (entry sys "Site updater in Rail" upd_src)
  let cf_src = read_file "/tmp/rail_td_cf_deploy.rail"
  let _ = write_entry f (entry sys "Cloudflare deploy in Rail" cf_src)
  let count = count + 9
  let _ = print (cat ["  Tool files: 9"])

  -- ═══ TOTAL + SPLIT ═══
  let _ = print (cat ["\n  TOTAL: ", show count])
  -- Split using shell (line-based, no arena needed)
  let _ = shell "cd ~/projects/rail && mkdir -p training"
  let total_lines = head (split "\n" (shell "wc -l < /tmp/rail_training_all.jsonl"))
  let _ = print (cat ["  Lines in file: ", total_lines])
  -- 90/5/5 split
  let _ = shell "cd ~/projects/rail && head -n 936 /tmp/rail_training_all.jsonl > training/train.jsonl"
  let _ = shell "cd ~/projects/rail && tail -n +937 /tmp/rail_training_all.jsonl | head -n 50 > training/valid.jsonl"
  let _ = shell "cd ~/projects/rail && tail -n +987 /tmp/rail_training_all.jsonl > training/test.jsonl"
  let train_n = head (split "\n" (shell "wc -l < ~/projects/rail/training/train.jsonl"))
  let valid_n = head (split "\n" (shell "wc -l < ~/projects/rail/training/valid.jsonl"))
  let test_n = head (split "\n" (shell "wc -l < ~/projects/rail/training/test.jsonl"))
  let _ = print (cat ["  Train: ", train_n, "  Valid: ", valid_n, "  Test: ", test_n])
  let _ = print "  Written to training/{train,valid,test}.jsonl"
  0
