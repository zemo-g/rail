-- lr_clip_test.rail — smoke tests for cosine_decay + clip_grad_norm.
-- Expected values verified analytically; visual pass/fail.
import "stdlib/tensor.rail"
import "stdlib/optim.rail"

main =
  let _ = print "=== cosine_decay (warmup=10, max=100, base_lr=1.0) ==="
  let _ = print "step 0   → 0.0       (warmup start)"
  let r0   = cosine_decay 0   10 100 1.0
  let _ = print (show_float r0)

  let _ = print "step 5   → 0.5       (mid warmup)"
  let r5   = cosine_decay 5   10 100 1.0
  let _ = print (show_float r5)

  let _ = print "step 10  → 1.0       (peak)"
  let r10  = cosine_decay 10  10 100 1.0
  let _ = print (show_float r10)

  let _ = print "step 55  → 0.5       (half-cosine midpoint)"
  let r55  = cosine_decay 55  10 100 1.0
  let _ = print (show_float r55)

  let _ = print "step 100 → 0.0       (clamp)"
  let r100 = cosine_decay 100 10 100 1.0
  let _ = print (show_float r100)

  let _ = print "\n=== clip_grad_norm ==="
  let _ = print "Grads: g1=[3,4] g2=[0,0] → norm=5"
  let g1 = tensor_new (cons 2 []) 0.0
  let _ = tensor_set_flat g1 0 3.0
  let _ = tensor_set_flat g1 1 4.0
  let g2 = tensor_new (cons 2 []) 0.0
  let grads = cons g1 (cons g2 [])

  let _ = print "Clip to max=1.0, expect norm pre=5 then scaled grads=[0.6,0.8]"
  let (clipped, pre_norm) = clip_grad_norm grads 1.0
  let _ = print (show_float pre_norm)
  let c1 = head clipped
  let c1_0 = tensor_get_flat c1 0
  let c1_1 = tensor_get_flat c1 1
  let _ = print (show_float c1_0)
  let _ = print (show_float c1_1)

  let _ = print "No-op clip (max=10, norm=5), expect norm=5 and g1[0]=3.0"
  let (clipped2, n2) = clip_grad_norm grads 10.0
  let _ = print (show_float n2)
  let c2 = head clipped2
  let c2_0 = tensor_get_flat c2 0
  let _ = print (show_float c2_0)

  let _ = print "\n=== done ==="
  0
