-- mlx_watchdog.rail — MLX server watchdog (replaces mlx_watchdog.sh)
-- Monitors MLX server health. Restarts on crash or every 30 minutes.
--
-- Usage: ./rail_native run tools/train/mlx_watchdog.rail

trim s = head (split "\n" s)

model = "/Users/ledaticempire/models/Qwen3.5-4B-4bit"
adapter = "/Users/ledaticempire/projects/rail/training/adapters_4b_v5_mlx"
mlx_python = "/Users/ledaticempire/homebrew/bin/python3.11"
port = "8080"
restart_interval = "1800"

start_server dummy =
  let _ = shell (append "pkill -f 'mlx_lm.server.*" (append port "' 2>/dev/null"))
  let _ = shell "sleep 3"
  let cmd = append mlx_python (append " -m mlx_lm.server --model " (append model (append " --adapter-path " (append adapter (append " --host 0.0.0.0 --port " (append port " --trust-remote-code --max-tokens 2048 >> /tmp/mlx_server.log 2>&1 &"))))))
  let _ = shell cmd
  let _ = shell "sleep 15"
  0

log msg =
  let ts = trim (shell "date")
  let line = append ts (append ": " msg)
  let _ = write_file "/tmp/rail_watchdog_line.txt" (append line "\n")
  shell "cat /tmp/rail_watchdog_line.txt >> /tmp/mlx_watchdog.log"

is_server_up dummy =
  trim (shell (append "curl -sf http://localhost:" (append port "/v1/models > /dev/null 2>&1 && echo yes || echo no")))

get_epoch dummy =
  trim (shell "date +%s")

-- Main watchdog loop
watchdog_loop last_restart =
  let _ = shell "sleep 10"
  let now = get_epoch 0
  let elapsed = trim (shell (append "echo $((" (append now (append " - " (append last_restart "))")))))
  let up = is_server_up 0
  if up == "no" then
    let _ = log "MLX server down, restarting..."
    let _ = start_server 0
    let new_ts = get_epoch 0
    watchdog_loop new_ts
  else
    let over = trim (shell (append "test " (append elapsed (append " -ge " (append restart_interval " && echo yes || echo no")))))
    if over == "yes" then
      let _ = log (append "Proactive restart (" (append elapsed "s)"))
      let _ = start_server 0
      let new_ts = get_epoch 0
      watchdog_loop new_ts
    else
      watchdog_loop last_restart

main =
  let ts = trim (shell "date")
  let _ = log (append "Watchdog v3 — 4B+v5 adapter (restart every " (append restart_interval "s)"))
  let _ = print "=== MLX WATCHDOG ==="
  let _ = print (append "  Model: " model)
  let _ = print (append "  Adapter: " adapter)
  let _ = print (append "  Port: " port)
  let _ = print (append "  Restart interval: " (append restart_interval "s"))
  let now = get_epoch 0
  let _ = watchdog_loop now
  0
