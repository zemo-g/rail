-- lm_xval.rail — cross-file holdout eval variant of lm_transformer.rail.
--
-- Same architecture (single-block pre-norm transformer, d=64, d_ff=256,
-- fixed γ/β) and same hyperparams (2000 steps, warmup=100, peak_lr=0.02,
-- Adam). The only change is the corpus:
--
--   train: first 1500 chars of stdlib/tensor.rail
--   val:   first 1500 chars of stdlib/json.rail   ← never seen
--
-- Both sequences encode through the SAME vocab (built from the union) so
-- val chars don't collide with <unk>. Both have the same length (1499
-- tokens) so one positional-encoding table serves both.
--
-- Arity note: the compiler's caller-side `cg_pop_regs` only reaches x27
-- safely before clobbering x28/x29/x30. `train_loop` therefore stays at
-- 28 args (identical signature to lm_transformer.rail); val eval lives
-- in `outer_loop`, which passes weights + Adam states as packed lists
-- so its own arity stays under the cap.
--
-- This run intentionally does NOT save a checkpoint: v0.2 weights on
-- the Shakespeare excerpt are the canonical ones referenced by the
-- running Terminal A work. v0.3 is a separate measurement.
import "stdlib/transformer.rail"
import "stdlib/optim.rail"
import "stdlib/tokenizer.rail"

-- ── Weight init (deterministic scatter, identical to lm_transformer) ──
init_weight arr n seed =
  init_w_loop arr n seed 0

init_w_loop arr n seed i =
  if i >= n then 0
  else
    let raw = ((i * 97 + seed * 13) % 100) - 50
    let _ = float_arr_set arr i (0.01 * int_to_float raw)
    init_w_loop arr n (seed + 1) (i + 1)

-- ── One-hot input fill ──
fill_onehot dst ids V seq i =
  if i >= seq then 0
  else
    let c = head ids
    let _ = float_arr_set dst (i * V + c) 1.0
    fill_onehot dst (tail ids) V seq (i + 1)

fill_labels arr ids seq i =
  if i >= seq then 0
  else
    let _ = float_arr_set arr i (int_to_float (head ids))
    fill_labels arr (tail ids) seq (i + 1)

-- ── Sinusoidal positional encoding [seq, d] ──
pe_loop arr seq d p k =
  if p >= seq then 0
  else if k >= d then pe_loop arr seq d (p + 1) 0
  else
    let exp_arg = int_to_float (k - (k % 2)) / int_to_float d
    let denom = pow 10000.0 exp_arg
    let angle = int_to_float p / denom
    let v = if (k % 2) == 0 then sin angle else cos angle
    let _ = float_arr_set arr (p * d + k) v
    pe_loop arr seq d p (k + 1)

build_pe seq d =
  let arr = float_arr_new (seq * d) 0.0
  let _ = pe_loop arr seq d 0 0
  arr

-- ── Helpers ──
add_buf_inplace dst src n i =
  if i >= n then 0
  else
    let cur = float_arr_get dst i
    let s = float_arr_get src i
    let _ = float_arr_set dst i (cur + s)
    add_buf_inplace dst src n (i + 1)

unwrap t = match t | Tensor d _ _ -> d

relu_fwd src dst mask n i =
  if i >= n then 0
  else
    let v = float_arr_get src i
    let pos = if v > 0.0 then 1.0 else 0.0
    let _ = float_arr_set mask i pos
    let _ = float_arr_set dst i (v * pos)
    relu_fwd src dst mask n (i + 1)

relu_bwd dy mask dx n i =
  if i >= n then 0
  else
    let g = float_arr_get dy i
    let m = float_arr_get mask i
    let _ = float_arr_set dx i (g * m)
    relu_bwd dy mask dx (n + 0) (i + 1)

-- ── Cross-entropy loss + grad over [seq, V] probs ──
lm_ce_loss_loop pd ld seq V acc i =
  if i >= seq then 0
  else
    let target = float_to_int (float_arr_get ld i)
    let p = float_arr_get pd (i * V + target)
    let p2 = if p < 0.00000001 then 0.00000001 else p
    let cur = float_arr_get acc 0
    let _ = float_arr_set acc 0 (cur - log p2)
    lm_ce_loss_loop pd ld seq V acc (i + 1)

ce_loss probs labels seq V = match probs
  | Tensor pd _ _ -> match labels
    | Tensor ld _ _ ->
      let acc = float_arr_new 1 0.0
      let _ = lm_ce_loss_loop pd ld seq V acc 0
      (float_arr_get acc 0) / int_to_float seq

ce_grad_loop dst probs labels seq V invN i =
  if i >= seq * V then 0
  else
    let row = i / V
    let col = i % V
    let target = float_to_int (float_arr_get labels row)
    let p = float_arr_get probs i
    let g = if col == target then (p - 1.0) * invN else p * invN
    let _ = float_arr_set dst i g
    ce_grad_loop dst probs labels seq V invN (i + 1)

-- ── Forward pass (identical to lm_transformer.rail) ──
forward x w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff =
  let e = matmul x w_e
  let ed = unwrap e
  let _ = add_buf_inplace ed pe (seq * d) 0
  let x_pe = e

  let ln1_pack = layernorm_save x_pe ln_g ln_b
  let ln1_out = head ln1_pack
  let ln1_mean = head (tail ln1_pack)
  let ln1_rstd = head (tail (tail ln1_pack))

  let q = matmul ln1_out w_q
  let k = matmul ln1_out w_k
  let v = matmul ln1_out w_v
  let kt = tensor_transpose k
  let scores = matmul q kt
  let scale = 1.0 / sqrt (int_to_float d)
  let scaled = tensor_scale scores scale
  let sd = unwrap scaled
  let _ = apply_causal_mask_loop sd seq 0 0
  let attn = tensor_softmax scaled
  let attn_out = matmul attn v

  let x_attn = tensor_add x_pe attn_out

  let ln2_pack = layernorm_save x_attn ln_g ln_b
  let ln2_out = head ln2_pack
  let ln2_mean = head (tail ln2_pack)
  let ln2_rstd = head (tail (tail ln2_pack))

  let ffn_h_pre = matmul ln2_out w_f1
  let ffn_h_pre_d = unwrap ffn_h_pre
  let ffn_h_data = float_arr_new (seq * d_ff) 0.0
  let ffn_mask = float_arr_new (seq * d_ff) 0.0
  let _ = relu_fwd ffn_h_pre_d ffn_h_data ffn_mask (seq * d_ff) 0
  let ffn_h = Tensor ffn_h_data (cons seq (cons d_ff [])) (compute_strides (cons seq (cons d_ff [])))
  let ffn_out = matmul ffn_h w_f2

  let x_blk = tensor_add x_attn ffn_out

  let logits = matmul x_blk w_o
  let probs = tensor_softmax logits

  let r0 = cons ln2_rstd []
  let r1 = cons ln2_mean r0
  let r2 = cons ln1_rstd r1
  let r3 = cons ln1_mean r2
  let r4 = cons ffn_mask r3
  let r5 = cons ffn_h r4
  let r6 = cons v r5
  let r7 = cons k r6
  let r8 = cons q r7
  let r9 = cons x_pe r8
  let r10 = cons ln1_out r9
  let r11 = cons x_attn r10
  let r12 = cons ln2_out r11
  let r13 = cons x_blk r12
  let r14 = cons attn r13
  cons probs r14

-- ── Training step (identical to lm_transformer.rail) ──
train_step x labels w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff dlog_buf st_we st_wq st_wk st_wv st_wo st_wf1 st_wf2 lr =
  let result = forward x w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff
  let probs = list_nth 0 result
  let attn = list_nth 1 result
  let x_blk = list_nth 2 result
  let ln2_out = list_nth 3 result
  let x_attn = list_nth 4 result
  let ln1_out = list_nth 5 result
  let x_pe = list_nth 6 result
  let q = list_nth 7 result
  let k = list_nth 8 result
  let v = list_nth 9 result
  let ffn_h = list_nth 10 result
  let ffn_mask = list_nth 11 result
  let ln1_mean = list_nth 12 result
  let ln1_rstd = list_nth 13 result
  let ln2_mean = list_nth 14 result
  let ln2_rstd = list_nth 15 result

  let loss = ce_loss probs labels seq V

  match probs | Tensor pd _ _ -> match labels | Tensor ld _ _ ->
    let invN = 1.0 / int_to_float seq
    let _ = ce_grad_loop dlog_buf pd ld seq V invN 0
    let dlog_t = Tensor dlog_buf (cons seq (cons V [])) (compute_strides (cons seq (cons V [])))

    let xblk_t = tensor_transpose x_blk
    let d_wo = matmul xblk_t dlog_t
    let wo_t = tensor_transpose w_o
    let dx_blk = matmul dlog_t wo_t

    let dffn_out = dx_blk

    let ffn_h_t = tensor_transpose ffn_h
    let d_wf2 = matmul ffn_h_t dffn_out
    let wf2_t = tensor_transpose w_f2
    let dffn_h = matmul dffn_out wf2_t

    let dffn_h_pre = float_arr_new (seq * d_ff) 0.0
    let dffn_h_d = unwrap dffn_h
    let _ = relu_bwd dffn_h_d ffn_mask dffn_h_pre (seq * d_ff) 0
    let dffn_h_pre_t = Tensor dffn_h_pre (cons seq (cons d_ff [])) (compute_strides (cons seq (cons d_ff [])))

    let ln2_t = tensor_transpose ln2_out
    let d_wf1 = matmul ln2_t dffn_h_pre_t
    let wf1_t = tensor_transpose w_f1
    let dln2_out = matmul dffn_h_pre_t wf1_t

    let dx_attn_ln = layernorm_backward_dx x_attn ln2_mean ln2_rstd ln_g dln2_out
    let dx_attn = tensor_add dx_blk dx_attn_ln

    let dattn_out = dx_attn

    let (d_q, d_k, d_v) = attention_backward q k v attn dattn_out

    let ln1_t = tensor_transpose ln1_out
    let d_wq = matmul ln1_t d_q
    let d_wk = matmul ln1_t d_k
    let d_wv = matmul ln1_t d_v
    let wq_t = tensor_transpose w_q
    let wk_t = tensor_transpose w_k
    let wv_t = tensor_transpose w_v
    let dx_q = matmul d_q wq_t
    let dx_k = matmul d_k wk_t
    let dx_v = matmul d_v wv_t
    let dln1_out = tensor_add (tensor_add dx_q dx_k) dx_v

    let dx_pe_ln = layernorm_backward_dx x_pe ln1_mean ln1_rstd ln_g dln1_out
    let dx_pe = tensor_add dx_attn dx_pe_ln

    let xT = tensor_transpose x
    let d_we = matmul xT dx_pe

    let we_d = unwrap w_e
    let wq_d = unwrap w_q
    let wk_d = unwrap w_k
    let wv_d = unwrap w_v
    let wo_d = unwrap w_o
    let wf1_d = unwrap w_f1
    let wf2_d = unwrap w_f2
    let dwe_d = unwrap d_we
    let dwq_d = unwrap d_wq
    let dwk_d = unwrap d_wk
    let dwv_d = unwrap d_wv
    let dwo_d = unwrap d_wo
    let dwf1_d = unwrap d_wf1
    let dwf2_d = unwrap d_wf2
    let _ = adam_update_raw we_d dwe_d st_we lr adam_default_b1 adam_default_b2 adam_default_eps
    let _ = adam_update_raw wq_d dwq_d st_wq lr adam_default_b1 adam_default_b2 adam_default_eps
    let _ = adam_update_raw wk_d dwk_d st_wk lr adam_default_b1 adam_default_b2 adam_default_eps
    let _ = adam_update_raw wv_d dwv_d st_wv lr adam_default_b1 adam_default_b2 adam_default_eps
    let _ = adam_update_raw wo_d dwo_d st_wo lr adam_default_b1 adam_default_b2 adam_default_eps
    let _ = adam_update_raw wf1_d dwf1_d st_wf1 lr adam_default_b1 adam_default_b2 adam_default_eps
    let _ = adam_update_raw wf2_d dwf2_d st_wf2 lr adam_default_b1 adam_default_b2 adam_default_eps
    loss

-- Same signature as lm_transformer.rail's train_loop (28 args). Runs
-- steps in [step, max_steps). Caller supplies the chunk bounds.
train_loop x labels w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff dlog_buf st_we st_wq st_wk st_wv st_wo st_wf1 st_wf2 base_lr warmup total_steps step =
  if step >= total_steps then 0
  else
    let lr = cosine_decay step warmup total_steps base_lr
    let mk = arena_mark 0
    let _ = train_step x labels w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff dlog_buf st_we st_wq st_wk st_wv st_wo st_wf1 st_wf2 lr
    let _ = arena_reset mk
    train_loop x labels w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff dlog_buf st_we st_wq st_wk st_wv st_wo st_wf1 st_wf2 base_lr warmup total_steps (step + 1)

eval_loss x labels w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff =
  let result = forward x w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff
  let probs = list_nth 0 result
  ce_loss probs labels seq V

-- ── Outer loop: runs train_loop in 100-step chunks and prints
-- train+val loss between chunks. Weights and Adam states arrive as
-- packed lists so the function fits under the 28-arg arity cap. ──
--
-- weights list index: 0 w_e  1 w_q  2 w_k  3 w_v  4 w_o  5 w_f1 6 w_f2
-- states  list index: 0 we   1 wq   2 wk   3 wv   4 wo   5 wf1  6 wf2
outer_loop x labels x_val labels_val weights states ln_g ln_b pe seq V d d_ff dlog_buf tracker chunk_size total_steps i =
  let start = i * chunk_size
  if start >= total_steps then 0
  else
    let w_e = list_nth 0 weights
    let w_q = list_nth 1 weights
    let w_k = list_nth 2 weights
    let w_v = list_nth 3 weights
    let w_o = list_nth 4 weights
    let w_f1 = list_nth 5 weights
    let w_f2 = list_nth 6 weights
    let st_we = list_nth 0 states
    let st_wq = list_nth 1 states
    let st_wk = list_nth 2 states
    let st_wv = list_nth 3 states
    let st_wo = list_nth 4 states
    let st_wf1 = list_nth 5 states
    let st_wf2 = list_nth 6 states

    let end = start + chunk_size
    let end2 = if end > total_steps then total_steps else end
    let _ = train_loop x labels w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff dlog_buf st_we st_wq st_wk st_wv st_wo st_wf1 st_wf2 0.02 100 end2 start

    let mk_eval = arena_mark 0
    let t_eval = eval_loss x labels w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff
    let v_eval = eval_loss x_val labels_val w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff
    let ratio = v_eval / t_eval
    let _ = print (cat ["step ", show end2, "  train=", show_float t_eval, "  val=", show_float v_eval, "  ratio=", show_float ratio])
    let cur_best = float_arr_get tracker 0
    let _ = if v_eval < cur_best then
      let _ = float_arr_set tracker 0 v_eval
      let _ = float_arr_set tracker 1 (int_to_float end2)
      0
    else 0
    let _ = arena_reset mk_eval

    outer_loop x labels x_val labels_val weights states ln_g ln_b pe seq V d d_ff dlog_buf tracker chunk_size total_steps (i + 1)

ones_loop arr n i =
  if i >= n then 0
  else
    let _ = float_arr_set arr i 1.0
    ones_loop arr n (i + 1)

main =
  let _ = print "=== lm_xval — cross-file holdout eval ==="

  -- Load + slice the two stdlib files. 1500 chars each keeps seq length
  -- (1499) tractable while giving enough Rail syntactic diversity to make
  -- generalization a real question.
  let train_full = read_file "stdlib/tensor.rail"
  let val_full = read_file "stdlib/json.rail"
  let train_text = str_sub train_full 0 1500
  let val_text = str_sub val_full 0 1500

  -- Single vocab from the union of both files. Otherwise a char that
  -- appears in val but not train would encode as -1 and ce_loss would
  -- silently index into garbage.
  let union_text = cat [train_text, val_text]
  let vocab = build_vocab union_text
  let V = vocab_size vocab
  let train_ids = encode vocab train_text
  let val_ids = encode vocab val_text
  let total_t = length train_ids
  let total_v = length val_ids
  let seq = total_t - 1
  let _ = print (cat ["train corpus=stdlib/tensor.rail[0:1500], val corpus=stdlib/json.rail[0:1500]"])
  let _ = print (cat ["train_chars=", show total_t, " val_chars=", show total_v, " vocab=", show V, " seq=", show seq])

  let x_data = float_arr_new (seq * V) 0.0
  let _ = fill_onehot x_data train_ids V seq 0
  let x = Tensor x_data (cons seq (cons V [])) (compute_strides (cons seq (cons V [])))
  let labels_data = float_arr_new seq 0.0
  let _ = fill_labels labels_data (tail train_ids) seq 0
  let labels = Tensor labels_data (cons seq []) (cons 1 [])

  let xv_data = float_arr_new (seq * V) 0.0
  let _ = fill_onehot xv_data val_ids V seq 0
  let x_val = Tensor xv_data (cons seq (cons V [])) (compute_strides (cons seq (cons V [])))
  let lv_data = float_arr_new seq 0.0
  let _ = fill_labels lv_data (tail val_ids) seq 0
  let labels_val = Tensor lv_data (cons seq []) (cons 1 [])

  let d = 64
  let d_ff = 256

  let we_data = float_arr_new (V * d) 0.0
  let _ = init_weight we_data (V * d) 1
  let w_e = Tensor we_data (cons V (cons d [])) (compute_strides (cons V (cons d [])))
  let wq_data = float_arr_new (d * d) 0.0
  let _ = init_weight wq_data (d * d) 2
  let w_q = Tensor wq_data (cons d (cons d [])) (compute_strides (cons d (cons d [])))
  let wk_data = float_arr_new (d * d) 0.0
  let _ = init_weight wk_data (d * d) 3
  let w_k = Tensor wk_data (cons d (cons d [])) (compute_strides (cons d (cons d [])))
  let wv_data = float_arr_new (d * d) 0.0
  let _ = init_weight wv_data (d * d) 4
  let w_v = Tensor wv_data (cons d (cons d [])) (compute_strides (cons d (cons d [])))
  let wo_data = float_arr_new (d * V) 0.0
  let _ = init_weight wo_data (d * V) 5
  let w_o = Tensor wo_data (cons d (cons V [])) (compute_strides (cons d (cons V [])))
  let wf1_data = float_arr_new (d * d_ff) 0.0
  let _ = init_weight wf1_data (d * d_ff) 6
  let w_f1 = Tensor wf1_data (cons d (cons d_ff [])) (compute_strides (cons d (cons d_ff [])))
  let wf2_data = float_arr_new (d_ff * d) 0.0
  let _ = init_weight wf2_data (d_ff * d) 7
  let w_f2 = Tensor wf2_data (cons d_ff (cons d [])) (compute_strides (cons d_ff (cons d [])))

  let lng_data = float_arr_new d 1.0
  let _ = ones_loop lng_data d 0
  let ln_g = Tensor lng_data (cons d []) (cons 1 [])
  let lnb_data = float_arr_new d 0.0
  let ln_b = Tensor lnb_data (cons d []) (cons 1 [])

  let pe = build_pe seq d

  let st_we = adam_state (V * d)
  let st_wq = adam_state (d * d)
  let st_wk = adam_state (d * d)
  let st_wv = adam_state (d * d)
  let st_wo = adam_state (d * V)
  let st_wf1 = adam_state (d * d_ff)
  let st_wf2 = adam_state (d_ff * d)

  let dlog_buf = float_arr_new (seq * V) 0.0

  -- Packed lists for outer_loop.
  let weights = cons w_e (cons w_q (cons w_k (cons w_v (cons w_o (cons w_f1 (cons w_f2 []))))))
  let states = cons st_we (cons st_wq (cons st_wk (cons st_wv (cons st_wo (cons st_wf1 (cons st_wf2 []))))))

  -- tracker: [best_val, best_step_as_float]. Seed best_val high.
  let tracker = float_arr_new 2 0.0
  let _ = float_arr_set tracker 0 1000000000.0
  let _ = float_arr_set tracker 1 (0.0 - 1.0)

  let loss0_t = eval_loss x labels w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff
  let loss0_v = eval_loss x_val labels_val w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff
  let _ = print (cat ["initial train=", show_float loss0_t, "  val=", show_float loss0_v, "  ratio=", show_float (loss0_v / loss0_t)])
  let _ = print (cat ["uniform-baseline (log V)=", show_float (log (int_to_float V))])

  let _ = print "\nTraining 500 steps (d=64, d_ff=256, 50-step chunks with val eval between):"
  let _ = outer_loop x labels x_val labels_val weights states ln_g ln_b pe seq V d d_ff dlog_buf tracker 50 500 0

  let final_t = eval_loss x labels w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff
  let final_v = eval_loss x_val labels_val w_e w_q w_k w_v w_o w_f1 w_f2 ln_g ln_b pe seq V d d_ff
  let final_r = final_v / final_t
  let _ = print (cat ["\nfinal_train=", show_float final_t, "  final_val=", show_float final_v, "  final_ratio=", show_float final_r])
  let best_val = float_arr_get tracker 0
  let best_step = float_to_int (float_arr_get tracker 1)
  let _ = print (cat ["best_val=", show_float best_val, " at step ", show best_step])

  let _ = if final_r < 1.3 then print "verdict: ratio < 1.3 — generalizes, greenlight scale-up"
          else if final_r < 2.0 then print "verdict: 1.3 <= ratio < 2.0 — partial overfit, more data before scaling"
          else print "verdict: ratio >= 2.0 — overfit, do not scale, debug architecture/data"
  0
