-- gen_repairs.rail — Generate synthetic repair training data
-- Takes known-good Rail programs, introduces common model errors,
-- compiles to get real compiler errors, pairs (broken + error -> fixed).
--
-- Usage: cd ~/projects/rail && ./rail_native run tools/train/gen_repairs.rail

cat parts = join "" parts
trim s = head (split "\n" s)
q = "\""

-- ══════════════════════════════════════════════════════════════════════════════
-- Paths
-- ══════════════════════════════════════════════════════════════════════════════

rail_dir = "."
output_file = "training/self_train/synthetic_repairs.jsonl"
repair_sys = "You are a Rail language expert that fixes compiler errors in Rail code."

-- ══════════════════════════════════════════════════════════════════════════════
-- JSON helpers
-- ══════════════════════════════════════════════════════════════════════════════

json_esc_bs s = join "\\\\" (split "\\" s)
json_esc_q s = join "\\\"" (split "\"" s)
json_esc_nl s = join "\\n" (split "\n" s)
json_esc s = json_esc_nl (json_esc_q (json_esc_bs s))

make_repair_entry broken error fixed =
  cat ["{", q, "messages", q, ":[{",
    q, "role", q, ":", q, "system", q, ",",
    q, "content", q, ":", q, json_esc repair_sys, q, "},{",
    q, "role", q, ":", q, "user", q, ",",
    q, "content", q, ":", q, "Fix this Rail code:\\n\\n", json_esc broken, "\\n\\nCompiler error:\\n", json_esc error, q, "},{",
    q, "role", q, ":", q, "assistant", q, ",",
    q, "content", q, ":", q, json_esc fixed, q, "}]}"]

-- ══════════════════════════════════════════════════════════════════════════════
-- Compiler verification
-- ══════════════════════════════════════════════════════════════════════════════

verify_compiles code =
  let _ = write_file "/tmp/rail_repair_test.rail" code
  let _ = shell "rm -f /tmp/rail_repair_bin"
  let _ = shell "cd ~/projects/rail && ./rail_native /tmp/rail_repair_test.rail 2>/tmp/rail_repair_err.txt && cp /tmp/rail_out /tmp/rail_repair_bin 2>/dev/null"
  let check = trim (shell "test -f /tmp/rail_repair_bin && echo ok || echo fail")
  check

verify_runs _ =
  let _ = shell "timeout 5 /tmp/rail_repair_bin > /tmp/rail_repair_run_out.txt 2>&1; echo $? > /tmp/rail_repair_exit.txt"
  let exit_code = trim (shell "cat /tmp/rail_repair_exit.txt 2>/dev/null")
  exit_code

get_compile_error _ =
  trim (shell "cat /tmp/rail_repair_err.txt 2>/dev/null | head -10")

-- Full verify: compiles AND runs
verify_good code =
  let comp = verify_compiles code
  if comp == "fail" then "no"
  else
    let exit = verify_runs 0
    if exit == "0" then "yes" else "no"

-- Verify broken: must fail to compile or crash
verify_broken code =
  let comp = verify_compiles code
  if comp == "fail" then
    let err = get_compile_error 0
    if err == "" then "no_error"
    else err
  else
    let exit = verify_runs 0
    if exit == "0" then "not_broken"
    else "runtime_fail"

-- ══════════════════════════════════════════════════════════════════════════════
-- Mutations — common LLM mistakes applied via shell (sed/perl)
-- Each writes the mutated code to /tmp/rail_mut.rail
-- ══════════════════════════════════════════════════════════════════════════════

-- Mutation 1: Add 'in' after let binding (OCaml/Haskell habit)
apply_let_in code =
  let _ = write_file "/tmp/rail_mut_src.rail" code
  let _ = shell "perl -pe 's/^(\\s+let .+=.*)$/$1 in/ && $c++ if $c < 1' /tmp/rail_mut_src.rail > /tmp/rail_mut.rail"
  let result = trim (shell "cat /tmp/rail_mut.rail")
  if result == code then "" else result

-- Mutation 2: Add 'fn' before function definition (Rust habit)
apply_fn_keyword code =
  let _ = write_file "/tmp/rail_mut_src.rail" code
  let _ = shell "perl -pe 's/^([a-z]\\w+\\s+\\w+.*=)/fn $1/ && $c++ if !$c && !/^(main|let|type|import|--)/' /tmp/rail_mut_src.rail > /tmp/rail_mut.rail"
  let result = trim (shell "cat /tmp/rail_mut.rail")
  if result == code then "" else result

-- Mutation 3: Add 'with' after match (OCaml habit)
apply_match_with code =
  let _ = write_file "/tmp/rail_mut_src.rail" code
  let _ = shell "perl -pe 's/(match\\s+\\w+)\\s*$/$1 with/ && $c++ if $c < 1' /tmp/rail_mut_src.rail > /tmp/rail_mut.rail"
  let result = trim (shell "cat /tmp/rail_mut.rail")
  if result == code then "" else result

-- Mutation 4: Replace cons with :: (OCaml habit)
apply_cons_op code =
  let _ = write_file "/tmp/rail_mut_src.rail" code
  let _ = shell "perl -pe 's/cons (\\w+) (\\w+)/$1 :: $2/ && $c++ if $c < 1' /tmp/rail_mut_src.rail > /tmp/rail_mut.rail"
  let result = trim (shell "cat /tmp/rail_mut.rail")
  if result == code then "" else result

-- Mutation 5: Add semicolons (C/Rust/JS habit)
apply_semicolons code =
  let _ = write_file "/tmp/rail_mut_src.rail" code
  let _ = shell "perl -pe 's/^(\\s*(?:let|print)\\s.+[^;,=])$/$1;/ && $c++ if $c < 1' /tmp/rail_mut_src.rail > /tmp/rail_mut.rail"
  let result = trim (shell "cat /tmp/rail_mut.rail")
  if result == code then "" else result

-- Mutation 6: Add return keyword (imperative habit)
apply_return code =
  let _ = write_file "/tmp/rail_mut_src.rail" code
  let _ = shell "perl -pe 's/^(\\s+)(\\d+)\\s*$/$1return $2/ && $c++ if $c < 1' /tmp/rail_mut_src.rail > /tmp/rail_mut.rail"
  let result = trim (shell "cat /tmp/rail_mut.rail")
  if result == code then "" else result

-- Mutation 7: fun x -> instead of \\x -> (OCaml lambda)
apply_wrong_lambda code =
  let _ = write_file "/tmp/rail_mut_src.rail" code
  let _ = shell "perl -pe 's/\\\\(\\w+)\\s*->/fun $1 ->/ && $c++ if $c < 1' /tmp/rail_mut_src.rail > /tmp/rail_mut.rail"
  let result = trim (shell "cat /tmp/rail_mut.rail")
  if result == code then "" else result

-- Mutation 8: let rec (OCaml habit)
apply_let_rec code =
  let _ = write_file "/tmp/rail_mut_src.rail" code
  let _ = shell "perl -pe 's/^([a-z]\\w+\\s+\\w+.*=)/let rec $1/ && $c++ if !$c && !/^(main|let|type|import|--)/' /tmp/rail_mut_src.rail > /tmp/rail_mut.rail"
  let result = trim (shell "cat /tmp/rail_mut.rail")
  if result == code then "" else result

-- Mutation 9: type annotations (TypeScript/Rust habit)
apply_type_colon code =
  let _ = write_file "/tmp/rail_mut_src.rail" code
  let _ = shell "perl -pe 's/^([a-z]\\w+)\\s+(\\w+)(\\s+=)/\"$1 ($2: int)$3\"/e && $c++ if !$c && !/^(main|let|type|import|--)/' /tmp/rail_mut_src.rail > /tmp/rail_mut.rail"
  let result = trim (shell "cat /tmp/rail_mut.rail")
  if result == code then "" else result

-- Mutation 10: do notation (Haskell habit)
apply_do code =
  let _ = write_file "/tmp/rail_mut_src.rail" code
  let _ = shell "perl -pe 's/^(main\\s*=)/main = do/ && $c++ if $c < 1' /tmp/rail_mut_src.rail > /tmp/rail_mut.rail"
  let result = trim (shell "cat /tmp/rail_mut.rail")
  if result == code then "" else result

-- ══════════════════════════════════════════════════════════════════════════════
-- Load good examples from JSONL files
-- ══════════════════════════════════════════════════════════════════════════════

load_examples _ =
  let _ = write_file "/tmp/rail_load_examples.py" "import json, random\nexamples = []\nfor path in [\n    'training/self_train/harvest.jsonl',\n    'training/handcrafted_l2_l5.jsonl',\n]:\n    try:\n        for line in open(path):\n            line = line.strip()\n            if not line: continue\n            try:\n                d = json.loads(line)\n                code = d['messages'][-1]['content']\n                if len(code) > 30 and 'main' in code:\n                    examples.append(code)\n            except: pass\n    except: pass\nrandom.seed(42)\nrandom.shuffle(examples)\nfor i, code in enumerate(examples):\n    path = f'/tmp/rail_repair_ex_{i}.rail'\n    with open(path, 'w') as f: f.write(code)\nprint(len(examples))\n"
  let count_str = trim (shell "cd ~/projects/rail && python3 /tmp/rail_load_examples.py 2>&1")
  count_str

-- ══════════════════════════════════════════════════════════════════════════════
-- Try one mutation on one example
-- ══════════════════════════════════════════════════════════════════════════════

try_mutation good_code mut_idx =
  let mutated = if mut_idx == 0 then apply_let_in good_code
    else if mut_idx == 1 then apply_fn_keyword good_code
    else if mut_idx == 2 then apply_match_with good_code
    else if mut_idx == 3 then apply_cons_op good_code
    else if mut_idx == 4 then apply_semicolons good_code
    else if mut_idx == 5 then apply_return good_code
    else if mut_idx == 6 then apply_wrong_lambda good_code
    else if mut_idx == 7 then apply_let_rec good_code
    else if mut_idx == 8 then apply_type_colon good_code
    else apply_do good_code
  if mutated == "" then ""
  else
    let err = verify_broken mutated
    if err == "not_broken" then ""
    else if err == "no_error" then ""
    else if err == "runtime_fail" then
      make_repair_entry mutated "Runtime error (segfault or crash)" good_code
    else
      make_repair_entry mutated err good_code

-- Process a single example through all mutations (max 2 per example)
process_one idx =
  let code = trim (shell (cat ["cat /tmp/rail_repair_ex_", show idx, ".rail 2>/dev/null"]))
  if code == "" then 0
  else
    let good = verify_good code
    if good != "yes" then 0
    else
      -- Try mutations 0-9, pick first 2 that work
      let _ = process_mutations idx code 0 0
      0

process_mutations idx code mut_idx found =
  if mut_idx > 9 then found
  else if found >= 2 then found
  else
    let entry = try_mutation code mut_idx
    if entry == "" then process_mutations idx code (mut_idx + 1) found
    else
      let _ = shell (cat ["echo '", entry, "' >> ", output_file])
      let _ = if (found + 1) == 1 then print (cat ["  [", show idx, "] mutation ", show mut_idx, " -> repair generated"])
        else 0
      process_mutations idx code (mut_idx + 1) (found + 1)

-- ══════════════════════════════════════════════════════════════════════════════
-- Main loop
-- ══════════════════════════════════════════════════════════════════════════════

run_loop idx total success =
  if idx >= total then success
  else
    let code = trim (shell (cat ["cat /tmp/rail_repair_ex_", show idx, ".rail 2>/dev/null"]))
    if code == "" then run_loop (idx + 1) total success
    else
      let good = verify_good code
      if good != "yes" then run_loop (idx + 1) total success
      else
        let before = trim (shell (cat ["wc -l < ", output_file, " 2>/dev/null || echo 0"]))
        let _ = process_mutations idx code 0 0
        let after = trim (shell (cat ["wc -l < ", output_file, " 2>/dev/null || echo 0"]))
        run_loop (idx + 1) total success

main =
  let _ = print "=== SYNTHETIC REPAIR GENERATOR (Rail) ==="
  let count_str = load_examples 0
  let _ = print (cat ["  Good examples loaded: ", count_str])
  let _ = print (cat ["  Mutation types: 10"])
  let _ = print (cat ["  Output: ", output_file])
  let _ = print ""
  -- Write header for append
  let _ = shell (cat ["touch ", output_file])
  let before = trim (shell (cat ["wc -l < ", output_file, " 2>/dev/null || echo 0"]))
  -- Process examples (limit to 200 to stay within allocator)
  let total_str = count_str
  let total = if total_str == "" then 0
    else let _ = write_file "/tmp/rail_repairs_total.txt" total_str
      let safe = trim (shell "head -c 10 /tmp/rail_repairs_total.txt | tr -cd '0-9'")
      if safe == "" then 0 else to_int_safe safe
  let limit = if total > 200 then 200 else total
  let _ = print (cat ["  Processing ", show limit, " examples..."])
  let _ = print ""
  let _ = run_loop 0 limit 0
  let after = trim (shell (cat ["wc -l < ", output_file, " 2>/dev/null || echo 0"]))
  let _ = print ""
  let _ = print "=== DONE ==="
  let _ = print (cat ["  Repairs before: ", before])
  let _ = print (cat ["  Repairs after:  ", after])
  let _ = print (cat ["  Total in file:  ", after])
  0
