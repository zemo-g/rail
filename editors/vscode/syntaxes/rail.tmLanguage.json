{
  "scopeName": "source.rail",
  "name": "Rail",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#builtins" },
    { "include": "#numbers" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.rail",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.rail",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.rail",
              "match": "\\\\."
            },
            {
              "name": "meta.embedded.line.rail",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.rail",
          "match": "\\b(if|then|else|match|let|import|module|export|type|effect|perform|handle|with|resume|prop|do)\\b"
        },
        {
          "name": "keyword.operator.arrow.rail",
          "match": "->|\\|>"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.rail",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.rail",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.rail",
          "match": "==|!=|<=|>=|&&|\\|\\||\\+|-|\\*|/|%|<|>|="
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.rail",
          "match": "\\b(print|show|map|filter|fold|head|tail|length|range|append|reverse|sort|zip|cons|enumerate|prompt|prompt_with|prompt_typed|prompt_stream|prompt_model|prompt_json|par_prompt|par_map|par_filter|agent_loop|context_new|context_push|context_prompt|embed|llm_usage|llm_reset|shell|shell_lines|read_file|write_file|read_line|http_get|http_post|json_parse|json_get|env|timestamp|sleep_ms|split|join|trim|chars|contains|starts_with|ends_with|to_upper|to_lower|replace|substring|sqrt|pow|log|sin|cos|tan|pi|abs|max|min|mod|not|int_to_float|floor|ceil|parse_int|parse_float|float_to_str|set_state|get_state|check_reload)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.rail",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.rail",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.rail",
          "match": "^([a-z_][a-zA-Z0-9_]*)\\s+.*="
        }
      ]
    }
  }
}
