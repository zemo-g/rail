{
  "name": "rail-language",
  "displayName": "Rail Language",
  "description": "Syntax highlighting and language server support for Rail",
  "version": "0.6.0",
  "publisher": "zemo-g",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:rail"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "rail",
        "aliases": ["Rail", "rail"],
        "extensions": [".rail"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rail",
        "scopeName": "source.rail",
        "path": "./syntaxes/rail.tmLanguage.json"
      }
    ]
  }
}
