{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Rail",
  "scopeName": "source.rail",
  "fileTypes": ["rail"],
  "comment": "TextMate grammar for Rail, derived from tools/compile.rail tokenizer (line 15 kw_list) and grammar/rail.ebnf in zemo-g/rail",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#keyword" },
    { "include": "#type_declaration" },
    { "include": "#foreign_declaration" },
    { "include": "#import_declaration" },
    { "include": "#constructor" },
    { "include": "#operator" },
    { "include": "#builtin_function" },
    { "include": "#function_declaration" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.double-dash.rail",
          "begin": "--",
          "end": "$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.rail" }
          }
        }
      ]
    },
    "string": {
      "name": "string.quoted.double.rail",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.rail" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.rail" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.rail",
          "match": "\\\\(n|t|r|\\\\|\"|\\{|\\})"
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.rail",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.rail",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.rail",
          "comment": "Reserved keywords from tools/compile.rail:15 kw_list",
          "match": "\\b(let|in|if|then|else|match|type|import|module|export|effect|perform|handle|with|resume|foreign|link)\\b"
        },
        {
          "name": "constant.language.boolean.rail",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.rail",
          "match": "\\bnull\\b"
        }
      ]
    },
    "type_declaration": {
      "match": "\\b(type)\\s+([A-Z][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.type.rail" },
        "2": { "name": "entity.name.type.rail" }
      }
    },
    "foreign_declaration": {
      "match": "\\b(foreign)\\s+([a-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.foreign.rail" },
        "2": { "name": "entity.name.function.foreign.rail" }
      }
    },
    "import_declaration": {
      "match": "\\b(import)\\s+(?:\"([^\"]*)\"|([a-z_][A-Za-z0-9_]*))",
      "captures": {
        "1": { "name": "keyword.control.import.rail" },
        "2": { "name": "string.quoted.double.import.rail" },
        "3": { "name": "entity.name.module.rail" }
      }
    },
    "constructor": {
      "comment": "ADT constructors and types — capitalized identifiers",
      "name": "entity.name.type.constructor.rail",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.rail",
          "match": "->"
        },
        {
          "name": "keyword.operator.pipe.rail",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.logical.rail",
          "match": "(&&|\\|\\||!(?!=))"
        },
        {
          "name": "keyword.operator.comparison.rail",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.rail",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.assignment.rail",
          "match": "="
        },
        {
          "name": "keyword.operator.lambda.rail",
          "match": "\\\\"
        },
        {
          "name": "keyword.operator.pattern.rail",
          "match": "\\|"
        }
      ]
    },
    "builtin_function": {
      "comment": "Builtin functions from tools/compile.rail dispatch tables",
      "name": "support.function.builtin.rail",
      "match": "\\b(print|read_line|read_file|write_file|shell|args|show|show_float|not|to_float|to_int|cons|head|tail|length|reverse|append|map|filter|fold|range|chars|split|cat|join|str_find|str_contains|str_replace|str_split|str_sub|sqrt|sin|cos|tan|tanh|exp|log|pow|fabs|floor|ceil|atan2|fneg|fsqrt|arr_new|arr_get|arr_set|arr_len|float_arr_new|float_arr_get|float_arr_set|float_arr_len|rc_alloc|rc_retain|rc_release|arena_mark|arena_reset|error|is_error|err_msg|gpu_map|spawn|channel|send|recv|fiber_await)\\b"
    },
    "function_declaration": {
      "comment": "Top-level function definitions: name at start of line followed by params and =",
      "match": "^([a-z_][A-Za-z0-9_]*)\\s+(?=[a-z_A-Z0-9_\\s]*=)",
      "captures": {
        "1": { "name": "entity.name.function.rail" }
      }
    },
    "identifier": {
      "name": "variable.other.rail",
      "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
    }
  }
}
