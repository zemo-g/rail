-- flywheel.rail - The Waterfall Orchestrator
-- Usage: cd ~/projects/rail && ./rail_native run flywheel/flywheel.rail [start|status|stop|cycle|auto]

cat parts = join "" parts
trim s = head (split "\n" s)
q = "\""

rail = "./rail_native_llm"
python = "/Users/ledaticempire/homebrew/bin/python3.11"
registry_file = "flywheel/registry.txt"
log_file = "flywheel/flywheel_log.txt"
harvest_file = "training/self_train/harvest.jsonl"
clean_file = "training/self_train/harvest_clean.jsonl"
cycle_interval = 300

write_line file text =
  let _ = write_file "/tmp/flywheel_line.txt" (cat [text, "\n"])
  shell (cat ["cat /tmp/flywheel_line.txt >> ", file])

is_entry l = if length l < 3 then false else head (chars l) != "#"

load_registry _ =
  let content = read_file registry_file
  if length content == 0 then []
  else filter is_entry (split "\n" content)

nth xs n = if n <= 0 then head xs else nth (tail xs) (n - 1)
nth_or xs n def = if n >= length xs then def else nth xs n

get_name e = nth (split "|" e) 0
get_model e = nth (split "|" e) 1
get_adapter e = nth (split "|" e) 2
get_port e = nth (split "|" e) 3

is_alive port =
  let check = trim (shell (cat ["curl -s -m 3 http://localhost:", port, "/v1/models 2>/dev/null | head -1"]))
  length check > 5

start_one entry =
  let name = get_name entry
  let port = get_port entry
  let alive = is_alive port
  if alive then print (cat ["  ", name, " :", port, " already UP"])
  else
    let ap = get_adapter entry
    let mp = get_model entry
    let _ = print (cat ["  Starting ", name, " on :", port, "..."])
    let af = if ap == "none" then "" else cat [" --adapter-path ", ap]
    let _ = shell (cat [python, " -m mlx_lm.server --model ", mp, af, " --host 0.0.0.0 --port ", port, " --trust-remote-code --max-tokens 4096 > /tmp/flywheel_", name, ".log 2>&1 &"])
    let _ = shell "sleep 12"
    let ok = is_alive port
    if ok then print "  Ready." else print "  Not responding"

stop_one entry =
  let port = get_port entry
  let _ = shell (cat ["lsof -ti:", port, " | xargs kill 2>/dev/null"])
  print (cat ["  Stopped ", get_name entry])

pid_for name = cat ["/tmp/flywheel_pid_", name, ".txt"]

is_fw_running name =
  let pid = trim (shell (cat ["cat ", pid_for name, " 2>/dev/null || echo 0"]))
  if pid == "0" then false
  else trim (shell (cat ["kill -0 ", pid, " 2>/dev/null && echo y || echo n"])) == "y"

start_fw entry =
  let name = get_name entry
  if is_fw_running name then print (cat ["  Flywheel ", name, " running"])
  else
    let _ = print (cat ["  Launching flywheel ", name, "..."])
    let _ = shell (cat [rail, " run tools/train/self_train.rail --port ", port, " > /tmp/flywheel_train_", name, ".log 2>&1 & echo $! > ", pid_for name])
    print (cat ["  Started ", name])

stop_fw entry =
  let name = get_name entry
  let pid = trim (shell (cat ["cat ", pid_for name, " 2>/dev/null || echo 0"]))
  if pid == "0" then 0
  else
    let _ = shell (cat ["kill ", pid, " 2>/dev/null; rm -f ", pid_for name])
    let _ = print (cat ["  Stopped flywheel ", name])
    0

show_one entry =
  let name = get_name entry
  let port = get_port entry
  let alive = is_alive port
  let fw = is_fw_running name
  print (cat ["  ", name, " :", port, " srv:", if alive then "UP" else "DOWN", " fw:", if fw then "RUN" else "off"])

merge_all _ =
  let _ = shell (cat [rail, " run flywheel/dataset.rail dedup 2>/dev/null"])
  let _ = shell (cat [rail, " run flywheel/dataset.rail merge 2>/dev/null"])
  let total = trim (shell (cat ["wc -l < ", clean_file, " 2>/dev/null || echo 0"]))
  print (cat ["  Pool: ", total, " clean examples"])

retrain_one entry =
  let name = get_name entry
  let ap = get_adapter entry
  if ap == "none" then 0
  else
    let mp = get_model entry
    let port = get_port entry
    let _ = print (cat ["  Retraining ", name, "..."])
    let _ = stop_fw entry
    let _ = shell (cat ["lsof -ti:", port, " | xargs kill 2>/dev/null; sleep 3"])
    let _ = shell (cat [rail, " run flywheel/dataset.rail prepare 2>/dev/null"])
    let _ = shell (cat [python, " -m mlx_lm lora --model ", mp, " --train --data /tmp/rail_flywheel_data/ --iters 2000 --batch-size 1 --learning-rate 5e-6 --num-layers 16 --max-seq-length 1024 --mask-prompt --adapter-path ", ap, " 2>&1 | tail -3"])
    let _ = start_one entry
    start_fw entry

cmd_start entries =
  let _ = print "== STARTING WATERFALL =="
  let _ = map start_one entries
  let _ = map start_fw entries
  print "== RUNNING =="

cmd_stop entries =
  let _ = map stop_fw entries
  map stop_one entries

cmd_status entries =
  let _ = print "=== FLYWHEEL STATUS ==="
  let raw = trim (shell (cat ["wc -l < ", harvest_file, " 2>/dev/null || echo 0"]))
  let clean = trim (shell (cat ["wc -l < ", clean_file, " 2>/dev/null || echo 0"]))
  let _ = print (cat ["  Pool: ", raw, " raw / ", clean, " clean"])
  map show_one entries

cmd_cycle entries =
  let _ = print "=== CYCLE ==="
  let _ = merge_all 0
  let _ = map retrain_one entries
  let ts = trim (shell "date +%Y-%m-%dT%H:%M:%S")
  let _ = write_line log_file (cat [ts, " cycle"])
  print "  Done."

cmd_auto entries =
  let _ = cmd_start entries
  auto_loop entries

auto_loop entries =
  let _ = shell (cat ["sleep ", show cycle_interval])
  let _ = cmd_cycle entries
  auto_loop entries

cmd_bench entries =
  if length entries == 0 then 0
  else
    let e = head entries
    let port = get_port e
    let _ = if is_alive port then
      shell (cat [rail, " run flywheel/bench.rail --port ", port, " 2>/dev/null | tail -10"])
    else print (cat ["  Skip ", get_name e])
    cmd_bench (tail entries)

get_cmd argv = if length argv <= 1 then "status" else head (tail argv)

main =
  let cmd = get_cmd args
  let entries = load_registry 0
  let _ = if cmd == "status" then cmd_status entries
    else if cmd == "start" then cmd_start entries
    else if cmd == "stop" then cmd_stop entries
    else if cmd == "cycle" then cmd_cycle entries
    else if cmd == "auto" then cmd_auto entries
    else if cmd == "bench" then cmd_bench entries
    else print (cat ["Unknown: ", cmd])
  0
