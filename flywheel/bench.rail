-- bench.rail — Benchmark suite for Rail models
-- Runs fixed tasks against a model, scores pass/fail, reports results.
-- Usage: cd ~/projects/rail && ./rail_native run flywheel/bench.rail [--port 8080]
--
-- The benchmark is deterministic: same tasks every time, comparable across models.

cat parts = join "" parts
trim s = head (split "\n" s)
q = "\""

-- ══════════════════════════════════════════════════════════════════════════════
-- JSON helpers
-- ══════════════════════════════════════════════════════════════════════════════

json_esc_bs s = join "\\\\" (split "\\" s)
json_esc_q s = join "\\\"" (split "\"" s)
json_esc_nl s = join "\\n" (split "\n" s)
json_esc s = json_esc_nl (json_esc_q (json_esc_bs s))

-- LLM interface - native builtin, parameterized by port
llm_call port sys_msg user_msg =
  llm (show port) sys_msg user_msg

-- ══════════════════════════════════════════════════════════════════════════════
-- Compile + Run verification (same as self_train)
-- ══════════════════════════════════════════════════════════════════════════════

verify code =
  let _ = write_file "/tmp/rail_bench_test.rail" code
  let _ = shell "rm -f /tmp/rail_bench_bin"
  let compile_out = shell "cd ~/projects/rail && ./rail_native /tmp/rail_bench_test.rail 2>&1 && cp /tmp/rail_out /tmp/rail_bench_bin 2>&1"
  let check = trim (shell "test -f /tmp/rail_bench_bin && echo ok || echo fail")
  if check == "fail" then "compile_fail"
  else
    let run_out = shell "perl -e 'alarm 5; exec @ARGV' /tmp/rail_bench_bin 2>&1; echo $?"
    let lines = split "\n" run_out
    let exit_code = last_nonempty lines
    if exit_code == "0" then "success"
    else if exit_code == "142" then "timeout"
    else "runtime_fail"

last_nonempty xs =
  if length xs == 0 then ""
  else if length xs == 1 then head xs
  else
    let last = last_nonempty (tail xs)
    if last == "" then head xs else last

-- Try with retry (3 attempts with compiler feedback)
try_task sys port task =
  try_task_acc sys port task "" 1

try_task_acc sys port task prev_err attempt =
  if attempt > 3 then "fail"
  else
    let user = if prev_err == "" then
      cat [task, "\n\nOutput ONLY Rail code. No markdown, no explanation. Functions before main."]
    else
      cat [task, "\n\nYour previous attempt failed:\n", prev_err, "\n\nFix the errors. Output ONLY Rail code."]
    let code = llm_call port sys user
    let result = verify code
    if result == "success" then "pass"
    else if result == "compile_fail" then
      let err_out = trim (shell "cat /tmp/rail_bench_test.rail 2>/dev/null | head -5")
      try_task_acc sys port task (cat ["Compile error for:\n", err_out]) (attempt + 1)
    else "fail"

-- ══════════════════════════════════════════════════════════════════════════════
-- Benchmark tasks — 5 per level band, fixed forever
-- These NEVER change. Scores are comparable across models and time.
-- ══════════════════════════════════════════════════════════════════════════════

-- Band 1: Fundamentals (levels 1-4)
bench_fundamentals _ = [
  "Write a Rail program that computes factorial of 10 and prints it",
  "Write a Rail program that reverses a list [1,2,3,4,5] and prints it",
  "Write a Rail program with a Shape ADT (Circle r | Rect w h) that computes area of Circle 5 and Rect 3 4",
  "Write a Rail program that implements insertion sort on [5,1,4,2,3] and prints the sorted list",
  "Write a Rail program that flattens [[1,2],[3],[4,5,6]] into [1,2,3,4,5,6] using fold and prints it"]

-- Band 2: Practical I/O (levels 5-6)
bench_io _ = [
  "Write a Rail program that writes name=flywheel and version=1 to /tmp/bench_cfg.txt then reads it back and prints each value",
  "Write a Rail program that builds a JSON object with fields name, status, and count as a string and prints it",
  "Write a Rail program that parses the string GET /health HTTP/1.1 into method, path, version and prints each",
  "Write a Rail program that uses shell to get the current date and wraps it in an HTTP 200 JSON response",
  "Write a Rail program that URL-encodes the string hello world & friends replacing spaces and ampersands"]

-- Band 3: Real tools (levels 7-8)
bench_tools _ = [
  "Write a Rail program that generates an HTML page with a title, a CSS style tag, and 3 list items",
  "Write a Rail program that reads /tmp/bench_cfg.txt as key=value pairs and returns the value for a given key",
  "Write a Rail program with a Result ADT (Ok v | Err msg) that chains 3 operations and short-circuits on error",
  "Write a Rail program that implements retry logic: try a shell command up to 3 times, return output or error",
  "Write a Rail program that checks if port 8080 is in use via shell lsof and prints alive or dead"]

-- Band 4: Compiler (level 9-10)
bench_compiler _ = [
  "Write a Rail program with a Bytecode ADT (Push n | Add | Print) and a stack VM that executes [Push 3, Push 4, Add, Print]",
  "Write a Rail program that evaluates an Expr ADT (Num n | Add a b | Mul a b) for Add (Mul (Num 2) (Num 3)) (Num 4)",
  "Write a Rail program that implements constant folding: simplify Add (Num 3) (Num 4) to Num 7 in an Expr ADT",
  "Write a Rail program that collects free variables from Let/Var expressions using an environment list",
  "Write a Rail program that generates a complete HTML dashboard showing hostname and disk usage via shell commands"]

-- Band 5: Advanced (levels 11+)
bench_advanced _ = [
  "Write a Rail program that calls an API via shell curl, extracts a field from the JSON response, and prints it",
  "Write a Rail program that creates a SQLite table, inserts 3 rows, queries them back via shell sqlite3, and prints results",
  "Write a Rail program that reads a JSONL file, filters lines containing a keyword, and writes matching lines to output",
  "Write a Rail program that generates a Rail function definition as a string given a name, params list, and body expression",
  "Write a Rail program that implements a feedback loop: read a score from file, adjust a parameter, write updated config"]

-- Band 6: Comprehension — fix broken code, complete partial code, refactor
-- These test understanding, not just generation.
bench_comprehension _ = [
  "Fix this broken Rail program so it compiles and prints 120:\nfact n = if n <= 1 then 1 else n * fact n - 1\nmain = let _ = print (show (fact 5))\n  0\nThe bug is in the recursive call. Output ONLY the fixed Rail code.",
  "Complete this partial Rail program by writing the missing flatten function that turns [[1,2],[3,4]] into [1,2,3,4]:\nflatten xs = ???\nmain =\n  let r = flatten [[1,2],[3,4]]\n  let _ = print (show (length r))\n  0\nReplace ??? with working code. Output ONLY the complete Rail program.",
  "Refactor this Rail program to use fold instead of manual recursion. It must still print 15:\nsum_list xs = if length xs == 0 then 0 else head xs + sum_list (tail xs)\nmain =\n  let _ = print (show (sum_list [1,2,3,4,5]))\n  0\nOutput ONLY the refactored Rail code.",
  "Fix this Rail program that has a type error — it tries to print a list directly. Make it print each element on a line:\nmain =\n  let xs = map (\\x -> x * 2) [1,2,3]\n  let _ = print xs\n  0\nOutput ONLY the fixed Rail code.",
  "This Rail program should read /tmp/bench_kv.txt (which contains key=val per line), find the value for key name, and print it. The current version crashes. Fix it:\nmain =\n  let _ = write_file \"/tmp/bench_kv.txt\" \"name=rail\\nversion=1\\n\"\n  let contents = read_file \"/tmp/bench_kv.txt\"\n  let lines = split \"\\n\" contents\n  let val = find_key lines \"name\"\n  let _ = print val\n  0\nYou need to write the find_key function. Output ONLY the complete fixed Rail program."]

-- ══════════════════════════════════════════════════════════════════════════════
-- Runner
-- ══════════════════════════════════════════════════════════════════════════════

run_band sys port band_name tasks =
  let _ = print (cat ["\n── ", band_name, " ──"])
  run_band_acc sys port tasks 0 0

run_band_acc sys port tasks pass total =
  if length tasks == 0 then (pass, total)
  else
    let task = head tasks
    let _ = print (cat ["  → ", task])
    let m = arena_mark 0
    let result = try_task sys port task
    let _ = arena_reset m
    let _ = print (cat ["    ", if result == "pass" then "PASS" else "FAIL"])
    run_band_acc sys port (tail tasks) (if result == "pass" then pass + 1 else pass) (total + 1)

-- ══════════════════════════════════════════════════════════════════════════════
-- Main
-- ══════════════════════════════════════════════════════════════════════════════

get_port argv =
  if length argv <= 1 then 8080
  else get_port_acc (tail argv)

get_port_acc argv =
  if length argv == 0 then 8080
  else if head argv == "--port" then
    if length (tail argv) > 0 then to_int (head (tail argv))
    else 8080
  else get_port_acc (tail argv)

mk_sys _ =
  let grammar = read_file "grammar/rail.ebnf"
  cat ["You are a Rail language expert. Rail compiles to native ARM64.\n\nGRAMMAR:\n", grammar, "\n\nCRITICAL RULES:\n- Functions: name params = body (top-level only, no 'let rec')\n- Let uses NEWLINES not 'in': let x = 5\\n  x + 1\n- If: if cond then a else b (always both branches)\n- Match: match expr | Pat args -> expr (NO 'with', NO '::')\n- Lambda: \\x -> expr (single arg only)\n- Lists: [1,2,3], head, tail, cons, map, filter, fold, length, reverse, range\n- Tuples: (a,b), let (x,y) = expr\n- ADTs: type T = | A x | B\\nmatch val | A x -> ... | B -> ...\n- Strings: \"hello\", NO char literals (no 'a'), NO string indexing\n- print outputs value, show converts int to string\n- join sep list, split sep str, chars str, append str1 str2\n- main must exist and return an int\n- Use let _ = print expr for side effects\n- NO: let rec, match...with, x::xs, [x], arr[i], where, in (at end of let)"]

write_line file text =
  let _ = write_file "/tmp/rail_bench_line.txt" (cat [text, "\n"])
  shell (cat ["cat /tmp/rail_bench_line.txt >> ", file])

main =
  let port = get_port args
  let sys = mk_sys 0

  -- Check server
  let check = trim (shell (cat ["curl -s -m 3 http://localhost:", show port, "/v1/models 2>/dev/null | head -1"]))
  let _ = if length check < 5 then
    let _ = print (cat ["ERROR: No MLX server on :", show port])
    let _ = print "Start one first: ./rail_native run flywheel/models.rail start <name>"
    shell "exit 1"
  else print (cat ["Connected to :", show port])

  let _ = print "╔═══════════════════════════════════════╗"
  let _ = print "║  RAIL FLYWHEEL BENCHMARK              ║"
  let _ = print "╚═══════════════════════════════════════╝"

  let (p1, t1) = run_band sys port "FUNDAMENTALS (1-4)" (bench_fundamentals 0)
  let (p2, t2) = run_band sys port "PRACTICAL I/O (5-6)" (bench_io 0)
  let (p3, t3) = run_band sys port "REAL TOOLS (7-8)" (bench_tools 0)
  let (p4, t4) = run_band sys port "COMPILER (9-10)" (bench_compiler 0)
  let (p5, t5) = run_band sys port "ADVANCED (11+)" (bench_advanced 0)
  let (p6, t6) = run_band sys port "COMPREHENSION" (bench_comprehension 0)

  let total_pass = p1 + p2 + p3 + p4 + p5 + p6
  let total_tasks = t1 + t2 + t3 + t4 + t5 + t6
  let pct = if total_tasks > 0 then total_pass * 100 / total_tasks else 0

  let _ = print "\n═══ RESULTS ═══"
  let _ = print (cat ["  Fundamentals: ", show p1, "/", show t1])
  let _ = print (cat ["  Practical IO: ", show p2, "/", show t2])
  let _ = print (cat ["  Real Tools:   ", show p3, "/", show t3])
  let _ = print (cat ["  Compiler:     ", show p4, "/", show t4])
  let _ = print (cat ["  Advanced:     ", show p5, "/", show t5])
  let _ = print (cat ["  Comprehend:   ", show p6, "/", show t6])
  let _ = print (cat ["  TOTAL:        ", show total_pass, "/", show total_tasks, " (", show pct, "%)"])

  -- Write results to log
  let timestamp = trim (shell "date +%Y-%m-%dT%H:%M:%S")
  let _ = write_line "flywheel/bench_log.txt" (cat [timestamp, " port=", show port, " fund=", show p1, "/", show t1, " io=", show p2, "/", show t2, " tools=", show p3, "/", show t3, " comp=", show p4, "/", show t4, " adv=", show p5, "/", show t5, " comp=", show p6, "/", show t6, " total=", show total_pass, "/", show total_tasks, " (", show pct, "%)"])

  let _ = print (cat ["\nLogged to flywheel/bench_log.txt"])
  0
