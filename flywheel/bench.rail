-- bench.rail — Benchmark suite for Rail models
-- Runs fixed tasks against a model, scores pass/fail, reports results.
-- Usage: cd ~/projects/rail && ./rail_native run flywheel/bench.rail [--port 8080]
--
-- The benchmark is deterministic: same tasks every time, comparable across models.

cat parts = join "" parts
trim s = head (split "\n" s)
q = "\""

-- ══════════════════════════════════════════════════════════════════════════════
-- JSON helpers
-- ══════════════════════════════════════════════════════════════════════════════

json_esc_bs s = join "\\\\" (split "\\" s)
json_esc_q s = join "\\\"" (split "\"" s)
json_esc_nl s = join "\\n" (split "\n" s)
json_esc s = json_esc_nl (json_esc_q (json_esc_bs s))

-- LLM interface - native builtin, parameterized by port
llm_call port sys_msg user_msg =
  llm (show port) sys_msg user_msg

-- ══════════════════════════════════════════════════════════════════════════════
-- Compile + Run verification (same as self_train)
-- ══════════════════════════════════════════════════════════════════════════════

-- Verify with optional expected output (empty = compile+run only)
verify code expected =
  let _ = write_file "/tmp/rail_bench_test.rail" code
  let _ = shell "rm -f /tmp/rail_bench_bin"
  let compile_out = shell "cd ~/projects/rail && ./rail_native /tmp/rail_bench_test.rail 2>&1 && cp /tmp/rail_out /tmp/rail_bench_bin 2>&1"
  let check = trim (shell "test -f /tmp/rail_bench_bin && echo ok || echo fail")
  if check == "fail" then "compile_fail"
  else
    let _ = shell "perl -e 'alarm 5; exec @ARGV' /tmp/rail_bench_bin > /tmp/rail_bench_out.txt 2>&1; echo $? > /tmp/rail_bench_exit.txt"
    let actual = trim (shell "cat /tmp/rail_bench_out.txt 2>/dev/null")
    let exit_code = trim (shell "cat /tmp/rail_bench_exit.txt 2>/dev/null")
    if exit_code != "0" then
      if exit_code == "142" then "timeout"
      else "runtime_fail"
    else if expected == "" then
      if actual != "" then "success" else "runtime_fail"
    else
      if actual == expected then "success"
      else "wrong_output"

last_nonempty xs =
  if length xs == 0 then ""
  else if length xs == 1 then head xs
  else
    let last = last_nonempty (tail xs)
    if last == "" then head xs else last

-- Try with retry (3 attempts with compiler feedback)
try_task sys port task expected =
  try_task_acc sys port task expected "" 1

try_task_acc sys port task expected prev_err attempt =
  if attempt > 3 then "fail"
  else
    let hint = if expected == "" then "" else cat ["\n\nThe program must print exactly: ", expected]
    let user = if prev_err == "" then
      cat [task, hint, "\n\nOutput ONLY Rail code. No markdown, no explanation. Functions before main."]
    else
      cat [task, hint, "\n\nYour previous attempt failed:\n", prev_err, "\n\nFix the errors. Output ONLY Rail code."]
    let code = llm_call port sys user
    let result = verify code expected
    if result == "success" then "pass"
    else if result == "compile_fail" then
      let err_out = trim (shell "cat /tmp/rail_bench_test.rail 2>/dev/null | head -5")
      try_task_acc sys port task expected (cat ["Compile error for:\n", err_out]) (attempt + 1)
    else if result == "wrong_output" then
      let actual = trim (shell "cat /tmp/rail_bench_out.txt 2>/dev/null")
      try_task_acc sys port task expected (cat ["Wrong output. Expected: ", expected, " Got: ", actual]) (attempt + 1)
    else "fail"

-- ══════════════════════════════════════════════════════════════════════════════
-- Benchmark tasks — 5 per level band, fixed forever
-- These NEVER change. Scores are comparable across models and time.
-- ══════════════════════════════════════════════════════════════════════════════

-- Band 1: Fundamentals (levels 1-4) — tab-separated: task\texpected
bench_fundamentals _ = [
  "Write a Rail program that computes the 8th triangular number (sum of 1..8) using recursion and prints it\t36",
  "Write a Rail program that builds a list [1,2,3,4,5] then drops the last element using reverse and tail and reverse again, printing the head\t1",
  "Write a Rail program with a Vehicle ADT (Car seats | Bike) that returns seats for Car and 0 for Bike, prints seats for Car 4\t4",
  "Write a Rail program that implements insertion sort on [5,1,4,2,3] and prints the head of the sorted list\t1",
  "Write a Rail program using fold with a named max function to find the largest in [12,7,25,3,18] and prints it\t25"]

-- Band 2: Practical I/O (levels 5-6)
bench_io _ = [
  "Write a Rail program that splits hello-world on - and prints the second element\tworld",
  "Write a Rail program that joins [a,b,c] with commas and prints it\ta,b,c",
  "Write a Rail program that splits GET /health HTTP/1.1 on space and prints the second element\t/health",
  "Write a Rail program that writes test42 to /tmp/rail_bench_io.txt then reads it back and prints it\ttest42",
  "Write a Rail program that takes the string hello world, splits on space, reverses each word using chars reverse join, and prints the first reversed word\tolleh"]

-- Band 3: Real tools (levels 7-8)
bench_tools _ = [
  "Write a Rail program that writes port=9000 to /tmp/rail_bench_cfg.txt, reads it, splits on =, and prints the value\t9000",
  "Write a Rail program that writes hello and world on separate lines to /tmp/rail_bench_lines.txt, reads and prints the line count\t2",
  "Write a Rail program with type Result = | Ok x | Err x, create Ok 42, match it, and print the value\t42",
  "Write a Rail program with type State = | Init | Run | Done, transition Init to Run to Done, and print Done\tDone",
  "Write a Rail program that writes abc to /tmp/rail_bench_cp.txt, copies via shell cp to /tmp/rail_bench_cp2.txt, reads the copy, and prints it\tabc"]

-- Band 4: Compiler (level 9-10)
bench_compiler _ = [
  "Write a Rail program with type Expr = | Num x | Add a b, evaluate Add (Num 3) (Num 4), and print the result\t7",
  "Write a Rail program with type Op = | Push x | Mul | Halt, execute [Push 6, Push 7, Mul, Halt] on a stack list, and print the top\t42",
  "Write a Rail program with type Expr = | Num x | Mul a b, write eval_expr that computes Mul (Num 6) (Num 7), print the value\t42",
  "Write a Rail program that generates the ARM64 string ldr x0, [sp] for a Load instruction from a stack frame and prints it\tldr x0, [sp]",
  "Write a Rail program that takes the token list [if, x, then, y, else, z] and pretty-prints it as if x then y else z\tif x then y else z"]

-- Band 5: Advanced (levels 11+) — self-contained with expected output
bench_advanced _ = [
  "Write a Rail program that writes three JSONL lines ({\"a\":1}, {\"b\":2,\"error\":true}, {\"c\":3}) to /tmp/rail_bench_jsonl.txt, reads it, filters lines containing the string error, and prints the count\t1",
  "Write a Rail program that generates a Rail function definition string for a function named double with param x and body x * 2, and prints it\tdouble x = x * 2",
  "Write a Rail program that writes score=70 to /tmp/rail_bench_score.txt, reads it, extracts the score, adds 5, writes score=75 back, reads again, and prints the final file contents\tscore=75",
  "Write a Rail program that writes k1=v1 and k2=v2 on separate lines to /tmp/rail_bench_kv.txt, reads the file, splits on newline, finds the line starting with k2, splits on =, and prints the value\tv2",
  "Write a Rail program that writes three lines (OK: start, ERROR: fail, ERROR: crash) to /tmp/rail_bench_log.txt, reads the file, splits on newline, counts lines containing ERROR, and prints the count\t2"]

-- Band 6: Comprehension — fix broken code, complete partial code, refactor
-- These test understanding, not just generation.
bench_comprehension _ = [
  "Fix this broken Rail program so it compiles and prints 120:\nfact n = if n <= 1 then 1 else n * fact n - 1\nmain = let _ = print (show (fact 5))\n  0\nThe bug is in the recursive call. Output ONLY the fixed Rail code.\t120",
  "Complete this partial Rail program by writing the missing flatten function that turns [[1,2],[3,4]] into [1,2,3,4]:\nflatten xs = ???\nmain =\n  let r = flatten [[1,2],[3,4]]\n  let _ = print (show (length r))\n  0\nReplace ??? with working code. Output ONLY the complete Rail program.\t4",
  "Refactor this Rail program to use fold instead of manual recursion. It must still print 15:\nsum_list xs = if length xs == 0 then 0 else head xs + sum_list (tail xs)\nmain =\n  let _ = print (show (sum_list [1,2,3,4,5]))\n  0\nOutput ONLY the refactored Rail code.\t15",
  "Fix this Rail program that has a type error — it tries to print a list directly. Make it print the sum of the doubled values instead:\nmain =\n  let xs = map (\\x -> x * 2) [1,2,3]\n  let _ = print xs\n  0\nOutput ONLY the fixed Rail code that prints 12.\t12",
  "This Rail program should read /tmp/bench_kv.txt (which contains key=val per line), find the value for key name, and print it. The current version crashes. Fix it:\nmain =\n  let _ = write_file \"/tmp/bench_kv.txt\" \"name=rail\\nversion=1\\n\"\n  let contents = read_file \"/tmp/bench_kv.txt\"\n  let lines = split \"\\n\" contents\n  let val = find_key lines \"name\"\n  let _ = print val\n  0\nYou need to write the find_key function. Output ONLY the complete fixed Rail program.\trail"]

-- ══════════════════════════════════════════════════════════════════════════════
-- Runner
-- ══════════════════════════════════════════════════════════════════════════════

-- Parse tab-separated task: "description\texpected" or just "description"
bench_task_desc t = head (split "\t" t)
bench_task_expected t =
  let parts = split "\t" t
  if length parts >= 2 then head (tail parts)
  else ""

run_band sys port band_name tasks =
  let _ = print (cat ["\n── ", band_name, " ──"])
  run_band_acc sys port tasks 0 0

run_band_acc sys port tasks pass total =
  if length tasks == 0 then (pass, total)
  else
    let task_line = head tasks
    let task = bench_task_desc task_line
    let expected = bench_task_expected task_line
    let _ = print (cat ["  → ", task, if expected == "" then "" else cat [" [expect: ", expected, "]"]])
    let m = arena_mark 0
    let result = try_task sys port task expected
    let _ = arena_reset m
    let _ = print (cat ["    ", if result == "pass" then "PASS" else "FAIL"])
    run_band_acc sys port (tail tasks) (if result == "pass" then pass + 1 else pass) (total + 1)

-- ══════════════════════════════════════════════════════════════════════════════
-- Main
-- ══════════════════════════════════════════════════════════════════════════════

get_port argv =
  if length argv <= 1 then 8080
  else get_port_acc (tail argv)

get_port_acc argv =
  if length argv == 0 then 8080
  else if head argv == "--port" then
    if length (tail argv) > 0 then to_int (head (tail argv))
    else 8080
  else get_port_acc (tail argv)

mk_sys _ =
  let grammar = read_file "grammar/rail.ebnf"
  cat ["You are a Rail language expert. Rail compiles to native ARM64.\n\nGRAMMAR:\n", grammar, "\n\nCRITICAL RULES:\n- Functions: name params = body (top-level only, no 'let rec')\n- Let uses NEWLINES not 'in': let x = 5\\n  x + 1\n- If: if cond then a else b (always both branches)\n- Match: match expr | Pat args -> expr (NO 'with', NO '::')\n- Lambda: \\x -> expr (single arg only)\n- Lists: [1,2,3], head, tail, cons, map, filter, fold, length, reverse, range\n- Tuples: (a,b), let (x,y) = expr\n- ADTs: type T = | A x | B\\nmatch val | A x -> ... | B -> ...\n- Strings: \"hello\", NO char literals (no 'a'), NO string indexing\n- print outputs value, show converts int to string\n- join sep list, split sep str, chars str, append str1 str2\n- main must exist and return an int\n- Use let _ = print expr for side effects\n- NO: let rec, match...with, x::xs, [x], arr[i], where, in (at end of let)"]

write_line file text =
  let _ = write_file "/tmp/rail_bench_line.txt" (cat [text, "\n"])
  shell (cat ["cat /tmp/rail_bench_line.txt >> ", file])

main =
  let port = get_port args
  let sys = mk_sys 0

  -- Check server
  let check = trim (shell (cat ["curl -s -m 3 http://localhost:", show port, "/v1/models 2>/dev/null | head -1"]))
  let _ = if length check < 5 then
    let _ = print (cat ["ERROR: No MLX server on :", show port])
    let _ = print "Start one first: ./rail_native run flywheel/models.rail start <name>"
    shell "exit 1"
  else print (cat ["Connected to :", show port])

  let _ = print "╔═══════════════════════════════════════╗"
  let _ = print "║  RAIL FLYWHEEL BENCHMARK              ║"
  let _ = print "╚═══════════════════════════════════════╝"

  let (p1, t1) = run_band sys port "FUNDAMENTALS (1-4)" (bench_fundamentals 0)
  let (p2, t2) = run_band sys port "PRACTICAL I/O (5-6)" (bench_io 0)
  let (p3, t3) = run_band sys port "REAL TOOLS (7-8)" (bench_tools 0)
  let (p4, t4) = run_band sys port "COMPILER (9-10)" (bench_compiler 0)
  let (p5, t5) = run_band sys port "ADVANCED (11+)" (bench_advanced 0)
  let (p6, t6) = run_band sys port "COMPREHENSION" (bench_comprehension 0)

  let total_pass = p1 + p2 + p3 + p4 + p5 + p6
  let total_tasks = t1 + t2 + t3 + t4 + t5 + t6
  let pct = if total_tasks > 0 then total_pass * 100 / total_tasks else 0

  let _ = print "\n═══ RESULTS ═══"
  let _ = print (cat ["  Fundamentals: ", show p1, "/", show t1])
  let _ = print (cat ["  Practical IO: ", show p2, "/", show t2])
  let _ = print (cat ["  Real Tools:   ", show p3, "/", show t3])
  let _ = print (cat ["  Compiler:     ", show p4, "/", show t4])
  let _ = print (cat ["  Advanced:     ", show p5, "/", show t5])
  let _ = print (cat ["  Comprehend:   ", show p6, "/", show t6])
  let _ = print (cat ["  TOTAL:        ", show total_pass, "/", show total_tasks, " (", show pct, "%)"])

  -- Write results to log
  let timestamp = trim (shell "date +%Y-%m-%dT%H:%M:%S")
  let _ = write_line "flywheel/bench_log.txt" (cat [timestamp, " port=", show port, " fund=", show p1, "/", show t1, " io=", show p2, "/", show t2, " tools=", show p3, "/", show t3, " comp=", show p4, "/", show t4, " adv=", show p5, "/", show t5, " comprehend=", show p6, "/", show t6, " total=", show total_pass, "/", show total_tasks, " (", show pct, "%)"])

  let _ = print (cat ["\nLogged to flywheel/bench_log.txt"])
  0
