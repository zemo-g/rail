-- hello.rail — first Rail program

add : i32 -> i32 -> i32
add x y =
  x + y

double : i32 -> i32
double n =
  n * 2

type Option T =
  | Some T
  | None

describe : i32 -> str
describe n =
  match n
    0 -> "zero"
    1 -> "one"
    _ -> "many"

factorial : i32 -> i32
factorial n =
  if n <= 1 then 1 else n * factorial (n - 1)

main =
  let _ = print "Hello from Rail!"
  let _ = print (append "5! = " (show (factorial 5)))
  let _ = print (describe 0)
  let _ = print (describe 42)
  0
