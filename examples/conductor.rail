-- conductor.rail — Rail program that orchestrates a local LLM
-- Demonstrates the conductor pattern: Rail controls the train, LLM does the work

analyze_file : String -> String -> String
analyze_file path content =
  let line_count = split "\n" content |> length
  let word_count = split " " content |> length
  append (append (append path ": ") (show line_count)) (append " lines, ~" (append (show word_count) " words"))

print_file_stats : String -> String -> i32
print_file_stats dir f =
  let content = read_file (append dir f)
  let info = analyze_file f content
  let _ = print info
  0

summarize : String -> String
summarize content = prompt_with "Summarize this code in one sentence. Be concise." content

main =
  let _ = print "=== Rail Conductor Demo ==="
  let _ = print ""
  let dir = "/Users/ledaticempire/projects/rail/examples/"
  let files = shell_lines (append "ls " dir)
  let rail_files = filter (\f -> contains ".rail" f) files
  let _ = print (append "Found " (append (show (length rail_files)) " Rail files:"))
  let _ = print ""
  let _ = map (\f -> print_file_stats dir f) rail_files
  let _ = print ""
  let _ = print "=== LLM Analysis of hello.rail ==="
  let hello = read_file (append dir "hello.rail")
  let summary = summarize hello
  let _ = print summary
  0
