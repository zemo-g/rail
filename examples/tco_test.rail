-- Tail call optimization test
-- These would stack overflow without TCO

count_down : i32 -> i32
count_down n =
  if n == 0 then 0 else count_down (n - 1)

sum_acc : i32 -> i32 -> i32
sum_acc n acc =
  if n == 0 then acc else sum_acc (n - 1) (acc + n)

main =
  let _ = print (count_down 1000000)
  let _ = print (sum_acc 1000000 0)
  0
