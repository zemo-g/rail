-- demo_pitch.rail — Ad Intelligence Pipeline Demo
-- Demonstrates Rail's conductor pattern: sandboxed orchestration of LLM analysis
-- Run: rail run examples/demo_pitch.rail --allow ai

-- Sample ad transcript (inline — no filesystem needed)
ad_transcript : String
ad_transcript =
  "Have you or a loved one been diagnosed with cancer after being stationed at Camp Lejeune? You may be entitled to significant compensation. The water at Camp Lejeune was contaminated with toxic chemicals for over 30 years. Call the law offices of Morrison & Associates now at 1-800-555-JUSTICE. Time is running out — the filing deadline is approaching fast. Don't wait. Call today for your FREE legal consultation. Morrison & Associates has recovered over $2 billion for victims nationwide."

-- Build the extraction prompt
extraction_prompt : String
extraction_prompt =
  append "Analyze this legal advertisement transcript and extract the following. Respond with exactly four lines, no labels, no extra text:\nLine 1: Advertiser name\nLine 2: Ad type (TV, Radio, Digital, Print, or Streaming)\nLine 3: Legal vertical (e.g. Camp Lejeune, Roundup, Talcum Powder, etc.)\nLine 4: Urgency score 1-5 (1=informational, 5=extremely aggressive)\n\nTranscript:\n" ad_transcript

-- Format a labeled result line
format_line : String -> String -> String
format_line label value =
  append (append "  " label) (append ": " value)

-- Print a section divider
divider : String -> i32
divider title =
  let _ = print ""
  let bar = "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  let _ = print bar
  let _ = print (append "  " title)
  let _ = print bar
  0

-- Print the four extracted fields from LLM response
safe_head : String -> [String] -> String
safe_head default xs = if length xs == 0 then default else head xs

safe_tail : [String] -> [String]
safe_tail xs = if length xs == 0 then [] else tail xs

print_extraction : String -> i32
print_extraction response =
  let lines = split "\n" response
  let advertiser = safe_head "N/A" lines
  let rest1 = safe_tail lines
  let ad_type = safe_head "N/A" rest1
  let rest2 = safe_tail rest1
  let vertical = safe_head "N/A" rest2
  let rest3 = safe_tail rest2
  let urgency = safe_head "N/A" rest3
  let _ = print (format_line "Advertiser" advertiser)
  let _ = print (format_line "Ad Type" ad_type)
  let _ = print (format_line "Vertical" vertical)
  let _ = print (format_line "Urgency" urgency)
  0

main =
  let t0 = timestamp 0
  let _ = print ""
  let _ = print "  RAIL — Ad Intelligence Pipeline"
  let _ = print "  Sandboxed Route: [ai] enabled"
  let _ = print "  All LLM calls run through the conductor pattern"
  let _ = divider "STAGE 1: Ad Transcript"
  let _ = print ""
  let _ = print "  Input: Camp Lejeune mass tort advertisement (Morrison & Associates)"
  let _ = print (append "  Length: " (append (show (length (split " " ad_transcript))) " words"))
  let _ = divider "STAGE 2: Structured Extraction (LLM)"
  let _ = print ""
  let extraction = prompt_with "You are an ad intelligence extraction engine. Return exactly four lines, no labels, no bullets, no extra text. Be concise, one line." extraction_prompt
  let _ = print_extraction extraction
  let _ = divider "STAGE 3: Competitive Intelligence Summary (LLM)"
  let _ = print ""
  let summary_prompt = append "You are a competitive intelligence analyst for legal advertising. Given this ad transcript, write a brief competitive intelligence summary covering: positioning strategy, target demographic, call-to-action effectiveness, and one recommended counter-strategy for a competing firm. Keep it to 4-5 sentences.\n\nTranscript:\n" ad_transcript
  let summary = prompt_with "You are a legal ad competitive intelligence analyst. Be concise, one line." summary_prompt
  let _ = print (append "  " summary)
  let t1 = timestamp 0
  let elapsed = t1 - t0
  let _ = divider "COMPLETE"
  let _ = print ""
  let _ = print (append "  Total pipeline time: " (append (show elapsed) "s"))
  let _ = print "  Route permissions used: [ai]"
  let _ = print "  Filesystem access: none (sandboxed)"
  let _ = print ""
  0
