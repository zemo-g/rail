-- native_closures.rail — tests closures and higher-order functions in native codegen

double : i32 -> i32
double x = x * 2

triple : i32 -> i32
triple x = x * 3

apply : (i32 -> i32) -> i32 -> i32
apply f x = f x

make_adder : i32 -> i32 -> i32
make_adder n x = n + x

main =
  let _ = print (apply double 5)
  let _ = print (apply triple 5)
  let _ = print (apply (make_adder 10) 5)
  let _ = print (apply (make_adder 100) 7)
  0
