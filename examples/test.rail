-- test.rail — interpreter showcase

add : i32 -> i32 -> i32
add x y = x + y

double : i32 -> i32
double n = n * 2

factorial : i32 -> i32
factorial n =
  if n == 0 then 1 else n * factorial (n - 1)

type Option T =
  | Some T
  | None

describe : i32 -> str
describe n =
  match n
    0 -> "zero"
    1 -> "one"
    _ -> "many"

type Point =
  x: f64
  y: f64

origin = { x: 0.0, y: 0.0 }

main =
  let _ = print (add 3 4)
  let _ = print (double 21)
  let _ = print (factorial 10)
  let _ = print (describe 0)
  let _ = print (describe 42)
  let _ = print (Some 99)
  let _ = print None
  let _ = print origin
  print (origin.x)
