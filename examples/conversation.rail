-- conversation.rail — Multi-turn conversation with memory
--
-- Uses context_new/context_push/context_prompt to maintain
-- conversation state across multiple LLM calls.
--
-- Run: rail run examples/conversation.rail --allow ai

main =
  let ctx = context_new "You are a patient math tutor. Explain concepts step by step."

  -- Turn 1
  let (ctx, r1) = context_prompt ctx "What is a derivative?"
  let _ = print "Tutor: {r1}"
  let _ = print ""

  -- Turn 2 (builds on previous context)
  let (ctx, r2) = context_prompt ctx "Can you give me a simple example?"
  let _ = print "Tutor: {r2}"
  let _ = print ""

  -- Turn 3
  let (ctx, r3) = context_prompt ctx "How is this used in machine learning?"
  let _ = print "Tutor: {r3}"

  let _ = print ""
  let _ = print "Conversation length: {length ctx.messages} messages"
  0
