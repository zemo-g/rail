-- agent.rail — Multi-turn agent with tools
--
-- The LLM decides which tool to call. Rail executes it.
-- Result is fed back. Loop until the LLM says DONE.
--
-- Run: rail run examples/agent.rail --allow ai

-- Tools are just Rail functions
search query =
  prompt_with "You are a search engine. Give a brief factual answer." query

calculate expr =
  prompt_with "You are a calculator. Evaluate this and give just the number." expr

-- Define tools and their descriptions
tools = [("search", "Search for factual information"), ("calculate", "Evaluate a math expression")]
fns = [search, calculate]

-- Run the agent
main =
  let result = agent_loop "You are a research assistant. Use tools to find information." tools fns "What is the population of Tokyo multiplied by 2?"
  let _ = print "Answer: {result.answer}"
  let _ = print ""
  let _ = print "Tool calls:"
  let _ = map (\step -> print "  {step.tool}({step.input}) -> {step.output}") result.history
  0
