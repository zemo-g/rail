-- evolve.rail — Autonomous Rail evolution loop
--
-- Generates Rail programs, validates them, learns from failures.
-- Each round uses failure feedback to improve the next generation.
--
-- RAIL_AI_PROVIDER=local RAIL_AI_MODEL="/Users/ledaticempire/models/Qwen3.5-9B-6bit" rail run examples/evolve.rail --open

base_prompt = "You write Rail programs. Output ONLY valid Rail code. No markdown, no backticks, no comments, no type signatures. CRITICAL RULES: 1) No colons after function names — just: fname arg = body. 2) No semicolons. 3) 2-space indent. 4) main = ... returns 0. 5) let _ = print val. 6) Lambda: (\\x -> x * 2). 7) if c then a else b (NOT guards). 8) Lists: [1,2,3]. map f list. filter f list. fold init f list. 9) range start end gives [start..end). 10) reverse list. append a b. length list. 11) No 'where', no 'do', no '@'. EXAMPLES:\nfactorial n = if n <= 1 then 1 else n * (factorial (n - 1))\nmain =\n  let _ = print (factorial 7)\n  0\n---\nmain =\n  let evens = filter (\\x -> x % 2 == 0) (range 1 21)\n  let _ = print evens\n  0\n---\nfib n = if n <= 1 then n else (fib (n - 1)) + (fib (n - 2))\nmain =\n  let fibs = map fib (range 0 10)\n  let _ = print fibs\n  0\n---\nmy_reverse lst = fold [] (\\acc -> \\x -> cons x acc) lst\nmain =\n  let _ = print (my_reverse [1, 2, 3, 4, 5])\n  0"

validate code =
  let _ = write_file "/tmp/_rail_evolve.rail" code
  trim (shell "cd /Users/ledaticempire/projects/rail && ./target/release/rail run /tmp/_rail_evolve.rail --open 2>&1")

score result =
  if contains "error" (to_lower result) then 0
  else if length (trim result) == 0 then 0
  else 1

run_task prompt task =
  let code = prompt_with prompt task
  let result = validate code
  let s = score result
  let _ = if s == 1 then print (append "  PASS: " task) else print (append "  FAIL: " (append task (append " -> " (substring 0 80 result))))
  s

tasks = [
  "Print numbers 1 through 5 each on its own line",
  "Print the factorial of 7",
  "Print the first 10 fibonacci numbers as a list",
  "Reverse the list [1,2,3,4,5] and print it",
  "Print all even numbers from 1 to 20",
  "Compute the sum of squares of [1,2,3,4,5] and print it",
  "Print the length of the string hello world",
  "Define a max function and find the max of 3 and 7"
]

main =
  let _ = print "=== Rail Evolution Loop ==="
  let _ = print ""

  -- Round 1: base prompt
  let _ = print "Round 1 (base prompt):"
  let r1_scores = map (run_task base_prompt) tasks
  let r1_pass = fold 0 (\acc -> \x -> acc + x) r1_scores
  let _ = print (append "  Score: " (append (show r1_pass) (append "/" (show (length tasks)))))
  let _ = print ""

  -- Build feedback from failures
  let _ = print "Round 2 (with failure feedback):"
  let enhanced = append base_prompt "\nADDITIONAL: Do NOT use type annotations like 'f : Int -> Int'. Do NOT use semicolons. Do NOT use pattern matching with pipes for simple functions — use if/else. Keep it simple. One function definition per line."
  let r2_scores = map (run_task enhanced) tasks
  let r2_pass = fold 0 (\acc -> \x -> acc + x) r2_scores
  let _ = print (append "  Score: " (append (show r2_pass) (append "/" (show (length tasks)))))
  let _ = print ""

  -- Round 3: even more specific
  let _ = print "Round 3 (maximally specific):"
  let final_prompt = append enhanced "\nREMEMBER: Output ONLY the Rail code. Start with function definitions, end with main = ... 0. Every function is just: name arg1 arg2 = expression. Multi-line bodies indent 2 spaces under the =. Use let _ = print (expr) to display values."
  let r3_scores = map (run_task final_prompt) tasks
  let r3_pass = fold 0 (\acc -> \x -> acc + x) r3_scores
  let _ = print (append "  Score: " (append (show r3_pass) (append "/" (show (length tasks)))))

  let _ = print ""
  let u = llm_usage ()
  let _ = print (append "Total: " (append (show u.total_tokens) (append " tokens, " (append (show u.calls) " calls"))))
  let _ = print (append "Improvement: " (append (show r1_pass) (append " -> " (append (show r2_pass) (append " -> " (show r3_pass))))))
  0
