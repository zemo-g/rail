-- simple.rail — basic functions

add : i32 -> i32 -> i32
add x y =
  x + y

double : i32 -> i32
double n =
  n * 2

factorial : i32 -> i32
factorial n =
  if n == 0 then 1 else n * factorial (n - 1)

type Option T =
  | Some T
  | None

type Point =
  x: f64
  y: f64

origin : Point
origin = { x: 0.0, y: 0.0 }

describe : i32 -> str
describe n =
  match n
    0 -> "zero"
    1 -> "one"
    _ -> "many"
