-- researcher.rail — AI research conductor
--
-- The full loop: reads a topic, generates questions in parallel,
-- gets answers in parallel, produces a report with token tracking.
-- 6 LLM calls, 3 angles, all parallel.

main =
  let topic = trim (read_file "/tmp/topic.txt")
  print "=== Research Conductor ==="
  print "Topic: {topic}\n"
  llm_reset ()

  -- Generate 3 research questions from different angles (parallel fan-out)
  let q_system = "Generate one specific, thought-provoking research question about the given topic from the requested angle. Output ONLY the question, nothing else."
  let angles = ["{topic} — angle: foundational (core mechanisms or causes)", "{topic} — angle: contrarian (challenge conventional wisdom)", "{topic} — angle: applied (practical implications or future use)"]
  let questions = par_prompt q_system angles
  print "Generated {length questions} questions:\n"
  map (\q -> print "  ? {q}") questions
  print ""

  -- Get answers for all 3 questions (parallel fan-out)
  let a_system = "Answer this research question concisely in 2-3 sentences. Be specific and insightful."
  let answers = par_prompt a_system questions
  print "=== Findings ===\n"

  -- Print Q&A pairs
  let pairs = zip questions answers
  map (\p -> print "Q: {p}\n") pairs

  -- Report
  let u = llm_usage ()
  print "=== {u.calls} LLM calls | {u.total_tokens} tokens ==="
