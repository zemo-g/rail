-- Chain AI calls — pure functional composition
summarize : str -> str
summarize text = prompt_with "Summarize in one sentence" text

translate : str -> str -> str
translate lang text = prompt_with (append "Translate to " lang) text

main =
  let text = "The quick brown fox jumps over the lazy dog. This sentence contains every letter of the alphabet."
  let summary = summarize text
  let _ = print summary
  let spanish = translate "Spanish" summary
  let _ = print spanish
  0
