-- code_reviewer.rail — AI code review conductor
--
-- Reviews ALL Rail source files in parallel (batched),
-- with thinking tag stripping and token tracking.

build_prompt path =
  let content = read_file path
  let n = split "\n" content |> length
  append "File: " (append path (append " (" (append (show n) (append " lines)\n\n" content))))

main =
  print "=== Rail Code Reviewer ==="
  llm_reset ()

  let files = shell_lines "ls examples/*.rail"
  print "Found {length files} files — reviewing in batches of 4...\n"

  let prompts = map build_prompt files
  let system = "You are reviewing Rail source code. Rail is a pure functional AI-native language with effects, auto-parallelization, and hot reload. For each file: 1) one-line summary 2) one strength 3) one suggestion. 3 lines max, no markdown."
  let reviews = par_prompt system prompts

  let pairs = zip files reviews
  map (\p -> print "{p}\n") pairs

  let u = llm_usage ()
  print "=== {u.calls} files | {u.total_tokens} tokens ==="
