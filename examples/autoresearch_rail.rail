-- autoresearch_rail.rail — Rail evolving Rail
--
-- This conductor asks the LLM to generate Rail programs of increasing
-- complexity, validates each one by running it, and feeds results back
-- to generate better programs. Autonomous prompt research, in Rail.
--
-- Run: RAIL_AI_PROVIDER=local RAIL_AI_MODEL="/Users/ledaticempire/models/Qwen3.5-9B-6bit" rail run examples/autoresearch_rail.rail --open

-- System prompt with working Rail examples
sys = "You write Rail programs. Output ONLY valid Rail code. No markdown, no explanation, no backticks, no comments. CRITICAL: Do NOT write type signatures. No colons after function names. Just write: fname arg1 arg2 = body. Rail syntax: 1) main = ... returns 0. 2) let _ = print value. 3) fname arg1 arg2 = body. 4) 2-space indent for multi-line. 5) if c then a else b. 6) Lists: [1, 2, 3]. 7) Lambda: (\\x -> x * 2). 8) map f list, filter f list, fold init f list. 9) ADTs: type Option T =\n  | Some T\n  | None. 10) match val\n  Some x -> x\n  None -> 0. 11) Records are defined with type Point = x: f64, y: f64. Access fields with dot: p.x. 12) reverse list reverses. 13) append list1 list2 or append str1 str2. 14) range start end makes [start..end). 15) No semicolons, no @, no where, no do, no guards. 16) Recursion with explicit if/else, not guards. EXAMPLES:\nfactorial n = if n <= 1 then 1 else n * (factorial (n - 1))\nmain =\n  let _ = print (factorial 7)\n  0\n---\nmain =\n  let nums = filter (\\x -> x % 2 == 0) (range 1 21)\n  let _ = print nums\n  0\n---\ndouble x = x * 2\nmain =\n  let result = map double [1, 2, 3, 4, 5]\n  let total = fold 0 (\\acc -> \\x -> acc + x) result\n  let _ = print total\n  0\n---\nfib n = if n <= 1 then n else (fib (n - 1)) + (fib (n - 2))\nmain =\n  let fibs = map fib (range 0 10)\n  let _ = print fibs\n  0"

-- Generate a Rail program for a given task
generate task =
  prompt_with sys task

-- Validate by actually running the generated code
validate code =
  let _ = write_file "/tmp/_rail_evolve.rail" code
  let result = shell "cd /Users/ledaticempire/projects/rail && ./target/release/rail run /tmp/_rail_evolve.rail --open 2>&1"
  result

-- Score: did it produce output without errors?
score result =
  if contains "error" (to_lower result) then 0
  else if contains "runtime" (to_lower result) then 0
  else if length (trim result) == 0 then 0
  else 1

-- One experiment: generate, validate, score
experiment task =
  let code = generate task
  let result = validate code
  let s = score result
  { task: task, code: code, result: trim result, score: s }

-- The tasks to try, ordered by difficulty
tasks = [
  "Print the numbers 1 through 5, one per line",
  "Print the factorial of 7",
  "Print the first 10 fibonacci numbers",
  "Define a function that reverses a list, then print the reverse of [1,2,3,4,5]",
  "Print all even numbers from 1 to 20 using filter",
  "Compute the sum of squares of [1,2,3,4,5] using map and fold",
  "Define a binary tree type, create a tree, and count its nodes",
  "Write a function that checks if a string is a palindrome, test it on 3 strings",
  "Implement insertion sort and sort [5,3,8,1,9,2]",
  "Create a record type for a person with name and age, make 3 people, print the oldest"
]

main =
  let _ = print "=== Rail Autoresearch ==="
  let _ = print "Generating and validating Rail programs with 9B local model"
  let _ = print ""

  let results = map experiment tasks
  let passed = filter (\r -> r.score == 1) results
  let failed = filter (\r -> r.score == 0) results

  let _ = print "=== Results ==="
  let _ = map (\r ->
    let status = if r.score == 1 then "PASS" else "FAIL"
    let _ = print (append (append status ": ") r.task)
    print (append "  -> " r.result)
  ) results

  let _ = print ""
  let total = length tasks
  let wins = length passed
  let _ = print (append "Score: " (append (show wins) (append "/" (show total))))

  let u = llm_usage ()
  let _ = print (append "Tokens: " (append (show u.total_tokens) (append " across " (append (show u.calls) " LLM calls"))))
  0
