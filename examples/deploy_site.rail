-- deploy_site.rail — Generate + deploy ledatic.org in pure Rail
-- Usage: rail run examples/deploy_site.rail --open

-- ── Helpers ──────────────────────────────────────────────────────────────────
cat parts = join "" parts
trim s = head (split "\n" s)

-- ── Live data ────────────────────────────────────────────────────────────────
get_services = trim (shell "launchctl list | grep ledatic | wc -l | tr -d ' '")
get_uptime = trim (shell "python3 -c 'import time,calendar; print(int((time.time()-calendar.timegm((2026,1,1,0,0,0)))/86400))'")
get_conclusions = trim (shell "sqlite3 /Volumes/OversightRAM/oversight.db 'SELECT COUNT(*) FROM conclusions' 2>/dev/null || echo 0")
get_time = trim (shell "date -u '+%H:%M:%S UTC'")

-- ── SVG builders ─────────────────────────────────────────────────────────────
svg_rect x y w h fill =
  cat ["<rect x='", show x, "' y='", show y, "' width='", show w, "' height='", show h, "' rx='4' fill='", fill, "'/>"]

svg_text x y color size txt =
  cat ["<text x='", show x, "' y='", show y, "' fill='", color, "' font-size='", show size, "' font-family='Share Tech Mono, monospace'>", txt, "</text>"]

svg_line x1 y1 x2 y2 color w =
  cat ["<line x1='", show x1, "' y1='", show y1, "' x2='", show x2, "' y2='", show y2, "' stroke='", color, "' stroke-width='", show w, "'/>"]

svg_dashed x1 y1 x2 y2 color =
  cat ["<line x1='", show x1, "' y1='", show y1, "' x2='", show x2, "' y2='", show y2, "' stroke='", color, "' stroke-width='1' stroke-dasharray='4 2'/>"]

svg_glow cx cy r color =
  cat ["<circle cx='", show cx, "' cy='", show cy, "' r='", show r, "' fill='", color, "' opacity='0.4'><animate attributeName='opacity' values='0.4;0.15;0.4' dur='2s' repeatCount='indefinite'/></circle>"]

svg_box x y w h label sub accent =
  let bg = svg_rect x y w h "#111111"
  let border = cat ["<rect x='", show x, "' y='", show y, "' width='", show w, "' height='", show h, "' rx='4' fill='none' stroke='", accent, "' stroke-opacity='0.4'/>"]
  let title = svg_text (x + 14) (y + 22) accent 13 label
  let desc = svg_text (x + 14) (y + 40) "#666" 10 sub
  let dot = svg_glow (x + w - 14) (y + 14) 4 accent
  cat [bg, border, title, desc, dot]

svg_pulse x1 y1 x2 y2 color dur =
  cat ["<circle r='3' fill='", color, "'><animate attributeName='cx' values='", show x1, ";", show x2, "' dur='", dur, "' repeatCount='indefinite'/><animate attributeName='cy' values='", show y1, ";", show y2, "' dur='", dur, "' repeatCount='indefinite'/></circle>"]

-- ── Signal Pipeline ──────────────────────────────────────────────────────────
signal_pipeline =
  let b1 = svg_box 20 70 150 60 "SIGNALFEED" "WebSocket" "#00ffff"
  let b2 = svg_box 210 70 150 60 "SAFETY" "15 gates" "#ff9f0a"
  let b3 = svg_box 400 70 150 60 "HONEYPOT" "5% sell" "#ff3b30"
  let b4 = svg_box 590 70 150 60 "SNIPER" "$3 entry" "#00ff41"
  let a1 = svg_line 170 100 210 100 "#00ffff" 2
  let a2 = svg_line 360 100 400 100 "#ff9f0a" 2
  let a3 = svg_line 550 100 590 100 "#ff3b30" 2
  let p1 = svg_pulse 170 100 210 100 "#00ffff" "0.6s"
  let p2 = svg_pulse 360 100 400 100 "#ff9f0a" "0.8s"
  let p3 = svg_pulse 550 100 590 100 "#ff3b30" "1.0s"
  let t1 = svg_text 20 170 "#666" 11 "20 tokens enter"
  let t2 = svg_text 210 170 "#666" 11 "~5 pass gates"
  let t3 = svg_text 400 170 "#666" 11 "~2 pass probe"
  let t4 = svg_text 590 170 "#00ff41" 11 "1 survives"
  let bar = svg_rect 20 190 720 3 "#222222"
  let anim = "<rect x='20' y='190' height='3' rx='1' fill='#00ff41' opacity='0.6'><animate attributeName='width' values='720;380;180;60' dur='3s' repeatCount='indefinite'/></rect>"
  cat ["<svg viewBox='0 0 780 210' xmlns='http://www.w3.org/2000/svg'>", svg_rect 0 0 780 210 "#0a0a0a", svg_text 20 28 "#00ff41" 15 "SIGNAL PIPELINE", svg_text 20 48 "#666" 10 "signalfeed -> safety_rails -> honeypot_probe -> sniper", b1, b2, b3, b4, a1, a2, a3, p1, p2, p3, t1, t2, t3, t4, bar, anim, "</svg>"]

-- ── Oversight Cycle ──────────────────────────────────────────────────────────
oversight_cycle conclusions =
  let b1 = svg_box 300 60 140 52 "VITALS" "read metrics" "#00ffff"
  let b2 = svg_box 520 90 140 52 "THINK" "Qwen 9B" "#b464ff"
  let b3 = svg_box 520 170 140 52 "DETECT" "drift" "#ff9f0a"
  let b4 = svg_box 300 200 140 52 "REFLECT" "dialectic" "#00ff41"
  let b5 = svg_box 80 170 140 52 "GROW" "questions" "#ff00ff"
  let b6 = svg_box 80 90 140 52 "ACT" "overrides" "#00ffff"
  let a1 = svg_dashed 440 86 520 110 "#00ffff"
  let a2 = svg_dashed 590 142 590 170 "#b464ff"
  let a3 = svg_dashed 520 196 440 220 "#ff9f0a"
  let a4 = svg_dashed 300 226 220 196 "#00ff41"
  let a5 = svg_dashed 150 170 150 142 "#ff00ff"
  let a6 = svg_dashed 220 116 300 86 "#00ffff"
  let orbit = "<circle r='4' fill='#00ff41'><animate attributeName='cx' values='440;590;590;440;220;150;220;440' dur='3.5s' repeatCount='indefinite'/><animate attributeName='cy' values='86;116;196;226;196;142;86;86' dur='3.5s' repeatCount='indefinite'/></circle>"
  let stat = cat [conclusions, " conclusions"]
  cat ["<svg viewBox='0 0 780 260' xmlns='http://www.w3.org/2000/svg'>", svg_rect 0 0 780 260 "#0a0a0a", svg_text 20 28 "#00ff41" 15 "OVERSIGHT V3", svg_text 20 48 "#666" 10 "autonomous parameter tuning -- zero human intervention", b1, b2, b3, b4, b5, b6, a1, a2, a3, a4, a5, a6, orbit, svg_text 300 250 "#00ff41" 11 stat, svg_text 480 250 "#666" 11 "815+ active questions", "</svg>"]

-- ── LLM Routing ──────────────────────────────────────────────────────────────
llm_routing =
  let router = svg_box 280 70 180 90 "AUTONOMY" "queue :5590" "#00ff41"
  let i1 = svg_text 20 100 "#666" 11 "traders P0"
  let i2 = svg_text 20 125 "#666" 11 "oversight P1"
  let i3 = svg_text 20 150 "#666" 11 "pipeline P4"
  let la1 = svg_dashed 110 96 280 100 "#666"
  let la2 = svg_dashed 110 121 280 120 "#666"
  let la3 = svg_dashed 110 146 280 140 "#666"
  let t1 = svg_box 540 50 210 48 "REASONING" "Qwen3.5-9B :8080" "#b464ff"
  let t2 = svg_box 540 108 210 48 "FAST" "Qwen3-1.7B :8081" "#00ffff"
  let t3 = svg_box 540 166 210 48 "CLOUD" "Claude Sonnet" "#ff9f0a"
  let o1 = svg_line 460 100 540 74 "#b464ff" 2
  let o2 = svg_line 460 120 540 132 "#00ffff" 2
  let o3 = svg_line 460 140 540 190 "#ff9f0a" 2
  let pulse = svg_pulse 110 96 540 74 "#00ff41" "1.8s"
  cat ["<svg viewBox='0 0 780 230' xmlns='http://www.w3.org/2000/svg'>", svg_rect 0 0 780 230 "#0a0a0a", svg_text 20 28 "#00ff41" 15 "AUTONOMY ROUTER", svg_text 20 48 "#666" 10 "three-tier LLM routing -- $0/inference", router, i1, i2, i3, la1, la2, la3, t1, t2, t3, o1, o2, o3, pulse, "</svg>"]

-- ── Page assembly ────────────────────────────────────────────────────────────
mk_section tag title bc bt desc svg bul =
  cat ["<div class='sec'><p class='tag'>", tag, "</p><h2>", title, " <span class='badge ", bc, "'>", bt, "</span></h2><p>", desc, "</p><div class='svg-wrap'>", svg, "</div><div class='buls'>", bul, "</div></div>"]

generate svc_count uptime conclusions now =
  let css = read_file "examples/dashboard.css"
  let fonts = "<link href='https://fonts.googleapis.com/css2?family=Inter:wght@400%3B500%3B600&family=Share+Tech+Mono&family=VT323&display=swap' rel='stylesheet'>"
  let hero = cat ["<p class='tag'>GENERATED BY RAIL // LIVE DATA FROM MAC MINI M4 PRO</p>", "<h1>I BUILD<br>THINGS<br><span>THAT THINK.</span></h1>", "<p style='font-size:19px;color:#d4d4d4;max-width:640px;line-height:1.6;margin-bottom:32px'>My job is to solve your problems, and more importantly to get your time back.</p>"]
  let stats = cat ["<div class='stat-bar'><div class='stat'><span class='sv'>", svc_count, "</span><span class='sl'>SERVICES</span></div><div class='stat'><span class='sv'>", uptime, "d</span><span class='sl'>UPTIME</span></div><div class='stat'><span class='sv'>$0</span><span class='sl'>PER QUERY</span></div><div class='stat'><span class='sv'>24/7</span><span class='sl'>ALWAYS ON</span></div></div>"]
  let s1 = mk_section "// 01 - DEFENSE" "SIGNAL PIPELINE" "badge-live" "LIVE" "<strong>Problem:</strong> Every candidate token runs a gauntlet. 20 enter. 1 survives." signal_pipeline "<span class='g'>&gt;</span> Token-2022 gate blocks honeypot factories<br><span class='g'>&gt;</span> Post-buy abort at -12%<br><span class='g'>&gt;</span> Escalating slippage: 300 - 5000 - 9900 bps"
  let s2 = mk_section "// 02 - OVERSIGHT" "AUTONOMOUS TUNING" "badge-dim" "PAUSED" (cat ["<strong>Problem:</strong> A live system needs constant monitoring. <strong>Solution:</strong> An AI that does the watching. ", conclusions, " conclusions."]) (oversight_cycle conclusions) "<span class='g'>&gt;</span> 30-120s adaptive cycles<br><span class='g'>&gt;</span> Settled knowledge at conf >= 0.85<br><span class='g'>&gt;</span> 23 auto-tuned parameters"
  let s3 = mk_section "// 03 - ROUTING" "AUTONOMY ROUTER" "badge-live" "LIVE" "<strong>Problem:</strong> Multiple AI services on one GPU crash everything. <strong>Solution:</strong> Three-tier routing. $0/inference." llm_routing "<span class='g'>&gt;</span> Qwen3.5-9B reasoning on Metal<br><span class='g'>&gt;</span> Qwen3-1.7B fast classify<br><span class='g'>&gt;</span> Claude Sonnet for deep analysis"
  let foot = cat ["<footer><span class='g'>&gt;</span> LEDATIC -- live from Mac Mini M4 Pro<br><span style='color:#333'>last deploy: ", now, "</span><br><br><span class='g'>this page was generated by <a href='https://github.com/zemo-g/rail' style='color:#00ff41;text-decoration:underline'>Rail</a></span><br><span style='color:#333'>a language i built -- pure functional, AI-native, written in Rust</span><br><a href='https://github.com/zemo-g/rail/blob/main/examples/deploy_site.rail' style='color:#333;text-decoration:underline;font-size:10px'>view source: deploy_site.rail</a></footer>"]
  cat ["<!DOCTYPE html><html lang='en'><head><meta charset='UTF-8'><meta name='viewport' content='width=device-width,initial-scale=1.0'><title>LEDATIC Systems</title>", fonts, "<style>", css, "</style></head><body><div class='container'>", hero, stats, s1, s2, s3, foot, "</div></body></html>"]

-- ── Deploy ───────────────────────────────────────────────────────────────────
deploy html =
  let _ = write_file "/tmp/ledatic_dashboard.html" html
  let size = trim (shell "wc -c < /tmp/ledatic_dashboard.html | tr -d ' '")
  let _ = print (cat ["  ", size, " bytes generated"])
  let kv_result = trim (shell "/Users/ledaticempire/projects/rail/examples/cf_deploy.sh /tmp/ledatic_dashboard.html")
  let _ = if kv_result == "OK" then print "  uploaded to KV" else print (cat ["  KV: ", kv_result])
  let _ = shell "cp /tmp/ledatic_dashboard.html /Users/ledaticempire/ledatic-site/index.html"
  let _ = shell "cd /Users/ledaticempire/ledatic-site && git add index.html && git commit -m 'daily: Rail dashboard' 2>/dev/null || true"
  let _ = shell "cd /Users/ledaticempire/ledatic-site && git push origin main 2>/dev/null || true"
  let _ = print "  git pushed"
  0

-- ── Main ─────────────────────────────────────────────────────────────────────
main =
  let _ = print "> rail deploy_site"
  let svc = get_services
  let up = get_uptime
  let con = get_conclusions
  let now = get_time
  let _ = print (cat ["  services=", svc, " uptime=", up, "d conclusions=", con])
  let html = generate svc up con now
  let _ = deploy html
  let _ = print "> done"
  0
