-- self_evolve.rail — Rail writing Rail
-- A program that generates, validates, and composes Rail programs using a local LLM.
-- This is the thing no other language can do natively.

generate_program : String -> String
generate_program task =
  prompt_with "You generate Rail code. Output ONLY code, no markdown, no explanation. Rail syntax: type sigs are name : type -> type. Function defs: name param = body. if cond then a else b. let x = expr (next line continues). main = expr, end with 0. print returns unit, use let _ = print x. Example: fact : i32 -> i32\nfact n = if n <= 1 then 1 else n * fact (n - 1)\nmain =\n  let _ = print (fact 5)\n  0" task

validate : String -> String
validate code =
  let _ = write_file "/tmp/_rail_evolve.rail" code
  trim (shell "rail run /tmp/_rail_evolve.rail --open 2>/dev/null || cargo run -q -- run /tmp/_rail_evolve.rail --open 2>/dev/null")

try_generate : String -> String -> String
try_generate task expected =
  let code = generate_program task
  let result = validate code
  if result == expected then append "PASS: " task else append (append (append "FAIL: " task) " | got: ") result

main =
  let _ = print "=== Rail Self-Evolution ==="
  let _ = print "Generating Rail programs with local LLM, then validating them..."
  let _ = print ""
  let _ = print (try_generate "Write a Rail program that computes factorial of 6 and prints it. Expected output: 720" "720")
  let _ = print (try_generate "Write a Rail program that prints the larger of 99 and 42 using an if expression." "99")
  let _ = print (try_generate "Write a Rail program that prints 55, the sum of integers 1 through 10. Use recursion." "55")
  let _ = print (try_generate "Write a Rail program that prints the string hello world (no quotes in output)." "hello world")
  let _ = print ""
  let _ = print "=== Done ==="
  0
