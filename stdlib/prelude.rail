-- prelude.rail — automatically available in all Rail programs

module Prelude
export (id, const, flip, compose, negate)

id : i32 -> i32
id x = x

const : i32 -> i32 -> i32
const x y = x

flip : (i32 -> i32 -> i32) -> i32 -> i32 -> i32
flip f x y = f y x

compose : (i32 -> i32) -> (i32 -> i32) -> i32 -> i32
compose f g x = f (g x)

negate : i32 -> i32
negate x = 0 - x
