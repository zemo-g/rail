module String
export (words, unwords, lines, unlines, is_empty, repeat_str)

words : str -> [str]
words s = split s " "

unwords : [str] -> str
unwords xs = join xs " "

lines : str -> [str]
lines s = split s "\n"

unlines : [str] -> str
unlines xs = join xs "\n"

is_empty : str -> i32
is_empty s = if length s == 0 then 1 else 0

repeat_str : str -> i32 -> str
repeat_str s n =
  if n == 0 then ""
  else s ++ repeat_str s (n - 1)
