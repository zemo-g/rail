-- stdlib/dlopen.rail — Dynamic loading via FFI
-- Import: import "stdlib/dlopen.rail"
-- Uses dlopen/dlsym/dlclose from libSystem

foreign dlopen path flags -> ptr
foreign dlsym handle symbol -> ptr
foreign dlclose handle -> int

-- Flags
rtld_lazy = 1
rtld_now = 2
rtld_global = 8

-- Load a shared library
load_lib path = dlopen path rtld_lazy

-- Look up a symbol
find_symbol handle name = dlsym handle name

-- Unload library
unload_lib handle = dlclose handle
