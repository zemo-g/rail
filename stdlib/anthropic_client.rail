-- stdlib/anthropic_client.rail — Pure-Rail client for api.anthropic.com /v1/messages.
--
-- Talks directly to api.anthropic.com:443 over TLS 1.3 in pure Rail. No
-- socat, no libssl, no curl. The previous v2 version required starting
-- ~/.fleet/tls_proxies.sh (socat on 127.0.0.1:8443); this is NOT needed
-- anymore.
--
-- API:
--   anthropic_chat model prompt max_tokens key_path -> (status, content)
--
--   status   — HTTP status (200 on success)
--   content  — message.content[0].text from the first message (plain string)
--
-- Notes:
--   Rail's shell() doesn't inherit env vars. Pass the API key via a file
--   (e.g. ~/.fleet/anthropic_key, mode 600). Callers manage secrets.

import "stdlib/https_client.rail"

a_trim_line s = head (split "\n" s)

-- Minimal JSON escape for a user prompt (backslash, quotes, newline).
a_esc s =
  let s1 = str_replace (char_from_int 92) (join "" [char_from_int 92, char_from_int 92]) s
  let s2 = str_replace (char_from_int 34) (join "" [char_from_int 92, char_from_int 34]) s1
  str_replace (char_from_int 10) (join "" [char_from_int 92, "n"]) s2

anthropic_payload model prompt max_tokens =
  join "" [
    "{", char_from_int 34, "model", char_from_int 34, ":", char_from_int 34, model, char_from_int 34, ",",
    char_from_int 34, "max_tokens", char_from_int 34, ":", show max_tokens, ",",
    char_from_int 34, "messages", char_from_int 34, ":[{",
    char_from_int 34, "role", char_from_int 34, ":", char_from_int 34, "user", char_from_int 34, ",",
    char_from_int 34, "content", char_from_int 34, ":", char_from_int 34, a_esc prompt, char_from_int 34,
    "}]}"]

-- Extract message.content[0].text from a successful response body.
a_extract_text body =
  let marker = join "" [char_from_int 34, "text", char_from_int 34, ":", char_from_int 34]
  let i = str_find marker body
  if i < 0 then ""
  else
    let start = i + length marker
    let rest = str_sub body start (length body - start)
    let j = str_find (join "" [char_from_int 34]) rest
    if j < 0 then rest
    else str_sub rest 0 j

-- Strip HTTP response header block, return just the body.
a_strip_headers raw =
  let eoh = join "" [char_from_int 13, char_from_int 10, char_from_int 13, char_from_int 10]
  let i = str_find eoh raw
  if i < 0 then raw
  else str_sub raw (i + 4) (length raw - i - 4)

anthropic_chat model prompt max_tokens key_path =
  let key = a_trim_line (read_file key_path)
  let body = anthropic_payload model prompt max_tokens
  let hdrs = [
    join "" ["x-api-key: ", key],
    "anthropic-version: 2023-06-01"]
  let result = https_post_url "https://api.anthropic.com/v1/messages" "application/json" body hdrs
  let status = let (a, _) = result in a
  let raw = let (_, b) = result in b
  if status == 200 then
    let body_only = a_strip_headers raw
    (status, a_extract_text body_only)
  else
    (status, raw)
