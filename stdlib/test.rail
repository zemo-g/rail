-- stdlib/test.rail — Test framework for Rail
-- Import: import "stdlib/test.rail"

-- Assert two values are equal
assert_eq name expected actual =
  if expected == actual then
    let _ = print (cat ["  PASS: ", name])
    true
  else
    let _ = print (cat ["  FAIL: ", name, " — expected [", show expected, "] got [", show actual, "]"])
    false

-- Assert two strings are equal
assert_eq_str name expected actual =
  if expected == actual then
    let _ = print (cat ["  PASS: ", name])
    true
  else
    let _ = print (cat ["  FAIL: ", name, " — expected [", expected, "] got [", actual, "]"])
    false

-- Assert condition is true
assert_true name cond =
  if cond then
    let _ = print (cat ["  PASS: ", name])
    true
  else
    let _ = print (cat ["  FAIL: ", name, " — expected true"])
    false

-- Assert condition is false
assert_false name cond =
  if not cond then
    let _ = print (cat ["  PASS: ", name])
    true
  else
    let _ = print (cat ["  FAIL: ", name, " — expected false"])
    false

-- Run a suite of test results (list of bools), print summary
run_suite name results =
  let total = length results
  let passed = length (filter (\x -> x) results)
  let failed = total - passed
  let _ = print ""
  let _ = print (cat ["=== ", name, ": ", show passed, "/", show total, " passed ==="])
  let _ = if failed > 0 then print (cat ["  ", show failed, " FAILED"]) else 0
  failed == 0
