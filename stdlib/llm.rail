-- stdlib/llm.rail — Pure Rail LLM interface
-- Import: import "stdlib/llm.rail"
-- Calls OpenAI-compatible chat completions API via curl + jq + perl.
--
-- llm_call port system_prompt user_prompt -> response string
-- Writes request JSON to /tmp/rail_llm_req.json to avoid shell quoting issues.
-- Strips <think>...</think> tags, markdown code fences, and trailing explanations.
-- Requires: curl, jq, perl (all standard on macOS)

-- JSON escape helpers (backslash must be first)
_llm_esc_bs s = join "\\\\" (split "\\" s)
_llm_esc_q s = join "\\\"" (split "\"" s)
_llm_esc_nl s = join "\\n" (split "\n" s)
_llm_esc_cr s = join "\\r" (split "\r" s)
_llm_esc_tab s = join "\\t" (split "\t" s)
_llm_json_esc s = _llm_esc_tab (_llm_esc_cr (_llm_esc_nl (_llm_esc_q (_llm_esc_bs s))))

-- Build the JSON request body
_llm_mk_body sys_prompt user_prompt =
  let q = "\""
  let esc_sys = _llm_json_esc sys_prompt
  let esc_usr = _llm_json_esc user_prompt
  join "" ["{", q, "messages", q, ":[",
    "{", q, "role", q, ":", q, "system", q, ",", q, "content", q, ":", q, esc_sys, q, "},",
    "{", q, "role", q, ":", q, "user", q, ",", q, "content", q, ":", q, esc_usr, q, "}],",
    q, "max_tokens", q, ":4096,",
    q, "temperature", q, ":0.3,",
    q, "chat_template_kwargs", q, ":{", q, "enable_thinking", q, ":true}}"]

-- Main LLM call function
-- port: port number as string (e.g. "8080")
-- sys_prompt: system prompt string
-- user_prompt: user prompt string
-- Returns: response content string
llm_call port sys_prompt user_prompt =
  let body = _llm_mk_body sys_prompt user_prompt
  let _ = write_file "/tmp/rail_llm_req.json" body
  let cmd = join "" [
    "curl -s http://localhost:", port, "/v1/chat/completions ",
    "-H 'Content-Type: application/json' ",
    "-d @/tmp/rail_llm_req.json 2>/dev/null | ",
    "jq -r '.choices[0].message.content // empty' 2>/dev/null > /tmp/rail_llm_resp.txt && ",
    "perl -0777 -pe '",
    "s/^\\s+//; s/\\s+$//; ",
    "s/<think>.*?<\\/think>\\s*//gs; ",
    "s/^```[^\\n]*\\n(.*?)\\n```.*$/$1/s; ",
    "s/\\n\\n\\*\\*.*//s; ",
    "s/\\n\\nExplanation.*//s; ",
    "s/\\n\\nNote:.*//s; ",
    "s/\\n\\nThis .*//s",
    "' /tmp/rail_llm_resp.txt"]
  shell cmd
